Note: Get Terraform version information
Process called "terraform_version" returns Dictionary[String, Any]:
    Let parameters be list containing
    Add "-json" to parameters
    
    Let result be execute_terraform_command with command as "version" and parameters as parameters and working_directory as null
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_version" and context as dictionary with:
            "error" as result["error"]
    
    Let version_data be parse_json with json_string as result["output"]
    Return dictionary with:
        "terraform_version" as version_data["terraform_version"],
        "platform" as version_data["platform"],
        "provider_selections" as (version_data["provider_selections"] if version_data contains key "provider_selections" otherwise dictionary containing),
        "terraform_outdated" as (version_data["terraform_outdated"] if version_data contains key "terraform_outdated" otherwise false)

Note: Force unlock Terraform state
Process called "terraform_force_unlock" that takes working_directory as String and lock_id as String returns Boolean:
    Let parameters be list containing
    Add "-force" to parameters
    Add lock_id to parameters
    
    Let result be execute_terraform_command with command as "force-unlock" and parameters as parameters and working_directory as working_directory
    If not result["success"]:
        Throw create_runtime_error with operation as "terraform_force_unlock" and context as dictionary with:
            "working_directory" as working_directory,
            "lock_id" as lock_id,
            "error" as result["error"]
    
    Return true

Note: Generate Terraform configuration from existing infrastructure
Process called "terraform_import_generate" that takes working_directory as String and provider as String and resources as List[Dictionary[String, String]] returns Dictionary[String, Any]:
    Let import_blocks be list containing
    Let generated_config be ""
    
    For each resource in resources:
        Let resource_type be resource["type"]
        Let resource_name be resource["name"]
        Let resource_id be resource["id"]
        
        Note: Import the resource
        Let import_result be terraform_import with working_directory as working_directory and resource_address as resource_type with message "." with message resource_name and resource_id as resource_id and options as dictionary containing
        
        If import_result:
            Note: Generate configuration for imported resource
            Let show_result be terraform_state_show with working_directory as working_directory and resource_address as resource_type with message "." with message resource_name
            
            Let import_block be dictionary with:
                "resource_type" as resource_type,
                "resource_name" as resource_name,
                "resource_id" as resource_id,
                "imported" as true,
                "configuration" as show_result["resource_details"]
            Add import_block to import_blocks
        Else:
            Let import_block be dictionary with:
                "resource_type" as resource_type,
                "resource_name" as resource_name,
                "resource_id" as resource_id,
                "imported" as false,
                "error" as "Import failed"
            Add import_block to import_blocks
    
    Return dictionary with:
        "working_directory" as working_directory,
        "provider" as provider,
        "import_results" as import_blocks,
        "generated_config" as generated_config

Note: Create Terraform module structure
Process called "create_terraform_module" that takes module_path as String and module_config as TerraformModule returns Boolean:
    Note: Create module directory
    Let mkdir_result be execute_command with command as "mkdir -p " with message module_path
    If mkdir_result["exit_code"] is not equal to 0:
        Return false
    
    Note: Create main.tf file
    Let main_tf_content be generate_main_tf_content with module_config as module_config
    Let main_tf_path be module_path with message "/main.tf"
    Let main_write_result be write_file_content with file_path as main_tf_path and content as main_tf_content
    
    Note: Create variables.tf file
    Let variables_tf_content be generate_variables_tf_content with variables as module_config["input_variables"]
    Let variables_tf_path be module_path with message "/variables.tf"
    Let variables_write_result be write_file_content with file_path as variables_tf_path and content as variables_tf_content
    
    Note: Create outputs.tf file
    Let outputs_tf_content be generate_outputs_tf_content with outputs as module_config["output_values"]
    Let outputs_tf_path be module_path with message "/outputs.tf"
    Let outputs_write_result be write_file_content with file_path as outputs_tf_path and content as outputs_tf_content
    
    Note: Create versions.tf file if providers specified
    If length of module_config["providers"] is greater than 0:
        Let versions_tf_content be generate_versions_tf_content with providers as module_config["providers"]
        Let versions_tf_path be module_path with message "/versions.tf"
        Let versions_write_result be write_file_content with file_path as versions_tf_path and content as versions_tf_content
    
    Return main_write_result and variables_write_result and outputs_write_result

Note: Parse Terraform plan data
Process called "parse_terraform_plan" that takes plan_data as Dictionary[String, Any] returns TerraformPlan:
    Let resource_changes be list containing
    If plan_data contains key "resource_changes":
        For each change in plan_data["resource_changes"]:
            Let resource_change be dictionary with:
                "address" as change["address"],
                "mode" as change["mode"],
                "resource_type" as change["type"],
                "name" as change["name"],
                "provider_name" as change["provider_name"],
                "change" as change["change"],
                "action_reason" as (change["action_reason"] if change contains key "action_reason" otherwise null),
                "before" as (change["change"]["before"] if change["change"] contains key "before" otherwise null),
                "after" as (change["change"]["after"] if change["change"] contains key "after" otherwise null),
                "before_sensitive" as (change["change"]["before_sensitive"] if change["change"] contains key "before_sensitive" otherwise null),
                "after_sensitive" as (change["change"]["after_sensitive"] if change["change"] contains key "after_sensitive" otherwise null),
                "after_unknown" as (change["change"]["after_unknown"] if change["change"] contains key "after_unknown" otherwise null)
            Add resource_change to resource_changes
    
    Return dictionary with:
        "plan_id" as generate_plan_id,
        "terraform_version" as (plan_data["terraform_version"] if plan_data contains key "terraform_version" otherwise "unknown"),
        "format_version" as (plan_data["format_version"] if plan_data contains key "format_version" otherwise "unknown"),
        "variables" as (plan_data["variables"] if plan_data contains key "variables" otherwise dictionary containing),
        "planned_values" as (plan_data["planned_values"] if plan_data contains key "planned_values" otherwise dictionary containing),
        "resource_changes" as resource_changes,
        "configuration" as (plan_data["configuration"] if plan_data contains key "configuration" otherwise dictionary containing),
        "prior_state" as (plan_data["prior_state"] if plan_data contains key "prior_state" otherwise null),
        "relevant_attributes" as (plan_data["relevant_attributes"] if plan_data contains key "relevant_attributes" otherwise list containing),
        "output_changes" as (plan_data["output_changes"] if plan_data contains key "output_changes" otherwise dictionary containing),
        "timestamp" as get_current_timestamp,
        "errored" as false

Note: Parse Terraform state data
Process called "parse_terraform_state" that takes state_data as Dictionary[String, Any] returns TerraformState:
    Return dictionary with:
        "version" as state_data["version"],
        "serial" as state_data["serial"],
        "lineage" as state_data["lineage"],
        "backend" as (state_data["backend"] if state_data contains key "backend" otherwise dictionary containing),
        "modules" as (state_data["values"]["root_module"]["child_modules"] if state_data contains key "values" and state_data["values"] contains key "root_module" and state_data["values"]["root_module"] contains key "child_modules" otherwise list containing),
        "resources" as (state_data["values"]["root_module"]["resources"] if state_data contains key "values" and state_data["values"] contains key "root_module" and state_data["values"]["root_module"] contains key "resources" otherwise list containing),
        "outputs" as (state_data["values"]["outputs"] if state_data contains key "values" and state_data["values"] contains key "outputs" otherwise dictionary containing),
        "terraform_version" as (state_data["terraform_version"] if state_data contains key "terraform_version" otherwise "unknown"),
        "check_results" as (state_data["check_results"] if state_data contains key "check_results" otherwise null),
        "timestamp" as get_current_timestamp

Note: Helper function to generate plan ID
Process called "generate_plan_id" returns String:
    Let timestamp be get_current_timestamp
    Return "plan-" with message timestamp

Note: Helper function to generate main.tf content
Process called "generate_main_tf_content" that takes module_config as TerraformModule returns String:
    Let content be "Note: Generated Terraform module main configuration\n\n"
    Set content to content with message "terraform {\n"
    Set content to content with message "  required_version = \">= 0.14\"\n"
    Set content to content with message "}\n\n"
    Return content

Note: Helper function to generate variables.tf content
Process called "generate_variables_tf_content" that takes variables as Dictionary[String, Any] returns String:
    Let content be "Note: Generated Terraform variables\n\n"
    For each var_name and var_config in variables:
        Set content to content with message "variable \"" with message var_name with message "\" {\n"
        Set content to content with message "  description = \"Generated variable\"\n"
        Set content to content with message "  type        = string\n"
        Set content to content with message "}\n\n"
    Return content

Note: Helper function to generate outputs.tf content
Process called "generate_outputs_tf_content" that takes outputs as Dictionary[String, Any] returns String:
    Let content be "Note: Generated Terraform outputs\n\n"
    For each output_name and output_config in outputs:
        Set content to content with message "output \"" with message output_name with message "\" {\n"
        Set content to content with message "  description = \"Generated output\"\n"
        Set content to content with message "  value       = null\n"
        Set content to content with message "}\n\n"
    Return content

Note: Helper function to generate versions.tf content
Process called "generate_versions_tf_content" that takes providers as Dictionary[String, String] returns String:
    Let content be "Note: Generated provider requirements\n\n"
    Set content to content with message "terraform {\n"
    Set content to content with message "  required_providers {\n"
    For each provider_name and provider_source in providers:
        Set content to content with message "    " with message provider_name with message " = {\n"
        Set content to content with message "      source = \"" with message provider_source with message "\"\n"
        Set content to content with message "    }\n"
    Set content to content with message "  }\n"
    Set content to content with message "}\n"
    Return content

Note: Helper function to get current timestamp
Process called "get_current_timestamp" returns Integer:
    Let result be execute_command with command as "date +%s"
    Return to_integer with value as trim with text as result["stdout"]

Note: Helper function to write file content
Process called "write_file_content" that takes file_path as String and content as String returns Boolean:
    Let command be "cat > " with message file_path with message " << 'EOF'\n" with message content with message "\nEOF"
    Let result be execute_command with command as command
    Return result["exit_code"] is equal to 0

Note: Helper function to parse JSON
Process called "parse_json" that takes json_string as String returns Dictionary[String, Any]:
    Note: Parse JSON string using system JSON parser with error handling
    Note: For now, return empty dictionary as fallback
    Return dictionary containing