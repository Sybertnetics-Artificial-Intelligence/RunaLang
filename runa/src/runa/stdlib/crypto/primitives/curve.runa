Process called "renes_costello_batina_x3" that takes t0 as field.FieldElement and t1 as field.FieldElement and t2 as field.FieldElement and t3 as field.FieldElement and t5 as field.FieldElement and curve as EllipticCurve returns field.FieldResult[field.FieldElement]:
    Note: Compute X3 coordinate using Renes-Costello-Batina complete addition formula
    Try:
        Note: X3 = t0 * t5 - t1 * t3
        Let t0_t5_result be field.multiply with a as t0 and b as t5
        Match t0_t5_result:
            When field.FieldSuccess:
                Let t1_t3_result be field.multiply with a as t1 and b as t3
                Match t1_t3_result:
                    When field.FieldSuccess:
                        Let x3_result be field.subtract with a as t0_t5_result.value and b as t1_t3_result.value
                        Return x3_result
                    When field.FieldFailure:
                        Return t1_t3_result
            When field.FieldFailure:
                Return t0_t5_result
    
    Catch error:
        Return field.FieldFailure with:
            error as field.FieldError.Arithmetic_Failure
            message as "X3 computation failed: " plus error as String

Process called "renes_costello_batina_y3" that takes t0 as field.FieldElement and t1 as field.FieldElement and t2 as field.FieldElement and t3 as field.FieldElement and t5 as field.FieldElement and curve as EllipticCurve returns field.FieldResult[field.FieldElement]:
    Note: Compute Y3 coordinate using Renes-Costello-Batina complete addition formula
    Try:
        Note: Y3 = t1 * t5 + t0 * t3
        Let t1_t5_result be field.multiply with a as t1 and b as t5
        Match t1_t5_result:
            When field.FieldSuccess:
                Let t0_t3_result be field.multiply with a as t0 and b as t3
                Match t0_t3_result:
                    When field.FieldSuccess:
                        Let y3_result be field.add with a as t1_t5_result.value and b as t0_t3_result.value
                        Return y3_result
                    When field.FieldFailure:
                        Return t0_t3_result
            When field.FieldFailure:
                Return t1_t5_result
    
    Catch error:
        Return field.FieldFailure with:
            error as field.FieldError.Arithmetic_Failure
            message as "Y3 computation failed: " plus error as String

Process called "renes_costello_batina_z3" that takes t0 as field.FieldElement and t1 as field.FieldElement and t2 as field.FieldElement and t3 as field.FieldElement and t5 as field.FieldElement and curve as EllipticCurve returns field.FieldResult[field.FieldElement]:
    Note: Compute Z3 coordinate using Renes-Costello-Batina complete addition formula
    Try:
        Note: Z3 = t2 * t5
        Let z3_result be field.multiply with a as t2 and b as t5
        Return z3_result
    
    Catch error:
        Return field.FieldFailure with:
            error as field.FieldError.Arithmetic_Failure
            message as "Z3 computation failed: " plus error as String

