Note:
Runa Standard Library: Inspect Module

Provides comprehensive code introspection and reflection capabilities for examining
objects, functions, types, and program structure at runtime. Supports AI-friendly
interfaces for code analysis and dynamic behavior.

Features:
- Object inspection and analysis
- Function and method introspection
- Type system reflection
- Source code analysis
- Call stack inspection
- Module and package inspection
- AI-friendly metadata extraction
- Performance profiling hooks
:End Note

Note: Core Types and Constants
Type ObjectInfo is Dictionary with:
    type_name as String
    module_name as String
    attributes as Dictionary[String, AttributeInfo]
    methods as Dictionary[String, MethodInfo]
    base_types as List[String]
    is_primitive as Boolean
    is_collection as Boolean
    is_callable as Boolean
    size_estimate as Integer
    metadata as Dictionary[String, Any]

Type AttributeInfo is Dictionary with:
    name as String
    type_name as String
    value as Any
    is_readonly as Boolean
    is_public as Boolean
    is_static as Boolean
    documentation as Optional[String]
    metadata as Dictionary[String, Any]

Type MethodInfo is Dictionary with:
    name as String
    signature as FunctionSignature
    return_type as String
    is_public as Boolean
    is_static as Boolean
    is_async as Boolean
    documentation as Optional[String]
    source_location as Optional[SourceLocation]
    metadata as Dictionary[String, Any]

Type FunctionSignature is Dictionary with:
    parameters as List[ParameterInfo]
    has_varargs as Boolean
    has_kwargs as Boolean
    default_values as Dictionary[String, Any]

Type ParameterInfo is Dictionary with:
    name as String
    type_name as String
    has_default as Boolean
    default_value as Any
    is_required as Boolean
    documentation as Optional[String]

Type SourceLocation is Dictionary with:
    file_path as String
    line_number as Integer
    column_number as Integer
    function_name as String
    module_name as String

Type CallStackFrame is Dictionary with:
    function_name as String
    module_name as String
    file_path as String
    line_number as Integer
    column_number as Integer
    local_variables as Dictionary[String, Any]
    arguments as List[Any]
    metadata as Dictionary[String, Any]

Type ModuleInfo is Dictionary with:
    name as String
    file_path as String
    functions as Dictionary[String, MethodInfo]
    types as Dictionary[String, ObjectInfo]
    constants as Dictionary[String, Any]
    imports as List[String]
    exports as List[String]
    documentation as Optional[String]
    metadata as Dictionary[String, Any]

Type InspectionOptions is Dictionary with:
    include_private as Boolean defaults to false
    include_static as Boolean defaults to true
    include_documentation as Boolean defaults to true
    include_source as Boolean defaults to false
    include_metadata as Boolean defaults to true
    max_depth as Integer defaults to 3
    include_callable_details as Boolean defaults to true

Note: Object Inspection Functions
Process called "inspect_object" that takes obj as Any returns ObjectInfo:
    Return inspect_object_with_options with obj as obj and options as create_default_options

Process called "inspect_object_with_options" that takes obj as Any and options as InspectionOptions returns ObjectInfo:
    Let type_name be get_type_name with obj as obj
    Let module_name be get_module_name with obj as obj
    Let is_primitive be is_primitive_type with obj as obj
    Let is_collection be is_collection_type with obj as obj
    Let is_callable be is_callable_object with obj as obj
    
    Let attributes be get_object_attributes with obj as obj and options as options
    Let methods be get_object_methods with obj as obj and options as options
    Let base_types be get_base_types with obj as obj
    Let size_estimate be estimate_object_size with obj as obj
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "inspection_depth" as 0
        "object_id" as get_object_id with obj as obj
    
    Return ObjectInfo with:
        type_name as type_name
        module_name as module_name
        attributes as attributes
        methods as methods
        base_types as base_types
        is_primitive as is_primitive
        is_collection as is_collection
        is_callable as is_callable
        size_estimate as size_estimate
        metadata as metadata

Process called "get_object_attributes" that takes obj as Any and options as InspectionOptions returns Dictionary[String, AttributeInfo]:
    Let attributes be dictionary containing
    
    If options.include_private:
        Let all_attrs be get_all_attributes with obj as obj
        For each attr_name in keys of all_attrs:
            Let attr_value be all_attrs at key attr_name
            Let attr_info be create_attribute_info with name as attr_name and value as attr_value and obj as obj and options as options
            Set attributes[attr_name] to attr_info
    Otherwise:
        Let public_attrs be get_public_attributes with obj as obj
        For each attr_name in keys of public_attrs:
            Let attr_value be public_attrs at key attr_name
            Let attr_info be create_attribute_info with name as attr_name and value as attr_value and obj as obj and options as options
            Set attributes[attr_name] to attr_info
    
    Return attributes

Process called "get_object_methods" that takes obj as Any and options as InspectionOptions returns Dictionary[String, MethodInfo]:
    Let methods be dictionary containing
    
    If is_callable_object with obj as obj:
        Let method_info be create_method_info with name as "call" and obj as obj and options as options
        Set methods["call"] to method_info
    
    If options.include_static:
        Let static_methods be get_static_methods with obj as obj
        For each method_name in keys of static_methods:
            Let method_obj be static_methods at key method_name
            Let method_info be create_method_info with name as method_name and obj as method_obj and options as options
            Set methods[method_name] to method_info
    
    Let instance_methods be get_instance_methods with obj as obj and options as options
    For each method_name in keys of instance_methods:
        Let method_obj be instance_methods at key method_name
        Let method_info be create_method_info with name as method_name and obj as method_obj and options as options
        Set methods[method_name] to method_info
    
    Return methods

Process called "create_attribute_info" that takes name as String and value as Any and obj as Any and options as InspectionOptions returns AttributeInfo:
    Let type_name be get_type_name with obj as value
    Let is_readonly be is_readonly_attribute with obj as obj and name as name
    Let is_public be is_public_name with name as name
    Let is_static be is_static_attribute with obj as obj and name as name
    
    Let documentation be None
    If options.include_documentation:
        Let documentation be get_attribute_documentation with obj as obj and name as name
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "attribute_type" as "instance"
    
    Return AttributeInfo with:
        name as name
        type_name as type_name
        value as value
        is_readonly as is_readonly
        is_public as is_public
        is_static as is_static
        documentation as documentation
        metadata as metadata

Process called "create_method_info" that takes name as String and obj as Any and options as InspectionOptions returns MethodInfo:
    Let signature be get_function_signature with func as obj
    Let return_type be get_return_type with func as obj
    Let is_public be is_public_name with name as name
    Let is_static be is_static_method with obj as obj
    Let is_async be is_async_function with func as obj
    
    Let documentation be None
    If options.include_documentation:
        Let documentation be get_function_documentation with func as obj
    
    Let source_location be None
    If options.include_source:
        Let source_location be get_function_source_location with func as obj
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "method_type" as "instance"
    
    Return MethodInfo with:
        name as name
        signature as signature
        return_type as return_type
        is_public as is_public
        is_static as is_static
        is_async as is_async
        documentation as documentation
        source_location as source_location
        metadata as metadata

Note: Function Inspection Functions
Process called "inspect_function" that takes func as Any returns MethodInfo:
    Return inspect_function_with_options with func as func and options as create_default_options

Process called "inspect_function_with_options" that takes func as Any and options as InspectionOptions returns MethodInfo:
    Let function_name be get_function_name with func as func
    Let signature be get_function_signature with func as func
    Let return_type be get_return_type with func as func
    Let is_async be is_async_function with func as func
    
    Let documentation be None
    If options.include_documentation:
        Let documentation be get_function_documentation with func as func
    
    Let source_location be None
    If options.include_source:
        Let source_location be get_function_source_location with func as func
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "function_type" as "function"
    
    Return MethodInfo with:
        name as function_name
        signature as signature
        return_type as return_type
        is_public as true
        is_static as false
        is_async as is_async
        documentation as documentation
        source_location as source_location
        metadata as metadata

Process called "get_function_signature" that takes func as Any returns FunctionSignature:
    Let parameters be get_function_parameters with func as func
    Let has_varargs be has_varargs_parameter with func as func
    Let has_kwargs be has_kwargs_parameter with func as func
    Let default_values be get_default_values with func as func
    
    Return FunctionSignature with:
        parameters as parameters
        has_varargs as has_varargs
        has_kwargs as has_kwargs
        default_values as default_values

Process called "get_function_parameters" that takes func as Any returns List[ParameterInfo]:
    Let parameters be list containing
    Let param_names be get_parameter_names with func as func
    Let param_types be get_parameter_types with func as func
    Let default_values be get_default_values with func as func
    
    For i from 0 to length of param_names:
        Let param_name be param_names at index i
        Let param_type be param_types at index i
        Let has_default be param_name is in keys of default_values
        Let default_value be None
        If has_default:
            Set default_value to default_values at key param_name
        
        Let parameter_info be ParameterInfo with:
            name as param_name
            type_name as param_type
            has_default as has_default
            default_value as default_value
            is_required as not has_default
            documentation as None
        
        Add parameter_info to parameters
    
    Return parameters

Process called "get_function_documentation" that takes func as Any returns Optional[String]:
    Let doc_string be get_doc_string with obj as func
    If doc_string is not None and length of doc_string is greater than 0:
        Return Some with value as doc_string
    Otherwise:
        Return None

Process called "get_function_source_location" that takes func as Any returns Optional[SourceLocation]:
    Let file_path be get_function_file with func as func
    Let line_number be get_function_line with func as func
    Let function_name be get_function_name with func as func
    Let module_name be get_function_module with func as func
    
    If file_path is not None and line_number is greater than 0:
        Return Some with value as SourceLocation with:
            file_path as file_path
            line_number as line_number
            column_number as 0
            function_name as function_name
            module_name as module_name
    Otherwise:
        Return None

Note: Type System Inspection
Process called "inspect_type" that takes type_obj as Any returns ObjectInfo:
    Return inspect_type_with_options with type_obj as type_obj and options as create_default_options

Process called "inspect_type_with_options" that takes type_obj as Any and options as InspectionOptions returns ObjectInfo:
    Let type_name be get_type_name with obj as type_obj
    Let module_name be get_module_name with obj as type_obj
    Let base_types be get_base_types with obj as type_obj
    
    Let attributes be get_type_attributes with type_obj as type_obj and options as options
    Let methods be get_type_methods with type_obj as type_obj and options as options
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "type_category" as "type"
    
    Return ObjectInfo with:
        type_name as type_name
        module_name as module_name
        attributes as attributes
        methods as methods
        base_types as base_types
        is_primitive as false
        is_collection as is_collection_type with obj as type_obj
        is_callable as is_callable_object with obj as type_obj
        size_estimate as 0
        metadata as metadata

Process called "get_base_types" that takes obj as Any returns List[String]:
    Let base_types be list containing
    Let type_obj be get_type_object with obj as obj
    
    If type_obj is not None:
        Let bases be get_type_bases with type_obj as type_obj
        For each base in bases:
            Let base_name be get_type_name with obj as base
            Add base_name to base_types
    
    Return base_types

Process called "is_subtype" that takes obj as Any and base_type as String returns Boolean:
    Let type_obj be get_type_object with obj as obj
    If type_obj is None:
        Return false
    
    Let bases be get_type_bases with type_obj as type_obj
    For each base in bases:
        Let base_name be get_type_name with obj as base
        If base_name is equal to base_type:
            Return true
    
    Return false

Process called "get_type_hierarchy" that takes obj as Any returns List[String]:
    Let hierarchy be list containing
    Let type_obj be get_type_object with obj as obj
    
    If type_obj is not None:
        Let current be type_obj
        While current is not None:
            Let type_name be get_type_name with obj as current
            Add type_name to hierarchy
            Let bases be get_type_bases with type_obj as current
            If length of bases is greater than 0:
                Set current to bases at index 0
            Otherwise:
                Set current to None
    
    Return hierarchy

Note: Call Stack Inspection
Process called "get_call_stack" that returns List[CallStackFrame]:
    Return get_call_stack_with_depth with depth as 10

Process called "get_call_stack_with_depth" that takes depth as Integer returns List[CallStackFrame]:
    Let stack be list containing
    Let frames be get_stack_frames with depth as depth
    
    For each frame in frames:
        Let frame_info be CallStackFrame with:
            function_name as frame.function_name
            module_name as frame.module_name
            file_path as frame.file_path
            line_number as frame.line_number
            column_number as frame.column_number
            local_variables as frame.local_variables
            arguments as frame.arguments
            metadata as dictionary containing:
                "inspection_time" as current_time
        
        Add frame_info to stack
    
    Return stack

Process called "get_current_frame" returns CallStackFrame:
    Let frames be get_call_stack_with_depth with depth as 1
    If length of frames is greater than 0:
        Return frames at index 0
    Otherwise:
        Return CallStackFrame with:
            function_name as "unknown"
            module_name as "unknown"
            file_path as "unknown"
            line_number as 0
            column_number as 0
            local_variables as dictionary containing
            arguments as list containing
            metadata as dictionary containing

Process called "get_caller_frame" returns CallStackFrame:
    Let frames be get_call_stack_with_depth with depth as 2
    If length of frames is greater than 1:
        Return frames at index 1
    Otherwise:
        Return get_current_frame

Note: Module Inspection
Process called "inspect_module" that takes module_name as String returns Optional[ModuleInfo]:
    Return inspect_module_with_options with module_name as module_name and options as create_default_options

Process called "inspect_module_with_options" that takes module_name as String and options as InspectionOptions returns Optional[ModuleInfo]:
    Let module_obj be get_module_object with name as module_name
    If module_obj is None:
        Return None
    
    Let file_path be get_module_file with module_obj as module_obj
    Let functions be get_module_functions with module_obj as module_obj and options as options
    Let types be get_module_types with module_obj as module_obj and options as options
    Let constants be get_module_constants with module_obj as module_obj
    Let imports be get_module_imports with module_obj as module_obj
    Let exports be get_module_exports with module_obj as module_obj
    
    Let documentation be None
    If options.include_documentation:
        Let documentation be get_module_documentation with module_obj as module_obj
    
    Let metadata be dictionary containing:
        "inspection_time" as current_time
        "module_type" as "module"
    
    Return Some with value as ModuleInfo with:
        name as module_name
        file_path as file_path
        functions as functions
        types as types
        constants as constants
        imports as imports
        exports as exports
        documentation as documentation
        metadata as metadata

Process called "get_loaded_modules" returns List[String]:
    Let modules be list containing
    Let loaded_modules be get_all_loaded_modules
    For each module in loaded_modules:
        Add module to modules
    Return modules

Process called "get_module_dependencies" that takes module_name as String returns List[String]:
    Let dependencies be list containing
    Let module_obj be get_module_object with name as module_name
    If module_obj is not None:
        Let imports be get_module_imports with module_obj as module_obj
        For each import_name in imports:
            Add import_name to dependencies
    Return dependencies

Note: Source Code Analysis
Process called "get_source_code" that takes obj as Any returns Optional[String]:
    Let source_location be get_function_source_location with func as obj
    If source_location is not None:
        Let source_location_value be source_location
        Return get_file_content with path as source_location_value.file_path
    Otherwise:
        Return None

Process called "get_source_lines" that takes obj as Any and start_line as Integer and end_line as Integer returns Optional[List[String]]:
    Let source_code be get_source_code with obj as obj
    If source_code is not None:
        Let lines be split_string with string as source_code and delimiter as "\n"
        Let start be max with a as start_line and b as 0
        Let end be min with a as end_line and b as length of lines
        Return slice_list with lst as lines and start as start and end as end
    Otherwise:
        Return None

Process called "get_function_source" that takes func as Any returns Optional[String]:
    Let source_location be get_function_source_location with func as func
    If source_location is not None:
        Let source_location_value be source_location
        Let source_code be get_source_code with obj as func
        If source_code is not None:
            Return extract_function_source with source_code as source_code and function_name as source_location_value.function_name
    Return None

Note: AI-Friendly Utilities
Process called "get_ai_metadata" that takes obj as Any returns Dictionary[String, Any]:
    Let metadata be dictionary containing:
        "object_type" as get_type_name with obj as obj
        "module" as get_module_name with obj as obj
        "inspection_time" as current_time
        "ai_friendly" as true
    
    If is_callable_object with obj as obj:
        Let signature be get_function_signature with func as obj
        Set metadata["signature"] to signature
        Let documentation be get_function_documentation with func as obj
        If documentation is not None:
            Set metadata["documentation"] to documentation
    
    Let attributes be get_public_attributes with obj as obj
    If length of keys of attributes is greater than 0:
        Set metadata["attributes"] to keys of attributes
    
    Return metadata

Process called "get_object_summary" that takes obj as Any returns String:
    Let type_name be get_type_name with obj as obj
    Let module_name be get_module_name with obj as obj
    Let is_callable be is_callable_object with obj as obj
    
    Let summary be type_name
    If module_name is not equal to "":
        Set summary to module_name plus "." plus summary
    
    If is_callable:
        Set summary to summary plus " (callable)"
    
    Let size_estimate be estimate_object_size with obj as obj
    If size_estimate is greater than 0:
        Set summary to summary plus " (size: " plus size_estimate plus " bytes)"
    
    Return summary

Process called "compare_objects" that takes obj1 as Any and obj2 as Any returns Dictionary[String, Any]:
    Let comparison be dictionary containing:
        "obj1_summary" as get_object_summary with obj as obj1
        "obj2_summary" as get_object_summary with obj as obj2
        "same_type" as get_type_name with obj as obj1 is equal to get_type_name with obj as obj2
        "same_module" as get_module_name with obj as obj1 is equal to get_module_name with obj as obj2
        "both_callable" as is_callable_object with obj as obj1 and is_callable_object with obj as obj2
    
    If comparison.same_type and comparison.both_callable:
        Let sig1 be get_function_signature with func as obj1
        Let sig2 be get_function_signature with func as obj2
        Set comparison["signature_match"] to compare_signatures with sig1 as sig1 and sig2 as sig2
    
    Return comparison

Note: Utility Functions
Process called "create_default_options" that returns InspectionOptions:
    Return InspectionOptions with:
        include_private as false
        include_static as true
        include_documentation as true
        include_source as false
        include_metadata as true
        max_depth as 3
        include_callable_details as true

Process called "create_deep_options" that returns InspectionOptions:
    Return InspectionOptions with:
        include_private as true
        include_static as true
        include_documentation as true
        include_source as true
        include_metadata as true
        max_depth as 10
        include_callable_details as true

Process called "create_ai_options" that returns InspectionOptions:
    Return InspectionOptions with:
        include_private as false
        include_static as true
        include_documentation as true
        include_source as false
        include_metadata as true
        max_depth as 5
        include_callable_details as true

