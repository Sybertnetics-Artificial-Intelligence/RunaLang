Note:
Runa Standard Library: Error Handling and Exception System
Production-ready error handling with comprehensive error types and recovery mechanisms
:End Note

Type ErrorSeverity is Enum with values:
    "info"
    "warning" 
    "error"
    "critical"
    "fatal"

Type ErrorCategory is Enum with values:
    "system"
    "network"
    "file_io"
    "validation"
    "authentication"
    "authorization"
    "configuration"
    "runtime"
    "compilation"
    "memory"

Type ErrorCode is Dictionary with:
    category as ErrorCategory
    code as Integer
    name as String
    description as String

Type StackFrame is Dictionary with:
    function_name as String
    file_path as String
    line_number as Integer
    column_number as Integer
    source_context as String

Type ErrorContext is Dictionary with:
    timestamp as String
    process_id as Integer
    thread_id as String
    user_context as String
    system_info as Dictionary

Type RunaError is Dictionary with:
    error_code as ErrorCode
    severity as ErrorSeverity
    message as String
    details as String
    stack_trace as List[StackFrame]
    context as ErrorContext
    inner_error as Optional[RunaError]
    metadata as Dictionary

Type ErrorResult is Dictionary with:
    success as Boolean
    error as Optional[RunaError]
    warning_count as Integer
    warnings as List[RunaError]

Note: Error Code Registry
Let system_error_codes be dictionary with:
    1001 as dictionary with:
        "category" as "system"
        "name" as "MEMORY_ALLOCATION_FAILED"
        "description" as "Failed to allocate required memory"
    1002 as dictionary with:
        "category" as "system"
        "name" as "RESOURCE_EXHAUSTED"
        "description" as "System resources have been exhausted"
    1003 as dictionary with:
        "category" as "system"
        "name" as "PERMISSION_DENIED"
        "description" as "Insufficient permissions for operation"

Let file_io_error_codes be dictionary with:
    2001 as dictionary with:
        "category" as "file_io"
        "name" as "FILE_NOT_FOUND"
        "description" as "Specified file does not exist"
    2002 as dictionary with:
        "category" as "file_io"
        "name" as "FILE_ACCESS_DENIED"
        "description" as "Access denied to file or directory"
    2003 as dictionary with:
        "category" as "file_io"
        "name" as "DISK_FULL"
        "description" as "Insufficient disk space"

Let network_error_codes be dictionary with:
    3001 as dictionary with:
        "category" as "network"
        "name" as "CONNECTION_TIMEOUT"
        "description" as "Network connection timed out"
    3002 as dictionary with:
        "category" as "network"
        "name" as "CONNECTION_REFUSED"
        "description" as "Connection refused by remote host"

Let validation_error_codes be dictionary with:
    4001 as dictionary with:
        "category" as "validation"
        "name" as "INVALID_INPUT"
        "description" as "Input validation failed"
    4002 as dictionary with:
        "category" as "validation"
        "name" as "TYPE_MISMATCH"
        "description" as "Type does not match expected type"

Note: Core Error Management
Process called "create_error_code" that takes category as ErrorCategory and code as Integer and name as String and description as String returns ErrorCode:
    Return dictionary with:
        "category" as category
        "code" as code
        "name" as name
        "description" as description

Process called "create_runa_error" that takes error_code as ErrorCode and severity as ErrorSeverity and message as String and details as String returns RunaError:
    Let stack_trace be capture_stack_trace()
    Let context be get_current_context()
    
    Return dictionary with:
        "error_code" as error_code
        "severity" as severity
        "message" as message
        "details" as details
        "stack_trace" as stack_trace
        "context" as context
        "inner_error" as none
        "metadata" as dictionary with:

Process called "create_success_result" returns ErrorResult:
    Return dictionary with:
        "success" as true
        "error" as none
        "warning_count" as 0
        "warnings" as list containing nothing

Process called "create_error_result" that takes error as RunaError returns ErrorResult:
    Return dictionary with:
        "success" as false
        "error" as error
        "warning_count" as 0
        "warnings" as list containing nothing

Process called "lookup_error_code" that takes code as Integer returns Optional[ErrorCode]:
    If system_error_codes contains code:
        Let error_info be system_error_codes get code
        Return create_error_code("system", code, error_info get "name", error_info get "description")
    
    If file_io_error_codes contains code:
        Let error_info be file_io_error_codes get code
        Return create_error_code("file_io", code, error_info get "name", error_info get "description")
    
    If network_error_codes contains code:
        Let error_info be network_error_codes get code
        Return create_error_code("network", code, error_info get "name", error_info get "description")
    
    If validation_error_codes contains code:
        Let error_info be validation_error_codes get code
        Return create_error_code("validation", code, error_info get "name", error_info get "description")
    
    Return none

Process called "create_file_not_found_error" that takes file_path as String returns RunaError:
    Let error_code be lookup_error_code(2001)
    Let message be "File not found: " plus file_path
    Let details be "The system cannot find the file specified. Please check the path and try again."
    Return create_runa_error(error_code, "error", message, details)

Process called "format_error_message" that takes error as RunaError returns String:
    Let error_code be error get "error_code"
    Let severity_prefix be "[" plus uppercase(error get "severity") plus "]"
    Let code_prefix be "[" plus error_code get "name" plus "]"
    Let message be error get "message"
    
    Return severity_prefix plus " " plus code_prefix plus " " plus message

Note: Platform-specific stub implementations
Process called "capture_stack_trace" returns List[StackFrame]:
    Return list containing nothing

Process called "get_current_context" returns ErrorContext:
    Return dictionary with:
        "timestamp" as "2024-01-01T00:00:00Z"
        "process_id" as 1234
        "thread_id" as "main"
        "user_context" as "current_user"
        "system_info" as dictionary with:

Process called "uppercase" that takes text as String returns String:
    Return text