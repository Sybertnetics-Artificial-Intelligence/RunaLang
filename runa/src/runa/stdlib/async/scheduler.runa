Note:
Runa Standard Library: Async Scheduler Module

Provides advanced task scheduling capabilities including priority scheduling,
deadline scheduling, rate limiting, and workload balancing.

Features:
- Multiple scheduling algorithms (FIFO, Priority, Deadline, Fair Share)
- Rate limiting and backpressure management
- Workload balancing and resource management
- Task dependency management
- Performance monitoring and optimization
:End Note

Import "async.async" as async
Import "async.core" as core

Note: Scheduler Types
Type SchedulingPolicy is:
    | ROUND_ROBIN
    | PRIORITY_BASED
    | DEADLINE_BASED
    | FAIR_SHARE
    | LOAD_BALANCED

Type TaskScheduler is Dictionary with:
    scheduler_id as String
    policy as SchedulingPolicy
    ready_tasks as List[Task]
    scheduled_tasks as List[Tuple[Float, Task]]
    rate_limiters as Dictionary[String, RateLimiter]
    stats as SchedulerStats
    running as Boolean

Type RateLimiter is Dictionary with:
    name as String
    max_rate as Integer
    current_count as Integer
    window_start as Float
    window_duration_ms as Float

Type SchedulerStats is Dictionary with:
    tasks_scheduled as Integer
    tasks_completed as Integer
    average_wait_time_ms as Float
    throughput_per_second as Float

Note: Core Scheduling Functions
Process called "create_task_scheduler" that takes policy as SchedulingPolicy returns TaskScheduler:
    Return TaskScheduler with:
        scheduler_id as generate_unique_id
        policy as policy
        ready_tasks as list containing
        scheduled_tasks as list containing
        rate_limiters as dictionary containing
        stats as create_scheduler_stats
        running as false

Process called "schedule_task" that takes scheduler as TaskScheduler and task as Task and delay_ms as Optional[Float] returns None:
    If delay_ms is not None and delay_ms is greater than 0:
        Let schedule_time be get_high_precision_time plus delay_ms
        Let scheduled_entry be tuple with schedule_time and task
        insert_scheduled_task with scheduled as scheduler["scheduled_tasks"] and entry as scheduled_entry
    Otherwise:
        Match scheduler["policy"]:
            When ROUND_ROBIN:
                Add task to end of scheduler["ready_tasks"]
            When PRIORITY_BASED:
                insert_by_priority with tasks as scheduler["ready_tasks"] and task as task
            When DEADLINE_BASED:
                insert_by_deadline with tasks as scheduler["ready_tasks"] and task as task
            When FAIR_SHARE:
                insert_with_fair_share with tasks as scheduler["ready_tasks"] and task as task
            When LOAD_BALANCED:
                insert_with_load_balancing with tasks as scheduler["ready_tasks"] and task as task
    
    Set scheduler["stats"]["tasks_scheduled"] to scheduler["stats"]["tasks_scheduled"] plus 1

Process called "get_next_task" that takes scheduler as TaskScheduler returns Optional[Task]:
    Note: Move ready scheduled tasks
    move_ready_scheduled_tasks with scheduler as scheduler
    
    If length of scheduler["ready_tasks"] is greater than 0:
        Let task be scheduler["ready_tasks"] at index 0
        Remove scheduler["ready_tasks"] at index 0
        Return task
    
    Return None

Process called "create_rate_limiter" that takes name as String and max_rate as Integer and window_duration_ms as Float returns RateLimiter:
    Return RateLimiter with:
        name as name
        max_rate as max_rate
        current_count as 0
        window_start as get_high_precision_time
        window_duration_ms as window_duration_ms

Async Process called "with_rate_limit" that takes scheduler as TaskScheduler and limiter_name as String and task as Process returns Any:
    If limiter_name is not in scheduler["rate_limiters"]:
        Throw "Rate limiter not found: " plus limiter_name
    
    Let limiter be scheduler["rate_limiters"][limiter_name]
    
    Note: Check and reset window if needed
    Let current_time be get_high_precision_time
    If current_time minus limiter["window_start"] is greater than limiter["window_duration_ms"]:
        Set limiter["current_count"] to 0
        Set limiter["window_start"] to current_time
    
    Note: Wait if rate limit exceeded
    If limiter["current_count"] is greater than or equal to limiter["max_rate"]:
        Let wait_time be limiter["window_duration_ms"] minus current_time minus limiter["window_start"]
        Await sleep with duration_ms as wait_time
        Set limiter["current_count"] to 0
        Set limiter["window_start"] to get_high_precision_time
    
    Set limiter["current_count"] to limiter["current_count"] plus 1
    Return Await task

Note: Specialized Schedulers
Process called "create_priority_scheduler" returns TaskScheduler:
    Return create_task_scheduler with policy as PRIORITY_BASED

Process called "create_deadline_scheduler" returns TaskScheduler:
    Return create_task_scheduler with policy as DEADLINE_BASED

Process called "create_fair_share_scheduler" returns TaskScheduler:
    Return create_task_scheduler with policy as FAIR_SHARE

Note: Helper Functions
Process called "insert_by_priority" that takes tasks as List[Task] and task as Task returns None:
    Let priority be get_task_priority with task as task
    Let i be 0
    
    While i is less than length of tasks:
        Let current_priority be get_task_priority with task as tasks at index i
        If priority is greater than current_priority:
            Insert task at index i in tasks
            Return
        Set i to i plus 1
    
    Add task to end of tasks

Process called "get_task_priority" that takes task as Task returns Integer:
    If "priority" is in task["metadata"]:
        Return task["metadata"]["priority"]
    Otherwise:
        Return 0

Process called "create_scheduler_stats" returns SchedulerStats:
    Return SchedulerStats with:
        tasks_scheduled as 0
        tasks_completed as 0
        average_wait_time_ms as 0.0
        throughput_per_second as 0.0

Process called "move_ready_scheduled_tasks" that takes scheduler as TaskScheduler returns None:
    Let current_time be get_high_precision_time
    Let ready_entries be list containing
    
    For each entry in scheduler["scheduled_tasks"]:
        If entry[0] is less than or equal to current_time:
            Add entry to ready_entries
    
    For each entry in ready_entries:
        Remove entry from scheduler["scheduled_tasks"]
        Add entry[1] to end of scheduler["ready_tasks"]