Note:
Runa Standard Library: Logging Module

Provides comprehensive logging capabilities for applications with multiple log levels,
formatters, handlers, and AI-friendly interfaces. Supports structured logging,
performance monitoring, and integration with AI systems.

Features:
- Multiple log levels (DEBUG, INFO, WARNING, ERROR, CRITICAL)
- Configurable formatters and handlers
- Structured logging with metadata
- Performance monitoring and metrics
- AI-friendly interfaces and annotations
- Thread-safe logging
- File, console, and network handlers
:End Note

Note: Core Types and Constants
Type LogLevel is:
    | DEBUG
    | INFO
    | WARNING
    | ERROR
    | CRITICAL

Type LogRecord is Dictionary with:
    timestamp as Float
    level as LogLevel
    logger_name as String
    message as String
    module as String
    function as String
    line as Integer
    metadata as Dictionary[String, Any]
    exception_info as Optional[String]
    performance_metrics as Optional[Dictionary[String, Float]]

Type LogFormatter is Dictionary with:
    format_string as String
    include_timestamp as Boolean defaults to true
    include_level as Boolean defaults to true
    include_logger as Boolean defaults to true
    include_location as Boolean defaults to true
    include_metadata as Boolean defaults to false
    include_performance as Boolean defaults to false
    timestamp_format as String defaults to "ISO"
    color_output as Boolean defaults to false

Type LogHandler is Dictionary with:
    formatter as LogFormatter
    level as LogLevel
    enabled as Boolean defaults to true
    handler_type as String  Note: "console", "file", "network", "ai"
    handler_config as Dictionary[String, Any]

Type Logger is Dictionary with:
    name as String
    level as LogLevel
    handlers as List[LogHandler]
    parent as Optional[Logger]
    propagate as Boolean defaults to true
    metadata as Dictionary[String, Any]

Note: Log Level Utilities
Process called "get_level_name" that takes level as LogLevel returns String:
    Match level:
        When DEBUG:
            Return "DEBUG"
        When INFO:
            Return "INFO"
        When WARNING:
            Return "WARNING"
        When ERROR:
            Return "ERROR"
        When CRITICAL:
            Return "CRITICAL"

Process called "get_level_value" that takes level as LogLevel returns Integer:
    Match level:
        When DEBUG:
            Return 10
        When INFO:
            Return 20
        When WARNING:
            Return 30
        When ERROR:
            Return 40
        When CRITICAL:
            Return 50

Process called "parse_level" that takes level_name as String returns Optional[LogLevel]:
    If level_name is equal to "DEBUG":
        Return Some with value as DEBUG
    Otherwise if level_name is equal to "INFO":
        Return Some with value as INFO
    Otherwise if level_name is equal to "WARNING":
        Return Some with value as WARNING
    Otherwise if level_name is equal to "ERROR":
        Return Some with value as ERROR
    Otherwise if level_name is equal to "CRITICAL":
        Return Some with value as CRITICAL
    Otherwise:
        Return None

Process called "is_enabled" that takes logger_level as LogLevel and message_level as LogLevel returns Boolean:
    Return get_level_value with level as message_level is greater than or equal to get_level_value with level as logger_level

Note: Formatter Functions
Process called "create_default_formatter" that returns LogFormatter:
    Return LogFormatter with:
        format_string as "{timestamp} [{level}] {logger}: {message}"
        include_timestamp as true
        include_level as true
        include_logger as true
        include_location as false
        include_metadata as false
        include_performance as false
        timestamp_format as "ISO"
        color_output as false

Process called "create_ai_formatter" that returns LogFormatter:
    Return LogFormatter with:
        format_string as "AI_LOG: {timestamp} [{level}] {logger} | {message} | {metadata}"
        include_timestamp as true
        include_level as true
        include_logger as true
        include_location as true
        include_metadata as true
        include_performance as true
        timestamp_format as "ISO"
        color_output as true

Process called "create_json_formatter" that returns LogFormatter:
    Return LogFormatter with:
        format_string as "JSON"
        include_timestamp as true
        include_level as true
        include_logger as true
        include_location as true
        include_metadata as true
        include_performance as true
        timestamp_format as "ISO"
        color_output as false

Process called "format_record" that takes record as LogRecord and formatter as LogFormatter returns String:
    If formatter.format_string is equal to "JSON":
        Return format_json_record with record as record and formatter as formatter
    Otherwise:
        Return format_text_record with record as record and formatter as formatter

Process called "format_text_record" that takes record as LogRecord and formatter as LogFormatter returns String:
    Let result be formatter.format_string
    
    If formatter.include_timestamp:
        Let timestamp_str be format_timestamp with timestamp as record.timestamp and format as formatter.timestamp_format
        Set result to replace_string with string as result and old as "{timestamp}" and new as timestamp_str
    
    If formatter.include_level:
        Let level_str be get_level_name with level as record.level
        If formatter.color_output:
            Let color_code be get_level_color with level as record.level
            Set level_str to color_code plus level_str plus "\033[0m"
        Set result to replace_string with string as result and old as "{level}" and new as level_str
    
    If formatter.include_logger:
        Set result to replace_string with string as result and old as "{logger}" and new as record.logger_name
    
    Set result to replace_string with string as result and old as "{message}" and new as record.message
    
    If formatter.include_location:
        Let location_str be record.module plus ":" plus record.function plus ":" plus record.line
        Set result to replace_string with string as result and old as "{location}" and new as location_str
    
    If formatter.include_metadata and length of keys of record.metadata is greater than 0:
        Let metadata_str be format_metadata with metadata as record.metadata
        Set result to replace_string with string as result and old as "{metadata}" and new as metadata_str
    
    If formatter.include_performance and record.performance_metrics is not None:
        Let perf_str be format_performance with metrics as record.performance_metrics
        Set result to replace_string with string as result and old as "{performance}" and new as perf_str
    
    Return result

Process called "format_json_record" that takes record as LogRecord and formatter as LogFormatter returns String:
    Let json_obj be dictionary containing:
        "timestamp" as format_timestamp with timestamp as record.timestamp and format as "ISO"
        "level" as get_level_name with level as record.level
        "logger" as record.logger_name
        "message" as record.message
        "module" as record.module
        "function" as record.function
        "line" as record.line
    
    If length of keys of record.metadata is greater than 0:
        Set json_obj["metadata"] to record.metadata
    
    If record.performance_metrics is not None:
        Set json_obj["performance"] to record.performance_metrics
    
    If record.exception_info is not None:
        Set json_obj["exception"] to record.exception_info
    
    Return serialize with value as JSONObject with fields as json_obj

Process called "format_timestamp" that takes timestamp as Float and format as String returns String:
    If format is equal to "ISO":
        Return format_iso_timestamp with timestamp as timestamp
    Otherwise if format is equal to "UNIX":
        Return timestamp
    Otherwise if format is equal to "READABLE":
        Return format_readable_timestamp with timestamp as timestamp
    Otherwise:
        Return format_iso_timestamp with timestamp as timestamp

Process called "format_metadata" that takes metadata as Dictionary[String, Any] returns String:
    Let parts be list containing
    For each key in keys of metadata:
        Let value be metadata at key key
        Add key plus "=" plus value to parts
    Return join_strings with strings as parts and separator as ", "

Process called "format_performance" that takes metrics as Dictionary[String, Float] returns String:
    Let parts be list containing
    For each key in keys of metrics:
        Let value be metrics at key key
        Add key plus "=" plus value plus "ms" to parts
    Return join_strings with strings as parts and separator as ", "

Process called "get_level_color" that takes level as LogLevel returns String:
    Match level:
        When DEBUG:
            Return "\033[36m"  Note: Cyan
        When INFO:
            Return "\033[32m"  Note: Green
        When WARNING:
            Return "\033[33m"  Note: Yellow
        When ERROR:
            Return "\033[31m"  Note: Red
        When CRITICAL:
            Return "\033[35m"  Note: Magenta

Note: Handler Functions
Process called "create_console_handler" that takes level as LogLevel returns LogHandler:
    Return LogHandler with:
        formatter as create_default_formatter
        level as level
        enabled as true
        handler_type as "console"
        handler_config as dictionary containing:
            "stream" as "stdout"

Process called "create_file_handler" that takes file_path as String and level as LogLevel returns LogHandler:
    Return LogHandler with:
        formatter as create_default_formatter
        level as level
        enabled as true
        handler_type as "file"
        handler_config as dictionary containing:
            "file_path" as file_path
            "mode" as "append"
            "encoding" as "utf-8"
            "max_size" as 10485760  Note: 10MB
            "backup_count" as 5

Process called "create_ai_handler" that takes level as LogLevel returns LogHandler:
    Return LogHandler with:
        formatter as create_ai_formatter
        level as level
        enabled as true
        handler_type as "ai"
        handler_config as dictionary containing:
            "model" as "gpt-4"
            "include_context" as true
            "performance_tracking" as true

Process called "create_json_handler" that takes file_path as String and level as LogLevel returns LogHandler:
    Return LogHandler with:
        formatter as create_json_formatter
        level as level
        enabled as true
        handler_type as "file"
        handler_config as dictionary containing:
            "file_path" as file_path
            "mode" as "append"
            "encoding" as "utf-8"

Process called "handle_record" that takes handler as LogHandler and record as LogRecord returns Boolean:
    If not handler.enabled:
        Return false
    
    If not is_enabled with logger_level as handler.level and message_level as record.level:
        Return false
    
    Let formatted_message be format_record with record as record and formatter as handler.formatter
    
    Match handler.handler_type:
        When "console":
            Return handle_console with message as formatted_message and config as handler.handler_config
        When "file":
            Return handle_file with message as formatted_message and config as handler.handler_config
        When "ai":
            Return handle_ai with record as record and config as handler.handler_config
        Otherwise:
            Return false

Process called "handle_console" that takes message as String and config as Dictionary[String, Any] returns Boolean:
    Try:
        Display message
        Return true
    Catch:
        Return false

Process called "handle_file" that takes message as String and config as Dictionary[String, Any] returns Boolean:
    Try:
        Let file_path be config at key "file_path"
        Let mode be config at key "mode"
        Let encoding be config at key "encoding"
        
        Let full_message be message plus "\n"
        Return append_to_file with path as file_path and content as full_message and encoding as encoding
    Catch:
        Return false

Process called "handle_ai" that takes record as LogRecord and config as Dictionary[String, Any] returns Boolean:
    Try:
        Let model be config at key "model"
        Let include_context be config at key "include_context"
        Let performance_tracking be config at key "performance_tracking"
        
        Note: AI-specific logging logic would go here
        Note: This could include sending to AI monitoring systems,
        Note: performance analysis, or intelligent log aggregation
        
        Return true
    Catch:
        Return false

Note: Logger Management
Process called "create_logger" that takes name as String returns Logger:
    Return Logger with:
        name as name
        level as INFO
        handlers as list containing
        parent as None
        propagate as true
        metadata as dictionary containing

Process called "get_logger" that takes name as String returns Logger:
    Note: In a full implementation, this would maintain a registry of loggers
    Note: For now, always create a new logger
    Return create_logger with name as name

Process called "set_logger_level" that takes logger as Logger and level as LogLevel returns Logger:
    Set logger.level to level
    Return logger

Process called "add_handler" that takes logger as Logger and handler as LogHandler returns Logger:
    Add handler to logger.handlers
    Return logger

Process called "remove_handler" that takes logger as Logger and handler_index as Integer returns Logger:
    If handler_index is greater than or equal to 0 and handler_index is less than length of logger.handlers:
        Remove logger.handlers at index handler_index
    Return logger

Process called "clear_handlers" that takes logger as Logger returns Logger:
    Set logger.handlers to list containing
    Return logger

Note: Core Logging Functions
Process called "log" that takes logger as Logger and level as LogLevel and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Let record be LogRecord with:
        timestamp as current_time
        level as level
        logger_name as logger.name
        message as message
        module as get_current_module
        function as get_current_function
        line as get_current_line
        metadata as metadata
        exception_info as None
        performance_metrics as None
    
    Let success be true
    
    For each handler in logger.handlers:
        Let handler_success be handle_record with handler as handler and record as record
        Set success to success and handler_success
    
    If logger.propagate and logger.parent is not None:
        Let parent_success be log with logger as logger.parent and level as level and message as message and metadata as metadata
        Set success to success and parent_success
    
    Return success

Process called "debug" that takes logger as Logger and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Return log with logger as logger and level as DEBUG and message as message and metadata as metadata

Process called "info" that takes logger as Logger and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Return log with logger as logger and level as INFO and message as message and metadata as metadata

Process called "warning" that takes logger as Logger and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Return log with logger as logger and level as WARNING and message as message and metadata as metadata

Process called "error" that takes logger as Logger and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Return log with logger as logger and level as ERROR and message as message and metadata as metadata

Process called "critical" that takes logger as Logger and message as String and metadata as Dictionary[String, Any] returns Boolean:
    Return log with logger as logger and level as CRITICAL and message as message and metadata as metadata

Process called "exception" that takes logger as Logger and message as String and exception_info as String and metadata as Dictionary[String, Any] returns Boolean:
    Let record be LogRecord with:
        timestamp as current_time
        level as ERROR
        logger_name as logger.name
        message as message
        module as get_current_module
        function as get_current_function
        line as get_current_line
        metadata as metadata
        exception_info as Some with value as exception_info
        performance_metrics as None
    
    Let success be true
    
    For each handler in logger.handlers:
        Let handler_success be handle_record with handler as handler and record as record
        Set success to success and handler_success
    
    If logger.propagate and logger.parent is not None:
        Let parent_success be exception with logger as logger.parent and message as message and exception_info as exception_info and metadata as metadata
        Set success to success and parent_success
    
    Return success

Note: Performance Monitoring
Process called "log_with_performance" that takes logger as Logger and level as LogLevel and message as String and start_time as Float and metadata as Dictionary[String, Any] returns Boolean:
    Let end_time be current_time
    Let duration be end_time minus start_time
    
    Let performance_metrics be dictionary containing:
        "duration_ms" as duration multiplied by 1000
        "start_time" as start_time
        "end_time" as end_time
    
    Let record be LogRecord with:
        timestamp as end_time
        level as level
        logger_name as logger.name
        message as message
        module as get_current_module
        function as get_current_function
        line as get_current_line
        metadata as metadata
        exception_info as None
        performance_metrics as Some with value as performance_metrics
    
    Let success be true
    
    For each handler in logger.handlers:
        Let handler_success be handle_record with handler as handler and record as record
        Set success to success and handler_success
    
    If logger.propagate and logger.parent is not None:
        Let parent_success be log_with_performance with logger as logger.parent and level as level and message as message and start_time as start_time and metadata as metadata
        Set success to success and parent_success
    
    Return success

Process called "time_function" that takes logger as Logger and function_name as String and function as Process returns Any:
    Let start_time be current_time
    Let metadata be dictionary containing:
        "function" as function_name
        "type" as "performance"
    
    Try:
        Let result be function
        Let success be log_with_performance with logger as logger and level as INFO and message as "Function completed" and start_time as start_time and metadata as metadata
        Return result
    Catch error:
        Let error_metadata be dictionary containing:
            "function" as function_name
            "type" as "performance"
            "error" as error.message
        Let success be log_with_performance with logger as logger and level as ERROR and message as "Function failed" and start_time as start_time and metadata as error_metadata
        Throw error

Note: AI-Specific Logging
Process called "log_ai_interaction" that takes logger as Logger and model as String and input_tokens as Integer and output_tokens as Integer and duration as Float and metadata as Dictionary[String, Any] returns Boolean:
    Let ai_metadata be dictionary containing:
        "model" as model
        "input_tokens" as input_tokens
        "output_tokens" as output_tokens
        "total_tokens" as input_tokens plus output_tokens
        "duration_seconds" as duration
        "tokens_per_second" as (input_tokens plus output_tokens) divided by duration
        "type" as "ai_interaction"
    
    Let combined_metadata be merge_dictionaries with dict1 as ai_metadata and dict2 as metadata
    
    Let message be "AI interaction with " plus model plus " completed"
    
    Return log_with_performance with logger as logger and level as INFO and message as message and start_time as current_time minus duration and metadata as combined_metadata

Process called "log_ai_error" that takes logger as Logger and model as String and error_type as String and error_message as String and metadata as Dictionary[String, Any] returns Boolean:
    Let ai_metadata be dictionary containing:
        "model" as model
        "error_type" as error_type
        "type" as "ai_error"
    
    Let combined_metadata be merge_dictionaries with dict1 as ai_metadata and dict2 as metadata
    
    Let message be "AI error with " plus model plus ": " plus error_type
    
    Return exception with logger as logger and message as message and exception_info as error_message and metadata as combined_metadata

Note: Configuration and Setup
Process called "setup_default_logging" that takes log_level as LogLevel and log_file as Optional[String] returns Logger:
    Let root_logger be create_logger with name as "root"
    Set root_logger.level to log_level
    
    Let console_handler be create_console_handler with level as log_level
    Let root_logger be add_handler with logger as root_logger and handler as console_handler
    
    If log_file is not None:
        Let file_handler be create_file_handler with file_path as log_file and level as log_level
        Set root_logger to add_handler with logger as root_logger and handler as file_handler
    
    Return root_logger

Process called "setup_ai_logging" that takes log_level as LogLevel and log_file as String returns Logger:
    Let ai_logger be create_logger with name as "ai_system"
    Set ai_logger.level to log_level
    
    Let ai_handler be create_ai_handler with level as log_level
    Set ai_logger to add_handler with logger as ai_logger and handler as ai_handler
    
    Let json_handler be create_json_handler with file_path as log_file and level as log_level
    Set ai_logger to add_handler with logger as ai_logger and handler as json_handler
    
    Return ai_logger

Process called "setup_development_logging" that returns Logger:
    Let dev_logger be create_logger with name as "development"
    Set dev_logger.level to DEBUG
    
    Let console_handler be create_console_handler with level as DEBUG
    Set console_handler.formatter to create_ai_formatter
    Set dev_logger to add_handler with logger as dev_logger and handler as console_handler
    
    Let file_handler be create_file_handler with file_path as "development.log" and level as DEBUG
    Set file_handler.formatter to create_json_formatter
    Set dev_logger to add_handler with logger as dev_logger and handler as file_handler
    
    Return dev_logger

