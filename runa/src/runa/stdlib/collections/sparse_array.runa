Note: Runa Sparse Array Implementation
Sparse Array is a memory-efficient data structure for arrays with many zero or null values.
Stores only non-zero elements using Dictionary-based architecture for optimal space utilization.

Provides O(1) access, insertion, and deletion with minimal memory footprint for sparse data.
All operations return Dictionary types with success indicators and maintain natural language syntax compliance.
:End Note

Type SparseArray is Dictionary with:
    elements as Dictionary
    default_value as Any
    dimensions as List
    total_size as Integer
    non_zero_count as Integer
    access_count as Integer
    modification_count as Integer
    compression_ratio as Float

Process called "create_sparse_array" that takes dimensions as List and default_value as Any returns Dictionary:
    If length of dimensions is equal to 0:
        Return dictionary with:
            "success" as false
            "error" as "Dimensions cannot be empty"
    
    Let total_size be 1
    For each dimension in dimensions:
        If dimension is less than or equal to 0:
            Return dictionary with:
                "success" as false
                "error" as "All dimensions must be positive integers"
        Set total_size to total_size multiplied by dimension
    
    Let sparse_array be dictionary with:
        "elements" as dictionary with:
        "default_value" as default_value
        "dimensions" as dimensions
        "total_size" as total_size
        "non_zero_count" as 0
        "access_count" as 0
        "modification_count" as 0
        "compression_ratio" as 100.0
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array

Process called "calculate_linear_index" that takes sparse_array as Dictionary and indices as List returns Dictionary:
    If length of indices is not equal to length of sparse_array["dimensions"]:
        Return dictionary with:
            "success" as false
            "error" as "Index dimensions mismatch"
    
    Let linear_index be 0
    Let multiplier be 1
    
    For i from length of indices minus 1 down to 0:
        Let index_value be indices[i] as Integer
        Let dimension_size be sparse_array["dimensions"][i] as Integer
        
        If index_value is less than 0 or index_value is greater than or equal to dimension_size:
            Return dictionary with:
                "success" as false
                "error" as "Index out of bounds"
        
        Set linear_index to linear_index plus index_value multiplied by multiplier
        Set multiplier to multiplier multiplied by dimension_size
    
    Return dictionary with:
        "success" as true
        "linear_index" as linear_index

Process called "sparse_array_get" that takes sparse_array as Dictionary and indices as List returns Dictionary:
    Let index_result be calculate_linear_index with sparse_array as sparse_array and indices as indices
    
    If not index_result["success"]:
        Return dictionary with:
            "success" as false
            "error" as index_result["error"]
            "value" as sparse_array["default_value"]
    
    Let linear_index be index_result["linear_index"]
    Let key be linear_index as String
    
    Set sparse_array["access_count"] to sparse_array["access_count"] plus 1
    
    If key is in sparse_array["elements"]:
        Return dictionary with:
            "success" as true
            "value" as sparse_array["elements"][key]
            "found" as true
    
    Return dictionary with:
        "success" as true
        "value" as sparse_array["default_value"]
        "found" as false

Process called "sparse_array_set" that takes sparse_array as Dictionary and indices as List and value as Any returns Dictionary:
    Let index_result be calculate_linear_index with sparse_array as sparse_array and indices as indices
    
    If not index_result["success"]:
        Return dictionary with:
            "success" as false
            "error" as index_result["error"]
    
    Let linear_index be index_result["linear_index"]
    Let key be linear_index as String
    
    Set sparse_array["modification_count"] to sparse_array["modification_count"] plus 1
    
    Let was_present be key is in sparse_array["elements"]
    Let old_value be sparse_array["default_value"]
    
    If was_present:
        Set old_value to sparse_array["elements"][key]
    
    If value is equal to sparse_array["default_value"]:
        If was_present:
            Remove key from sparse_array["elements"]
            Set sparse_array["non_zero_count"] to sparse_array["non_zero_count"] minus 1
    Otherwise:
        Set sparse_array["elements"][key] to value
        If not was_present:
            Set sparse_array["non_zero_count"] to sparse_array["non_zero_count"] plus 1
    
    Let compression_ratio be sparse_array["non_zero_count"] as Float divided by sparse_array["total_size"] as Float multiplied by 100.0
    Set sparse_array["compression_ratio"] to compression_ratio
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array
        "old_value" as old_value
        "was_present" as was_present

Process called "sparse_array_delete" that takes sparse_array as Dictionary and indices as List returns Dictionary:
    Let index_result be calculate_linear_index with sparse_array as sparse_array and indices as indices
    
    If not index_result["success"]:
        Return dictionary with:
            "success" as false
            "error" as index_result["error"]
    
    Let linear_index be index_result["linear_index"]
    Let key be linear_index as String
    
    If key is in sparse_array["elements"]:
        Let deleted_value be sparse_array["elements"][key]
        Remove key from sparse_array["elements"]
        Set sparse_array["non_zero_count"] to sparse_array["non_zero_count"] minus 1
        Set sparse_array["modification_count"] to sparse_array["modification_count"] plus 1
        
        Let compression_ratio be sparse_array["non_zero_count"] as Float divided by sparse_array["total_size"] as Float multiplied by 100.0
        Set sparse_array["compression_ratio"] to compression_ratio
        
        Return dictionary with:
            "success" as true
            "deleted_value" as deleted_value
            "was_present" as true
            "sparse_array" as sparse_array
    
    Return dictionary with:
        "success" as true  
        "deleted_value" as sparse_array["default_value"]
        "was_present" as false
        "sparse_array" as sparse_array

Process called "sparse_array_get_all_elements" that takes sparse_array as Dictionary returns List:
    Let elements be list containing
    
    For each key and value in sparse_array["elements"]:
        Let linear_index be key as Integer
        Let indices be convert_linear_to_indices with sparse_array as sparse_array and linear_index as linear_index
        
        Let element be dictionary with:
            "indices" as indices
            "value" as value
            "linear_index" as linear_index
        
        Add element to elements
    
    Return elements

Process called "convert_linear_to_indices" that takes sparse_array as Dictionary and linear_index as Integer returns List:
    Let indices be list containing
    Let remaining be linear_index
    
    For i from length of sparse_array["dimensions"] minus 1 down to 0:
        Let dimension_size be sparse_array["dimensions"][i] as Integer
        Let index_value be remaining modulo dimension_size
        Add index_value at beginning of indices
        Set remaining to remaining divided by dimension_size rounded down
    
    Return indices

Process called "sparse_array_clear" that takes sparse_array as Dictionary returns Dictionary:
    Set sparse_array["elements"] to dictionary with:
    Set sparse_array["non_zero_count"] to 0
    Set sparse_array["modification_count"] to sparse_array["modification_count"] plus 1
    Set sparse_array["compression_ratio"] to 100.0
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array

Process called "sparse_array_copy" that takes sparse_array as Dictionary returns Dictionary:
    Let new_elements be dictionary with:
    
    For each key and value in sparse_array["elements"]:
        Set new_elements[key] to value
    
    Let copied_array be dictionary with:
        "elements" as new_elements
        "default_value" as sparse_array["default_value"]
        "dimensions" as sparse_array["dimensions"]
        "total_size" as sparse_array["total_size"]
        "non_zero_count" as sparse_array["non_zero_count"]
        "access_count" as 0
        "modification_count" as 0
        "compression_ratio" as sparse_array["compression_ratio"]
    
    Return dictionary with:
        "success" as true
        "sparse_array" as copied_array

Process called "sparse_array_resize" that takes sparse_array as Dictionary and new_dimensions as List returns Dictionary:
    If length of new_dimensions is equal to 0:
        Return dictionary with:
            "success" as false
            "error" as "New dimensions cannot be empty"
    
    Let new_total_size be 1
    For each dimension in new_dimensions:
        If dimension is less than or equal to 0:
            Return dictionary with:
                "success" as false
                "error" as "All dimensions must be positive integers"
        Set new_total_size to new_total_size multiplied by dimension
    
    Let create_result be create_sparse_array with dimensions as new_dimensions and default_value as sparse_array["default_value"]
    Let new_array be create_result["sparse_array"]
    
    Let old_elements be sparse_array_get_all_elements with sparse_array as sparse_array
    
    For each element in old_elements:
        Let old_indices be element["indices"]
        Let value be element["value"]
        
        Let valid be true
        For i from 0 to length of old_indices minus 1:
            If old_indices[i] is greater than or equal to new_dimensions[i]:
                Set valid to false
                Break
        
        If valid:
            Let set_result be sparse_array_set with sparse_array as new_array and indices as old_indices and value as value
    
    Return dictionary with:
        "success" as true
        "sparse_array" as new_array
        "old_dimensions" as sparse_array["dimensions"]
        "new_dimensions" as new_dimensions

Process called "sparse_array_transpose" that takes sparse_array as Dictionary returns Dictionary:
    If length of sparse_array["dimensions"] is not equal to 2:
        Return dictionary with:
            "success" as false
            "error" as "Transpose only supported for 2D arrays"
    
    Let original_dimensions be sparse_array["dimensions"]
    Let transposed_dimensions be list containing original_dimensions[1], original_dimensions[0]
    
    Let create_result be create_sparse_array with dimensions as transposed_dimensions and default_value as sparse_array["default_value"]
    Let transposed_array be create_result["sparse_array"]
    
    Let elements be sparse_array_get_all_elements with sparse_array as sparse_array
    
    For each element in elements:
        Let old_indices be element["indices"]
        Let value be element["value"]  
        Let new_indices be list containing old_indices[1], old_indices[0]
        
        Let set_result be sparse_array_set with sparse_array as transposed_array and indices as new_indices and value as value
    
    Return dictionary with:
        "success" as true
        "sparse_array" as transposed_array

Process called "sparse_array_add" that takes sparse_array1 as Dictionary and sparse_array2 as Dictionary returns Dictionary:
    If sparse_array1["dimensions"] is not equal to sparse_array2["dimensions"]:
        Return dictionary with:
            "success" as false
            "error" as "Array dimensions must match for addition"
    
    Let create_result be create_sparse_array with dimensions as sparse_array1["dimensions"] and default_value as sparse_array1["default_value"]
    Let result_array be create_result["sparse_array"]
    
    Let all_keys be list containing
    
    For each key in keys of sparse_array1["elements"]:
        If key is not in all_keys:
            Add key to all_keys
    
    For each key in keys of sparse_array2["elements"]:
        If key is not in all_keys:
            Add key to all_keys
    
    For each key in all_keys:
        Let value1 be sparse_array1["default_value"]
        Let value2 be sparse_array2["default_value"]
        
        If key is in sparse_array1["elements"]:
            Set value1 to sparse_array1["elements"][key]
        
        If key is in sparse_array2["elements"]:
            Set value2 to sparse_array2["elements"][key]
        
        Let sum_value be value1 plus value2
        
        If sum_value is not equal to result_array["default_value"]:
            Set result_array["elements"][key] to sum_value
            Set result_array["non_zero_count"] to result_array["non_zero_count"] plus 1
    
    Let compression_ratio be result_array["non_zero_count"] as Float divided by result_array["total_size"] as Float multiplied by 100.0
    Set result_array["compression_ratio"] to compression_ratio
    
    Return dictionary with:
        "success" as true
        "sparse_array" as result_array

Process called "sparse_array_multiply_scalar" that takes sparse_array as Dictionary and scalar as Float returns Dictionary:
    Let create_result be create_sparse_array with dimensions as sparse_array["dimensions"] and default_value as sparse_array["default_value"] multiplied by scalar
    Let result_array be create_result["sparse_array"]
    
    For each key and value in sparse_array["elements"]:
        Let multiplied_value be value multiplied by scalar
        Set result_array["elements"][key] to multiplied_value
        Set result_array["non_zero_count"] to result_array["non_zero_count"] plus 1
    
    Let compression_ratio be result_array["non_zero_count"] as Float divided by result_array["total_size"] as Float multiplied by 100.0
    Set result_array["compression_ratio"] to compression_ratio
    
    Return dictionary with:
        "success" as true
        "sparse_array" as result_array

Process called "sparse_array_get_row" that takes sparse_array as Dictionary and row_index as Integer returns Dictionary:
    If length of sparse_array["dimensions"] is not equal to 2:
        Return dictionary with:
            "success" as false
            "error" as "Get row only supported for 2D arrays"
    
    Let rows be sparse_array["dimensions"][0] as Integer
    Let cols be sparse_array["dimensions"][1] as Integer
    
    If row_index is less than 0 or row_index is greater than or equal to rows:
        Return dictionary with:
            "success" as false
            "error" as "Row index out of bounds"
    
    Let row_data be list containing
    
    For col from 0 to cols minus 1:
        Let get_result be sparse_array_get with sparse_array as sparse_array and indices as list containing row_index, col
        Add get_result["value"] to row_data
    
    Return dictionary with:
        "success" as true
        "row_data" as row_data
        "row_index" as row_index

Process called "sparse_array_get_column" that takes sparse_array as Dictionary and col_index as Integer returns Dictionary:
    If length of sparse_array["dimensions"] is not equal to 2:
        Return dictionary with:
            "success" as false
            "error" as "Get column only supported for 2D arrays"
    
    Let rows be sparse_array["dimensions"][0] as Integer
    Let cols be sparse_array["dimensions"][1] as Integer
    
    If col_index is less than 0 or col_index is greater than or equal to cols:
        Return dictionary with:
            "success" as false
            "error" as "Column index out of bounds"
    
    Let col_data be list containing
    
    For row from 0 to rows minus 1:
        Let get_result be sparse_array_get with sparse_array as sparse_array and indices as list containing row, col_index
        Add get_result["value"] to col_data
    
    Return dictionary with:
        "success" as true
        "column_data" as col_data
        "column_index" as col_index

Process called "sparse_array_set_row" that takes sparse_array as Dictionary and row_index as Integer and row_data as List returns Dictionary:
    If length of sparse_array["dimensions"] is not equal to 2:
        Return dictionary with:
            "success" as false
            "error" as "Set row only supported for 2D arrays"
    
    Let rows be sparse_array["dimensions"][0] as Integer
    Let cols be sparse_array["dimensions"][1] as Integer
    
    If row_index is less than 0 or row_index is greater than or equal to rows:
        Return dictionary with:
            "success" as false
            "error" as "Row index out of bounds"
    
    If length of row_data is not equal to cols:
        Return dictionary with:
            "success" as false
            "error" as "Row data length must match number of columns"
    
    For col from 0 to cols minus 1:
        Let value be row_data[col]
        Let set_result be sparse_array_set with sparse_array as sparse_array and indices as list containing row_index, col and value as value
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array

Process called "sparse_array_set_column" that takes sparse_array as Dictionary and col_index as Integer and col_data as List returns Dictionary:
    If length of sparse_array["dimensions"] is not equal to 2:
        Return dictionary with:
            "success" as false
            "error" as "Set column only supported for 2D arrays"
    
    Let rows be sparse_array["dimensions"][0] as Integer
    Let cols be sparse_array["dimensions"][1] as Integer
    
    If col_index is less than 0 or col_index is greater than or equal to cols:
        Return dictionary with:
            "success" as false
            "error" as "Column index out of bounds"
    
    If length of col_data is not equal to rows:
        Return dictionary with:
            "success" as false
            "error" as "Column data length must match number of rows"
    
    For row from 0 to rows minus 1:
        Let value be col_data[row]
        Let set_result be sparse_array_set with sparse_array as sparse_array and indices as list containing row, col_index and value as value
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array

Process called "sparse_array_find_non_zero" that takes sparse_array as Dictionary returns List:
    Let non_zero_elements be list containing
    
    For each key and value in sparse_array["elements"]:
        Let linear_index be key as Integer
        Let indices be convert_linear_to_indices with sparse_array as sparse_array and linear_index as linear_index
        
        Let element be dictionary with:
            "indices" as indices
            "value" as value
            "linear_index" as linear_index
        
        Add element to non_zero_elements
    
    Return non_zero_elements

Process called "sparse_array_statistics" that takes sparse_array as Dictionary returns Dictionary:
    Let memory_used be sparse_array["non_zero_count"] multiplied by 2
    Let memory_would_use be sparse_array["total_size"]
    Let memory_efficiency be memory_used as Float divided by memory_would_use as Float multiplied by 100.0
    
    Let sum_of_values be 0.0
    Let count_of_values be 0
    
    For each key and value in sparse_array["elements"]:
        Set sum_of_values to sum_of_values plus value as Float
        Set count_of_values to count_of_values plus 1
    
    Let average_non_zero be 0.0
    If count_of_values is greater than 0:
        Set average_non_zero to sum_of_values divided by count_of_values as Float
    
    Return dictionary with:
        "total_size" as sparse_array["total_size"]
        "non_zero_count" as sparse_array["non_zero_count"]
        "zero_count" as sparse_array["total_size"] minus sparse_array["non_zero_count"]
        "sparsity_ratio" as 100.0 minus sparse_array["compression_ratio"]
        "compression_ratio" as sparse_array["compression_ratio"]
        "memory_efficiency_percent" as memory_efficiency
        "access_count" as sparse_array["access_count"]
        "modification_count" as sparse_array["modification_count"]
        "dimensions" as sparse_array["dimensions"]
        "default_value" as sparse_array["default_value"]
        "average_non_zero_value" as average_non_zero
        "sum_of_non_zero_values" as sum_of_values

Process called "sparse_array_compress" that takes sparse_array as Dictionary returns Dictionary:
    Let keys_to_remove be list containing
    
    For each key and value in sparse_array["elements"]:
        If value is equal to sparse_array["default_value"]:
            Add key to keys_to_remove
    
    For each key in keys_to_remove:
        Remove key from sparse_array["elements"]
        Set sparse_array["non_zero_count"] to sparse_array["non_zero_count"] minus 1
    
    Let compression_ratio be sparse_array["non_zero_count"] as Float divided by sparse_array["total_size"] as Float multiplied by 100.0
    Set sparse_array["compression_ratio"] to compression_ratio
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array
        "removed_count" as length of keys_to_remove

Process called "sparse_array_fill_range" that takes sparse_array as Dictionary and start_indices as List and end_indices as List and value as Any returns Dictionary:
    If length of start_indices is not equal to length of sparse_array["dimensions"]:
        Return dictionary with:
            "success" as false
            "error" as "Start indices dimension mismatch"
    
    If length of end_indices is not equal to length of sparse_array["dimensions"]:
        Return dictionary with:
            "success" as false
            "error" as "End indices dimension mismatch"
    
    For i from 0 to length of start_indices minus 1:
        Let start_val be start_indices[i] as Integer
        Let end_val be end_indices[i] as Integer
        Let dim_size be sparse_array["dimensions"][i] as Integer
        
        If start_val is less than 0 or start_val is greater than or equal to dim_size:
            Return dictionary with:
                "success" as false
                "error" as "Start index out of bounds"
        
        If end_val is less than 0 or end_val is greater than or equal to dim_size:
            Return dictionary with:
                "success" as false
                "error" as "End index out of bounds"
        
        If start_val is greater than end_val:
            Return dictionary with:
                "success" as false
                "error" as "Start index must be less than or equal to end index"
    
    Let modified_count be 0
    Let current_indices be list containing
    
    For i from 0 to length of start_indices minus 1:
        Add start_indices[i] to current_indices
    
    Let fill_recursive_result be fill_range_recursive with sparse_array as sparse_array and current_indices as current_indices and start_indices as start_indices and end_indices as end_indices and value as value and dimension as 0
    
    Return dictionary with:
        "success" as true
        "sparse_array" as sparse_array
        "modified_count" as fill_recursive_result["modified_count"]

Process called "fill_range_recursive" that takes sparse_array as Dictionary and current_indices as List and start_indices as List and end_indices as List and value as Any and dimension as Integer returns Dictionary:
    If dimension is equal to length of sparse_array["dimensions"]:
        Let set_result be sparse_array_set with sparse_array as sparse_array and indices as current_indices and value as value
        Return dictionary with:
            "modified_count" as 1
    
    Let total_modified be 0
    Let start_val be start_indices[dimension] as Integer
    Let end_val be end_indices[dimension] as Integer
    
    For index from start_val to end_val:
        Set current_indices[dimension] to index
        Let recursive_result be fill_range_recursive with sparse_array as sparse_array and current_indices as current_indices and start_indices as start_indices and end_indices as end_indices and value as value and dimension as dimension plus 1
        Set total_modified to total_modified plus recursive_result["modified_count"]
    
    Return dictionary with:
        "modified_count" as total_modified