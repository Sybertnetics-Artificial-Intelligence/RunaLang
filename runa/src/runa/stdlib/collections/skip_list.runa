Note: Runa Skip List Implementation
Skip List is a probabilistic data structure that maintains sorted order with fast search, insertion, and deletion.
Provides O(log n) expected time complexity for all operations using Dictionary-based architecture.

All operations return Dictionary types with success indicators and maintain natural language syntax compliance.
:End Note

Type SkipList is Dictionary with:
    header as Dictionary
    max_level as Integer
    current_level as Integer
    size as Integer
    probability as Float
    comparisons_count as Integer
    insertions_count as Integer
    deletions_count as Integer
    random_seed as Integer

Process called "create_skip_list" that takes max_level as Integer and probability as Float returns Dictionary:
    If max_level is less than 1:
        Return dictionary with:
            "success" as false
            "error" as "Max level must be at least 1"
    
    If probability is less than or equal to 0.0 or probability is greater than or equal to 1.0:
        Return dictionary with:
            "success" as false
            "error" as "Probability must be between 0.0 and 1.0"
    
    Let forward_list be list containing
    For i from 0 to max_level:
        Add nothing to forward_list
    
    Let header be dictionary with:
        "key" as negative 999999.0
        "value" as nothing
        "forward" as forward_list
        "level" as max_level
    
    Let skip_list be dictionary with:
        "header" as header
        "max_level" as max_level
        "current_level" as 0
        "size" as 0
        "probability" as probability
        "comparisons_count" as 0
        "insertions_count" as 0
        "deletions_count" as 0
        "random_seed" as 12345
    
    Return dictionary with:
        "success" as true
        "skip_list" as skip_list

Process called "generate_random_level" that takes skip_list as Dictionary returns Integer:
    Let level be 0
    Let current_seed be skip_list["random_seed"]
    
    While level is less than skip_list["max_level"]:
        Set current_seed to current_seed multiplied by 1103515245 plus 12345
        Set current_seed to current_seed modulo 2147483647
        Let random_float be current_seed as Float divided by 2147483647.0
        
        If random_float is greater than or equal to skip_list["probability"]:
            Break
        
        Set level to level plus 1
    
    Set skip_list["random_seed"] to current_seed
    Return level

Process called "create_skip_list_node" that takes key as Float and value as Any and level as Integer returns Dictionary:
    Let forward_list be list containing
    For i from 0 to level:
        Add nothing to forward_list
    
    Return dictionary with:
        "key" as key
        "value" as value
        "forward" as forward_list
        "level" as level

Process called "skip_list_search" that takes skip_list as Dictionary and key as Float returns Dictionary:
    Let current be skip_list["header"]
    Set skip_list["comparisons_count"] to skip_list["comparisons_count"] plus 1
    
    For level from skip_list["current_level"] down to 0:
        While current["forward"][level] is not nothing:
            Let next_node be current["forward"][level]
            Set skip_list["comparisons_count"] to skip_list["comparisons_count"] plus 1
            
            If next_node["key"] is less than key:
                Set current to next_node
            Otherwise:
                Break
    
    Let current be current["forward"][0]
    
    If current is not nothing and current["key"] is equal to key:
        Return dictionary with:
            "found" as true
            "value" as current["value"]
            "node" as current
    
    Return dictionary with:
        "found" as false
        "value" as nothing
        "node" as nothing

Process called "skip_list_insert" that takes skip_list as Dictionary and key as Float and value as Any returns Dictionary:
    Let update_list be list containing
    For i from 0 to skip_list["max_level"]:
        Add skip_list["header"] to update_list
    
    Let current be skip_list["header"]
    
    For level from skip_list["current_level"] down to 0:
        While current["forward"][level] is not nothing:
            Let next_node be current["forward"][level]
            Set skip_list["comparisons_count"] to skip_list["comparisons_count"] plus 1
            
            If next_node["key"] is less than key:
                Set current to next_node
            Otherwise:
                Break
        
        Set update_list[level] to current
    
    Set current to current["forward"][0]
    
    If current is not nothing and current["key"] is equal to key:
        Set current["value"] to value
        Return dictionary with:
            "success" as true
            "skip_list" as skip_list
            "action" as "updated"
    
    Let new_level be generate_random_level with skip_list as skip_list
    
    If new_level is greater than skip_list["current_level"]:
        For level from skip_list["current_level"] plus 1 to new_level:
            Set update_list[level] to skip_list["header"]
        
        Set skip_list["current_level"] to new_level
    
    Let new_node be create_skip_list_node with key as key and value as value and level as new_level
    
    For level from 0 to new_level:
        Set new_node["forward"][level] to update_list[level]["forward"][level]
        Set update_list[level]["forward"][level] to new_node
    
    Set skip_list["size"] to skip_list["size"] plus 1
    Set skip_list["insertions_count"] to skip_list["insertions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "skip_list" as skip_list
        "action" as "inserted"

Process called "skip_list_delete" that takes skip_list as Dictionary and key as Float returns Dictionary:
    Let update_list be list containing
    For i from 0 to skip_list["max_level"]:
        Add skip_list["header"] to update_list
    
    Let current be skip_list["header"]
    
    For level from skip_list["current_level"] down to 0:
        While current["forward"][level] is not nothing:
            Let next_node be current["forward"][level]
            Set skip_list["comparisons_count"] to skip_list["comparisons_count"] plus 1
            
            If next_node["key"] is less than key:
                Set current to next_node
            Otherwise:
                Break
        
        Set update_list[level] to current
    
    Set current to current["forward"][0]
    
    If current is nothing or current["key"] is not equal to key:
        Return dictionary with:
            "success" as false
            "found" as false
            "skip_list" as skip_list
    
    For level from 0 to skip_list["current_level"]:
        If update_list[level]["forward"][level] is equal to current:
            Set update_list[level]["forward"][level] to current["forward"][level]
    
    While skip_list["current_level"] is greater than 0 and skip_list["header"]["forward"][skip_list["current_level"]] is nothing:
        Set skip_list["current_level"] to skip_list["current_level"] minus 1
    
    Set skip_list["size"] to skip_list["size"] minus 1
    Set skip_list["deletions_count"] to skip_list["deletions_count"] plus 1
    
    Return dictionary with:
        "success" as true
        "found" as true
        "deleted_value" as current["value"]
        "skip_list" as skip_list

Process called "skip_list_get_all_pairs" that takes skip_list as Dictionary returns List:
    Let pairs be list containing
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        Let pair be dictionary with:
            "key" as current["key"]
            "value" as current["value"]
        
        Add pair to pairs
        Set current to current["forward"][0]
    
    Return pairs

Process called "skip_list_get_range" that takes skip_list as Dictionary and min_key as Float and max_key as Float returns List:
    Let results be list containing
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        If current["key"] is greater than max_key:
            Break
        
        If current["key"] is greater than or equal to min_key:
            Let pair be dictionary with:
                "key" as current["key"]
                "value" as current["value"]
            Add pair to results
        
        Set current to current["forward"][0]
    
    Return results

Process called "skip_list_count_range" that takes skip_list as Dictionary and min_key as Float and max_key as Float returns Integer:
    Let count be 0
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        If current["key"] is greater than max_key:
            Break
        
        If current["key"] is greater than or equal to min_key:
            Set count to count plus 1
        
        Set current to current["forward"][0]
    
    Return count

Process called "skip_list_find_predecessor" that takes skip_list as Dictionary and key as Float returns Dictionary:
    Let current be skip_list["header"]
    Let predecessor be nothing
    
    For level from skip_list["current_level"] down to 0:
        While current["forward"][level] is not nothing:
            Let next_node be current["forward"][level]
            
            If next_node["key"] is less than key:
                Set current to next_node
                Set predecessor to current
            Otherwise:
                Break
    
    If predecessor is not nothing:
        Return dictionary with:
            "found" as true
            "key" as predecessor["key"]
            "value" as predecessor["value"]
    
    Return dictionary with:
        "found" as false
        "key" as nothing
        "value" as nothing

Process called "skip_list_find_successor" that takes skip_list as Dictionary and key as Float returns Dictionary:
    Let current be skip_list["header"]
    
    For level from skip_list["current_level"] down to 0:
        While current["forward"][level] is not nothing:
            Let next_node be current["forward"][level]
            
            If next_node["key"] is less than or equal to key:
                Set current to next_node
            Otherwise:
                Break
    
    Let successor be current["forward"][0]
    
    If successor is not nothing and successor["key"] is greater than key:
        Return dictionary with:
            "found" as true
            "key" as successor["key"]
            "value" as successor["value"]
    
    Return dictionary with:
        "found" as false
        "key" as nothing
        "value" as nothing

Process called "skip_list_get_rank" that takes skip_list as Dictionary and key as Float returns Integer:
    Let rank be 0
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        If current["key"] is greater than or equal to key:
            Break
        
        Set rank to rank plus 1
        Set current to current["forward"][0]
    
    Return rank

Process called "skip_list_get_by_rank" that takes skip_list as Dictionary and rank as Integer returns Dictionary:
    If rank is less than 0 or rank is greater than or equal to skip_list["size"]:
        Return dictionary with:
            "found" as false
            "key" as nothing
            "value" as nothing
    
    Let current_rank be 0
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        If current_rank is equal to rank:
            Return dictionary with:
                "found" as true
                "key" as current["key"]
                "value" as current["value"]
        
        Set current_rank to current_rank plus 1
        Set current to current["forward"][0]
    
    Return dictionary with:
        "found" as false
        "key" as nothing
        "value" as nothing

Process called "skip_list_clear" that takes skip_list as Dictionary returns Dictionary:
    For i from 0 to skip_list["max_level"]:
        Set skip_list["header"]["forward"][i] to nothing
    
    Set skip_list["current_level"] to 0
    Set skip_list["size"] to 0
    Set skip_list["comparisons_count"] to 0
    Set skip_list["insertions_count"] to 0
    Set skip_list["deletions_count"] to 0
    
    Return skip_list

Process called "skip_list_is_empty" that takes skip_list as Dictionary returns Boolean:
    Return skip_list["size"] is equal to 0

Process called "skip_list_statistics" that takes skip_list as Dictionary returns Dictionary:
    Let level_counts be list containing
    For i from 0 to skip_list["max_level"]:
        Add 0 to level_counts
    
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        Let node_level be current["level"]
        
        For level from 0 to node_level:
            Set level_counts[level] to level_counts[level] plus 1
        
        Set current to current["forward"][0]
    
    Let expected_nodes_at_level be skip_list["size"] as Float
    Let level_efficiency be list containing
    
    For level from 0 to skip_list["current_level"]:
        Let actual_count be level_counts[level] as Float
        
        If expected_nodes_at_level is greater than 0.0:
            Let efficiency be actual_count divided by expected_nodes_at_level
            Add efficiency to level_efficiency
        Otherwise:
            Add 0.0 to level_efficiency
        
        Set expected_nodes_at_level to expected_nodes_at_level multiplied by skip_list["probability"]
    
    Return dictionary with:
        "size" as skip_list["size"]
        "max_level" as skip_list["max_level"]
        "current_level" as skip_list["current_level"]
        "probability" as skip_list["probability"]
        "comparisons_count" as skip_list["comparisons_count"]
        "insertions_count" as skip_list["insertions_count"]
        "deletions_count" as skip_list["deletions_count"]
        "level_distribution" as level_counts
        "level_efficiency" as level_efficiency

Process called "skip_list_bulk_insert" that takes skip_list as Dictionary and pairs as List returns Dictionary:
    For each pair in pairs:
        Let key be pair["key"] as Float
        Let value be pair["value"]
        Let insert_result be skip_list_insert with skip_list as skip_list and key as key and value as value
        Set skip_list to insert_result["skip_list"]
    
    Return dictionary with:
        "success" as true
        "skip_list" as skip_list

Process called "skip_list_merge" that takes skip_list1 as Dictionary and skip_list2 as Dictionary returns Dictionary:
    Let max_level be skip_list1["max_level"]
    If skip_list2["max_level"] is greater than max_level:
        Set max_level to skip_list2["max_level"]
    
    Let probability be skip_list1["probability"]
    If skip_list2["probability"] is less than probability:
        Set probability to skip_list2["probability"]
    
    Let merged_result be create_skip_list with max_level as max_level and probability as probability
    Let merged_list be merged_result["skip_list"]
    
    Let pairs1 be skip_list_get_all_pairs with skip_list as skip_list1
    Let bulk_result1 be skip_list_bulk_insert with skip_list as merged_list and pairs as pairs1
    Set merged_list to bulk_result1["skip_list"]
    
    Let pairs2 be skip_list_get_all_pairs with skip_list as skip_list2
    Let bulk_result2 be skip_list_bulk_insert with skip_list as merged_list and pairs as pairs2
    Set merged_list to bulk_result2["skip_list"]
    
    Return dictionary with:
        "success" as true
        "merged_skip_list" as merged_list

Process called "skip_list_split_at_key" that takes skip_list as Dictionary and split_key as Float returns Dictionary:
    Let left_result be create_skip_list with max_level as skip_list["max_level"] and probability as skip_list["probability"]
    Let left_list be left_result["skip_list"]
    
    Let right_result be create_skip_list with max_level as skip_list["max_level"] and probability as skip_list["probability"]
    Let right_list be right_result["skip_list"]
    
    Let current be skip_list["header"]["forward"][0]
    
    While current is not nothing:
        If current["key"] is less than split_key:
            Let left_insert be skip_list_insert with skip_list as left_list and key as current["key"] and value as current["value"]
            Set left_list to left_insert["skip_list"]
        Otherwise:
            Let right_insert be skip_list_insert with skip_list as right_list and key as current["key"] and value as current["value"]
            Set right_list to right_insert["skip_list"]
        
        Set current to current["forward"][0]
    
    Return dictionary with:
        "success" as true
        "left_skip_list" as left_list
        "right_skip_list" as right_list

Process called "create_skip_list_from_sorted_pairs" that takes sorted_pairs as List and max_level as Integer and probability as Float returns Dictionary:
    Let create_result be create_skip_list with max_level as max_level and probability as probability
    Let skip_list be create_result["skip_list"]
    
    For each pair in sorted_pairs:
        Let key be pair["key"] as Float
        Let value be pair["value"]
        Let insert_result be skip_list_insert with skip_list as skip_list and key as key and value as value
        Set skip_list to insert_result["skip_list"]
    
    Return dictionary with:
        "success" as true
        "skip_list" as skip_list