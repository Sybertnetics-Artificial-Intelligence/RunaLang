Note:
Runa Standard Library: Heap (Priority Queue)

Provides comprehensive heap/priority queue functionality with natural language operations for pushing, popping, peeking, and heapifying elements. Supports both min-heap and max-heap with custom comparators, bulk operations, and advanced heap algorithms.

Features include:
- Min-heap and max-heap support
- Custom comparator functions
- Bulk operations and heap merging
- K-largest/smallest element extraction
- Heap validation and debugging
- Performance optimizations
- Thread-safe operations (when supported)
:End Note

Type Heap[T] is Dictionary with:
    items as List[T]
    comparator as Process
    heap_type as String

Type HeapNode[T] is Dictionary with:
    priority as Number
    value as T
    timestamp as Integer

Note: Core Heap Operations
Process called "create_heap" that returns Heap[Any]:
    Return Heap with:
        items as create_list with elements as list containing
        comparator as lambda a and b: a is less than b
        heap_type as "min"

Process called "create_max_heap" that returns Heap[Any]:
    Return Heap with:
        items as create_list with elements as list containing
        comparator as lambda a and b: a is greater than b
        heap_type as "max"

Process called "create_heap_with_comparator" that takes comparator as Process returns Heap[Any]:
    Return Heap with:
        items as create_list with elements as list containing
        comparator as comparator
        heap_type as "custom"

Process called "heap_length" that takes heap as Heap[Any] returns Integer:
    Let items be heap["items"]
    Return length of items

Process called "heap_is_empty" that takes heap as Heap[Any] returns Boolean:
    Return heap_length with heap as heap is equal to 0

Process called "push" that takes heap as Heap[Any] and value as Any returns Heap[Any]:
    Let items be heap["items"]
    Let new_items be append with lst as items and value as value
    Let new_heap be set_field with obj as heap and field as "items" and value as new_items
    Return heapify_up with heap as new_heap and index as heap_length with heap as new_heap minus 1

Process called "push_with_priority" that takes heap as Heap[Any] and value as Any and priority as Number returns Heap[Any]:
    Let items be heap["items"]
    Let timestamp be get_current_timestamp
    Let node be HeapNode with:
        priority as priority
        value as value
        timestamp as timestamp
    Let new_items be append with lst as items and value as node
    Let new_heap be set_field with obj as heap and field as "items" and value as new_items
    Return heapify_up_with_comparator with heap as new_heap and index as heap_length with heap as new_heap minus 1

Process called "pop" that takes heap as Heap[Any] returns (Heap[Any], Any):
    If heap_is_empty with heap as heap:
        Throw IndexError with message "Heap is empty"
    Let items be heap["items"]
    Let top be items[0]
    Let last_index be length of items minus 1
    Let last_item be items[last_index]
    Let items_swapped be set_at_index with lst as items and index as 0 and value as last_item
    Let items_removed be remove_at_index with lst as items_swapped and index as last_index
    Let new_heap be set_field with obj as heap and field as "items" and value as items_removed
    Let heapified_heap be heapify_down_with_comparator with heap as new_heap and index as 0
    Return (heapified_heap, top)

Process called "pop_with_priority" that takes heap as Heap[Any] returns (Heap[Any], Any, Number):
    If heap_is_empty with heap as heap:
        Throw IndexError with message "Heap is empty"
    Let items be heap["items"]
    Let top_node be items[0]
    Let last_index be length of items minus 1
    Let last_item be items[last_index]
    Let items_swapped be set_at_index with lst as items and index as 0 and value as last_item
    Let items_removed be remove_at_index with lst as items_swapped and index as last_index
    Let new_heap be set_field with obj as heap and field as "items" and value as items_removed
    Let heapified_heap be heapify_down_with_comparator with heap as new_heap and index as 0
    Return (heapified_heap, top_node["value"], top_node["priority"])

Process called "peek" that takes heap as Heap[Any] returns Any:
    If heap_is_empty with heap as heap:
        Throw IndexError with message "Heap is empty"
    Let items be heap["items"]
    Return items[0]

Process called "peek_with_priority" that takes heap as Heap[Any] returns (Any, Number):
    If heap_is_empty with heap as heap:
        Throw IndexError with message "Heap is empty"
    Let items be heap["items"]
    Let top_node be items[0]
    Return (top_node["value"], top_node["priority"])

Note: Heap Maintenance Operations
Process called "heapify_up" that takes heap as Heap[Any] and index as Integer returns Heap[Any]:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let idx be index
    While idx is greater than 0:
        Let parent be (idx minus 1) divided by 2
        If comparator with a as items[idx] and b as items[parent]:
            Let temp be items[idx]
            Let items_swapped1 be set_at_index with lst as items and index as idx and value as items[parent]
            Let items_swapped2 be set_at_index with lst as items_swapped1 and index as parent and value as temp
            Set items to items_swapped2
            Set idx to parent
        Otherwise:
            Break
    Return set_field with obj as heap and field as "items" and value as items

Process called "heapify_up_with_comparator" that takes heap as Heap[Any] and index as Integer returns Heap[Any]:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let idx be index
    While idx is greater than 0:
        Let parent be (idx minus 1) divided by 2
        Let current_node be items[idx]
        Let parent_node be items[parent]
        If comparator with a as current_node["priority"] and b as parent_node["priority"]:
            Let temp be items[idx]
            Let items_swapped1 be set_at_index with lst as items and index as idx and value as items[parent]
            Let items_swapped2 be set_at_index with lst as items_swapped1 and index as parent and value as temp
            Set items to items_swapped2
            Set idx to parent
        Otherwise:
            Break
    Return set_field with obj as heap and field as "items" and value as items

Process called "heapify_down" that takes heap as Heap[Any] and index as Integer returns Heap[Any]:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let size be length of items
    Let idx be index
    While True:
        Let left be (idx multiplied by 2) plus 1
        Let right be (idx multiplied by 2) plus 2
        Let smallest be idx
        If left is less than size and comparator with a as items[left] and b as items[smallest]:
            Set smallest to left
        If right is less than size and comparator with a as items[right] and b as items[smallest]:
            Set smallest to right
        If smallest is not equal to idx:
            Let temp be items[idx]
            Let items_swapped1 be set_at_index with lst as items and index as idx and value as items[smallest]
            Let items_swapped2 be set_at_index with lst as items_swapped1 and index as smallest and value as temp
            Set items to items_swapped2
            Set idx to smallest
        Otherwise:
            Break
    Return set_field with obj as heap and field as "items" and value as items

Process called "heapify_down_with_comparator" that takes heap as Heap[Any] and index as Integer returns Heap[Any]:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let size be length of items
    Let idx be index
    While True:
        Let left be (idx multiplied by 2) plus 1
        Let right be (idx multiplied by 2) plus 2
        Let smallest be idx
        If left is less than size and comparator with a as items[left]["priority"] and b as items[smallest]["priority"]:
            Set smallest to left
        If right is less than size and comparator with a as items[right]["priority"] and b as items[smallest]["priority"]:
            Set smallest to right
        If smallest is not equal to idx:
            Let temp be items[idx]
            Let items_swapped1 be set_at_index with lst as items and index as idx and value as items[smallest]
            Let items_swapped2 be set_at_index with lst as items_swapped1 and index as smallest and value as temp
            Set items to items_swapped2
            Set idx to smallest
        Otherwise:
            Break
    Return set_field with obj as heap and field as "items" and value as items

Note: Bulk Operations
Process called "heapify" that takes items as List[Any] returns Heap[Any]:
    Let heap be create_heap
    Let heap be set_field with obj as heap and field as "items" and value as items
    Let size be length of items
    For i from (size divided by 2) minus 1 to negative 1 by negative 1:
        Let heap be heapify_down with heap as heap and index as i
    Return heap

Process called "heapify_max" that takes items as List[Any] returns Heap[Any]:
    Let heap be create_max_heap
    Let heap be set_field with obj as heap and field as "items" and value as items
    Let size be length of items
    For i from (size divided by 2) minus 1 to negative 1 by negative 1:
        Let heap be heapify_down with heap as heap and index as i
    Return heap

Process called "heapify_with_comparator" that takes items as List[Any] and comparator as Process returns Heap[Any]:
    Let heap be create_heap_with_comparator with comparator as comparator
    Let heap be set_field with obj as heap and field as "items" and value as items
    Let size be length of items
    For i from (size divided by 2) minus 1 to negative 1 by negative 1:
        Let heap be heapify_down with heap as heap and index as i
    Return heap

Process called "merge_heaps" that takes heap1 as Heap[Any] and heap2 as Heap[Any] returns Heap[Any]:
    Let items1 be heap1["items"]
    Let items2 be heap2["items"]
    Let merged_items be concatenate_lists with lst1 as items1 and lst2 as items2
    Let merged_heap be create_heap
    Let merged_heap be set_field with obj as merged_heap and field as "items" and value as merged_items
    Let merged_heap be set_field with obj as merged_heap and field as "comparator" and value as heap1["comparator"]
    Let merged_heap be set_field with obj as merged_heap and field as "heap_type" and value as heap1["heap_type"]
    Let size be length of merged_items
    For i from (size divided by 2) minus 1 to negative 1 by negative 1:
        Let merged_heap be heapify_down with heap as merged_heap and index as i
    Return merged_heap

Process called "extend" that takes heap as Heap[Any] and values as List[Any] returns Heap[Any]:
    Let items be heap["items"]
    Let new_items be concatenate_lists with lst1 as items and lst2 as values
    Let new_heap be set_field with obj as heap and field as "items" and value as new_items
    Let size be length of new_items
    For i from (size divided by 2) minus 1 to negative 1 by negative 1:
        Let new_heap be heapify_down with heap as new_heap and index as i
    Return new_heap

Note: K-Element Operations
Process called "k_largest" that takes heap as Heap[Any] and k as Integer returns List[Any]:
    Let result be create_list with elements as list containing
    Let temp_heap be copy_heap with heap as heap
    For i from 1 to k:
        If heap_is_empty with heap as temp_heap:
            Break
        Let (temp_heap, value) be pop with heap as temp_heap
        Add value to result
    Return result

Process called "k_smallest" that takes heap as Heap[Any] and k as Integer returns List[Any]:
    Let result be create_list with elements as list containing
    Let temp_heap be copy_heap with heap as heap
    For i from 1 to k:
        If heap_is_empty with heap as temp_heap:
            Break
        Let (temp_heap, value) be pop with heap as temp_heap
        Add value to result
    Return result

Process called "nlargest" that takes items as List[Any] and n as Integer returns List[Any]:
    Let heap be heapify with items as items
    Return k_largest with heap as heap and k as n

Process called "nsmallest" that takes items as List[Any] and n as Integer returns List[Any]:
    Let heap be heapify_max with items as items
    Return k_smallest with heap as heap and k as n

Note: Heap Validation and Debugging
Process called "is_valid_heap" that takes heap as Heap[Any] returns Boolean:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let size be length of items
    For i from 0 to (size divided by 2) minus 1:
        Let left be (i multiplied by 2) plus 1
        Let right be (i multiplied by 2) plus 2
        If left is less than size and not comparator with a as items[i] and b as items[left]:
            Return false
        If right is less than size and not comparator with a as items[i] and b as items[right]:
            Return false
    Return true

Process called "heap_to_list" that takes heap as Heap[Any] returns List[Any]:
    Let items be heap["items"]
    Let result be create_list with elements as list containing
    For each item in items:
        Add item to result
    Return result

Process called "heap_to_sorted_list" that takes heap as Heap[Any] returns List[Any]:
    Let result be create_list with elements as list containing
    Let temp_heap be copy_heap with heap as heap
    While not heap_is_empty with heap as temp_heap:
        Let (temp_heap, value) be pop with heap as temp_heap
        Add value to result
    Return result

Process called "copy_heap" that takes heap as Heap[Any] returns Heap[Any]:
    Let items be heap["items"]
    Let comparator be heap["comparator"]
    Let heap_type be heap["heap_type"]
    Let new_items be create_list with elements as list containing
    For each item in items:
        Add item to new_items
    Return Heap with:
        items as new_items
        comparator as comparator
        heap_type as heap_type

Note: Advanced Operations
Process called "replace" that takes heap as Heap[Any] and value as Any returns (Heap[Any], Any):
    If heap_is_empty with heap as heap:
        Throw IndexError with message "Heap is empty"
    Let items be heap["items"]
    Let old_top be items[0]
    Let items_updated be set_at_index with lst as items and index as 0 and value as value
    Let new_heap be set_field with obj as heap and field as "items" and value as items_updated
    Let heapified_heap be heapify_down with heap as new_heap and index as 0
    Return (heapified_heap, old_top)

Process called "pushpop" that takes heap as Heap[Any] and value as Any returns (Heap[Any], Any):
    If heap_is_empty with heap as heap:
        Return (push with heap as heap and value as value, value)
    Let items be heap["items"]
    Let top be items[0]
    Let comparator be heap["comparator"]
    If comparator with a as value and b as top:
        Return (heap, value)
    Let items_updated be set_at_index with lst as items and index as 0 and value as value
    Let new_heap be set_field with obj as heap and field as "items" and value as items_updated
    Let heapified_heap be heapify_down with heap as new_heap and index as 0
    Return (heapified_heap, top)

Process called "update_priority" that takes heap as Heap[Any] and index as Integer and new_priority as Number returns Heap[Any]:
    Let items be heap["items"]
    Let size be length of items
    If index is less than 0 or index is greater than or equal to size:
        Throw IndexError with message "Index out of bounds"
    Let node be items[index]
    Let updated_node be HeapNode with:
        priority as new_priority
        value as node["value"]
        timestamp as node["timestamp"]
    Let items_updated be set_at_index with lst as items and index as index and value as updated_node
    Let new_heap be set_field with obj as heap and field as "items" and value as items_updated
    If new_priority is less than node["priority"]:
        Return heapify_up_with_comparator with heap as new_heap and index as index
    Otherwise:
        Return heapify_down_with_comparator with heap as new_heap and index as index

Process called "remove_at_index" that takes heap as Heap[Any] and index as Integer returns Heap[Any]:
    Let items be heap["items"]
    Let size be length of items
    If index is less than 0 or index is greater than or equal to size:
        Throw IndexError with message "Index out of bounds"
    If index is equal to 0:
        Return pop with heap as heap
    Let last_index be size minus 1
    Let last_item be items[last_index]
    Let items_swapped be set_at_index with lst as items and index as index and value as last_item
    Let items_removed be remove_at_index with lst as items_swapped and index as last_index
    Let new_heap be set_field with obj as heap and field as "items" and value as items_removed
    Return heapify_down_with_comparator with heap as new_heap and index as index

Note: Utility Operations
Process called "clear" that takes heap as Heap[Any] returns Heap[Any]:
    Return set_field with obj as heap and field as "items" and value as create_list with elements as list containing

Process called "get_heap_type" that takes heap as Heap[Any] returns String:
    Return heap["heap_type"]

Process called "get_comparator" that takes heap as Heap[Any] returns Process:
    Return heap["comparator"]

Note: Helper Functions
Process called "append" that takes lst as List[Any] and value as Any returns List[Any]:
    Let new_lst be create_list with elements as list containing
    For each item in lst:
        Add item to new_lst
    Add value to new_lst
    Return new_lst

Process called "set_at_index" that takes lst as List[Any] and index as Integer and value as Any returns List[Any]:
    Let new_lst be create_list with elements as list containing
    For i from 0 to length of lst:
        If i is equal to index:
            Add value to new_lst
        Otherwise:
            Add lst[i] to new_lst
    Return new_lst

Process called "remove_at_index" that takes lst as List[Any] and index as Integer returns List[Any]:
    Let new_lst be create_list with elements as list containing
    For i from 0 to length of lst:
        If i is not equal to index:
            Add lst[i] to new_lst
    Return new_lst

Process called "concatenate_lists" that takes lst1 as List[Any] and lst2 as List[Any] returns List[Any]:
    Let result be create_list with elements as list containing
    For each item in lst1:
        Add item to result
    For each item in lst2:
        Add item to result
    Return result

Process called "create_list" that takes elements as List[Any] returns List[Any]:
    Let result be list containing
    For each element in elements:
        Add element to result
    Return result

Process called "set_field" that takes obj as Dictionary and field as String and value as Any returns Dictionary:
    Set obj[field] to value
    Return obj

Process called "get_current_timestamp" that returns Integer:
    Return 0  Note: Placeholder for actual timestamp implementation 