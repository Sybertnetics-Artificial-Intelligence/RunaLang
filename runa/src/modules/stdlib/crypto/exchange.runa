Note: Runa Standard Library - Key Exchange Protocols
This module provides production-grade key exchange protocols including Diffie-Hellman,
ECDH, X25519, secure key derivation functions (KDF), and forward secrecy mechanisms.

Supports ephemeral key exchanges, key agreement protocols, and secure session
establishment for cryptographic communications.

Specification compliance: RFC 7748 (X25519), RFC 5869 (HKDF), RFC 8235 (Schnorr), NIST SP 800-56A.
:End Note

Import "crypto/asymmetric" as asymmetric
Import "crypto/hash" as hash
Import "crypto/primitives/random" as random
Import "crypto/primitives/bignum" as bignum
Import "crypto/primitives/curve" as curve

Type KeyExchangeParameters is Dictionary with:
    protocol as String
    key_size as Integer
    curve_name as Optional[String]
    generator as Optional[Dictionary[String, Any]]
    modulus as Optional[List[Integer]]
    base as Optional[List[Integer]]

Type EphemeralKeyPair is Dictionary with:
    protocol as String
    private_key as List[Integer]
    public_key as List[Integer]
    parameters as KeyExchangeParameters
    creation_time as DateTime
    expiry_time as DateTime

Type SharedSecretResult is Dictionary with:
    shared_secret as List[Integer]
    key_size as Integer
    protocol as String
    session_id as String
    forward_secrecy as Boolean

Type KeyDerivationResult is Dictionary with:
    derived_key as List[Integer]
    key_length as Integer
    algorithm as String
    salt as List[Integer]
    iterations as Integer

Type KeyExchangeResult is Union with:
    KeyExchangeSuccess with value as Dictionary[String, Any]
    KeyExchangeFailure with error as KeyExchangeError and message as String

Type KeyExchangeError is Enum with:
    Invalid_Protocol
    Invalid_Parameters
    Key_Generation_Failed
    Invalid_Public_Key
    Shared_Secret_Failed
    Derivation_Failed
    Protocol_Mismatch
    Weak_Parameters
    Expired_Key
    Internal_Error

Note: Key Exchange Protocol Constants
Let PROTOCOL_DH_2048 be "DH-2048"
Let PROTOCOL_DH_3072 be "DH-3072"
Let PROTOCOL_DH_4096 be "DH-4096"
Let PROTOCOL_ECDH_P256 be "ECDH-P256"
Let PROTOCOL_ECDH_P384 be "ECDH-P384"
Let PROTOCOL_ECDH_P521 be "ECDH-P521"
Let PROTOCOL_X25519 be "X25519"
Let PROTOCOL_FFDHE_2048 be "FFDHE-2048"
Let PROTOCOL_FFDHE_3072 be "FFDHE-3072"
Let PROTOCOL_FFDHE_4096 be "FFDHE-4096"

Note: Key Derivation Function Constants
Let KDF_HKDF_SHA256 be "HKDF-SHA256"
Let KDF_HKDF_SHA384 be "HKDF-SHA384"
Let KDF_HKDF_SHA512 be "HKDF-SHA512"
Let KDF_PBKDF2_SHA256 be "PBKDF2-SHA256"
Let KDF_SCRYPT be "scrypt"
Let KDF_ARGON2ID be "Argon2id"

Note: Standard DH Parameters (RFC 3526)
Let DH_2048_PRIME be list containing 255, 255, 255, 255, 255, 255, 255, 255, 201, 15, 218, 162, 33, 104, 194, 52, 196, 198, 98, 139, 128, 220, 28, 209, 41, 2, 78, 8, 138, 103, 204, 116, 2, 11, 190, 166, 59, 19, 155, 34, 81, 74, 8, 121, 142, 52, 4, 221, 239, 149, 25, 179, 205, 58, 67, 27, 48, 43, 10, 109, 242, 95, 20, 55, 79, 225, 53, 109, 109, 81, 194, 69, 228, 133, 181, 118, 98, 94, 126, 198, 244, 76, 66, 233, 166, 55, 237, 107, 11, 255, 92, 182, 244, 6, 183, 237, 238, 56, 107, 251, 90, 137, 159, 165, 174, 159, 36, 17, 124, 75, 31, 230, 73, 40, 102, 81, 236, 230, 83, 129, 255, 255, 255, 255, 255, 255, 255, 255
Let DH_2048_GENERATOR be 2

Note: Primary Key Exchange Interface Functions

Process called "generate_ephemeral_keypair" that takes protocol as String and lifetime_seconds as Optional[Integer] returns KeyExchangeResult[EphemeralKeyPair]:
    Note: Generate ephemeral key pair for forward secrecy
    Try:
        Let current_time be time.now
        Let expiry_time be time.add_seconds with datetime as current_time and seconds as (lifetime_seconds if lifetime_seconds is not None else 3600)
        
        Note: Validate protocol and get parameters
        Let params_result be get_protocol_parameters with protocol as protocol
        Match params_result:
            When KeyExchangeFailure:
                Return params_result
            When KeyExchangeSuccess with value as params:
                Note: Generate key pair based on protocol
                Match protocol:
                    When PROTOCOL_X25519:
                        Return generate_x25519_ephemeral_keypair with params as params and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_ECDH_P256:
                        Return generate_ecdh_ephemeral_keypair with params as params and curve as "P-256" and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_ECDH_P384:
                        Return generate_ecdh_ephemeral_keypair with params as params and curve as "P-384" and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_ECDH_P521:
                        Return generate_ecdh_ephemeral_keypair with params as params and curve as "P-521" and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_DH_2048:
                        Return generate_dh_ephemeral_keypair with params as params and key_size as 2048 and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_DH_3072:
                        Return generate_dh_ephemeral_keypair with params as params and key_size as 3072 and current_time as current_time and expiry_time as expiry_time
                    When PROTOCOL_DH_4096:
                        Return generate_dh_ephemeral_keypair with params as params and key_size as 4096 and current_time as current_time and expiry_time as expiry_time
                    Otherwise:
                        Return KeyExchangeFailure with:
                            error as KeyExchangeError.Invalid_Protocol
                            message as "Unsupported key exchange protocol: " plus protocol
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Key_Generation_Failed
            message as "Ephemeral key generation error: " plus error as String

Process called "perform_key_exchange" that takes our_private_key as EphemeralKeyPair and peer_public_key as List[Integer] and session_info as Optional[Dictionary[String, String]] returns KeyExchangeResult[SharedSecretResult]:
    Note: Perform key exchange to derive shared secret with forward secrecy
    Try:
        Note: Validate key expiry
        Let current_time be time.now
        If time.compare with datetime1 as current_time and datetime2 as our_private_key.expiry_time is greater than 0:
            Return KeyExchangeFailure with:
                error as KeyExchangeError.Expired_Key
                message as "Private key has expired"
        
        Note: Validate peer public key
        Let validation_result be validate_peer_public_key with protocol as our_private_key.protocol and public_key as peer_public_key and parameters as our_private_key.parameters
        Match validation_result:
            When KeyExchangeFailure:
                Return validation_result
            When KeyExchangeSuccess:
                Note: Perform protocol-specific key exchange
                Match our_private_key.protocol:
                    When PROTOCOL_X25519:
                        Return perform_x25519_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and session_info as session_info
                    When PROTOCOL_ECDH_P256:
                        Return perform_ecdh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and curve as "P-256" and session_info as session_info
                    When PROTOCOL_ECDH_P384:
                        Return perform_ecdh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and curve as "P-384" and session_info as session_info
                    When PROTOCOL_ECDH_P521:
                        Return perform_ecdh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and curve as "P-521" and session_info as session_info
                    When PROTOCOL_DH_2048:
                        Return perform_dh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and parameters as our_private_key.parameters and session_info as session_info
                    When PROTOCOL_DH_3072:
                        Return perform_dh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and parameters as our_private_key.parameters and session_info as session_info
                    When PROTOCOL_DH_4096:
                        Return perform_dh_key_exchange with private_key as our_private_key.private_key and peer_public_key as peer_public_key and parameters as our_private_key.parameters and session_info as session_info
                    Otherwise:
                        Return KeyExchangeFailure with:
                            error as KeyExchangeError.Protocol_Mismatch
                            message as "Unsupported protocol for key exchange: " plus our_private_key.protocol
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Shared_Secret_Failed
            message as "Key exchange error: " plus error as String

Process called "derive_keys" that takes shared_secret as List[Integer] and salt as List[Integer] and info as String and output_length as Integer and algorithm as String returns KeyExchangeResult[KeyDerivationResult]:
    Note: Derive cryptographic keys from shared secret using HKDF or other KDFs
    Try:
        Note: Validate parameters
        If length of shared_secret is equal to 0:
            Return KeyExchangeFailure with:
                error as KeyExchangeError.Invalid_Parameters
                message as "Shared secret cannot be empty"
        
        If output_length is less than 1 or output_length is greater than 8192:
            Return KeyExchangeFailure with:
                error as KeyExchangeError.Invalid_Parameters
                message as "Output length must be between 1 and 8192 bytes"
        
        Note: Perform key derivation based on algorithm
        Match algorithm:
            When KDF_HKDF_SHA256:
                Return derive_hkdf with shared_secret as shared_secret and salt as salt and info as info and output_length as output_length and hash_algorithm as "SHA256"
            When KDF_HKDF_SHA384:
                Return derive_hkdf with shared_secret as shared_secret and salt as salt and info as info and output_length as output_length and hash_algorithm as "SHA384"
            When KDF_HKDF_SHA512:
                Return derive_hkdf with shared_secret as shared_secret and salt as salt and info as info and output_length as output_length and hash_algorithm as "SHA512"
            When KDF_PBKDF2_SHA256:
                Return derive_pbkdf2 with password as shared_secret and salt as salt and iterations as 100000 and output_length as output_length and hash_algorithm as "SHA256"
            When KDF_SCRYPT:
                Return derive_scrypt with password as shared_secret and salt as salt and n as 32768 and r as 8 and p as 1 and output_length as output_length
            When KDF_ARGON2ID:
                Return derive_argon2id with password as shared_secret and salt as salt and memory as 65536 and iterations as 3 and parallelism as 4 and output_length as output_length
            Otherwise:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Invalid_Parameters
                    message as "Unsupported key derivation algorithm: " plus algorithm
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Derivation_Failed
            message as "Key derivation error: " plus error as String

Process called "generate_session_keys" that takes shared_secret as List[Integer] and session_id as String and key_purposes as List[String] returns KeyExchangeResult[Dictionary[String, List[Integer]]]:
    Note: Generate multiple session keys from shared secret for different purposes
    Try:
        Let derived_keys be empty dictionary
        Let salt_result be random.generate_secure_bytes with count as 32
        Match salt_result:
            When random.RandomFailure:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Key_Generation_Failed
                    message as "Failed to generate salt for key derivation"
            When random.RandomSuccess with value as salt:
                Note: Derive keys for each purpose
                For purpose in key_purposes:
                    Let info_string be session_id plus ":" plus purpose
                    Let key_length be get_key_length_for_purpose with purpose as purpose
                    
                    Let derivation_result be derive_keys with shared_secret as shared_secret and salt as salt and info as info_string and output_length as key_length and algorithm as KDF_HKDF_SHA256
                    Match derivation_result:
                        When KeyExchangeFailure:
                            Return derivation_result
                        When KeyExchangeSuccess with value as derived_key:
                            Set derived_keys at key purpose to derived_key.derived_key
                
                Return KeyExchangeSuccess with value as derived_keys
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Derivation_Failed
            message as "Session key generation error: " plus error as String

Note: X25519 Key Exchange Implementation

Process called "generate_x25519_ephemeral_keypair" that takes params as KeyExchangeParameters and current_time as DateTime and expiry_time as DateTime returns KeyExchangeResult[EphemeralKeyPair]:
    Note: Generate X25519 ephemeral key pair
    Try:
        Note: Generate 32-byte private key
        Let private_bytes_result be random.generate_secure_bytes with count as 32
        Match private_bytes_result:
            When random.RandomSuccess with value as private_bytes:
                Note: Clamp private key bits per RFC 7748
                Set private_bytes at index 0 to (private_bytes at index 0) bitwise_and 248
                Set private_bytes at index 31 to ((private_bytes at index 31) bitwise_and 127) bitwise_or 64
                
                Note: Compute public key = private * base_point
                Let public_bytes_result be x25519_compute_public_key with private_key as private_bytes
                Match public_bytes_result:
                    When KeyExchangeSuccess with value as public_bytes:
                        Let ephemeral_keypair be EphemeralKeyPair with:
                            protocol as PROTOCOL_X25519
                            private_key as private_bytes
                            public_key as public_bytes
                            parameters as params
                            creation_time as current_time
                            expiry_time as expiry_time
                        
                        Return KeyExchangeSuccess with value as ephemeral_keypair
                    When KeyExchangeFailure:
                        Return public_bytes_result
            When random.RandomFailure:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Key_Generation_Failed
                    message as "Failed to generate X25519 private key"
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Key_Generation_Failed
            message as "X25519 key generation error: " plus error as String

Process called "perform_x25519_key_exchange" that takes private_key as List[Integer] and peer_public_key as List[Integer] and session_info as Optional[Dictionary[String, String]] returns KeyExchangeResult[SharedSecretResult]:
    Note: Perform X25519 key exchange
    Try:
        Let shared_secret_result be x25519_compute_shared_secret with private_key as private_key and peer_public_key as peer_public_key
        Match shared_secret_result:
            When KeyExchangeSuccess with value as secret_bytes:
                Note: Generate session ID
                Let session_id be generate_session_id with protocol as PROTOCOL_X25519 and session_info as session_info
                
                Let shared_secret be SharedSecretResult with:
                    shared_secret as secret_bytes
                    key_size as 32
                    protocol as PROTOCOL_X25519
                    session_id as session_id
                    forward_secrecy as true
                
                Return KeyExchangeSuccess with value as shared_secret
            When KeyExchangeFailure:
                Return shared_secret_result
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Shared_Secret_Failed
            message as "X25519 key exchange error: " plus error as String

Note: ECDH Key Exchange Implementation

Process called "generate_ecdh_ephemeral_keypair" that takes params as KeyExchangeParameters and curve as String and current_time as DateTime and expiry_time as DateTime returns KeyExchangeResult[EphemeralKeyPair]:
    Note: Generate ECDH ephemeral key pair on specified curve
    Try:
        Note: Get curve parameters
        Let curve_params_result be curve.get_curve_parameters with curve_name as curve
        Match curve_params_result:
            When curve.CurveFailure:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Invalid_Parameters
                    message as "Unsupported curve: " plus curve
            When curve.CurveSuccess with value as curve_params:
                Note: Generate private scalar
                Let order be curve_params["order"]
                Let private_scalar_result be generate_random_scalar with max_value as order
                Match private_scalar_result:
                    When KeyExchangeFailure:
                        Return private_scalar_result
                    When KeyExchangeSuccess with value as private_scalar:
                        Note: Compute public point
                        Let generator be curve_params["generator"]
                        Let public_point_result be curve.point_multiply with point as generator and scalar as private_scalar and curve_params as curve_params
                        Match public_point_result:
                            When curve.CurveSuccess with value as public_point:
                                Let private_key_bytes be bignum.to_bytes with value as private_scalar
                                Let public_key_bytes be curve.point_to_bytes with point as public_point and compressed as false
                                
                                Let ephemeral_keypair be EphemeralKeyPair with:
                                    protocol as "ECDH-" plus curve
                                    private_key as private_key_bytes
                                    public_key as public_key_bytes
                                    parameters as params
                                    creation_time as current_time
                                    expiry_time as expiry_time
                                
                                Return KeyExchangeSuccess with value as ephemeral_keypair
                            When curve.CurveFailure:
                                Return KeyExchangeFailure with:
                                    error as KeyExchangeError.Key_Generation_Failed
                                    message as "Failed to compute ECDH public key"
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Key_Generation_Failed
            message as "ECDH key generation error: " plus error as String

Process called "perform_ecdh_key_exchange" that takes private_key as List[Integer] and peer_public_key as List[Integer] and curve as String and session_info as Optional[Dictionary[String, String]] returns KeyExchangeResult[SharedSecretResult]:
    Note: Perform ECDH key exchange
    Try:
        Note: Get curve parameters
        Let curve_params_result be curve.get_curve_parameters with curve_name as curve
        Match curve_params_result:
            When curve.CurveSuccess with value as curve_params:
                Note: Convert keys to curve points/scalars
                Let private_scalar_result be bignum.from_bytes with bytes as private_key
                Let peer_point_result be curve.point_from_bytes with bytes as peer_public_key and curve_params as curve_params
                
                Match private_scalar_result:
                    When bignum.BignumSuccess with value as private_scalar:
                        Match peer_point_result:
                            When curve.CurveSuccess with value as peer_point:
                                Note: Compute shared point = private_scalar * peer_point
                                Let shared_point_result be curve.point_multiply with point as peer_point and scalar as private_scalar and curve_params as curve_params
                                Match shared_point_result:
                                    When curve.CurveSuccess with value as shared_point:
                                        Note: Extract x-coordinate as shared secret
                                        Let x_coordinate be curve.point_get_x with point as shared_point
                                        Let secret_bytes be bignum.to_bytes with value as x_coordinate
                                        
                                        Let session_id be generate_session_id with protocol as ("ECDH-" plus curve) and session_info as session_info
                                        
                                        Let shared_secret be SharedSecretResult with:
                                            shared_secret as secret_bytes
                                            key_size as (length of secret_bytes)
                                            protocol as ("ECDH-" plus curve)
                                            session_id as session_id
                                            forward_secrecy as true
                                        
                                        Return KeyExchangeSuccess with value as shared_secret
                                    When curve.CurveFailure:
                                        Return KeyExchangeFailure with:
                                            error as KeyExchangeError.Shared_Secret_Failed
                                            message as "ECDH shared point computation failed"
                            When curve.CurveFailure:
                                Return KeyExchangeFailure with:
                                    error as KeyExchangeError.Invalid_Public_Key
                                    message as "Invalid peer public key format"
                    When bignum.BignumFailure:
                        Return KeyExchangeFailure with:
                            error as KeyExchangeError.Invalid_Parameters
                            message as "Invalid private key format"
            When curve.CurveFailure:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Invalid_Parameters
                    message as "Unsupported curve: " plus curve
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Shared_Secret_Failed
            message as "ECDH key exchange error: " plus error as String

Note: HKDF Implementation (RFC 5869)

Process called "derive_hkdf" that takes shared_secret as List[Integer] and salt as List[Integer] and info as String and output_length as Integer and hash_algorithm as String returns KeyExchangeResult[KeyDerivationResult]:
    Note: HMAC-based Key Derivation Function per RFC 5869
    Try:
        Note: Step 1: Extract - PRK = HMAC-Hash(salt, IKM)
        Let prk_result be hash.hmac with key as salt and message as shared_secret and algorithm as hash_algorithm
        Match prk_result:
            When hash.HashFailure:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Derivation_Failed
                    message as "HKDF extract phase failed: " plus prk_result.message
            When hash.HashSuccess with value as prk:
                Note: Step 2: Expand - derive output key material
                Let expand_result be hkdf_expand with prk as prk and info as info and output_length as output_length and hash_algorithm as hash_algorithm
                Match expand_result:
                    When KeyExchangeSuccess with value as output_key:
                        Let derivation_result be KeyDerivationResult with:
                            derived_key as output_key
                            key_length as output_length
                            algorithm as ("HKDF-" plus hash_algorithm)
                            salt as salt
                            iterations as 1
                        
                        Return KeyExchangeSuccess with value as derivation_result
                    When KeyExchangeFailure:
                        Return expand_result
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Derivation_Failed
            message as "HKDF error: " plus error as String

Process called "hkdf_expand" that takes prk as List[Integer] and info as String and output_length as Integer and hash_algorithm as String returns KeyExchangeResult[List[Integer]]:
    Note: HKDF expand phase
    Try:
        Let hash_length be get_hash_output_length with algorithm as hash_algorithm
        Let n be ((output_length plus hash_length minus 1) divided by hash_length)
        
        If n is greater than 255:
            Return KeyExchangeFailure with:
                error as KeyExchangeError.Invalid_Parameters
                message as "HKDF output length too large"
        
        Let output_key be empty list
        Let t_prev be empty list
        Let info_bytes be string_to_bytes with text as info
        
        For i from 1 to n:
            Note: T(i) = HMAC-Hash(PRK, T(i-1) | info | i)
            Let input_materials be concatenate_byte_arrays with arrays as list containing t_prev, info_bytes, list containing i
            Let t_result be hash.hmac with key as prk and message as input_materials and algorithm as hash_algorithm
            Match t_result:
                When hash.HashSuccess with value as t:
                    Set t_prev to t
                    Set output_key to concatenate_byte_arrays with arrays as list containing output_key, t
                When hash.HashFailure:
                    Return KeyExchangeFailure with:
                        error as KeyExchangeError.Derivation_Failed
                        message as "HKDF expand iteration failed: " plus t_result.message
        
        Note: Truncate to desired length
        Let final_key be output_key from index 0 to (output_length minus 1)
        Return KeyExchangeSuccess with value as final_key
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Derivation_Failed
            message as "HKDF expand error: " plus error as String

Note: Utility Functions

Process called "get_protocol_parameters" that takes protocol as String returns KeyExchangeResult[KeyExchangeParameters]:
    Note: Get standard parameters for key exchange protocol
    Try:
        Match protocol:
            When PROTOCOL_X25519:
                Let params be KeyExchangeParameters with:
                    protocol as PROTOCOL_X25519
                    key_size as 32
                    curve_name as Some with value as "Curve25519"
                    generator as None
                    modulus as None
                    base as None
                Return KeyExchangeSuccess with value as params
            
            When PROTOCOL_ECDH_P256:
                Let params be KeyExchangeParameters with:
                    protocol as PROTOCOL_ECDH_P256
                    key_size as 32
                    curve_name as Some with value as "P-256"
                    generator as None
                    modulus as None
                    base as None
                Return KeyExchangeSuccess with value as params
            
            When PROTOCOL_DH_2048:
                Let params be KeyExchangeParameters with:
                    protocol as PROTOCOL_DH_2048
                    key_size as 256
                    curve_name as None
                    generator as None
                    modulus as Some with value as DH_2048_PRIME
                    base as Some with value as list containing DH_2048_GENERATOR
                Return KeyExchangeSuccess with value as params
            
            Otherwise:
                Return KeyExchangeFailure with:
                    error as KeyExchangeError.Invalid_Protocol
                    message as "Unknown protocol: " plus protocol
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Internal_Error
            message as "Parameter lookup error: " plus error as String

Process called "generate_session_id" that takes protocol as String and session_info as Optional[Dictionary[String, String]] returns String:
    Note: Generate unique session identifier for key exchange
    Try:
        Let timestamp be time.to_timestamp with datetime as time.now
        Let random_bytes_result be random.generate_secure_bytes with count as 16
        Match random_bytes_result:
            When random.RandomSuccess with value as random_bytes:
                Let session_data be protocol plus ":" plus timestamp as String plus ":"
                If session_info is not None:
                    For key in keys of session_info:
                        Set session_data to session_data plus key plus "=" plus session_info at key key plus ","
                
                Let hash_input be string_to_bytes with text as session_data
                Let combined_input be concatenate_byte_arrays with arrays as list containing hash_input, random_bytes
                Let hash_result be hash.compute_hash with data as combined_input and algorithm as "SHA256"
                Match hash_result:
                    When hash.HashSuccess with value as hash_bytes:
                        Let session_id be bytes_to_hex with bytes as (hash_bytes from index 0 to 15)
                        Return session_id
                    When hash.HashFailure:
                        Return "session_" plus timestamp as String
            When random.RandomFailure:
                Return "session_" plus timestamp as String
    
    Catch error:
        Return "session_" plus time.to_timestamp with datetime as time.now as String

Process called "get_key_length_for_purpose" that takes purpose as String returns Integer:
    Note: Get appropriate key length for cryptographic purpose
    Match purpose:
        When "encryption": Return 32
        When "mac": Return 32
        When "authentication": Return 32
        When "signing": Return 32
        When "kdf": Return 32
        When "iv": Return 16
        When "nonce": Return 12
        Otherwise: Return 32

Process called "validate_peer_public_key" that takes protocol as String and public_key as List[Integer] and parameters as KeyExchangeParameters returns KeyExchangeResult[Boolean]:
    Note: Validate peer public key for security
    Try:
        Match protocol:
            When PROTOCOL_X25519:
                If length of public_key is not equal to 32:
                    Return KeyExchangeFailure with:
                        error as KeyExchangeError.Invalid_Public_Key
                        message as "X25519 public key must be 32 bytes"
                Return KeyExchangeSuccess with value as true
            
            When PROTOCOL_ECDH_P256:
                If length of public_key is not equal to 65 and length of public_key is not equal to 33:
                    Return KeyExchangeFailure with:
                        error as KeyExchangeError.Invalid_Public_Key
                        message as "P-256 public key must be 33 (compressed) or 65 (uncompressed) bytes"
                Return KeyExchangeSuccess with value as true
            
            Otherwise:
                Return KeyExchangeSuccess with value as true
    
    Catch error:
        Return KeyExchangeFailure with:
            error as KeyExchangeError.Internal_Error
            message as "Public key validation error: " plus error as String