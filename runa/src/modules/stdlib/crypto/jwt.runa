Note: Runa Standard Library - JSON Web Tokens (JWT)
This module provides production-grade JWT creation, validation, and management
including JWS (JSON Web Signature), JWE (JSON Web Encryption), and JWK (JSON Web Keys).

Supports RS256, HS256, ES256, EdDSA signatures, token validation, claims verification,
and secure JWT handling for authentication and authorization systems.

Specification compliance: RFC 7519 (JWT), RFC 7515 (JWS), RFC 7516 (JWE), RFC 7517 (JWK).
:End Note

Import "crypto/asymmetric" as asymmetric
Import "crypto/hash" as hash
Import "crypto/aead" as aead
Import "encoding/json" as json
Import "encoding/base64" as base64
Import "time" as time

Type JwtHeader is Dictionary with:
    alg as String
    typ as String
    kid as Optional[String]
    cty as Optional[String]
    crit as Optional[List[String]]

Type JwtPayload is Dictionary with:
    iss as Optional[String]
    sub as Optional[String]
    aud as Optional[List[String]]
    exp as Optional[Integer]
    nbf as Optional[Integer]
    iat as Optional[Integer]
    jti as Optional[String]
    custom_claims as Dictionary[String, Any]

Type JsonWebToken is Dictionary with:
    header as JwtHeader
    payload as JwtPayload
    signature as List[Integer]
    raw_token as String
    header_b64 as String
    payload_b64 as String
    signature_b64 as String

Type JwtValidationOptions is Dictionary with:
    verify_signature as Boolean
    verify_expiration as Boolean
    verify_not_before as Boolean
    verify_issuer as Optional[String]
    verify_audience as Optional[List[String]]
    clock_tolerance_seconds as Integer
    require_exp as Boolean
    require_iat as Boolean
    require_nbf as Boolean

Type JwtValidationResult is Dictionary with:
    is_valid as Boolean
    token as Optional[JsonWebToken]
    errors as List[String]
    warnings as List[String]
    claims as Dictionary[String, Any]

Type JsonWebKey is Dictionary with:
    kty as String
    use as Optional[String]
    key_ops as Optional[List[String]]
    alg as Optional[String]
    kid as Optional[String]
    x5c as Optional[List[String]]
    x5t as Optional[String]
    key_value as asymmetric.PublicKey

Type JwtResult is Union with:
    JwtSuccess with value as Dictionary[String, Any]
    JwtFailure with error as JwtError and message as String

Type JwtError is Enum with:
    Invalid_Token
    Invalid_Header
    Invalid_Payload
    Invalid_Signature
    Token_Expired
    Token_Not_Yet_Valid
    Invalid_Issuer
    Invalid_Audience
    Invalid_Algorithm
    Missing_Key
    Invalid_Key
    Encoding_Error
    Decoding_Error
    Internal_Error

Note: JWT Algorithm Constants
Let ALG_HS256 be "HS256"
Let ALG_HS384 be "HS384"
Let ALG_HS512 be "HS512"
Let ALG_RS256 be "RS256"
Let ALG_RS384 be "RS384"
Let ALG_RS512 be "RS512"
Let ALG_ES256 be "ES256"
Let ALG_ES384 be "ES384"
Let ALG_ES512 be "ES512"
Let ALG_EDDSA be "EdDSA"
Let ALG_NONE be "none"

Note: Standard JWT Claims
Let CLAIM_ISSUER be "iss"
Let CLAIM_SUBJECT be "sub"
Let CLAIM_AUDIENCE be "aud"
Let CLAIM_EXPIRATION be "exp"
Let CLAIM_NOT_BEFORE be "nbf"
Let CLAIM_ISSUED_AT be "iat"
Let CLAIM_JWT_ID be "jti"

Note: Primary JWT Interface Functions

Process called "create_jwt" that takes payload as JwtPayload and signing_key as Dictionary[String, Any] and algorithm as String and header_claims as Optional[Dictionary[String, String]] returns JwtResult[String]:
    Note: Create and sign a JSON Web Token
    Try:
        Note: Build JWT header
        Let header be JwtHeader with:
            alg as algorithm
            typ as "JWT"
            kid as (header_claims["kid"] if header_claims is not None and "kid" is in header_claims else None)
            cty as (header_claims["cty"] if header_claims is not None and "cty" is in header_claims else None)
            crit as (header_claims["crit"] if header_claims is not None and "crit" is in header_claims else None)
        
        Note: Add issued at time if not present
        If payload.iat is None:
            Set payload.iat to time.to_timestamp with datetime as time.now
        
        Note: Encode header and payload
        Let header_json_result be json.stringify with data as header
        Match header_json_result:
            When json.JsonFailure:
                Return JwtFailure with:
                    error as JwtError.Encoding_Error
                    message as "Failed to encode header: " plus header_json_result.message
            When json.JsonSuccess with value as header_json:
                Let payload_json_result be json.stringify with data as payload
                Match payload_json_result:
                    When json.JsonFailure:
                        Return JwtFailure with:
                            error as JwtError.Encoding_Error
                            message as "Failed to encode payload: " plus payload_json_result.message
                    When json.JsonSuccess with value as payload_json:
                        Note: Base64URL encode header and payload
                        Let header_b64_result be base64.encode_url_safe with data as string_to_bytes with text as header_json
                        Let payload_b64_result be base64.encode_url_safe with data as string_to_bytes with text as payload_json
                        
                        Match header_b64_result:
                            When base64.Base64Success with value as header_b64:
                                Match payload_b64_result:
                                    When base64.Base64Success with value as payload_b64:
                                        Note: Create signing input
                                        Let signing_input be header_b64 plus "." plus payload_b64
                                        
                                        Note: Sign the token
                                        Let signature_result be sign_jwt_data with data as signing_input and key as signing_key and algorithm as algorithm
                                        Match signature_result:
                                            When JwtFailure:
                                                Return signature_result
                                            When JwtSuccess with value as signature_b64:
                                                Note: Construct final JWT
                                                Let jwt_token be signing_input plus "." plus signature_b64
                                                Return JwtSuccess with value as jwt_token
                                    When base64.Base64Failure:
                                        Return JwtFailure with:
                                            error as JwtError.Encoding_Error
                                            message as "Failed to base64 encode payload"
                            When base64.Base64Failure:
                                Return JwtFailure with:
                                    error as JwtError.Encoding_Error
                                    message as "Failed to base64 encode header"
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT creation error: " plus error as String

Process called "parse_jwt" that takes token as String returns JwtResult[JsonWebToken]:
    Note: Parse JWT token into components without validation
    Try:
        Note: Split token into parts
        Let parts be split_string with text as token and delimiter as "."
        If length of parts is not equal to 3:
            Return JwtFailure with:
                error as JwtError.Invalid_Token
                message as "JWT must have exactly 3 parts separated by dots"
        
        Let header_b64 be parts at index 0
        Let payload_b64 be parts at index 1
        Let signature_b64 be parts at index 2
        
        Note: Decode header
        Let header_bytes_result be base64.decode_url_safe with data as header_b64
        Match header_bytes_result:
            When base64.Base64Failure:
                Return JwtFailure with:
                    error as JwtError.Invalid_Header
                    message as "Failed to decode JWT header"
            When base64.Base64Success with value as header_bytes:
                Let header_json be bytes_to_string with bytes as header_bytes
                Let header_result be json.parse with data as header_json
                Match header_result:
                    When json.JsonFailure:
                        Return JwtFailure with:
                            error as JwtError.Invalid_Header
                            message as "Failed to parse header JSON: " plus header_result.message
                    When json.JsonSuccess with value as header_dict:
                        Note: Decode payload
                        Let payload_bytes_result be base64.decode_url_safe with data as payload_b64
                        Match payload_bytes_result:
                            When base64.Base64Failure:
                                Return JwtFailure with:
                                    error as JwtError.Invalid_Payload
                                    message as "Failed to decode JWT payload"
                            When base64.Base64Success with value as payload_bytes:
                                Let payload_json be bytes_to_string with bytes as payload_bytes
                                Let payload_result be json.parse with data as payload_json
                                Match payload_result:
                                    When json.JsonFailure:
                                        Return JwtFailure with:
                                            error as JwtError.Invalid_Payload
                                            message as "Failed to parse payload JSON: " plus payload_result.message
                                    When json.JsonSuccess with value as payload_dict:
                                        Note: Decode signature
                                        Let signature_bytes_result be base64.decode_url_safe with data as signature_b64
                                        Match signature_bytes_result:
                                            When base64.Base64Success with value as signature_bytes:
                                                Note: Convert dictionaries to proper types
                                                Let jwt_header be dict_to_jwt_header with dict as header_dict
                                                Let jwt_payload be dict_to_jwt_payload with dict as payload_dict
                                                
                                                Let jwt be JsonWebToken with:
                                                    header as jwt_header
                                                    payload as jwt_payload
                                                    signature as signature_bytes
                                                    raw_token as token
                                                    header_b64 as header_b64
                                                    payload_b64 as payload_b64
                                                    signature_b64 as signature_b64
                                                
                                                Return JwtSuccess with value as jwt
                                            When base64.Base64Failure:
                                                Return JwtFailure with:
                                                    error as JwtError.Invalid_Signature
                                                    message as "Failed to decode JWT signature"
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT parsing error: " plus error as String

Process called "validate_jwt" that takes token as String and verification_key as Dictionary[String, Any] and options as JwtValidationOptions returns JwtResult[JwtValidationResult]:
    Note: Validate JWT token with comprehensive checks
    Try:
        Let errors be empty list
        Let warnings be empty list
        
        Note: Parse the token
        Let parse_result be parse_jwt with token as token
        Match parse_result:
            When JwtFailure:
                Let validation_result be JwtValidationResult with:
                    is_valid as false
                    token as None
                    errors as list containing parse_result.message
                    warnings as warnings
                    claims as empty dictionary
                Return JwtSuccess with value as validation_result
            When JwtSuccess with value as jwt:
                Note: Validate signature if required
                If options.verify_signature:
                    Let signature_result be verify_jwt_signature with jwt as jwt and key as verification_key
                    Match signature_result:
                        When JwtFailure:
                            Add "Signature verification failed: " plus signature_result.message to errors
                        When JwtSuccess with value as signature_valid:
                            If not signature_valid:
                                Add "JWT signature is invalid" to errors
                
                Note: Validate time claims
                Let current_time be time.to_timestamp with datetime as time.now
                
                Note: Check expiration
                If options.verify_expiration and jwt.payload.exp is not None:
                    If current_time is greater than (jwt.payload.exp plus options.clock_tolerance_seconds):
                        Add "JWT token has expired" to errors
                
                Note: Check not before
                If options.verify_not_before and jwt.payload.nbf is not None:
                    If current_time is less than (jwt.payload.nbf minus options.clock_tolerance_seconds):
                        Add "JWT token is not yet valid" to errors
                
                Note: Check required claims
                If options.require_exp and jwt.payload.exp is None:
                    Add "JWT token missing required 'exp' claim" to errors
                
                If options.require_iat and jwt.payload.iat is None:
                    Add "JWT token missing required 'iat' claim" to errors
                
                If options.require_nbf and jwt.payload.nbf is None:
                    Add "JWT token missing required 'nbf' claim" to errors
                
                Note: Validate issuer
                If options.verify_issuer is not None:
                    If jwt.payload.iss is None or jwt.payload.iss is not equal to options.verify_issuer:
                        Add "JWT issuer validation failed" to errors
                
                Note: Validate audience
                If options.verify_audience is not None:
                    Let audience_valid be false
                    If jwt.payload.aud is not None:
                        For expected_aud in options.verify_audience:
                            If expected_aud is in jwt.payload.aud:
                                Set audience_valid to true
                                Break
                    
                    If not audience_valid:
                        Add "JWT audience validation failed" to errors
                
                Note: Build claims dictionary
                Let claims be dictionary containing:
                    CLAIM_ISSUER as jwt.payload.iss,
                    CLAIM_SUBJECT as jwt.payload.sub,
                    CLAIM_AUDIENCE as jwt.payload.aud,
                    CLAIM_EXPIRATION as jwt.payload.exp,
                    CLAIM_NOT_BEFORE as jwt.payload.nbf,
                    CLAIM_ISSUED_AT as jwt.payload.iat,
                    CLAIM_JWT_ID as jwt.payload.jti
                
                Note: Add custom claims
                For key in keys of jwt.payload.custom_claims:
                    Set claims at key key to jwt.payload.custom_claims at key key
                
                Let validation_result be JwtValidationResult with:
                    is_valid as (length of errors is equal to 0)
                    token as Some with value as jwt
                    errors as errors
                    warnings as warnings
                    claims as claims
                
                Return JwtSuccess with value as validation_result
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT validation error: " plus error as String

Process called "create_jwt_with_claims" that takes claims as Dictionary[String, Any] and signing_key as Dictionary[String, Any] and algorithm as String and expiry_minutes as Optional[Integer] returns JwtResult[String]:
    Note: Create JWT with custom claims and automatic expiry
    Try:
        Let current_time be time.to_timestamp with datetime as time.now
        Let expiry_time be current_time plus ((expiry_minutes if expiry_minutes is not None else 60) multiplied by 60)
        
        Note: Build payload with claims
        Let payload be JwtPayload with:
            iss as (claims["iss"] if "iss" is in claims else None)
            sub as (claims["sub"] if "sub" is in claims else None)
            aud as (claims["aud"] if "aud" is in claims else None)
            exp as Some with value as expiry_time
            nbf as (claims["nbf"] if "nbf" is in claims else None)
            iat as Some with value as current_time
            jti as (claims["jti"] if "jti" is in claims else None)
            custom_claims as filter_standard_claims with claims as claims
        
        Let jwt_result be create_jwt with payload as payload and signing_key as signing_key and algorithm as algorithm and header_claims as None
        Return jwt_result
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT creation with claims error: " plus error as String

Process called "refresh_jwt" that takes token as String and signing_key as Dictionary[String, Any] and new_expiry_minutes as Optional[Integer] returns JwtResult[String]:
    Note: Refresh JWT with new expiration time
    Try:
        Note: Parse existing token
        Let parse_result be parse_jwt with token as token
        Match parse_result:
            When JwtFailure:
                Return parse_result
            When JwtSuccess with value as jwt:
                Note: Update expiration time
                Let current_time be time.to_timestamp with datetime as time.now
                Let new_expiry be current_time plus ((new_expiry_minutes if new_expiry_minutes is not None else 60) multiplied by 60)
                
                Set jwt.payload.exp to Some with value as new_expiry
                Set jwt.payload.iat to Some with value as current_time
                
                Note: Create new token with updated payload
                Let new_jwt_result be create_jwt with payload as jwt.payload and signing_key as signing_key and algorithm as jwt.header.alg and header_claims as None
                Return new_jwt_result
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT refresh error: " plus error as String

Note: JWT Signing Implementation

Process called "sign_jwt_data" that takes data as String and key as Dictionary[String, Any] and algorithm as String returns JwtResult[String]:
    Note: Sign JWT data using specified algorithm
    Try:
        Let data_bytes be string_to_bytes with text as data
        
        Match algorithm:
            When ALG_HS256:
                Return sign_hmac_jwt with data as data_bytes and key as key and hash_algorithm as "SHA256"
            When ALG_HS384:
                Return sign_hmac_jwt with data as data_bytes and key as key and hash_algorithm as "SHA384"
            When ALG_HS512:
                Return sign_hmac_jwt with data as data_bytes and key as key and hash_algorithm as "SHA512"
            When ALG_RS256:
                Return sign_rsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA256"
            When ALG_RS384:
                Return sign_rsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA384"
            When ALG_RS512:
                Return sign_rsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA512"
            When ALG_ES256:
                Return sign_ecdsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA256"
            When ALG_ES384:
                Return sign_ecdsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA384"
            When ALG_ES512:
                Return sign_ecdsa_jwt with data as data_bytes and key as key and hash_algorithm as "SHA512"
            When ALG_EDDSA:
                Return sign_eddsa_jwt with data as data_bytes and key as key
            When ALG_NONE:
                Return JwtSuccess with value as ""
            Otherwise:
                Return JwtFailure with:
                    error as JwtError.Invalid_Algorithm
                    message as "Unsupported JWT signing algorithm: " plus algorithm
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT signing error: " plus error as String

Process called "sign_hmac_jwt" that takes data as List[Integer] and key as Dictionary[String, Any] and hash_algorithm as String returns JwtResult[String]:
    Note: Sign JWT using HMAC
    Try:
        Let secret_key be key["secret"]
        Let hmac_result be hash.hmac with key as secret_key and message as data and algorithm as hash_algorithm
        Match hmac_result:
            When hash.HashFailure:
                Return JwtFailure with:
                    error as JwtError.Invalid_Signature
                    message as "HMAC signing failed: " plus hmac_result.message
            When hash.HashSuccess with value as signature_bytes:
                Let signature_b64_result be base64.encode_url_safe with data as signature_bytes
                Match signature_b64_result:
                    When base64.Base64Success with value as signature_b64:
                        Return JwtSuccess with value as signature_b64
                    When base64.Base64Failure:
                        Return JwtFailure with:
                            error as JwtError.Encoding_Error
                            message as "Failed to base64 encode HMAC signature"
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "HMAC JWT signing error: " plus error as String

Process called "sign_rsa_jwt" that takes data as List[Integer] and key as Dictionary[String, Any] and hash_algorithm as String returns JwtResult[String]:
    Note: Sign JWT using RSA
    Try:
        Let private_key be key["private_key"]
        Let padding_scheme be "PSS"  Note: Use PSS padding for JWT
        
        Let signature_result be asymmetric.sign_message with private_key as private_key and message as data and hash_algorithm as hash_algorithm and padding_scheme as Some with value as padding_scheme
        Match signature_result:
            When asymmetric.AsymmetricFailure:
                Return JwtFailure with:
                    error as JwtError.Invalid_Signature
                    message as "RSA signing failed: " plus signature_result.message
            When asymmetric.AsymmetricSuccess with value as signature:
                Let signature_b64_result be base64.encode_url_safe with data as signature.signature_bytes
                Match signature_b64_result:
                    When base64.Base64Success with value as signature_b64:
                        Return JwtSuccess with value as signature_b64
                    When base64.Base64Failure:
                        Return JwtFailure with:
                            error as JwtError.Encoding_Error
                            message as "Failed to base64 encode RSA signature"
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "RSA JWT signing error: " plus error as String

Process called "verify_jwt_signature" that takes jwt as JsonWebToken and key as Dictionary[String, Any] returns JwtResult[Boolean]:
    Note: Verify JWT signature
    Try:
        Let signing_input be jwt.header_b64 plus "." plus jwt.payload_b64
        Let data_bytes be string_to_bytes with text as signing_input
        
        Match jwt.header.alg:
            When ALG_HS256:
                Return verify_hmac_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA256"
            When ALG_HS384:
                Return verify_hmac_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA384"
            When ALG_HS512:
                Return verify_hmac_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA512"
            When ALG_RS256:
                Return verify_rsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA256"
            When ALG_RS384:
                Return verify_rsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA384"
            When ALG_RS512:
                Return verify_rsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA512"
            When ALG_ES256:
                Return verify_ecdsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA256"
            When ALG_ES384:
                Return verify_ecdsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA384"
            When ALG_ES512:
                Return verify_ecdsa_jwt with data as data_bytes and signature as jwt.signature and key as key and hash_algorithm as "SHA512"
            When ALG_EDDSA:
                Return verify_eddsa_jwt with data as data_bytes and signature as jwt.signature and key as key
            When ALG_NONE:
                Return JwtSuccess with value as (length of jwt.signature is equal to 0)
            Otherwise:
                Return JwtFailure with:
                    error as JwtError.Invalid_Algorithm
                    message as "Unsupported verification algorithm: " plus jwt.header.alg
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "JWT signature verification error: " plus error as String

Process called "verify_hmac_jwt" that takes data as List[Integer] and signature as List[Integer] and key as Dictionary[String, Any] and hash_algorithm as String returns JwtResult[Boolean]:
    Note: Verify HMAC JWT signature
    Try:
        Let secret_key be key["secret"]
        Let hmac_result be hash.hmac with key as secret_key and message as data and algorithm as hash_algorithm
        Match hmac_result:
            When hash.HashFailure:
                Return JwtFailure with:
                    error as JwtError.Invalid_Signature
                    message as "HMAC verification failed: " plus hmac_result.message
            When hash.HashSuccess with value as expected_signature:
                Let is_valid be secure_compare_bytes with a as signature and b as expected_signature
                Return JwtSuccess with value as is_valid
    
    Catch error:
        Return JwtFailure with:
            error as JwtError.Internal_Error
            message as "HMAC verification error: " plus error as String

Note: Utility Functions

Process called "dict_to_jwt_header" that takes dict as Dictionary[String, Any] returns JwtHeader:
    Note: Convert dictionary to JwtHeader type
    Try:
        Let header be JwtHeader with:
            alg as (dict["alg"] if "alg" is in dict else "HS256")
            typ as (dict["typ"] if "typ" is in dict else "JWT")
            kid as (dict["kid"] if "kid" is in dict else None)
            cty as (dict["cty"] if "cty" is in dict else None)
            crit as (dict["crit"] if "crit" is in dict else None)
        
        Return header
    
    Catch error:
        Return JwtHeader with:
            alg as "HS256"
            typ as "JWT"
            kid as None
            cty as None
            crit as None

Process called "dict_to_jwt_payload" that takes dict as Dictionary[String, Any] returns JwtPayload:
    Note: Convert dictionary to JwtPayload type
    Try:
        Note: Extract standard claims
        Let standard_claims be list containing "iss", "sub", "aud", "exp", "nbf", "iat", "jti"
        Let custom_claims be empty dictionary
        
        For key in keys of dict:
            If key is not in standard_claims:
                Set custom_claims at key key to dict at key key
        
        Let payload be JwtPayload with:
            iss as (dict["iss"] if "iss" is in dict else None)
            sub as (dict["sub"] if "sub" is in dict else None)
            aud as (dict["aud"] if "aud" is in dict else None)
            exp as (dict["exp"] if "exp" is in dict else None)
            nbf as (dict["nbf"] if "nbf" is in dict else None)
            iat as (dict["iat"] if "iat" is in dict else None)
            jti as (dict["jti"] if "jti" is in dict else None)
            custom_claims as custom_claims
        
        Return payload
    
    Catch error:
        Return JwtPayload with:
            iss as None
            sub as None
            aud as None
            exp as None
            nbf as None
            iat as None
            jti as None
            custom_claims as empty dictionary

Process called "filter_standard_claims" that takes claims as Dictionary[String, Any] returns Dictionary[String, Any]:
    Note: Filter out standard JWT claims, return only custom claims
    Try:
        Let standard_claims be list containing "iss", "sub", "aud", "exp", "nbf", "iat", "jti"
        Let custom_claims be empty dictionary
        
        For key in keys of claims:
            If key is not in standard_claims:
                Set custom_claims at key key to claims at key key
        
        Return custom_claims
    
    Catch error:
        Return empty dictionary

Process called "create_default_validation_options" returns JwtValidationOptions:
    Note: Create default JWT validation options
    Let options be JwtValidationOptions with:
        verify_signature as true
        verify_expiration as true
        verify_not_before as true
        verify_issuer as None
        verify_audience as None
        clock_tolerance_seconds as 300
        require_exp as true
        require_iat as false
        require_nbf as false
    
    Return options

Process called "secure_compare_bytes" that takes a as List[Integer] and b as List[Integer] returns Boolean:
    Note: Constant-time byte array comparison to prevent timing attacks
    If length of a is not equal to length of b:
        Return false
    
    Let result be 0
    For i from 0 to (length of a minus 1):
        Set result to result bitwise_or (a at index i bitwise_xor b at index i)
    
    Return result is equal to 0

Process called "split_string" that takes text as String and delimiter as String returns List[String]:
    Note: Split string by delimiter
    Try:
        Let parts be empty list
        Let current_part be ""
        Let i be 0
        
        While i is less than (length of text):
            Let char be character at index i in text
            If char is equal to delimiter:
                Add current_part to parts
                Set current_part to ""
            Else:
                Set current_part to current_part plus char
            Set i to i plus 1
        
        Add current_part to parts
        Return parts
    
    Catch error:
        Return list containing text

Process called "string_to_bytes" that takes text as String returns List[Integer]:
    Note: Convert string to UTF-8 byte array
    Try:
        Let bytes be empty list
        For i from 0 to (length of text minus 1):
            Let char be character at index i in text
            Let char_code be character_code_at with text as text and index as i
            
            If char_code is less than 128:
                Add char_code to bytes
            Else:
                Note: Handle UTF-8 encoding for non-ASCII characters
                Let utf8_bytes be encode_utf8_char with char_code as char_code
                For byte in utf8_bytes:
                    Add byte to bytes
        
        Return bytes
    
    Catch error:
        Return empty list

Process called "bytes_to_string" that takes bytes as List[Integer] returns String:
    Note: Convert UTF-8 byte array to string
    Try:
        Let text be ""
        Let i be 0
        
        While i is less than (length of bytes):
            Let byte be bytes at index i
            
            If byte is less than 128:
                Note: ASCII character
                Let char be character_from_code with code as byte
                Set text to text plus char
                Set i to i plus 1
            Else:
                Note: Multi-byte UTF-8 character
                Let utf8_result be decode_utf8_char with bytes as bytes and start_index as i
                Set text to text plus utf8_result["char"]
                Set i to utf8_result["next_index"]
        
        Return text
    
    Catch error:
        Return ""