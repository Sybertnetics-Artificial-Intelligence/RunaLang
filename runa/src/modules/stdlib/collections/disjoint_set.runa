Note:
Runa Standard Library: Disjoint Set (Union-Find Data Structure)

Provides efficient data structure for tracking connected components and set operations
with near-constant time union and find operations using path compression and union by rank.
Essential for AI systems requiring graph connectivity analysis, clustering algorithms,
and dynamic equivalence queries.

Advanced features include:
- Path compression for optimal find operations
- Union by rank for balanced tree structures
- Weighted union-find for applications with weighted edges
- Persistent union-find with historical state queries
- Compact memory-optimized implementation
- Statistical analysis and performance metrics
:End Note

Type DisjointSetNode is Dictionary with:
    parent as Integer
    rank as Integer
    size as Integer

Type DisjointSet is Dictionary with:
    nodes as List[DisjointSetNode]
    num_sets as Integer
    total_elements as Integer

Process called "create_disjoint_set" that takes n as Integer returns DisjointSet:
    If n is less than or equal to 0:
        Throw error "Number of elements must be positive"
    
    Let nodes be list containing
    
    For i from 0 to n minus 1:
        Let node be dictionary with:
            parent as i
            rank as 0
            size as 1
        Add node to nodes
    
    Return dictionary with:
        nodes as nodes
        num_sets as n
        total_elements as n

Process called "find_root" that takes disjoint_set as DisjointSet and element as Integer returns Integer:
    If element is less than 0 or element is greater than or equal to disjoint_set["total_elements"]:
        Throw error "Element index out of bounds"
    
    Let current_element be element
    Let path be list containing
    
    While disjoint_set["nodes"][current_element]["parent"] is not equal to current_element:
        Add current_element to path
        Let current_element be disjoint_set["nodes"][current_element]["parent"]
    
    Let root be current_element
    
    For each node_index in path:
        Set disjoint_set["nodes"][node_index]["parent"] to root
    
    Return root

Process called "union_sets" that takes disjoint_set as DisjointSet and element1 as Integer and element2 as Integer returns Boolean:
    Let root1 be find_root with disjoint_set as disjoint_set and element as element1
    Let root2 be find_root with disjoint_set as disjoint_set and element as element2
    
    If root1 is equal to root2:
        Return false
    
    Let node1 be disjoint_set["nodes"][root1]
    Let node2 be disjoint_set["nodes"][root2]
    
    If node1["rank"] is less than node2["rank"]:
        Set node1["parent"] to root2
        Set node2["size"] to node2["size"] plus node1["size"]
    Otherwise if node1["rank"] is greater than node2["rank"]:
        Set node2["parent"] to root1
        Set node1["size"] to node1["size"] plus node2["size"]
    Otherwise:
        Set node2["parent"] to root1
        Set node1["rank"] to node1["rank"] plus 1
        Set node1["size"] to node1["size"] plus node2["size"]
    
    Set disjoint_set["num_sets"] to disjoint_set["num_sets"] minus 1
    Return true

Process called "are_connected" that takes disjoint_set as DisjointSet and element1 as Integer and element2 as Integer returns Boolean:
    Let root1 be find_root with disjoint_set as disjoint_set and element as element1
    Let root2 be find_root with disjoint_set as disjoint_set and element as element2
    Return root1 is equal to root2

Process called "get_set_size" that takes disjoint_set as DisjointSet and element as Integer returns Integer:
    Let root be find_root with disjoint_set as disjoint_set and element as element
    Return disjoint_set["nodes"][root]["size"]

Process called "get_set_members" that takes disjoint_set as DisjointSet and element as Integer returns List[Integer]:
    Let target_root be find_root with disjoint_set as disjoint_set and element as element
    Let members be list containing
    
    For i from 0 to disjoint_set["total_elements"] minus 1:
        Let root be find_root with disjoint_set as disjoint_set and element as i
        If root is equal to target_root:
            Add i to members
    
    Return members

Process called "get_all_sets" that takes disjoint_set as DisjointSet returns List[List[Integer]]:
    Let root_to_members be dictionary with:
    
    For i from 0 to disjoint_set["total_elements"] minus 1:
        Let root be find_root with disjoint_set as disjoint_set and element as i
        
        If not root in root_to_members:
            Set root_to_members[root] to list containing
        
        Let members_list be root_to_members[root]
        Add i to members_list
        Set root_to_members[root] to members_list
    
    Let all_sets be list containing
    For each root and members in root_to_members:
        Add members to all_sets
    
    Return all_sets

Process called "get_set_representatives" that takes disjoint_set as DisjointSet returns List[Integer]:
    Let representatives be list containing
    
    For i from 0 to disjoint_set["total_elements"] minus 1:
        If disjoint_set["nodes"][i]["parent"] is equal to i:
            Add i to representatives
    
    Return representatives

Process called "reset_disjoint_set" that takes disjoint_set as DisjointSet returns DisjointSet:
    For i from 0 to disjoint_set["total_elements"] minus 1:
        Set disjoint_set["nodes"][i]["parent"] to i
        Set disjoint_set["nodes"][i]["rank"] to 0
        Set disjoint_set["nodes"][i]["size"] to 1
    
    Set disjoint_set["num_sets"] to disjoint_set["total_elements"]
    Return disjoint_set

Process called "get_disjoint_set_stats" that takes disjoint_set as DisjointSet returns Dictionary[String, Any]:
    Let stats be dictionary with:
    Set stats["total_elements"] to disjoint_set["total_elements"]
    Set stats["num_sets"] to disjoint_set["num_sets"]
    
    Let set_sizes be list containing
    Let representatives be get_set_representatives with disjoint_set as disjoint_set
    
    For each root in representatives:
        Let size be disjoint_set["nodes"][root]["size"]
        Add size to set_sizes
    
    If length of set_sizes is greater than 0:
        Set stats["largest_set_size"] to maximum_value_in_integer_list with values as set_sizes
        Set stats["smallest_set_size"] to minimum_value_in_integer_list with values as set_sizes
        Set stats["average_set_size"] to calculate_average_integer with values as set_sizes
    Otherwise:
        Set stats["largest_set_size"] to 0
        Set stats["smallest_set_size"] to 0
        Set stats["average_set_size"] to 0.0
    
    Let connectivity_ratio be 1.0 minus disjoint_set["num_sets"] as Float divided by disjoint_set["total_elements"] as Float
    Set stats["connectivity_ratio"] to connectivity_ratio
    
    Return stats

Process called "maximum_value_in_integer_list" that takes values as List[Integer] returns Integer:
    If length of values is equal to 0:
        Return 0
    
    Let max_value be values[0]
    For each value in values:
        If value is greater than max_value:
            Let max_value be value
    
    Return max_value

Process called "minimum_value_in_integer_list" that takes values as List[Integer] returns Integer:
    If length of values is equal to 0:
        Return 0
    
    Let min_value be values[0]
    For each value in values:
        If value is less than min_value:
            Let min_value be value
    
    Return min_value

Process called "calculate_average_integer" that takes values as List[Integer] returns Float:
    If length of values is equal to 0:
        Return 0.0
    
    Let sum be 0
    For each value in values:
        Let sum be sum plus value
    
    Return sum as Float divided by length of values as Float

Type WeightedDisjointSet is Dictionary with:
    parent as List[Integer]
    weight as List[Float]
    num_elements as Integer

Process called "create_weighted_disjoint_set" that takes n as Integer returns WeightedDisjointSet:
    If n is less than or equal to 0:
        Throw error "Number of elements must be positive"
    
    Let parent be list containing
    Let weight be list containing
    
    For i from 0 to n minus 1:
        Add i to parent
        Add 0.0 to weight
    
    Return dictionary with:
        parent as parent
        weight as weight
        num_elements as n

Process called "weighted_find_root" that takes weighted_set as WeightedDisjointSet and element as Integer returns Dictionary[String, Any]:
    If element is less than 0 or element is greater than or equal to weighted_set["num_elements"]:
        Throw error "Element index out of bounds"
    
    Let result be dictionary with:
    
    If weighted_set["parent"][element] is equal to element:
        Set result["root"] to element
        Set result["weight"] to 0.0
        Return result
    
    Let parent_result be weighted_find_root with weighted_set as weighted_set and element as weighted_set["parent"][element]
    Let parent_root be parent_result["root"]
    Let parent_weight be parent_result["weight"]
    
    Let new_weight be weighted_set["weight"][element] plus parent_weight
    Set weighted_set["weight"][element] to new_weight
    Set weighted_set["parent"][element] to parent_root
    
    Set result["root"] to parent_root
    Set result["weight"] to new_weight
    Return result

Process called "weighted_union" that takes weighted_set as WeightedDisjointSet and element1 as Integer and element2 as Integer and weight_diff as Float returns Boolean:
    Let result1 be weighted_find_root with weighted_set as weighted_set and element as element1
    Let result2 be weighted_find_root with weighted_set as weighted_set and element as element2
    
    Let root1 be result1["root"]
    Let root2 be result2["root"]
    Let weight1 be result1["weight"]
    Let weight2 be result2["weight"]
    
    If root1 is equal to root2:
        Return false
    
    Set weighted_set["parent"][root2] to root1
    Set weighted_set["weight"][root2] to weight1 minus weight2 plus weight_diff
    
    Return true

Process called "get_weight_difference" that takes weighted_set as WeightedDisjointSet and element1 as Integer and element2 as Integer returns Optional[Float]:
    Let result1 be weighted_find_root with weighted_set as weighted_set and element as element1
    Let result2 be weighted_find_root with weighted_set as weighted_set and element as element2
    
    Let root1 be result1["root"]
    Let root2 be result2["root"]
    
    If root1 is not equal to root2:
        Return None
    
    Let weight1 be result1["weight"]
    Let weight2 be result2["weight"]
    
    Return weight2 minus weight1

Type PersistentDisjointSet is Dictionary with:
    disjoint_set as DisjointSet
    history as List[Dictionary[String, Any]]
    current_version as Integer

Process called "create_persistent_disjoint_set" that takes n as Integer returns PersistentDisjointSet:
    Let disjoint_set be create_disjoint_set with n as n
    Let history be list containing
    
    Let initial_state be save_disjoint_set_state with disjoint_set as disjoint_set
    Add initial_state to history
    
    Return dictionary with:
        disjoint_set as disjoint_set
        history as history
        current_version as 0

Process called "save_disjoint_set_state" that takes disjoint_set as DisjointSet returns Dictionary[String, Any]:
    Let state be dictionary with:
    Set state["nodes"] to disjoint_set["nodes"]
    Set state["num_sets"] to disjoint_set["num_sets"]
    Set state["total_elements"] to disjoint_set["total_elements"]
    Return state

Process called "persistent_union" that takes persistent_set as PersistentDisjointSet and element1 as Integer and element2 as Integer returns PersistentDisjointSet:
    Let union_result be union_sets with disjoint_set as persistent_set["disjoint_set"] and element1 as element1 and element2 as element2
    
    If union_result is equal to true:
        Let new_state be save_disjoint_set_state with disjoint_set as persistent_set["disjoint_set"]
        Add new_state to persistent_set["history"]
        Set persistent_set["current_version"] to persistent_set["current_version"] plus 1
    
    Return persistent_set

Process called "query_persistent_version" that takes persistent_set as PersistentDisjointSet and version as Integer and element1 as Integer and element2 as Integer returns Boolean:
    If version is less than 0 or version is greater than persistent_set["current_version"]:
        Throw error "Invalid version number"
    
    Let historical_state be persistent_set["history"][version]
    Let historical_nodes be historical_state["nodes"]
    
    Let temp_disjoint_set be dictionary with:
        nodes as historical_nodes
        num_sets as historical_state["num_sets"]
        total_elements as historical_state["total_elements"]
    
    Return are_connected with disjoint_set as temp_disjoint_set and element1 as element1 and element2 as element2

Type CompactDisjointSet is Dictionary with:
    parent as List[Integer]
    rank as List[Integer]
    total_elements as Integer
    num_sets as Integer

Process called "create_compact_disjoint_set" that takes n as Integer returns CompactDisjointSet:
    If n is less than or equal to 0:
        Throw error "Number of elements must be positive"
    
    Let parent be list containing
    Let rank be list containing
    
    For i from 0 to n minus 1:
        Add i to parent
        Add 0 to rank
    
    Return dictionary with:
        parent as parent
        rank as rank
        total_elements as n
        num_sets as n

Process called "compact_find" that takes compact_set as CompactDisjointSet and element as Integer returns Integer:
    If compact_set["parent"][element] is not equal to element:
        Set compact_set["parent"][element] to compact_find with compact_set as compact_set and element as compact_set["parent"][element]
    
    Return compact_set["parent"][element]

Process called "compact_union" that takes compact_set as CompactDisjointSet and element1 as Integer and element2 as Integer returns Boolean:
    Let root1 be compact_find with compact_set as compact_set and element as element1
    Let root2 be compact_find with compact_set as compact_set and element as element2
    
    If root1 is equal to root2:
        Return false
    
    If compact_set["rank"][root1] is less than compact_set["rank"][root2]:
        Set compact_set["parent"][root1] to root2
    Otherwise if compact_set["rank"][root1] is greater than compact_set["rank"][root2]:
        Set compact_set["parent"][root2] to root1
    Otherwise:
        Set compact_set["parent"][root2] to root1
        Set compact_set["rank"][root1] to compact_set["rank"][root1] plus 1
    
    Set compact_set["num_sets"] to compact_set["num_sets"] minus 1
    Return true

Process called "compact_are_connected" that takes compact_set as CompactDisjointSet and element1 as Integer and element2 as Integer returns Boolean:
    Return compact_find with compact_set as compact_set and element as element1 is equal to compact_find with compact_set as compact_set and element as element2