Note:
Runa Standard Library: ArgParse Validation Module

Provides comprehensive argument validation, sanitization, and security features
for enterprise-grade command-line argument processing.

Features:
- Input validation and sanitization
- Security validation (injection prevention)
- Custom validation rules and chains
- Schema-based validation
- Internationalization support
- Accessibility features
:End Note

Import "argparse.argparse" as argparse
Import "argparse.parser" as parser

Note: Validation Types and Rules
Type ValidationSeverity is:
    | INFO
    | WARNING
    | ERROR
    | CRITICAL

Type ValidationResult is:
    | ValidationSuccess
    | ValidationFailure with message as String and severity as ValidationSeverity and code as String

Type ValidationRule is Dictionary with:
    name as String
    description as String
    validator as Process
    severity as ValidationSeverity defaults to ERROR
    enabled as Boolean defaults to true
    metadata as Dictionary[String, Any]

Type ValidationChain is Dictionary with:
    name as String
    rules as List[ValidationRule]
    stop_on_first_failure as Boolean defaults to true
    aggregate_results as Boolean defaults to false

Type ValidationSchema is Dictionary with:
    name as String
    version as String
    argument_rules as Dictionary[String, List[ValidationRule]]
    global_rules as List[ValidationRule]
    chains as List[ValidationChain]
    metadata as Dictionary[String, Any]

Note: Core Validation Functions
Process called "create_validation_rule" that takes name as String and description as String and validator as Process returns ValidationRule:
    Return ValidationRule with:
        name as name
        description as description
        validator as validator
        severity as ERROR
        enabled as true
        metadata as dictionary containing

Process called "create_validation_chain" that takes name as String and rules as List[ValidationRule] returns ValidationChain:
    Return ValidationChain with:
        name as name
        rules as rules
        stop_on_first_failure as true
        aggregate_results as false

Process called "validate_argument_value" that takes argument as Argument and value as Any and rules as List[ValidationRule] returns List[ValidationResult]:
    Let results be list containing
    
    For each rule in rules:
        If rule["enabled"]:
            Try:
                Let rule_result be rule["validator"] with argument as argument and value as value
                If rule_result is ValidationSuccess:
                    Add ValidationSuccess to results
                Otherwise:
                    Add rule_result to results
                    If rule["severity"] is CRITICAL or rule["severity"] is ERROR:
                        Break loop
            Catch error:
                Add ValidationFailure with:
                    message as "Validation rule '" plus rule["name"] plus "' failed: " plus error
                    severity as CRITICAL
                    code as "VALIDATOR_ERROR"
                to results
                Break loop
    
    Return results

Process called "validate_with_chain" that takes chain as ValidationChain and argument as Argument and value as Any returns List[ValidationResult]:
    Let results be list containing
    
    For each rule in chain["rules"]:
        If rule["enabled"]:
            Let rule_results be validate_argument_value with argument as argument and value as value and rules as list containing rule
            
            If chain["aggregate_results"]:
                For each result in rule_results:
                    Add result to results
            Otherwise:
                For each result in rule_results:
                    If result is ValidationFailure:
                        Add result to results
                        If chain["stop_on_first_failure"]:
                            Return results
    
    Return results

Process called "validate_with_schema" that takes schema as ValidationSchema and parser as ArgumentParser and values as Dictionary[String, Any] returns Dictionary[String, List[ValidationResult]]:
    Let all_results be dictionary containing
    
    Note: Validate global rules first
    For each rule in schema["global_rules"]:
        If rule["enabled"]:
            Let global_results be rule["validator"] with parser as parser and values as values
            Set all_results["_global"] to global_results
    
    Note: Validate argument-specific rules
    For each argument_name in values:
        If argument_name is in schema["argument_rules"]:
            Let argument_rules be schema["argument_rules"][argument_name]
            Let argument be find_argument_by_name with parser as parser and name as argument_name
            Let value be values[argument_name]
            
            If argument is not None:
                Let validation_results be validate_argument_value with argument as argument and value as value and rules as argument_rules
                Set all_results[argument_name] to validation_results
    
    Note: Execute validation chains
    For each chain in schema["chains"]:
        For each argument_name in values:
            Let argument be find_argument_by_name with parser as parser and name as argument_name
            Let value be values[argument_name]
            
            If argument is not None:
                Let chain_results be validate_with_chain with chain as chain and argument as argument and value as value
                If argument_name is not in all_results:
                    Set all_results[argument_name] to list containing
                For each result in chain_results:
                    Add result to all_results[argument_name]
    
    Return all_results

Note: Built-in Validation Rules
Process called "create_length_validator" that takes min_length as Optional[Integer] and max_length as Optional[Integer] returns Process:
    Return Process called "validate_length" that takes argument as Argument and value as Any returns ValidationResult:
        Let string_value be value as String
        Let value_length be length of string_value
        
        If min_length is not None and value_length is less than min_length:
            Return ValidationFailure with:
                message as "Value too short. Minimum length: " plus min_length plus ", actual: " plus value_length
                severity as ERROR
                code as "LENGTH_TOO_SHORT"
        
        If max_length is not None and value_length is greater than max_length:
            Return ValidationFailure with:
                message as "Value too long. Maximum length: " plus max_length plus ", actual: " plus value_length
                severity as ERROR
                code as "LENGTH_TOO_LONG"
        
        Return ValidationSuccess

Process called "create_range_validator" that takes min_value as Optional[Number] and max_value as Optional[Number] returns Process:
    Return Process called "validate_range" that takes argument as Argument and value as Any returns ValidationResult:
        Let numeric_value be value as Number
        
        If min_value is not None and numeric_value is less than min_value:
            Return ValidationFailure with:
                message as "Value too small. Minimum: " plus min_value plus ", actual: " plus numeric_value
                severity as ERROR
                code as "VALUE_TOO_SMALL"
        
        If max_value is not None and numeric_value is greater than max_value:
            Return ValidationFailure with:
                message as "Value too large. Maximum: " plus max_value plus ", actual: " plus numeric_value
                severity as ERROR
                code as "VALUE_TOO_LARGE"
        
        Return ValidationSuccess

Process called "create_regex_validator" that takes pattern as String and flags as List[String] returns Process:
    Return Process called "validate_regex" that takes argument as Argument and value as Any returns ValidationResult:
        Let string_value be value as String
        
        Try:
            Let match_result be regex_match with pattern as pattern and text as string_value and flags as flags
            If match_result is not None:
                Return ValidationSuccess
            Otherwise:
                Return ValidationFailure with:
                    message as "Value does not match required pattern: " plus pattern
                    severity as ERROR
                    code as "PATTERN_MISMATCH"
        Catch error:
            Return ValidationFailure with:
                message as "Regex validation failed: " plus error
                severity as CRITICAL
                code as "REGEX_ERROR"

Process called "create_choice_validator" that takes allowed_choices as List[Any] and case_sensitive as Boolean returns Process:
    Return Process called "validate_choice" that takes argument as Argument and value as Any returns ValidationResult:
        Let found be false
        
        For each choice in allowed_choices:
            If case_sensitive:
                If value is equal to choice:
                    Set found to true
                    Break loop
            Otherwise:
                If lowercase string value is equal to lowercase string choice:
                    Set found to true
                    Break loop
        
        If found:
            Return ValidationSuccess
        Otherwise:
            Return ValidationFailure with:
                message as "Invalid choice. Allowed values: " plus allowed_choices plus ", got: " plus value
                severity as ERROR
                code as "INVALID_CHOICE"

Process called "create_file_validator" that takes must_exist as Boolean and readable as Boolean and writable as Boolean returns Process:
    Return Process called "validate_file" that takes argument as Argument and value as Any returns ValidationResult:
        Let file_path be value as String
        
        If must_exist and not file_exists with path as file_path:
            Return ValidationFailure with:
                message as "File does not exist: " plus file_path
                severity as ERROR
                code as "FILE_NOT_FOUND"
        
        If readable and not file_readable with path as file_path:
            Return ValidationFailure with:
                message as "File is not readable: " plus file_path
                severity as ERROR
                code as "FILE_NOT_READABLE"
        
        If writable and not file_writable with path as file_path:
            Return ValidationFailure with:
                message as "File is not writable: " plus file_path
                severity as ERROR
                code as "FILE_NOT_WRITABLE"
        
        Return ValidationSuccess

Process called "create_directory_validator" that takes must_exist as Boolean and readable as Boolean and writable as Boolean returns Process:
    Return Process called "validate_directory" that takes argument as Argument and value as Any returns ValidationResult:
        Let dir_path be value as String
        
        If must_exist and not directory_exists with path as dir_path:
            Return ValidationFailure with:
                message as "Directory does not exist: " plus dir_path
                severity as ERROR
                code as "DIRECTORY_NOT_FOUND"
        
        If readable and not directory_readable with path as dir_path:
            Return ValidationFailure with:
                message as "Directory is not readable: " plus dir_path
                severity as ERROR
                code as "DIRECTORY_NOT_READABLE"
        
        If writable and not directory_writable with path as dir_path:
            Return ValidationFailure with:
                message as "Directory is not writable: " plus dir_path
                severity as ERROR
                code as "DIRECTORY_NOT_WRITABLE"
        
        Return ValidationSuccess

Note: Security Validation
Process called "create_injection_validator" returns Process:
    Return Process called "validate_injection" that takes argument as Argument and value as Any returns ValidationResult:
        Let string_value be value as String
        
        Note: Check for common injection patterns
        Let dangerous_patterns be list containing:
            "'; DROP TABLE",
            "<script",
            "javascript:",
            "eval(",
            "exec(",
            "../",
            "..\\",
            "/etc/passwd",
            "cmd.exe",
            "powershell"
        
        For each pattern in dangerous_patterns:
            If lowercase string_value contains lowercase pattern:
                Return ValidationFailure with:
                    message as "Potentially dangerous input detected"
                    severity as CRITICAL
                    code as "INJECTION_DETECTED"
        
        Return ValidationSuccess

Process called "create_path_traversal_validator" returns Process:
    Return Process called "validate_path_traversal" that takes argument as Argument and value as Any returns ValidationResult:
        Let path_value be value as String
        
        Note: Check for path traversal patterns
        If path_value contains ".." or path_value contains "~/" or path_value starts with "/":
            Let normalized_path be normalize_path with path as path_value
            Let base_path be get_current_directory
            
            If not normalized_path starts with base_path:
                Return ValidationFailure with:
                    message as "Path traversal detected: " plus path_value
                    severity as CRITICAL
                    code as "PATH_TRAVERSAL"
        
        Return ValidationSuccess

Process called "create_command_injection_validator" returns Process:
    Return Process called "validate_command_injection" that takes argument as Argument and value as Any returns ValidationResult:
        Let string_value be value as String
        
        Note: Check for command injection patterns
        Let dangerous_chars be list containing ";", "|", "&", "$", "`", "(", ")", "{", "}", "[", "]"
        
        For each char in dangerous_chars:
            If char is in string_value:
                Return ValidationFailure with:
                    message as "Potentially dangerous character in input: " plus char
                    severity as WARNING
                    code as "DANGEROUS_CHARACTER"
        
        Note: Check for command patterns
        Let command_patterns be list containing "rm ", "del ", "format ", "shutdown", "reboot"
        
        For each pattern in command_patterns:
            If lowercase string_value contains pattern:
                Return ValidationFailure with:
                    message as "Potentially dangerous command detected"
                    severity as CRITICAL
                    code as "COMMAND_INJECTION"
        
        Return ValidationSuccess

Note: Input Sanitization
Process called "sanitize_string_input" that takes value as String and options as Dictionary[String, Any] returns String:
    Let sanitized_value be value
    
    Note: Remove control characters
    If "remove_control_chars" is in options and options["remove_control_chars"]:
        Set sanitized_value to remove_control_characters with text as sanitized_value
    
    Note: Escape HTML characters
    If "escape_html" is in options and options["escape_html"]:
        Set sanitized_value to escape_html with text as sanitized_value
    
    Note: Remove or escape quotes
    If "escape_quotes" is in options and options["escape_quotes"]:
        Set sanitized_value to escape_quotes with text as sanitized_value
    
    Note: Normalize whitespace
    If "normalize_whitespace" is in options and options["normalize_whitespace"]:
        Set sanitized_value to normalize_whitespace with text as sanitized_value
    
    Note: Trim whitespace
    If "trim_whitespace" is in options and options["trim_whitespace"]:
        Set sanitized_value to trim string sanitized_value
    
    Note: Convert to lowercase
    If "to_lowercase" is in options and options["to_lowercase"]:
        Set sanitized_value to lowercase string sanitized_value
    
    Note: Convert to uppercase
    If "to_uppercase" is in options and options["to_uppercase"]:
        Set sanitized_value to uppercase string sanitized_value
    
    Return sanitized_value

Process called "sanitize_numeric_input" that takes value as Number and options as Dictionary[String, Any] returns Number:
    Let sanitized_value be value
    
    Note: Clamp to range
    If "min_value" is in options and sanitized_value is less than options["min_value"]:
        Set sanitized_value to options["min_value"]
    
    If "max_value" is in options and sanitized_value is greater than options["max_value"]:
        Set sanitized_value to options["max_value"]
    
    Note: Round to precision
    If "precision" is in options:
        Set sanitized_value to round number sanitized_value to precision options["precision"]
    
    Return sanitized_value

Note: Validation Schema Builder
Process called "create_validation_schema" that takes name as String and version as String returns ValidationSchema:
    Return ValidationSchema with:
        name as name
        version as version
        argument_rules as dictionary containing
        global_rules as list containing
        chains as list containing
        metadata as dictionary containing

Process called "add_argument_validation" that takes schema as ValidationSchema and argument_name as String and rules as List[ValidationRule] returns ValidationSchema:
    Set schema["argument_rules"][argument_name] to rules
    Return schema

Process called "add_global_validation" that takes schema as ValidationSchema and rule as ValidationRule returns ValidationSchema:
    Add rule to schema["global_rules"]
    Return schema

Process called "add_validation_chain" that takes schema as ValidationSchema and chain as ValidationChain returns ValidationSchema:
    Add chain to schema["chains"]
    Return schema

Note: Common Validation Schemas
Process called "create_security_validation_schema" returns ValidationSchema:
    Let schema be create_validation_schema with name as "security" and version as "1.0"
    
    Note: Add security rules
    Let injection_rule be create_validation_rule with:
        name as "injection_check"
        description as "Check for injection attacks"
        validator as create_injection_validator
    
    Let path_traversal_rule be create_validation_rule with:
        name as "path_traversal_check"
        description as "Check for path traversal attacks"
        validator as create_path_traversal_validator
    
    Let command_injection_rule be create_validation_rule with:
        name as "command_injection_check"
        description as "Check for command injection attacks"
        validator as create_command_injection_validator
    
    Add injection_rule to schema["global_rules"]
    Add path_traversal_rule to schema["global_rules"]
    Add command_injection_rule to schema["global_rules"]
    
    Return schema

Process called "create_file_validation_schema" returns ValidationSchema:
    Let schema be create_validation_schema with name as "file" and version as "1.0"
    
    Note: Create file validation rules
    Let file_rule be create_validation_rule with:
        name as "file_check"
        description as "Validate file arguments"
        validator as create_file_validator with must_exist as true and readable as true and writable as false
    
    Let directory_rule be create_validation_rule with:
        name as "directory_check"
        description as "Validate directory arguments"
        validator as create_directory_validator with must_exist as true and readable as true and writable as false
    
    Note: Add rules for common file argument names
    Set schema["argument_rules"]["file"] to list containing file_rule
    Set schema["argument_rules"]["input"] to list containing file_rule
    Set schema["argument_rules"]["output"] to list containing file_rule
    Set schema["argument_rules"]["directory"] to list containing directory_rule
    Set schema["argument_rules"]["dir"] to list containing directory_rule
    Set schema["argument_rules"]["path"] to list containing file_rule
    
    Return schema

Note: Validation Result Processing
Process called "has_validation_errors" that takes results as Dictionary[String, List[ValidationResult]] returns Boolean:
    For each argument_name in results:
        Let argument_results be results[argument_name]
        For each result in argument_results:
            If result is ValidationFailure:
                If result["severity"] is ERROR or result["severity"] is CRITICAL:
                    Return true
    Return false

Process called "get_validation_errors" that takes results as Dictionary[String, List[ValidationResult]] returns List[Dictionary[String, Any]]:
    Let errors be list containing
    
    For each argument_name in results:
        Let argument_results be results[argument_name]
        For each result in argument_results:
            If result is ValidationFailure:
                Add dictionary with:
                    "argument" as argument_name
                    "message" as result["message"]
                    "severity" as result["severity"]
                    "code" as result["code"]
                to errors
    
    Return errors

Process called "format_validation_errors" that takes errors as List[Dictionary[String, Any]] returns String:
    If length of errors is equal to 0:
        Return "No validation errors"
    
    Let error_text be "Validation errors:\n"
    
    For each error in errors:
        Set error_text to error_text plus "  - " plus error["argument"] plus ": " plus error["message"]
        
        If error["severity"] is CRITICAL:
            Set error_text to error_text plus " [CRITICAL]"
        Otherwise if error["severity"] is ERROR:
            Set error_text to error_text plus " [ERROR]"
        Otherwise if error["severity"] is WARNING:
            Set error_text to error_text plus " [WARNING]"
        
        Set error_text to error_text plus "\n"
    
    Return error_text

Note: Integration with Main Parser
Process called "validate_parsed_args" that takes parser as ArgumentParser and values as Dictionary[String, Any] and schema as Optional[ValidationSchema] returns ValidationResult:
    Let validation_results be dictionary containing
    
    If schema is not None:
        Set validation_results to validate_with_schema with schema as schema and parser as parser and values as values
    Otherwise:
        Note: Use default validation rules from arguments
        For each argument_name in values:
            Let argument be find_argument_by_name with parser as parser and name as argument_name
            If argument is not None and argument["validator"] is not None:
                Let value be values[argument_name]
                Let rule_result be argument["validator"] with argument as argument and value as value
                Set validation_results[argument_name] to list containing rule_result
    
    If has_validation_errors with results as validation_results:
        Let errors be get_validation_errors with results as validation_results
        Let error_message be format_validation_errors with errors as errors
        Return ValidationFailure with:
            message as error_message
            severity as ERROR
            code as "VALIDATION_FAILED"
    
    Return ValidationSuccess