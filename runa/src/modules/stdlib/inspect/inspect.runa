        Return false

Process called "is_list_type" that takes obj as Any returns Boolean:
    Note: Check if object is a list type using pure Runa reflection
    Try:
        Note: Use reflection runtime call for type information
        Let type_info be system_call_reflection_get_type_info with obj as obj
        If type_info is not None and type_info contains key "name":
            Let type_name be type_info at key "name"
            Return type_name is equal to "List"
        Otherwise:
            Return false
    Catch error:
        Return false

Process called "is_dictionary_type" that takes obj as Any returns Boolean:
    Note: Check if object is a dictionary type using pure Runa reflection
    Try:
        Note: Use reflection runtime call for type information
        Let type_info be system_call_reflection_get_type_info with obj as obj
        If type_info is not None and type_info contains key "name":
            Let type_name be type_info at key "name"
            Return type_name is equal to "Dictionary"
        Otherwise:
            Return false
    Catch error:
        Return false

Process called "is_set_type" that takes obj as Any returns Boolean:
    Note: Check if object is a set type using pure Runa reflection
    Try:
        Note: Use reflection runtime call for type information
        Let type_info be system_call_reflection_get_type_info with obj as obj
        If type_info is not None and type_info contains key "name":
            Let type_name be type_info at key "name"
            Return type_name is equal to "Set"
        Otherwise:
