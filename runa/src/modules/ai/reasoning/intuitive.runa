Note: Advanced Intuitive Reasoning System for AI Agents
Note: Implements pattern recognition, heuristic processing, implicit knowledge,
Note: tacit understanding, and rapid non-analytic reasoning

Note: Core intuitive reasoning types
Type IntuitivePattern is Dictionary with:
    pattern id as String
    pattern type as String  Note: "perceptual", "conceptual", "emotional", "social", "temporal"
    pattern structure as Dictionary
    activation threshold as Float
    confidence level as Float
    source domain as String
    applicable contexts as List[String]
    learned from as List[String]
    strength as Float
    last activated as String

Type Heuristic is Dictionary with:
    heuristic id as String
    heuristic name as String
    heuristic type as String  Note: "availability", "representativeness", "anchoring", "affect"
    trigger conditions as List[String]
    processing rules as List[String]
    accuracy rate as Float
    speed advantage as Float
    bias potential as Float
    applicable domains as List[String]
    usage frequency as Integer

Type TacitKnowledge is Dictionary with:
    knowledge id as String
    knowledge domain as String
    implicit rules as List[Dictionary]
    context dependencies as List[String]
    confidence in knowledge as Float
    source of learning as String
    transferability as Float
    articulation difficulty as Float
    usage patterns as Dictionary

Type IntuitiveInsight is Dictionary with:
    insight id as String
    insight content as String
    insight type as String  Note: "solution", "connection", "understanding", "prediction"
    certainty level as Float
    emergence context as Dictionary
    supporting patterns as List[String]
    verification suggestions as List[String]
    generalizability as Float
    actionability as Float

Type HeuristicResponse is Dictionary with:
    response id as String
    trigger pattern as String
    applied heuristic as String
    generated response as Dictionary
    confidence in response as Float
    processing speed as Float
    accuracy estimation as Float
    context factors as Dictionary

Type PatternMatchResult is Dictionary with:
    match id as String
    matched pattern as IntuitivePattern
    input stimulus as Dictionary
    match strength as Float
    pattern completion as Dictionary
    analogous cases as List[Dictionary]
    prediction generated as Dictionary
    uncertainty level as Float

Type IntuitiveReasoner is Dictionary with:
    pattern library as List[IntuitivePattern]
    heuristic collection as List[Heuristic]
    tacit knowledge base as List[TacitKnowledge]
    processing mode as String  Note: "fast", "slow", "adaptive"
    sensitivity threshold as Float
    confidence calibration as Float
    pattern learning enabled as Boolean
    bias monitoring enabled as Boolean

Note: Pattern recognition and matching
Process called "recognize_patterns" that takes input_data as Dictionary and reasoner as IntuitiveReasoner returns List[PatternMatchResult]:
    Let pattern_library be reasoner with field pattern_library
    Let matches be empty list
    Let sensitivity_threshold be reasoner with field sensitivity_threshold
    
    For each pattern in pattern_library:
        Let match_result be attempt_pattern_match with input_data and pattern and sensitivity_threshold
        If match_result with field match_strength is greater than sensitivity_threshold:
            Add match_result to matches
    
    Note: Sort matches by strength
    Let sorted_matches be sort_by_strength with matches
    
    Note: Apply pattern completion and prediction
    For each match in sorted_matches:
        Let completion be complete_pattern with match and input_data
        Set match with field pattern_completion to completion
        
        Let prediction be generate_pattern_prediction with match and input_data
        Set match with field prediction_generated to prediction
    
    Return sorted_matches

Process called "attempt_pattern_match" that takes input_data as Dictionary and pattern as IntuitivePattern and threshold as Float returns PatternMatchResult:
    Let pattern_structure be pattern with field pattern_structure
    Let pattern_type be pattern with field pattern_type
    
    Let match_strength be 0.0
    
    If pattern_type is equal to "perceptual":
        Set match_strength to calculate_perceptual_match with input_data and pattern_structure
    
    If pattern_type is equal to "conceptual":
        Set match_strength to calculate_conceptual_match with input_data and pattern_structure
    
    If pattern_type is equal to "temporal":
        Set match_strength to calculate_temporal_match with input_data and pattern_structure
    
    If pattern_type is equal to "social":
        Set match_strength to calculate_social_match with input_data and pattern_structure
    
    If pattern_type is equal to "emotional":
        Set match_strength to calculate_emotional_match with input_data and pattern_structure
    
    Note: Create match result
    Let match_result be create_pattern_match_result_structure
    Set match_result with field matched_pattern to pattern
    Set match_result with field input_stimulus to input_data
    Set match_result with field match_strength to match_strength
    Set match_result with field uncertainty_level to calculate_match_uncertainty with match_strength and pattern
    
    Return match_result

Process called "calculate_perceptual_match" that takes input_data as Dictionary and pattern_structure as Dictionary returns Float:
    Let features be extract_perceptual_features with input_data
    Let pattern_features be pattern_structure with key "features"
    
    Let feature_matches be 0
    Let total_features be length of pattern_features
    
    For each pattern_feature in pattern_features:
        Let feature_name be pattern_feature with key "name"
        Let expected_value be pattern_feature with key "value"
        Let tolerance be pattern_feature with key "tolerance" or 0.1
        
        If features contains key feature_name:
            Let actual_value be features with key feature_name
            Let difference be absolute_value of (actual_value minus expected_value)
            If difference is less than or equal to tolerance:
                Set feature_matches to feature_matches plus 1
    
    Return feature_matches as Float divided by total_features as Float

Note: Heuristic processing
Process called "apply_heuristic_processing" that takes stimulus as Dictionary and reasoner as IntuitiveReasoner returns List[HeuristicResponse]:
    Let heuristic_collection be reasoner with field heuristic_collection
    Let triggered_heuristics be empty list
    
    Note: Identify triggered heuristics
    For each heuristic in heuristic_collection:
        Let trigger_conditions be heuristic with field trigger_conditions
        Let is_triggered be check_heuristic_triggers with stimulus and trigger_conditions
        
        If is_triggered is equal to true:
            Add heuristic to triggered_heuristics
    
    Note: Apply triggered heuristics
    Let heuristic_responses be empty list
    For each triggered_heuristic in triggered_heuristics:
        Let response be process_with_heuristic with stimulus and triggered_heuristic
        Add response to heuristic_responses
    
    Note: Rank responses by confidence and speed
    Let ranked_responses be rank_heuristic_responses with heuristic_responses
    
    Return ranked_responses

Process called "process_with_heuristic" that takes stimulus as Dictionary and heuristic as Heuristic returns HeuristicResponse:
    Let heuristic_type be heuristic with field heuristic_type
    Let processing_rules be heuristic with field processing_rules
    
    Let response be create_heuristic_response_structure
    Set response with field applied_heuristic to heuristic with field heuristic_id
    Set response with field trigger_pattern to identify_trigger_pattern with stimulus and heuristic
    
    If heuristic_type is equal to "availability":
        Let availability_response be apply_availability_heuristic with stimulus and processing_rules
        Set response with field generated_response to availability_response
        Set response with field processing_speed to 0.95  Note: Very fast
        Set response with field accuracy_estimation to 0.7  Note: Moderate accuracy
    
    If heuristic_type is equal to "representativeness":
        Let representativeness_response be apply_representativeness_heuristic with stimulus and processing_rules
        Set response with field generated_response to representativeness_response
        Set response with field processing_speed to 0.9   Note: Fast
        Set response with field accuracy_estimation to 0.6  Note: Lower accuracy
    
    If heuristic_type is equal to "anchoring":
        Let anchoring_response be apply_anchoring_heuristic with stimulus and processing_rules
        Set response with field generated_response to anchoring_response
        Set response with field processing_speed to 0.85  Note: Fast
        Set response with field accuracy_estimation to 0.65  Note: Moderate accuracy
    
    If heuristic_type is equal to "affect":
        Let affect_response be apply_affect_heuristic with stimulus and processing_rules
        Set response with field generated_response to affect_response
        Set response with field processing_speed to 0.98  Note: Very fast
        Set response with field accuracy_estimation to 0.55  Note: Lower accuracy, high bias
    
    Note: Calculate overall confidence
    Let confidence be calculate_heuristic_confidence with response and heuristic
    Set response with field confidence_in_response to confidence
    
    Return response

Process called "apply_availability_heuristic" that takes stimulus as Dictionary and rules as List[String] returns Dictionary:
    Let available_examples be retrieve_available_examples with stimulus
    Let most_accessible be find_most_accessible_examples with available_examples
    
    Note: Judge probability/frequency based on ease of recall
    Let estimated_probability be calculate_availability_based_probability with most_accessible
    Let generated_judgment be create_availability_judgment with estimated_probability and most_accessible
    
    Return dictionary with keys "judgment_type", "estimated_probability", "basis", "examples":
        "judgment_type" maps to "availability_based"
        "estimated_probability" maps to estimated_probability
        "basis" maps to "ease_of_recall"
        "examples" maps to most_accessible

Note: Tacit knowledge application
Process called "apply_tacit_knowledge" that takes context as Dictionary and reasoner as IntuitiveReasoner returns Dictionary:
    Let tacit_knowledge_base be reasoner with field tacit_knowledge_base
    Let applicable_knowledge be filter_applicable_tacit_knowledge with tacit_knowledge_base and context
    
    Let tacit_insights be empty list
    For each knowledge_item in applicable_knowledge:
        Let implicit_rules be knowledge_item with field implicit_rules
        Let insights be apply_implicit_rules with context and implicit_rules
        Add all insights to tacit_insights
    
    Note: Synthesize tacit understanding
    Let tacit_understanding be synthesize_tacit_insights with tacit_insights and context
    
    Return dictionary with keys "tacit_insights", "synthesized_understanding", "confidence", "articulation_difficulty":
        "tacit_insights" maps to tacit_insights
        "synthesized_understanding" maps to tacit_understanding
        "confidence" maps to calculate_tacit_confidence with tacit_insights
        "articulation_difficulty" maps to assess_articulation_difficulty with tacit_understanding

Process called "apply_implicit_rules" that takes context as Dictionary and implicit_rules as List[Dictionary] returns List[Dictionary]:
    Let applied_insights be empty list
    
    For each rule in implicit_rules:
        Let rule_conditions be rule with key "conditions"
        Let rule_action be rule with key "action"
        Let rule_confidence be rule with key "confidence"
        
        Let conditions_met be check_implicit_conditions with context and rule_conditions
        If conditions_met is equal to true:
            Let insight be apply_implicit_action with context and rule_action
            Set insight with key "confidence" to rule_confidence
            Set insight with key "source_rule" to rule with key "rule_id"
            Add insight to applied_insights
    
    Return applied_insights

Note: Intuitive insight generation
Process called "generate_intuitive_insights" that takes problem_context as Dictionary and reasoner as IntuitiveReasoner returns List[IntuitiveInsight]:
    Let insights be empty list
    
    Note: Pattern-based insight generation
    Let pattern_matches be recognize_patterns with problem_context and reasoner
    For each match in pattern_matches:
        Let pattern_insight be derive_insight_from_pattern with match and problem_context
        If pattern_insight is not equal to null:
            Add pattern_insight to insights
    
    Note: Heuristic-based insight generation
    Let heuristic_responses be apply_heuristic_processing with problem_context and reasoner
    For each response in heuristic_responses:
        Let heuristic_insight be derive_insight_from_heuristic with response and problem_context
        If heuristic_insight is not equal to null:
            Add heuristic_insight to insights
    
    Note: Tacit knowledge-based insight generation
    Let tacit_application be apply_tacit_knowledge with problem_context and reasoner
    Let tacit_insight be derive_insight_from_tacit_knowledge with tacit_application and problem_context
    If tacit_insight is not equal to null:
        Add tacit_insight to insights
    
    Note: Cross-domain analogical insights
    Let analogical_insights be generate_analogical_insights with problem_context and reasoner
    Add all analogical_insights to insights
    
    Note: Filter and rank insights
    Let filtered_insights be filter_plausible_insights with insights
    Let ranked_insights be rank_insights_by_potential with filtered_insights
    
    Return ranked_insights

Process called "derive_insight_from_pattern" that takes pattern_match as PatternMatchResult and context as Dictionary returns IntuitiveInsight:
    Let matched_pattern be pattern_match with field matched_pattern
    Let pattern_completion be pattern_match with field pattern_completion
    Let prediction be pattern_match with field prediction_generated
    
    Note: Generate insight based on pattern implications
    Let insight_content be generate_pattern_based_insight with matched_pattern and pattern_completion and prediction
    
    If insight_content is not equal to null:
        Let insight be create_intuitive_insight_structure
        Set insight with field insight_content to insight_content
        Set insight with field insight_type to "pattern_recognition"
        Set insight with field certainty_level to pattern_match with field match_strength
        Set insight with field emergence_context to context
        Set insight with field supporting_patterns to list containing (matched_pattern with field pattern_id)
        
        Note: Generate verification suggestions
        Let verification_suggestions be suggest_pattern_verification with matched_pattern and insight_content
        Set insight with field verification_suggestions to verification_suggestions
        
        Return insight
    
    Return null

Note: Fast-and-frugal decision making
Process called "make_fast_frugal_decision" that takes decision_context as Dictionary and reasoner as IntuitiveReasoner returns Dictionary:
    Let available_cues be extract_decision_cues with decision_context
    Let fast_frugal_trees be load_fast_frugal_trees
    
    Note: Find applicable decision tree
    Let applicable_tree be find_applicable_tree with available_cues and fast_frugal_trees
    
    If applicable_tree is not equal to null:
        Let decision be traverse_decision_tree with available_cues and applicable_tree
        Return dictionary with keys "decision", "method", "confidence", "speed":
            "decision" maps to decision with field choice
            "method" maps to "fast_and_frugal_tree"
            "confidence" maps to decision with field confidence
            "speed" maps to decision with field processing_time
    
    Note: Fallback to single-cue heuristic
    Let primary_cue be identify_primary_cue with available_cues
    Let simple_decision be make_single_cue_decision with primary_cue and decision_context
    
    Return dictionary with keys "decision", "method", "confidence", "speed":
        "decision" maps to simple_decision with field choice
        "method" maps to "single_cue_heuristic"
        "confidence" maps to simple_decision with field confidence
        "speed" maps to simple_decision with field processing_time

Process called "traverse_decision_tree" that takes cues as Dictionary and tree as Dictionary returns Dictionary:
    Let current_node be tree with key "root_node"
    Let decision_path be empty list
    Let processing_steps be 0
    
    While current_node with key "node_type" is not equal to "leaf":
        Set processing_steps to processing_steps plus 1
        Let cue_name be current_node with key "cue"
        Let threshold be current_node with key "threshold"
        
        Add current_node to decision_path
        
        If cues contains key cue_name:
            Let cue_value be cues with key cue_name
            If cue_value is greater than threshold:
                Set current_node to current_node with key "high_branch"
            Otherwise:
                Set current_node to current_node with key "low_branch"
        Otherwise:
            Note: Missing cue - use default branch
            Set current_node to current_node with key "default_branch"
    
    Note: Reached leaf node - extract decision
    Let decision be current_node with key "decision"
    Let confidence be current_node with key "confidence"
    
    Return dictionary with keys "choice", "confidence", "processing_time", "decision_path":
        "choice" maps to decision
        "confidence" maps to confidence
        "processing_time" maps to processing_steps as Float
        "decision_path" maps to decision_path

Note: Intuitive learning and adaptation
Process called "learn_intuitive_patterns" that takes experiences as List[Dictionary] and reasoner as IntuitiveReasoner returns IntuitiveReasoner:
    Let updated_reasoner be copy of reasoner
    Let pattern_library be updated_reasoner with field pattern_library
    
    Note: Extract patterns from experiences
    Let discovered_patterns be extract_patterns_from_experiences with experiences
    
    Note: Validate and integrate new patterns
    For each new_pattern in discovered_patterns:
        Let validation_result be validate_pattern with new_pattern and experiences
        If validation_result with field valid is equal to true:
            Note: Check if pattern already exists
            Let existing_pattern be find_similar_pattern with new_pattern and pattern_library
            If existing_pattern is not equal to null:
                Note: Strengthen existing pattern
                Let strengthened_pattern be strengthen_pattern with existing_pattern and new_pattern
                Replace existing_pattern with strengthened_pattern in pattern_library
            Otherwise:
                Note: Add new pattern
                Add new_pattern to pattern_library
    
    Note: Update heuristic accuracy based on performance
    Let heuristic_collection be updated_reasoner with field heuristic_collection
    For each heuristic in heuristic_collection:
        Let performance_data be extract_heuristic_performance with heuristic and experiences
        Let updated_heuristic be update_heuristic_accuracy with heuristic and performance_data
        Replace heuristic with updated_heuristic in heuristic_collection
    
    Note: Update tacit knowledge
    Let tacit_knowledge_base be updated_reasoner with field tacit_knowledge_base
    Let refined_tacit_knowledge be refine_tacit_knowledge with tacit_knowledge_base and experiences
    Set updated_reasoner with field tacit_knowledge_base to refined_tacit_knowledge
    
    Return updated_reasoner

Note: Intuitive-analytic integration
Process called "integrate_intuitive_analytic_reasoning" that takes problem as Dictionary and intuitive_results as Dictionary and analytic_results as Dictionary returns Dictionary:
    Let integration_method be determine_integration_method with problem and intuitive_results and analytic_results
    
    Let integrated_result be empty dictionary
    
    If integration_method is equal to "convergent":
        Note: Both approaches agree
        Set integrated_result to create_convergent_integration with intuitive_results and analytic_results
    
    If integration_method is equal to "complementary":
        Note: Different aspects, both valuable
        Set integrated_result to create_complementary_integration with intuitive_results and analytic_results
    
    If integration_method is equal to "conflicting":
        Note: Disagreement requires resolution
        Set integrated_result to resolve_intuitive_analytic_conflict with intuitive_results and analytic_results and problem
    
    If integration_method is equal to "sequential":
        Note: Use one to inform the other
        Set integrated_result to create_sequential_integration with intuitive_results and analytic_results
    
    Note: Add meta-reasoning assessment
    Let meta_assessment be assess_reasoning_quality with integrated_result and problem
    Set integrated_result with key "meta_assessment" to meta_assessment
    
    Return integrated_result

Note: Main intuitive reasoning coordination
Process called "create_intuitive_reasoner" that takes configuration as Dictionary returns IntuitiveReasoner:
    Let reasoner be create_intuitive_reasoner_structure
    
    Set reasoner with field processing_mode to configuration with key "processing_mode" or "adaptive"
    Set reasoner with field sensitivity_threshold to configuration with key "sensitivity_threshold" or 0.6
    Set reasoner with field confidence_calibration to configuration with key "confidence_calibration" or 0.8
    Set reasoner with field pattern_learning_enabled to configuration with key "pattern_learning" or true
    Set reasoner with field bias_monitoring_enabled to configuration with key "bias_monitoring" or true
    
    Note: Load initial knowledge
    Set reasoner with field pattern_library to load_initial_patterns
    Set reasoner with field heuristic_collection to load_common_heuristics
    Set reasoner with field tacit_knowledge_base to load_domain_tacit_knowledge
    
    Return reasoner

Process called "execute_intuitive_reasoning" that takes reasoner as IntuitiveReasoner and query as Dictionary returns Dictionary:
    Let query_type be query with key "type"
    Let result be empty dictionary
    
    If query_type is equal to "pattern_recognition":
        Let input_data be query with key "input_data"
        Let patterns be recognize_patterns with input_data and reasoner
        Set result with key "recognized_patterns" to patterns
    
    If query_type is equal to "heuristic_processing":
        Let stimulus be query with key "stimulus"
        Let heuristic_responses be apply_heuristic_processing with stimulus and reasoner
        Set result with key "heuristic_responses" to heuristic_responses
    
    If query_type is equal to "insight_generation":
        Let problem_context be query with key "problem_context"
        Let insights be generate_intuitive_insights with problem_context and reasoner
        Set result with key "generated_insights" to insights
    
    If query_type is equal to "fast_decision":
        Let decision_context be query with key "decision_context"
        Let decision be make_fast_frugal_decision with decision_context and reasoner
        Set result with key "fast_decision" to decision
    
    If query_type is equal to "tacit_knowledge":
        Let context be query with key "context"
        Let tacit_application be apply_tacit_knowledge with context and reasoner
        Set result with key "tacit_knowledge_application" to tacit_application
    
    If query_type is equal to "intuitive_analytic_integration":
        Let problem be query with key "problem"
        Let intuitive_results be query with key "intuitive_results"
        Let analytic_results be query with key "analytic_results"
        Let integration be integrate_intuitive_analytic_reasoning with problem and intuitive_results and analytic_results
        Set result with key "integrated_reasoning" to integration
    
    Note: Monitor for biases if enabled
    If reasoner with field bias_monitoring_enabled is equal to true:
        Let bias_assessment be monitor_intuitive_biases with result and query
        Set result with key "bias_assessment" to bias_assessment
    
    Note: Add metadata
    Set result with key "reasoning_timestamp" to current_timestamp
    Set result with key "reasoner_config" to extract_reasoner_summary with reasoner
    
    Return result