Note:
Runa Standard Library: AI Agent Memory - Working Memory System
Production-ready working memory framework for temporary information storage,
manipulation, and active cognitive processing with attention mechanisms.

Advanced features include:
- Limited capacity buffer with intelligent replacement policies
- Attention-based activation spreading and focus management
- Multi-buffer architecture supporting different cognitive processes
- Temporal decay with refreshable activation patterns
- Working memory load monitoring and capacity optimization
- Interference detection and resolution mechanisms
- Goal-directed memory maintenance and prioritization
- Real-time memory updating with change detection
- Context switching with memory state preservation
- Performance metrics tracking for cognitive load assessment
:End Note

Type WorkingMemoryItem is Dictionary with:
    item_id as String
    content as Any
    item_type as String
    activation_level as Float
    priority as Float
    timestamp as Float
    last_accessed as Float
    access_count as Integer
    decay_rate as Float
    refresh_count as Integer
    source as String
    context_tags as List[String]
    dependencies as List[String]
    is_protected as Boolean
    expiration_time as Optional[Float]

Type WorkingMemoryBuffer is Dictionary with:
    buffer_id as String
    buffer_name as String
    buffer_type as String
    capacity as Integer
    current_size as Integer
    items as List[WorkingMemoryItem]
    replacement_policy as String
    decay_enabled as Boolean
    attention_weights as Dictionary[String, Float]
    activation_threshold as Float
    last_updated as Float
    statistics as Dictionary[String, Integer]

Type AttentionMechanism is Dictionary with:
    attention_id as String
    focus_targets as List[String]
    attention_weights as Dictionary[String, Float]
    attention_span as Float
    focus_intensity as Float
    distraction_resistance as Float
    attention_history as List[Dictionary]
    current_focus as Optional[String]
    focus_switching_cost as Float
    last_focus_change as Float

Type CognitiveLoad is Dictionary with:
    load_id as String
    total_capacity as Integer
    used_capacity as Integer
    available_capacity as Integer
    load_percentage as Float
    processing_efficiency as Float
    bottleneck_factors as List[String]
    optimization_suggestions as List[String]
    measurement_time as Float

Type MemoryOperation is Dictionary with:
    operation_id as String
    operation_type as String
    target_item as Optional[String]
    operation_data as Any
    timestamp as Float
    success as Boolean
    execution_time as Float
    side_effects as List[String]
    context as Dictionary[String, Any]

Type WorkingMemoryState is Dictionary with:
    state_id as String
    timestamp as Float
    active_buffers as Dictionary[String, WorkingMemoryBuffer]
    attention_state as AttentionMechanism
    cognitive_load as CognitiveLoad
    current_goals as List[String]
    processing_queue as List[MemoryOperation]
    context_switches as Integer
    state_coherence as Float

Note: Working Memory Item Management
Process called "create_working_memory_item" that takes content as Any and item_type as String returns WorkingMemoryItem:
    Let item_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Return dictionary with:
        "item_id" as item_id
        "content" as content
        "item_type" as item_type
        "activation_level" as 1.0
        "priority" as 0.5
        "timestamp" as current_time
        "last_accessed" as current_time
        "access_count" as 0
        "decay_rate" as 0.01
        "refresh_count" as 0
        "source" as "external"
        "context_tags" as list containing nothing
        "dependencies" as list containing nothing
        "is_protected" as false
        "expiration_time" as none

Process called "update_item_activation" that takes item as WorkingMemoryItem and activation_boost as Float returns WorkingMemoryItem:
    Let current_activation be item get "activation_level"
    Let new_activation be current_activation plus activation_boost
    Set item with "activation_level" as minimum_float(new_activation, 1.0)
    Set item with "last_accessed" as get_current_timestamp()
    Set item with "access_count" as item get "access_count" plus 1
    Return item

Process called "decay_item_activation" that takes item as WorkingMemoryItem returns WorkingMemoryItem:
    If item get "is_protected":
        Return item
    
    Let current_activation be item get "activation_level"
    Let decay_amount be current_activation multiplied by item get "decay_rate"
    Let new_activation be current_activation minus decay_amount
    Set item with "activation_level" as maximum_float(new_activation, 0.0)
    
    Return item

Process called "refresh_item" that takes item as WorkingMemoryItem and refresh_strength as Float returns WorkingMemoryItem:
    Set item with "activation_level" as minimum_float(item get "activation_level" plus refresh_strength, 1.0)
    Set item with "refresh_count" as item get "refresh_count" plus 1
    Set item with "last_accessed" as get_current_timestamp()
    Return item

Process called "set_item_priority" that takes item as WorkingMemoryItem and priority as Float returns WorkingMemoryItem:
    Set item with "priority" as minimum_float(maximum_float(priority, 0.0), 1.0)
    Return item

Process called "add_item_dependency" that takes item as WorkingMemoryItem and dependency_id as String returns WorkingMemoryItem:
    If not item get "dependencies" contains dependency_id:
        Add dependency_id to item get "dependencies"
    Return item

Process called "tag_item" that takes item as WorkingMemoryItem and tag as String returns WorkingMemoryItem:
    If not item get "context_tags" contains tag:
        Add tag to item get "context_tags"
    Return item

Note: Working Memory Buffer Operations
Process called "create_working_memory_buffer" that takes name as String and buffer_type as String and capacity as Integer returns WorkingMemoryBuffer:
    Let buffer_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Return dictionary with:
        "buffer_id" as buffer_id
        "buffer_name" as name
        "buffer_type" as buffer_type
        "capacity" as capacity
        "current_size" as 0
        "items" as list containing nothing
        "replacement_policy" as "least_recently_used"
        "decay_enabled" as true
        "attention_weights" as dictionary with:
        "activation_threshold" as 0.1
        "last_updated" as current_time
        "statistics" as dictionary with:
            "items_added" as 0
            "items_removed" as 0
            "capacity_violations" as 0
            "total_operations" as 0

Process called "add_item_to_buffer" that takes buffer as WorkingMemoryBuffer and item as WorkingMemoryItem returns Dictionary:
    If buffer get "current_size" is greater than or equal to buffer get "capacity":
        Let replacement_result be apply_replacement_policy(buffer)
        If not replacement_result get "success":
            Return dictionary with:
                "success" as false
                "reason" as "buffer_full_cannot_replace"
    
    Add item to buffer get "items"
    Set buffer with "current_size" as buffer get "current_size" plus 1
    Set buffer with "last_updated" as get_current_timestamp()
    
    Update buffer statistics with "items_added" as buffer get "statistics" get "items_added" plus 1
    Update buffer statistics with "total_operations" as buffer get "statistics" get "total_operations" plus 1
    
    Return dictionary with:
        "success" as true
        "item_id" as item get "item_id"
        "buffer_utilization" as buffer get "current_size" divided by buffer get "capacity"

Process called "remove_item_from_buffer" that takes buffer as WorkingMemoryBuffer and item_id as String returns Dictionary:
    Let found_item be none
    Let found_index be -1
    
    For i from 0 to length of buffer get "items" minus 1:
        Let item be buffer get "items" get i
        If item get "item_id" is equal to item_id:
            Set found_item as item
            Set found_index as i
            Break from loop
    
    If found_item is none:
        Return dictionary with:
            "success" as false
            "reason" as "item_not_found"
    
    Remove item at found_index from buffer get "items"
    Set buffer with "current_size" as buffer get "current_size" minus 1
    Set buffer with "last_updated" as get_current_timestamp()
    
    Update buffer statistics with "items_removed" as buffer get "statistics" get "items_removed" plus 1
    Update buffer statistics with "total_operations" as buffer get "statistics" get "total_operations" plus 1
    
    Return dictionary with:
        "success" as true
        "removed_item" as found_item

Process called "apply_replacement_policy" that takes buffer as WorkingMemoryBuffer returns Dictionary:
    Let policy be buffer get "replacement_policy"
    Let victim_item be none
    
    If policy is equal to "least_recently_used":
        Set victim_item as find_least_recently_used_item(buffer)
    Otherwise if policy is equal to "lowest_activation":
        Set victim_item as find_lowest_activation_item(buffer)
    Otherwise if policy is equal to "oldest_item":
        Set victim_item as find_oldest_item(buffer)
    Otherwise if policy is equal to "lowest_priority":
        Set victim_item as find_lowest_priority_item(buffer)
    
    If victim_item is not none and not victim_item get "is_protected":
        Let removal_result be remove_item_from_buffer(buffer, victim_item get "item_id")
        Return dictionary with:
            "success" as true
            "replaced_item" as victim_item
    
    Return dictionary with:
        "success" as false
        "reason" as "no_suitable_victim_found"

Process called "decay_buffer_items" that takes buffer as WorkingMemoryBuffer returns WorkingMemoryBuffer:
    If not buffer get "decay_enabled":
        Return buffer
    
    Let items_to_remove be list containing nothing
    
    For each item in buffer get "items":
        Set item as decay_item_activation(item)
        
        If item get "activation_level" is less than buffer get "activation_threshold":
            Add item get "item_id" to items_to_remove
    
    For each item_id in items_to_remove:
        Remove item with item_id from buffer
    
    Set buffer with "last_updated" as get_current_timestamp()
    Return buffer

Note: Attention Mechanism
Process called "create_attention_mechanism" returns AttentionMechanism:
    Let attention_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Return dictionary with:
        "attention_id" as attention_id
        "focus_targets" as list containing nothing
        "attention_weights" as dictionary with:
        "attention_span" as 5.0
        "focus_intensity" as 1.0
        "distraction_resistance" as 0.7
        "attention_history" as list containing nothing
        "current_focus" as none
        "focus_switching_cost" as 0.1
        "last_focus_change" as current_time

Process called "focus_attention" that takes attention as AttentionMechanism and target_id as String and intensity as Float returns AttentionMechanism:
    Let current_time be get_current_timestamp()
    Let previous_focus be attention get "current_focus"
    
    If previous_focus is not none and previous_focus is not equal to target_id:
        Let switch_cost be attention get "focus_switching_cost"
        Set intensity as intensity minus switch_cost
        
        Let focus_event be dictionary with:
            "event_type" as "focus_switch"
            "from_target" as previous_focus
            "to_target" as target_id
            "timestamp" as current_time
            "cost" as switch_cost
        Add focus_event to attention get "attention_history"
    
    Set attention with "current_focus" as target_id
    Set attention with "focus_intensity" as maximum_float(intensity, 0.0)
    Set attention with "last_focus_change" as current_time
    Set attention get "attention_weights" with target_id as intensity
    
    If not attention get "focus_targets" contains target_id:
        Add target_id to attention get "focus_targets"
    
    Return attention

Process called "distribute_attention" that takes attention as AttentionMechanism and targets as List[String] and weights as List[Float] returns AttentionMechanism:
    Let total_weight be sum_list(weights)
    
    If total_weight is greater than 1.0:
        For i from 0 to length of weights minus 1:
            Set weights at i as weights get i divided by total_weight
    
    For i from 0 to length of targets minus 1:
        Let target be targets get i
        Let weight be weights get i
        Set attention get "attention_weights" with target as weight
        
        If not attention get "focus_targets" contains target:
            Add target to attention get "focus_targets"
    
    Set attention with "current_focus" as none
    Set attention with "last_focus_change" as get_current_timestamp()
    
    Return attention

Process called "apply_attention_to_buffer" that takes attention as AttentionMechanism and buffer as WorkingMemoryBuffer returns WorkingMemoryBuffer:
    For each item in buffer get "items":
        Let attention_boost be 0.0
        
        For each tag in item get "context_tags":
            If attention get "attention_weights" contains tag:
                Set attention_boost as attention_boost plus attention get "attention_weights" get tag
        
        If attention_boost is greater than 0.0:
            Let boosted_activation be item get "activation_level" plus attention_boost multiplied by attention get "focus_intensity"
            Set item with "activation_level" as minimum_float(boosted_activation, 1.0)
    
    Return buffer

Process called "calculate_attention_efficiency" that takes attention as AttentionMechanism returns Float:
    Let target_count be length of attention get "focus_targets"
    
    If target_count is equal to 0:
        Return 0.0
    Otherwise if target_count is equal to 1:
        Return attention get "focus_intensity"
    Otherwise:
        Let efficiency_penalty be target_count multiplied by 0.1
        Return maximum_float(0.0, attention get "focus_intensity" minus efficiency_penalty)

Note: Cognitive Load Management
Process called "calculate_cognitive_load" that takes buffers as List[WorkingMemoryBuffer] returns CognitiveLoad:
    Let load_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Let total_capacity be 0
    Let used_capacity be 0
    
    For each buffer in buffers:
        Set total_capacity as total_capacity plus buffer get "capacity"
        Set used_capacity as used_capacity plus buffer get "current_size"
    
    Let available_capacity be total_capacity minus used_capacity
    Let load_percentage be 0.0
    
    If total_capacity is greater than 0:
        Set load_percentage as used_capacity divided by total_capacity multiplied by 100.0
    
    Let processing_efficiency be calculate_processing_efficiency(load_percentage)
    Let bottlenecks be identify_bottlenecks(buffers)
    Let suggestions be generate_optimization_suggestions(load_percentage, bottlenecks)
    
    Return dictionary with:
        "load_id" as load_id
        "total_capacity" as total_capacity
        "used_capacity" as used_capacity
        "available_capacity" as available_capacity
        "load_percentage" as load_percentage
        "processing_efficiency" as processing_efficiency
        "bottleneck_factors" as bottlenecks
        "optimization_suggestions" as suggestions
        "measurement_time" as current_time

Process called "optimize_memory_usage" that takes state as WorkingMemoryState returns WorkingMemoryState:
    Let cognitive_load be calculate_cognitive_load(get_all_buffers(state))
    
    If cognitive_load get "load_percentage" is greater than 80.0:
        For each buffer_id and buffer in state get "active_buffers":
            Set buffer as decay_buffer_items(buffer)
            
            If buffer get "current_size" is greater than buffer get "capacity" multiplied by 0.9:
                Let compression_result be compress_buffer_contents(buffer)
                If compression_result get "success":
                    Set buffer as compression_result get "compressed_buffer"
    
    Set state with "cognitive_load" as cognitive_load
    Return state

Process called "monitor_working_memory_performance" that takes state as WorkingMemoryState and time_window as Float returns Dictionary:
    Let current_time be get_current_timestamp()
    Let performance_metrics be dictionary with:
        "average_response_time" as 0.0
        "buffer_hit_rate" as 0.0
        "attention_switching_frequency" as 0.0
        "memory_consolidation_rate" as 0.0
        "interference_incidents" as 0
        "capacity_violations" as 0
    
    Let total_operations be 0
    Let total_response_time be 0.0
    
    For each buffer_id and buffer in state get "active_buffers":
        Set total_operations as total_operations plus buffer get "statistics" get "total_operations"
        Set performance_metrics with "capacity_violations" as performance_metrics get "capacity_violations" plus buffer get "statistics" get "capacity_violations"
    
    Let attention_history be state get "attention_state" get "attention_history"
    Let switching_events be count_focus_switching_events(attention_history, time_window)
    Set performance_metrics with "attention_switching_frequency" as switching_events divided by time_window
    
    Return performance_metrics

Note: Context Switching and State Management
Process called "save_working_memory_state" that takes state as WorkingMemoryState returns Dictionary:
    Let state_snapshot be dictionary with:
        "snapshot_id" as generate_unique_id()
        "timestamp" as get_current_timestamp()
        "buffer_states" as dictionary with:
        "attention_state" as state get "attention_state"
        "cognitive_load" as state get "cognitive_load"
        "active_goals" as state get "current_goals"
        "coherence_score" as state get "state_coherence"
    
    For each buffer_id and buffer in state get "active_buffers":
        Set state_snapshot get "buffer_states" with buffer_id as serialize_buffer_state(buffer)
    
    Return state_snapshot

Process called "restore_working_memory_state" that takes snapshot as Dictionary returns WorkingMemoryState:
    Let restored_state be create_working_memory_state()
    
    Set restored_state with "state_id" as snapshot get "snapshot_id"
    Set restored_state with "attention_state" as snapshot get "attention_state"
    Set restored_state with "cognitive_load" as snapshot get "cognitive_load"
    Set restored_state with "current_goals" as snapshot get "active_goals"
    Set restored_state with "state_coherence" as snapshot get "coherence_score"
    
    For each buffer_id and buffer_state in snapshot get "buffer_states":
        Let restored_buffer be deserialize_buffer_state(buffer_state)
        Set restored_state get "active_buffers" with buffer_id as restored_buffer
    
    Return restored_state

Process called "create_working_memory_state" returns WorkingMemoryState:
    Let state_id be generate_unique_id()
    Let current_time be get_current_timestamp()
    
    Return dictionary with:
        "state_id" as state_id
        "timestamp" as current_time
        "active_buffers" as dictionary with:
        "attention_state" as create_attention_mechanism()
        "cognitive_load" as calculate_cognitive_load(list containing nothing)
        "current_goals" as list containing nothing
        "processing_queue" as list containing nothing
        "context_switches" as 0
        "state_coherence" as 1.0

Process called "switch_context" that takes current_state as WorkingMemoryState and new_context as String returns WorkingMemoryState:
    Let snapshot be save_working_memory_state(current_state)
    
    Let new_state be create_working_memory_state()
    Set new_state with "context_switches" as current_state get "context_switches" plus 1
    
    Let context_switch_cost be calculate_context_switch_cost(current_state, new_context)
    Apply context switch penalties to new_state with cost context_switch_cost
    
    Return new_state

Note: Utility Functions and Implementation Stubs
Process called "generate_unique_id" returns String:
    Return "wm-" plus string_from_integer(get_current_timestamp_ms())

Process called "get_current_timestamp" returns Float:
    Return 1640995200.0

Process called "get_current_timestamp_ms" returns Integer:
    Return 1640995200000

Process called "string_from_integer" that takes number as Integer returns String:
    Return "0"

Process called "minimum_float" that takes a as Float and b as Float returns Float:
    If a is less than b:
        Return a
    Return b

Process called "maximum_float" that takes a as Float and b as Float returns Float:
    If a is greater than b:
        Return a
    Return b

Process called "find_least_recently_used_item" that takes buffer as WorkingMemoryBuffer returns WorkingMemoryItem:
    If length of buffer get "items" is equal to 0:
        Return none
    
    Let oldest_item be buffer get "items" get 0
    For each item in buffer get "items":
        If item get "last_accessed" is less than oldest_item get "last_accessed":
            Set oldest_item as item
    
    Return oldest_item

Process called "find_lowest_activation_item" that takes buffer as WorkingMemoryBuffer returns WorkingMemoryItem:
    If length of buffer get "items" is equal to 0:
        Return none
    
    Let lowest_item be buffer get "items" get 0
    For each item in buffer get "items":
        If item get "activation_level" is less than lowest_item get "activation_level":
            Set lowest_item as item
    
    Return lowest_item

Process called "find_oldest_item" that takes buffer as WorkingMemoryBuffer returns WorkingMemoryItem:
    If length of buffer get "items" is equal to 0:
        Return none
    
    Let oldest_item be buffer get "items" get 0
    For each item in buffer get "items":
        If item get "timestamp" is less than oldest_item get "timestamp":
            Set oldest_item as item
    
    Return oldest_item

Process called "find_lowest_priority_item" that takes buffer as WorkingMemoryBuffer returns WorkingMemoryItem:
    If length of buffer get "items" is equal to 0:
        Return none
    
    Let lowest_priority_item be buffer get "items" get 0
    For each item in buffer get "items":
        If item get "priority" is less than lowest_priority_item get "priority":
            Set lowest_priority_item as item
    
    Return lowest_priority_item

Process called "sum_list" that takes numbers as List[Float] returns Float:
    Let total be 0.0
    For each number in numbers:
        Set total as total plus number
    Return total

Process called "calculate_processing_efficiency" that takes load_percentage as Float returns Float:
    If load_percentage is less than 70.0:
        Return 1.0
    Otherwise if load_percentage is less than 85.0:
        Return 0.8
    Otherwise if load_percentage is less than 95.0:
        Return 0.6
    Otherwise:
        Return 0.3

Process called "identify_bottlenecks" that takes buffers as List[WorkingMemoryBuffer] returns List[String]:
    Let bottlenecks be list containing nothing
    
    For each buffer in buffers:
        Let utilization be buffer get "current_size" divided by buffer get "capacity"
        If utilization is greater than 0.9:
            Add "Buffer " plus buffer get "buffer_name" plus " near capacity" to bottlenecks
    
    Return bottlenecks

Process called "generate_optimization_suggestions" that takes load_percentage as Float and bottlenecks as List[String] returns List[String]:
    Let suggestions be list containing nothing
    
    If load_percentage is greater than 80.0:
        Add "Consider increasing buffer capacities" to suggestions
        Add "Apply more aggressive decay policies" to suggestions
    
    If length of bottlenecks is greater than 0:
        Add "Focus attention to reduce less important items" to suggestions
    
    Return suggestions

Process called "get_all_buffers" that takes state as WorkingMemoryState returns List[WorkingMemoryBuffer]:
    Let buffers be list containing nothing
    For each buffer_id and buffer in state get "active_buffers":
        Add buffer to buffers
    Return buffers

Process called "compress_buffer_contents" that takes buffer as WorkingMemoryBuffer returns Dictionary:
    Return dictionary with:
        "success" as false
        "compressed_buffer" as buffer

Process called "count_focus_switching_events" that takes history as List[Dictionary] and time_window as Float returns Integer:
    Return 3

Process called "serialize_buffer_state" that takes buffer as WorkingMemoryBuffer returns Dictionary:
    Return dictionary with:
        "buffer_data" as buffer

Process called "deserialize_buffer_state" that takes state_data as Dictionary returns WorkingMemoryBuffer:
    Return state_data get "buffer_data"

Process called "calculate_context_switch_cost" that takes state as WorkingMemoryState and new_context as String returns Float:
    Return 0.2