Note: Debug and Performance Monitoring Functions
Process called "create_expansion_debug_tracer" that takes context as MacroContext returns ExpansionDebugTracer:
    Return ExpansionDebugTracer with:
        trace_level as "info"
        trace_output as list containing
        breakpoints as list containing
        metadata as dictionary containing

Process called "create_expansion_performance_monitor" that takes context as MacroContext returns ExpansionPerformanceMonitor:
    Return ExpansionPerformanceMonitor with:
        metrics as dictionary containing
        thresholds as dictionary containing:
            "expansion_time" as 1.0
            "memory_usage" as 1024.0
            "complexity" as 10.0
        alerts as list containing
        metadata as dictionary containing

Process called "add_debug_breakpoint" that takes engine as ExpansionEngine and condition as String and action as String returns Boolean:
    Try:
        Let breakpoint be DebugBreakpoint with:
            condition as condition
            action as action
            enabled as true
            metadata as dictionary containing
        
        Add breakpoint to engine.debug_tracer.breakpoints
        Return true
        
    Catch error:
        Return false

Process called "get_expansion_trace" that takes engine as ExpansionEngine returns List[TraceEntry]:
    Return engine.debug_tracer.trace_output

Process called "clear_expansion_trace" that takes engine as ExpansionEngine:
    Set engine.debug_tracer.trace_output to list containing

Process called "get_performance_metrics" that takes engine as ExpansionEngine returns Dictionary[String, PerformanceMetric]:
    Return engine.performance_monitor.metrics

Process called "get_performance_alerts" that takes engine as ExpansionEngine returns List[PerformanceAlert]:
    Return engine.performance_monitor.alerts

Process called "set_performance_threshold" that takes engine as ExpansionEngine and metric as String and threshold as Float returns Boolean:
    Try:
        Set engine.performance_monitor.thresholds[metric] to threshold
        Return true
        
    Catch error:
        Return false 