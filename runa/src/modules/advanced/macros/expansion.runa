Note: Expansion Optimization Functions
Process called "create_expansion_optimizer" that takes context as MacroContext returns ExpansionOptimizer:
    Let optimizers be dictionary containing:
        "constant_folding" as constant_folding_optimizer
        "dead_code_elimination" as dead_code_elimination_optimizer
        "common_subexpression_elimination" as common_subexpression_elimination_optimizer
        "loop_optimization" as loop_optimization_optimizer
    
    Let analyzers be dictionary containing:
        "complexity" as complexity_analyzer
        "performance" as performance_analyzer
        "memory" as memory_analyzer
    
    Let transformers be dictionary containing:
        "simplification" as simplification_transformer
        "inlining" as inlining_transformer
        "specialization" as specialization_transformer
    
    Return ExpansionOptimizer with:
        optimizers as optimizers
        analyzers as analyzers
        transformers as transformers
        metadata as dictionary containing

Process called "analyze_expansion" that takes engine as ExpansionEngine and expansion as ExpansionResult returns ExpansionAnalysis:
    Try:
        Let complexity_analyzer be engine.expansion_optimizer.analyzers["complexity"]
        Let performance_analyzer be engine.expansion_optimizer.analyzers["performance"]
        Let memory_analyzer be engine.expansion_optimizer.analyzers["memory"]
        
        Let complexity be complexity_analyzer with expansion as expansion
        Let performance_impact be performance_analyzer with expansion as expansion
        Let memory_usage be memory_analyzer with expansion as expansion
        
        Let optimization_opportunities be list containing
        
        If complexity is greater than 10.0:
            Add "High complexity detected - consider simplification" to optimization_opportunities
        
        If performance_impact is greater than 100.0:
            Add "High performance impact detected - consider optimization" to optimization_opportunities
        
        If memory_usage is greater than 1024.0:
            Add "High memory usage detected - consider optimization" to optimization_opportunities
        
        Return ExpansionAnalysis with:
            complexity as complexity
            performance_impact as performance_impact
            memory_usage as memory_usage
            optimization_opportunities as optimization_opportunities
            metadata as dictionary containing
        
    Catch error:
        Return ExpansionAnalysis with:
            complexity as 0.0
            performance_impact as 0.0
            memory_usage as 0.0
            optimization_opportunities as list containing
            metadata as dictionary containing

