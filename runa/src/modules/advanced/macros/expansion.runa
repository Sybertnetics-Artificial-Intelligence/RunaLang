Process called "create_template_expander" that takes context as MacroContext returns TemplateExpander:
    Let expanders be dictionary containing:
        "code_template" as code_template_expander
        "ast_template" as ast_template_expander
        "hybrid_template" as hybrid_template_expander
    
    Let variable_substitutors be dictionary containing:
        "simple" as simple_variable_substitutor
        "expression" as expression_variable_substitutor
        "conditional" as conditional_variable_substitutor
    
    Let conditional_processors be dictionary containing:
        "if" as if_conditional_processor
        "switch" as switch_conditional_processor
        "loop" as loop_conditional_processor
    
    Return TemplateExpander with:
        expanders as expanders
        variable_substitutors as variable_substitutors
        conditional_processors as conditional_processors
        metadata as dictionary containing

