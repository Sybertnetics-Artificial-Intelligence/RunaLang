Note: Code Optimization Functions
Process called "create_code_optimizer" that takes context as MacroContext returns CodeOptimizer:
    Let optimizers be dictionary containing:
        "constant_folding" as constant_folding_optimizer
        "dead_code_elimination" as dead_code_elimination_optimizer
        "common_subexpression_elimination" as common_subexpression_elimination_optimizer
        "loop_optimization" as loop_optimization_optimizer
    
    Let analyzers be dictionary containing:
        "optimization_opportunities" as optimization_opportunities_analyzer
        "performance_impact" as performance_impact_analyzer
    
    Let transformers be dictionary containing:
        "simplification" as simplification_transformer
        "inlining" as inlining_transformer
    
    Return CodeOptimizer with:
        optimizers as optimizers
        analyzers as analyzers
        transformers as transformers
        metadata as dictionary containing

Process called "optimize_generated_code" that takes generator as CodeGenerator and code as GeneratedCode returns OptimizedCode:
    Try:
        Let analysis be analyze_optimization_opportunities with generator as generator and code as code
        
        Let optimized_content be code.content
        Let optimizations_applied be list containing
        Let performance_improvement be 0.0
        
        For each optimizer_name in generator.optimizer.optimizers:
            Let optimizer_function be generator.optimizer.optimizers[optimizer_name]
            Let optimization_result be optimizer_function with code as code
            
            If optimization_result is not code:
                Set optimized_content to optimization_result.content
                Add optimizer_name to optimizations_applied
                Set performance_improvement to performance_improvement plus 0.1
        
        Return OptimizedCode with:
            original_code as code
            optimized_content as optimized_content
            optimizations_applied as optimizations_applied
            performance_improvement as performance_improvement
            metadata as dictionary containing
        
    Catch error:
        Return OptimizedCode with:
            original_code as code
            optimized_content as code.content
            optimizations_applied as list containing
            performance_improvement as 0.0
            metadata as dictionary containing

Process called "analyze_optimization_opportunities" that takes generator as CodeGenerator and code as GeneratedCode returns OptimizationAnalysis:
