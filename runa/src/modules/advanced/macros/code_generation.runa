        Let opportunities_analyzer be generator.optimizer.analyzers["optimization_opportunities"]
        Let performance_analyzer be generator.optimizer.analyzers["performance_impact"]
        
        Let opportunities be opportunities_analyzer with code as code
        Let estimated_improvement be performance_analyzer with code as code
        
        Return OptimizationAnalysis with:
            optimization_opportunities as opportunities
            estimated_improvement as estimated_improvement
            complexity_impact as 0.0
            metadata as dictionary containing
        
    Catch error:
        Return OptimizationAnalysis with:
