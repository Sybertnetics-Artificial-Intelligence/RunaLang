        template_id as template.template_id
        processed_content as template.template_code
        variable_bindings as variables
        sections as list containing
        metadata as dictionary containing

Process called "nested_template_processor" that takes template as CodeTemplate and variables as Dictionary[String, Any] returns ProcessedTemplate:
    Note: Nested template processor implementation
    Return ProcessedTemplate with:
        template_id as template.template_id
        processed_content as template.template_code
        variable_bindings as variables
        sections as list containing
        metadata as dictionary containing

Process called "default_template_processor" that takes template as CodeTemplate and variables as Dictionary[String, Any] returns ProcessedTemplate:
    Note: Default template processor implementation
    Return ProcessedTemplate with:
        template_id as template.template_id
        processed_content as template.template_code
        variable_bindings as variables
        sections as list containing
        metadata as dictionary containing

Process called "text_template_renderer" that takes processed_template as ProcessedTemplate and context as Dictionary[String, Any] returns String:
    Note: Text template renderer implementation
    Return processed_template.processed_content

Process called "code_template_renderer" that takes processed_template as ProcessedTemplate and context as Dictionary[String, Any] returns String:
    Note: Code template renderer implementation
    Return processed_template.processed_content

Process called "html_template_renderer" that takes processed_template as ProcessedTemplate and context as Dictionary[String, Any] returns String:
    Note: HTML template renderer implementation
    Return processed_template.processed_content

Process called "default_template_renderer" that takes processed_template as ProcessedTemplate and context as Dictionary[String, Any] returns String:
    Note: Default template renderer implementation
    Return processed_template.processed_content

Note: AST Generator Functions
Process called "create_ast_generator" that takes context as MacroContext returns ASTGenerator:
    Let generators be dictionary containing:
        "function" as function_ast_generator
        "class" as class_ast_generator
        "variable" as variable_ast_generator
        "expression" as expression_ast_generator
    
    Let transformers be dictionary containing:
        "simplify" as simplify_ast_transformer
        "optimize" as optimize_ast_transformer
        "normalize" as normalize_ast_transformer
    
    Let builders be dictionary containing:
        "builder" as builder_ast_builder
        "factory" as factory_ast_builder
    
    Return ASTGenerator with:
        generators as generators
        transformers as transformers
        builders as builders
        metadata as dictionary containing

Process called "generate_ast_from_specification" that takes generator as CodeGenerator and ast_spec as ASTSpecification returns ASTNode:
    Try:
        Let generator_function be generator.ast_generator.generators[ast_spec.node_type] if generator.ast_generator.generators contains ast_spec.node_type else default_ast_generator
        
        Let ast_node be generator_function with ast_spec as ast_spec and context as dictionary containing
        
        Return ast_node
        
    Catch error:
        Return create_error_ast with message as error.message

Process called "generate_ast_from_code" that takes generator as CodeGenerator and code as String returns ASTNode:
    Note: Generate AST from code string
    Return ASTNode with:
        node_type as "root"
        value as None
        children as list containing
        position as Position with:
            line as 0
            column as 0
            offset as 0
            metadata as dictionary containing
        metadata as dictionary containing

