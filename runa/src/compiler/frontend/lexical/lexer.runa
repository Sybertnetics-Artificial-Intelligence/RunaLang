Note:
compiler/frontend/lexical/lexer.runa
Main Lexical Analyzer with Dual Syntax Support

This module provides comprehensive lexical analysis functionality including:
- Dual syntax mode support (natural language vs technical)
- Token stream generation and management
- Mathematical symbol preprocessing and recognition
- Mode switching based on compiler flags (--developer, --viewer)
- Multi-word identifier tokenization
- Context-sensitive keyword detection
- Integration with advanced mathematical notation
- Error detection and recovery during tokenization
- Position tracking for accurate diagnostics
- Performance optimized tokenization algorithms
- Unicode support for international characters
- Comment processing and preservation for tooling
:End Note

Import "dev/debug/errors/core" as Errors
Import "compiler/frontend/lexical/math_symbols" as MathSymbols
Import "compiler/frontend/lexical/token_stream" as TokenStream
Import "compiler/frontend/lexical/keywords" as Keywords
Import "compiler/frontend/lexical/operators" as Operators
Import "compiler/frontend/lexical/literals" as Literals

Note: =====================================================================
Note: LEXER DATA STRUCTURES
Note: =====================================================================

Type called "LexerMode":
    mode_name as String
    natural_language as Boolean
    technical_syntax as Boolean
    math_symbols_enabled as Boolean
    strict_indentation as Boolean
    allow_mixed_syntax as Boolean

Type called "TokenPosition":
    line as Integer
    column as Integer
    offset as Integer
    length as Integer
    file_path as String

Type called "Token":
    token_type as String
    value as String
    position as TokenPosition
    original_text as String
    mode_generated as String
    math_symbol_info as Dictionary[String, String]
    indentation_level as Integer

Type called "LexerContext":
    current_position as Integer
    current_line as Integer
    current_column as Integer
    indentation_stack as List[Integer]
    string_interpolation_depth as Integer
    comment_nesting_depth as Integer
    parentheses_depth as Integer
    bracket_depth as Integer
    brace_depth as Integer

Type called "LexerState":
    mode as LexerMode
    source_code as String
    preprocessed_code as String
    context as LexerContext
    tokens as List[Token]
    errors as List[String]
    warnings as List[String]
    symbol_replacements as Dictionary[String, String]

Type called "Lexer":
    lexer_id as String
    lexer_name as String
    state as LexerState
    token_stream as String
    keywords_recognizer as String
    operators_recognizer as String
    literals_parser as String
    math_symbols_processor as String
    statistics as Dictionary[String, Integer]

