Note:
compiler/frontend/primitives/operators/logical.runa
Logical Operator Compiler Integration Layer

This module maps logical operator tokens from the parser to the appropriate
functions in the standard library. It handles operator precedence, type resolution,
compile-time constant folding, and IR generation for logical expressions.

Key responsibilities:
- Map operator tokens (and, or, not) to standard library functions
- Resolve operator overloading based on operand types
- Perform compile-time evaluation of constant expressions
- Generate IR/bytecode for runtime logical evaluation
- Handle operator precedence and associativity
- Support both natural language and technical operators
- Validate logical operator usage in appropriate contexts
- Handle short-circuit evaluation optimization
:End Note

Import "math/discrete/logic" as Logic
Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: OPERATOR TOKEN DEFINITIONS
Note: =====================================================================

Type called "LogicalOperatorToken":
    symbol as String                    Note: and, or, not
    technical_form as String            Note: &&, ||, ! (future expansion)
    precedence as Integer               Note: Operator precedence level
    associativity as String             Note: left, right
    arity as Integer                    Note: 1 for unary, 2 for binary
    short_circuits as Boolean           Note: Whether operator short-circuits
    evaluation_order as String          Note: left_to_right, right_to_left

Type called "LogicalOperatorMapping":
    token as LogicalOperatorToken
    target_function as String           Note: Function name in math/discrete/logic
    module_path as String              Note: Module containing the function
    requires_boolean_operands as Boolean Note: Whether operands must be boolean
    compile_time_evaluable as Boolean  Note: Can be evaluated at compile time

Type called "LogicalOperatorResolution":
    operator as LogicalOperatorToken
    left_type as String
    right_type as Optional[String]      Note: None for unary operators
    resolved_function as String
    needs_type_conversion as Boolean
    short_circuit_possible as Boolean
    evaluation_context as String

Note: =====================================================================
Note: LOGICAL OPERATOR TOKEN REGISTRY
Note: =====================================================================

Process called "get_logical_operators" returns List[LogicalOperatorToken]:
    Note: Return all logical operator tokens with their properties
    
    Let operators be List[LogicalOperatorToken].new()
    
    Note: Logical AND operator
    Let and_op be LogicalOperatorToken.new()
    Set and_op.symbol to "and"
    Set and_op.technical_form to "logical and"
    Set and_op.precedence to 13
    Set and_op.associativity to "left"
    Set and_op.arity to 2
    Set and_op.short_circuits to true
    Set and_op.evaluation_order to "left_to_right"
    operators.append(and_op)
    
    Note: Logical OR operator
    Let or_op be LogicalOperatorToken.new()
    Set or_op.symbol to "or"
    Set or_op.technical_form to "logical or"
    Set or_op.precedence to 14
    Set or_op.associativity to "left"
    Set or_op.arity to 2
    Set or_op.short_circuits to true
    Set or_op.evaluation_order to "left_to_right"
    operators.append(or_op)
    
    Note: Logical NOT operator
    Let not_op be LogicalOperatorToken.new()
    Set not_op.symbol to "not"
    Set not_op.technical_form to "logical not"
    Set not_op.precedence to 12
    Set not_op.associativity to "right"
    Set not_op.arity to 1
    Set not_op.short_circuits to false
    Set not_op.evaluation_order to "right_to_left"
    operators.append(not_op)
    
    Return operators

Note: =====================================================================
Note: OPERATOR MAPPING TO STANDARD LIBRARY
Note: =====================================================================

Process called "map_logical_operator_to_function" that takes operator_symbol as String, arity as Integer returns LogicalOperatorMapping:
    Note: Map a logical operator symbol to its corresponding standard library function
    
    Let mapping be LogicalOperatorMapping.new()
    Let token be find_logical_operator_token(operator_symbol, arity)
    Set mapping.token to token
    Set mapping.module_path to "math/discrete/logic"
    Set mapping.compile_time_evaluable to true
    Set mapping.requires_boolean_operands to true
    
    If operator_symbol equals "and" and arity equals 2:
        Set mapping.target_function to "evaluate_boolean_expression"
        Note: Will pass "AND" as operator to the function
    Otherwise:
        If operator_symbol equals "or" and arity equals 2:
            Set mapping.target_function to "evaluate_boolean_expression"
            Note: Will pass "OR" as operator to the function
        Otherwise:
            If operator_symbol equals "not" and arity equals 1:
                Set mapping.target_function to "evaluate_boolean_expression"
                Note: Will pass "NOT" as operator to the function
            Otherwise:
                Throw Errors.InvalidOperation with "Unknown logical operator"
    
    Return mapping

Process called "find_logical_operator_token" that takes symbol as String, arity as Integer returns LogicalOperatorToken:
    Note: Find logical operator token by symbol and arity
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.symbol equals symbol and op.arity equals arity:
            Return op
    
    Throw Errors.NotFound with "Logical operator token not found"

Note: =====================================================================
Note: OPERATOR RESOLUTION AND TYPE CHECKING
Note: =====================================================================

Process called "resolve_logical_operator" that takes operator_symbol as String, left_type as String, right_type as Optional[String] returns LogicalOperatorResolution:
    Note: Resolve which function to call based on operator and operand types
    
    Let resolution be LogicalOperatorResolution.new()
    Let arity be 2
    If right_type is None:
        Set arity to 1
    
    Let mapping be map_logical_operator_to_function(operator_symbol, arity)
    Set resolution.operator to mapping.token
    Set resolution.left_type to left_type
    Set resolution.right_type to right_type
    Set resolution.resolved_function to mapping.target_function
    
    Note: Check if types need conversion to boolean
    Let boolean_types be List[String].from_array(["Boolean", "Bool"])
    
    If not boolean_types.contains(left_type):
        Set resolution.needs_type_conversion to true
    Otherwise:
        If right_type is not None and not boolean_types.contains(right_type.unwrap()):
            Set resolution.needs_type_conversion to true
        Otherwise:
            Set resolution.needs_type_conversion to false
    
    Note: Determine if short-circuit evaluation is possible
    Set resolution.short_circuit_possible to mapping.token.short_circuits
    Set resolution.evaluation_context to "boolean_logic"
    
    Return resolution

Note: =====================================================================
Note: COMPILE-TIME CONSTANT FOLDING
Note: =====================================================================

Process called "evaluate_constant_logical" that takes operator_symbol as String, left_value as String, right_value as Optional[String], left_type as String, right_type as Optional[String] returns String:
    Note: Evaluate logical expression at compile time if both operands are constants
    
    Let resolution be resolve_logical_operator(operator_symbol, left_type, right_type)
    
    Note: Convert string values to boolean for evaluation
    Let left_bool be parse_boolean_value(left_value)
    
    If operator_symbol equals "and":
        Let right_bool be parse_boolean_value(right_value.unwrap())
        Let result be left_bool and right_bool
        Return format_boolean_result(result)
    
    If operator_symbol equals "or":
        Let right_bool be parse_boolean_value(right_value.unwrap())
        Let result be left_bool or right_bool
        Return format_boolean_result(result)
    
    If operator_symbol equals "not":
        Let result be not left_bool
        Return format_boolean_result(result)
    
    Throw Errors.InvalidOperation with "Unknown logical operator for constant folding"

Process called "parse_boolean_value" that takes value as String returns Boolean:
    Note: Parse string representation to boolean value
    
    If value equals "true" or value equals "True":
        Return true
    
    If value equals "false" or value equals "False":
        Return false
    
    Throw Errors.InvalidValue with "Cannot parse boolean value"

Process called "format_boolean_result" that takes result as Boolean returns String:
    Note: Format boolean result back to string representation
    
    If result:
        Return "true"
    Otherwise:
        Return "false"

Process called "can_fold_logical_expression" that takes left_is_constant as Boolean, right_is_constant as Optional[Boolean] returns Boolean:
    Note: Check if a logical expression can be evaluated at compile time
    
    If right_is_constant is None:
        Return left_is_constant
    
    Return left_is_constant and right_is_constant.unwrap()

Note: =====================================================================
Note: IR GENERATION FOR LOGICAL OPERATIONS
Note: =====================================================================

Process called "generate_logical_ir" that takes operator_symbol as String, left_operand as String, right_operand as Optional[String], left_type as String, right_type as Optional[String] returns String:
    Note: Generate intermediate representation for runtime logical evaluation
    
    Let resolution be resolve_logical_operator(operator_symbol, left_type, right_type)
    Let ir_instruction be ""
    
    If resolution.needs_type_conversion:
        Set ir_instruction to "CONVERT_TO_BOOLEAN " joined with left_type joined with "\\n"
    
    If resolution.short_circuit_possible:
        Set ir_instruction to ir_instruction joined with "SHORT_CIRCUIT_EVAL "
    
    Let operation_name be operator_symbol.to_uppercase()
    Set ir_instruction to ir_instruction joined with "CALL_LOGIC " joined with operation_name
    
    Return ir_instruction

Note: =====================================================================
Note: OPERATOR PRECEDENCE AND VALIDATION
Note: =====================================================================

Process called "get_logical_operator_precedence" that takes operator_symbol as String returns Integer:
    Note: Return the precedence level for a logical operator
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.symbol equals operator_symbol:
            Return op.precedence
    
    Return 0

Process called "is_logical_operator" that takes token as String returns Boolean:
    Note: Check if a token is a logical operator
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.symbol equals token or op.technical_form equals token:
            Return true
    
    Return false

Process called "validate_logical_context" that takes operator_symbol as String, left_type as String, right_type as Optional[String] returns Boolean:
    Note: Validate that logical operator is used in appropriate boolean context
    
    Note: Check if types can be converted to boolean
    Let convertible_types be List[String].from_array(["Boolean", "Bool", "Integer", "String", "Optional"])
    
    If not convertible_types.contains(left_type):
        Return false
    
    If right_type is not None:
        If not convertible_types.contains(right_type.unwrap()):
            Return false
    
    Return true

Process called "get_technical_form" that takes operator_symbol as String returns String:
    Note: Convert natural language logical operator to technical form
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.symbol equals operator_symbol:
            Return op.technical_form
    
    Return operator_symbol

Process called "get_natural_form" that takes technical_form as String returns String:
    Note: Convert technical logical operator to natural language form
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.technical_form equals technical_form:
            Return op.symbol
    
    Return technical_form

Note: =====================================================================
Note: SHORT-CIRCUIT EVALUATION SUPPORT
Note: =====================================================================

Process called "supports_short_circuit" that takes operator_symbol as String returns Boolean:
    Note: Check if operator supports short-circuit evaluation
    
    Let operators be get_logical_operators()
    For each op in operators:
        If op.symbol equals operator_symbol:
            Return op.short_circuits
    
    Return false

Process called "get_short_circuit_condition" that takes operator_symbol as String returns String:
    Note: Get the condition that triggers short-circuit evaluation
    
    If operator_symbol equals "and":
        Return "left_operand_false"
    
    If operator_symbol equals "or":
        Return "left_operand_true"
    
    Return "no_short_circuit"

Process called "generate_short_circuit_ir" that takes operator_symbol as String, left_operand as String, right_operand as String returns String:
    Note: Generate IR for short-circuit evaluation optimization
    
    If operator_symbol equals "and":
        Return "JUMP_IF_FALSE " joined with left_operand joined with " SKIP_" joined with right_operand
    
    If operator_symbol equals "or":
        Return "JUMP_IF_TRUE " joined with left_operand joined with " SKIP_" joined with right_operand
    
    Return "NO_SHORT_CIRCUIT"