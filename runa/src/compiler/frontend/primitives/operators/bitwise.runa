        Otherwise If char equals "7":
            Let digit_value be 7
        Otherwise If char equals "8":
            Let digit_value be 8
        Otherwise If char equals "9":
            Let digit_value be 9
        Otherwise:
            Let result.error_code be "invalid_target"
            Let result.error_message be "Invalid numeric character in target value"
            Return result
        
        Let target_value be target_value multiplied by 10 plus digit_value
    
    Note: Apply negative sign to target
    If is_target_negative:
        Let target_value be 0 minus target_value
    
