    If gray_input_value is less than 0:
        Let max_value be 1
        Loop with i from 0 to bit_width minus 1:
            Let max_value be max_value multiplied by 2
        Let gray_input_value be gray_input_value plus max_value
    
    Note: Convert Gray code to binary using iterative XOR
    Note: Binary[MSB] = Gray[MSB], Binary[i] = Binary[i+1] XOR Gray[i] for other bits
    Let binary_value be 0
    Let previous_binary_bit be 0
    
    Note: Process bits from MSB to LSB
    Loop with bit_pos from bit_width minus 1 down to 0:
        Note: Calculate divisor for current Gray bit position (2^bit_pos)
        Let gray_divisor be 1
        Loop with j from 0 to bit_pos minus 1:
            Let gray_divisor be gray_divisor multiplied by 2
        
        Note: Extract current Gray bit
        Let gray_quotient be gray_input_value divided by gray_divisor
        Let gray_bit be gray_quotient modulo 2
        
        Let binary_bit be gray_bit
        
        Note: For non-MSB bits, XOR with previous binary bit
        If bit_pos is less than bit_width minus 1:
            Note: XOR with previous binary bit (which is the next higher bit)
            If previous_binary_bit equals gray_bit:
                Let binary_bit be 0
            Otherwise:
                Let binary_bit be 1
        
        Note: Store this binary bit for next iteration
        Let previous_binary_bit be binary_bit
        
        Note: Add binary bit to result
        If binary_bit equals 1:
            Let bit_contribution be 1
            Loop with k from 0 to bit_pos minus 1:
                Let bit_contribution be bit_contribution multiplied by 2
            Let binary_value be binary_value plus bit_contribution
    
    Note: Convert result back to decimal string
    If binary_value equals 0:
        Let result.result_value be "0"
    Otherwise:
        Let temp_value be binary_value
        Let digit_stack be ""
        
