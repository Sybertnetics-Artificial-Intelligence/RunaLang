        Let char be character at index i in field_value
        Let digit_value be 0
        
        If char equals "0":
            Let digit_value be 0
        Otherwise If char equals "1":
            Let digit_value be 1
        Otherwise If char equals "2":
            Let digit_value be 2
        Otherwise If char equals "3":
            Let digit_value be 3
        Otherwise If char equals "4":
            Let digit_value be 4
        Otherwise If char equals "5":
            Let digit_value be 5
        Otherwise If char equals "6":
            Let digit_value be 6
        Otherwise If char equals "7":
            Let digit_value be 7
        Otherwise If char equals "8":
            Let digit_value be 8
        Otherwise If char equals "9":
            Let digit_value be 9
        Otherwise:
            Let result.error_code be "invalid_field_value"
            Let result.error_message be "Invalid numeric character in field value"
            Return result
        
        Let field_int_value be field_int_value multiplied by 10 plus digit_value
    
    Note: Apply negative sign to field value
    If is_field_negative:
        Let field_int_value be 0 minus field_int_value
    
    Note: Get bit width from target type
    Let bit_width be 32
    If target_type contains "8":
        Let bit_width be 8
    Otherwise If target_type contains "16":
        Let bit_width be 16  
    Otherwise If target_type contains "32":
        Let bit_width be 32
    Otherwise If target_type contains "64":
        Let bit_width be 64
    
    Note: Validate parameters
    If start_bit is less than 0 Or start_bit is greater than or equal to bit_width:
        Let result.error_code be "invalid_start_bit"
        Let result.error_message be "Start bit position out of range"
        Return result
    
    If bit_count is less than 1 Or bit_count is greater than bit_width:
        Let result.error_code be "invalid_bit_count"
        Let result.error_message be "Bit count out of valid range"
        Return result
    
    If start_bit plus bit_count is greater than bit_width:
        Let result.error_code be "field_exceeds_width"
        Let result.error_message be "Bit field exceeds target bit width"
        Return result
    
    Note: Validate field value fits in specified bit count
    Let max_field_value be 1
    Loop with i from 0 to bit_count minus 1:
        Let max_field_value be max_field_value multiplied by 2
    Let max_field_value be max_field_value minus 1
    
    If field_int_value is greater than max_field_value Or field_int_value is less than 0:
        Let result.error_code be "field_value_too_large"
        Let result.error_message be "Field value does not fit in specified bit count"
        Return result
    
    Note: Step 1: Clear the target bits where we'll insert the field
    Note: Create a mask with zeros in the insertion range and ones elsewhere
    Let clear_mask be 0
    
    Loop with bit_pos from 0 to bit_width minus 1:
        Note: Check if this bit is outside the insertion range
        If bit_pos is less than start_bit Or bit_pos is greater than or equal to start_bit plus bit_count:
            Note: Set this bit to 1 in the mask
            Let bit_contribution be 1
            Loop with j from 0 to bit_pos minus 1:
                Let bit_contribution be bit_contribution multiplied by 2
            Let clear_mask be clear_mask plus bit_contribution
    
    Note: Clear the target bits using AND operation
    Let cleared_target be 0
    
    Loop with bit_pos from 0 to bit_width minus 1:
        Note: Calculate divisor for this bit position (2^bit_pos)
        Let divisor be 1
        Loop with j from 0 to bit_pos minus 1:
            Let divisor be divisor multiplied by 2
        
        Note: Get bit from target value
        Let target_quotient be target_value divided by divisor
        Let target_bit be target_quotient modulo 2
        
        Note: Get bit from clear mask
        Let mask_quotient be clear_mask divided by divisor
        Let mask_bit be mask_quotient modulo 2
        
        Note: AND the bits (both must be 1 for result 1)
        Let result_bit be 0
        If target_bit equals 1 And mask_bit equals 1:
            Let result_bit be 1
        
        Note: Add result bit to cleared target
        If result_bit equals 1:
            Let bit_contribution be 1
            Loop with k from 0 to bit_pos minus 1:
                Let bit_contribution be bit_contribution multiplied by 2
            Let cleared_target be cleared_target plus bit_contribution
    
    Note: Step 2: Shift field value to correct position
    Let shift_multiplier be 1
    Loop with i from 0 to start_bit minus 1:
        Let shift_multiplier be shift_multiplier multiplied by 2
    Let shifted_field be field_int_value multiplied by shift_multiplier
    
    Note: Step 3: OR the cleared target with shifted field value
    Let final_result be 0
    
    Loop with bit_pos from 0 to bit_width minus 1:
        Note: Calculate divisor for this bit position (2^bit_pos)
        Let divisor be 1
        Loop with j from 0 to bit_pos minus 1:
            Let divisor be divisor multiplied by 2
        
        Note: Get bit from cleared target
        Let cleared_quotient be cleared_target divided by divisor
        Let cleared_bit be cleared_quotient modulo 2
        
        Note: Get bit from shifted field
        Let field_quotient be shifted_field divided by divisor
        Let field_bit be field_quotient modulo 2
        
        Note: OR the bits (either bit being 1 makes result 1)
        Let result_bit be 0
        If cleared_bit equals 1 Or field_bit equals 1:
            Let result_bit be 1
        
        Note: Add result bit to final result
        If result_bit equals 1:
            Let bit_contribution be 1
            Loop with k from 0 to bit_pos minus 1:
                Let bit_contribution be bit_contribution multiplied by 2
            Let final_result be final_result plus bit_contribution
    
    Note: Convert result back to decimal string
    If final_result equals 0:
        Let result.result_value be "0"
    Otherwise:
        Let temp_value be final_result
        Let digit_stack be ""
        
        Loop while temp_value is greater than 0:
            Let remainder be temp_value modulo 10
            Let digit_char be "0"
            
            If remainder equals 0:
                Let digit_char be "0"
            Otherwise If remainder equals 1:
                Let digit_char be "1"
            Otherwise If remainder equals 2:
                Let digit_char be "2"
            Otherwise If remainder equals 3:
                Let digit_char be "3"
            Otherwise If remainder equals 4:
                Let digit_char be "4"
            Otherwise If remainder equals 5:
                Let digit_char be "5"
            Otherwise If remainder equals 6:
                Let digit_char be "6"
            Otherwise If remainder equals 7:
                Let digit_char be "7"
            Otherwise If remainder equals 8:
                Let digit_char be "8"
            Otherwise If remainder equals 9:
                Let digit_char be "9"
            
            Let digit_stack be digit_char concatenated with digit_stack
            Let temp_value be temp_value divided by 10
        
        Let result.result_value be digit_stack
    
    Note: Set result metadata
    Let result.result_type be target_type
    Let result.bit_width be bit_width
    Let result.is_valid be true
    Let result.operations_performed be 1
    Return result

