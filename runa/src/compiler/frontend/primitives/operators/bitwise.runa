                Let temp_value be temp_value divided by 10
            
            Let result.result_value be "-" concatenated with digit_stack
        Otherwise:
            Note: Handle positive numbers
            Let temp_value be not_result
            Let digit_stack be ""
            
            Loop while temp_value is greater than 0:
                Let remainder be temp_value modulo 10
                Let digit_char be "0"
                
                If remainder equals 0:
