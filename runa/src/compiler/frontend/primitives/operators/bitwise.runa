        Otherwise If char equals "8":
            Let digit_value be 8
        Otherwise If char equals "9":
            Let digit_value be 9
        Otherwise:
            Let result.error_code be "invalid_number"
            Let result.error_message be "Invalid numeric character in Gray code value"
            Return result
        
        Let gray_input_value be gray_input_value multiplied by 10 plus digit_value
    
    Note: Apply negative sign
    If is_negative:
        Let gray_input_value be 0 minus gray_input_value
    
