    Let shift_result be input_value multiplied by shift_multiplier
    
    Note: Check for overflow by examining if any bits were lost
    Let max_value_for_width be 1
    Loop with i from 0 to bit_width minus 1:
        Let max_value_for_width be max_value_for_width multiplied by 2
    Let max_value_for_width be max_value_for_width minus 1
    
    If shift_result is greater than max_value_for_width:
        Let result.overflow_occurred be true
        Note: Truncate to fit within bit width
        Let shift_result be shift_result modulo (max_value_for_width plus 1)
    
    Note: Count affected bits (those that moved)
    Let bits_moved be 0
    Let temp_value be input_value
    
    Loop while temp_value is greater than 0:
        Let bits_moved be bits_moved plus 1
        Let temp_value be temp_value divided by 2
    
    Note: All existing bits are affected by the shift
    Let result.bits_affected be bits_moved
    
    Note: Format output based on output_format
    If output_format equals "decimal":
        Let result.result_value be ""
        
