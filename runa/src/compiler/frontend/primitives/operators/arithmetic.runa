Note:
compiler/frontend/primitives/operators/arithmetic.runa
Arithmetic Operator Compiler Integration Layer

This module maps arithmetic operator tokens from the parser to the appropriate
functions in math/core/operations. It handles operator precedence, type resolution,
compile-time constant folding, and IR generation for arithmetic expressions.

Key responsibilities:
- Map operator tokens (+, -, *, /, %, **) to math library functions
- Resolve operator overloading based on operand types
- Perform compile-time evaluation of constant expressions
- Generate IR/bytecode for runtime arithmetic evaluation
- Handle operator precedence and associativity
- Support both mathematical symbols and natural language operators
- Validate mathematical symbol usage in appropriate contexts
:End Note

Import "math/core/operations" as MathOps
Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: OPERATOR TOKEN DEFINITIONS
Note: =====================================================================

Type called "OperatorToken":
    symbol as String                    Note: +, -, *, /, %, **
    natural_form as String              Note: plus, minus, multiplied by, etc.
    precedence as Integer               Note: Operator precedence level
    associativity as String             Note: left, right
    arity as Integer                    Note: 1 for unary, 2 for binary
    is_mathematical as Boolean          Note: Requires numeric operands

Type called "OperatorMapping":
    token as OperatorToken
    target_function as String           Note: Function name in math/core/operations
    module_path as String              Note: Module containing the function
    requires_precision as Boolean       Note: Whether precision parameter is needed
    compile_time_evaluable as Boolean  Note: Can be evaluated at compile time

Type called "OperatorResolution":
    operator as OperatorToken
    left_type as String
    right_type as Optional[String]      Note: None for unary operators
    resolved_function as String
    needs_type_promotion as Boolean
    target_precision as Integer

Note: =====================================================================
Note: OPERATOR TOKEN REGISTRY
Note: =====================================================================

Process called "get_arithmetic_operators" returns List[OperatorToken]:
    Note: Return all arithmetic operator tokens with their properties
    
    Let operators be List[OperatorToken].new()
    
    Note: Addition operator
    Let plus_op be OperatorToken.new()
    Set plus_op.symbol to "+"
    Set plus_op.natural_form to "plus"
    Set plus_op.precedence to 4
    Set plus_op.associativity to "left"
    Set plus_op.arity to 2
    Set plus_op.is_mathematical to true
    operators.append(plus_op)
    
    Note: Subtraction operator (binary)
    Let minus_op be OperatorToken.new()
    Set minus_op.symbol to "-"
    Set minus_op.natural_form to "minus"
    Set minus_op.precedence to 4
    Set minus_op.associativity to "left"
    Set minus_op.arity to 2
    Set minus_op.is_mathematical to true
    operators.append(minus_op)
    
    Note: Multiplication operator
    Let multiply_op be OperatorToken.new()
    Set multiply_op.symbol to "*"
    Set multiply_op.natural_form to "multiplied by"
    Set multiply_op.precedence to 5
    Set multiply_op.associativity to "left"
    Set multiply_op.arity to 2
    Set multiply_op.is_mathematical to true
    operators.append(multiply_op)
    
    Note: Division operator
    Let divide_op be OperatorToken.new()
    Set divide_op.symbol to "/"
    Set divide_op.natural_form to "divided by"
    Set divide_op.precedence to 5
    Set divide_op.associativity to "left"
    Set divide_op.arity to 2
    Set divide_op.is_mathematical to true
    operators.append(divide_op)
    
    Note: Modulo operator
    Let modulo_op be OperatorToken.new()
    Set modulo_op.symbol to "%"
    Set modulo_op.natural_form to "modulo"
    Set modulo_op.precedence to 5
    Set modulo_op.associativity to "left"
    Set modulo_op.arity to 2
    Set modulo_op.is_mathematical to true
    operators.append(modulo_op)
    
    Note: Power operator
    Let power_op be OperatorToken.new()
    Set power_op.symbol to "**"
    Set power_op.natural_form to "to the power of"
    Set power_op.precedence to 6
    Set power_op.associativity to "right"
    Set power_op.arity to 2
    Set power_op.is_mathematical to true
    operators.append(power_op)
    
    Note: Unary negation
    Let negate_op be OperatorToken.new()
    Set negate_op.symbol to "-"
    Set negate_op.natural_form to "negative"
    Set negate_op.precedence to 7
    Set negate_op.associativity to "right"
    Set negate_op.arity to 1
    Set negate_op.is_mathematical to true
    operators.append(negate_op)
    
    Return operators

Note: =====================================================================
Note: OPERATOR MAPPING TO MATH LIBRARY
Note: =====================================================================

Process called "map_operator_to_function" that takes operator_symbol as String, arity as Integer returns OperatorMapping:
    Note: Map an operator symbol to its corresponding math library function
    
    Let mapping be OperatorMapping.new()
    Let token be find_operator_token(operator_symbol, arity)
    Set mapping.token to token
    Set mapping.module_path to "math/core/operations"
    Set mapping.compile_time_evaluable to true
    
    If operator_symbol equals "+" and arity equals 2:
        Set mapping.target_function to "add"
        Set mapping.requires_precision to true
    Otherwise:
        If operator_symbol equals "-" and arity equals 2:
            Set mapping.target_function to "subtract"
            Set mapping.requires_precision to true
        Otherwise:
            If operator_symbol equals "-" and arity equals 1:
                Set mapping.target_function to "negate"
                Set mapping.requires_precision to false
            Otherwise:
                If operator_symbol equals "*":
                    Set mapping.target_function to "multiply"
                    Set mapping.requires_precision to true
                Otherwise:
                    If operator_symbol equals "/":
                        Set mapping.target_function to "divide"
                        Set mapping.requires_precision to true
                    Otherwise:
                        If operator_symbol equals "%":
                            Set mapping.target_function to "modulo"
                            Set mapping.requires_precision to false
                        Otherwise:
                            If operator_symbol equals "**":
                                Set mapping.target_function to "power"
                                Set mapping.requires_precision to true
                            Otherwise:
                                Throw Errors.InvalidOperation with "Unknown arithmetic operator"
    
    Return mapping

Process called "find_operator_token" that takes symbol as String, arity as Integer returns OperatorToken:
    Note: Find operator token by symbol and arity
    
    Let operators be get_arithmetic_operators()
    For each op in operators:
        If op.symbol equals symbol and op.arity equals arity:
            Return op
    
    Throw Errors.NotFound with "Operator token not found"

Note: =====================================================================
Note: OPERATOR RESOLUTION AND TYPE CHECKING
Note: =====================================================================

Process called "resolve_arithmetic_operator" that takes operator_symbol as String, left_type as String, right_type as Optional[String] returns OperatorResolution:
    Note: Resolve which function to call based on operator and operand types
    
    Let resolution be OperatorResolution.new()
    Let arity be 2
    If right_type is None:
        Let arity be 1
    
    Let mapping be map_operator_to_function(operator_symbol, arity)
    Set resolution.operator to mapping.token
    Set resolution.left_type to left_type
    Set resolution.right_type to right_type
    Set resolution.resolved_function to mapping.target_function
    
    Note: Check if types need promotion
    If right_type is not None:
        If left_type equals "Integer" and right_type.unwrap() equals "Float":
            Set resolution.needs_type_promotion to true
            Set resolution.target_precision to 15
        Otherwise:
            If left_type equals "Float" and right_type.unwrap() equals "Integer":
                Set resolution.needs_type_promotion to true
                Set resolution.target_precision to 15
            Otherwise:
                Set resolution.needs_type_promotion to false
                Set resolution.target_precision to 20
    Otherwise:
        Set resolution.needs_type_promotion to false
        Set resolution.target_precision to 20
    
    Return resolution

Note: =====================================================================
Note: COMPILE-TIME CONSTANT FOLDING
Note: =====================================================================

Process called "evaluate_constant_arithmetic" that takes operator_symbol as String, left_value as String, right_value as Optional[String], left_type as String, right_type as Optional[String] returns String:
    Note: Evaluate arithmetic expression at compile time if both operands are constants
    
    Let resolution be resolve_arithmetic_operator(operator_symbol, left_type, right_type)
    Let precision be resolution.target_precision
    
    If operator_symbol equals "+":
        Let result be MathOps.add(left_value, right_value.unwrap(), precision)
        Return result.result_value
    
    If operator_symbol equals "-":
        If right_value is not None:
            Let result be MathOps.subtract(left_value, right_value.unwrap(), precision)
            Return result.result_value
        Otherwise:
            Let result be MathOps.negate(left_value)
            Return result.result_value
    
    If operator_symbol equals "*":
        Let result be MathOps.multiply(left_value, right_value.unwrap(), precision)
        Return result.result_value
    
    If operator_symbol equals "/":
        Let result be MathOps.divide(left_value, right_value.unwrap(), precision)
        Return result.result_value
    
    If operator_symbol equals "%":
        Let result be MathOps.modulo(left_value, right_value.unwrap())
        Return result.remainder
    
    If operator_symbol equals "**":
        Let result be MathOps.power(left_value, right_value.unwrap(), precision)
        Return result.result_value
    
    Throw Errors.InvalidOperation with "Unknown operator for constant folding"

Process called "can_fold_arithmetic_expression" that takes left_is_constant as Boolean, right_is_constant as Optional[Boolean] returns Boolean:
    Note: Check if an arithmetic expression can be evaluated at compile time
    
    If right_is_constant is None:
        Return left_is_constant
    
    Return left_is_constant and right_is_constant.unwrap()

Note: =====================================================================
Note: IR GENERATION FOR ARITHMETIC
Note: =====================================================================

Process called "generate_arithmetic_ir" that takes operator_symbol as String, left_operand as String, right_operand as Optional[String], left_type as String, right_type as Optional[String] returns String:
    Note: Generate intermediate representation for runtime arithmetic evaluation
    
    Let resolution be resolve_arithmetic_operator(operator_symbol, left_type, right_type)
    Let ir_instruction be ""
    
    If resolution.needs_type_promotion:
        Set ir_instruction to "PROMOTE " joined with left_type joined with " TO Float\n"
    
    Let operation_name be resolution.resolved_function.to_uppercase()
    Set ir_instruction to ir_instruction joined with "CALL_MATH " joined with operation_name
    
    If resolution.target_precision > 0:
        Set ir_instruction to ir_instruction joined with " PRECISION=" joined with resolution.target_precision.to_string()
    
    Return ir_instruction

Note: =====================================================================
Note: OPERATOR PRECEDENCE AND VALIDATION
Note: =====================================================================

Process called "get_operator_precedence" that takes operator_symbol as String returns Integer:
    Note: Return the precedence level for an arithmetic operator
    
    Let operators be get_arithmetic_operators()
    For each op in operators:
        If op.symbol equals operator_symbol:
            Return op.precedence
    
    Return 0

Process called "is_arithmetic_operator" that takes token as String returns Boolean:
    Note: Check if a token is an arithmetic operator
    
    Let operators be get_arithmetic_operators()
    For each op in operators:
        If op.symbol equals token or op.natural_form equals token:
            Return true
    
    Return false

Process called "validate_arithmetic_context" that takes operator_symbol as String, left_type as String, right_type as Optional[String] returns Boolean:
    Note: Validate that operator is used in appropriate mathematical context
    
    Note: Check if types are numeric
    Let valid_types be List[String].from_array(["Integer", "Float", "Decimal", "BigInteger", "BigDecimal"])
    
    If not valid_types.contains(left_type):
        Return false
    
    If right_type is not None:
        If not valid_types.contains(right_type.unwrap()):
            Return false
    
    Return true

Process called "get_natural_language_form" that takes operator_symbol as String returns String:
    Note: Convert mathematical symbol to natural language equivalent
    
    Let operators be get_arithmetic_operators()
    For each op in operators:
        If op.symbol equals operator_symbol:
            Return op.natural_form
    
    Return operator_symbol

Process called "get_mathematical_symbol" that takes natural_form as String returns String:
    Note: Convert natural language operator to mathematical symbol
    
    Let operators be get_arithmetic_operators()
    For each op in operators:
        If op.natural_form equals natural_form:
            Return op.symbol
    
    Return natural_form