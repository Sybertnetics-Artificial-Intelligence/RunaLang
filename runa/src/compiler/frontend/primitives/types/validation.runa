Process called "validate_list" that takes value as List[String], element_validator as String, constraints as Optional[Dictionary[String, String]] returns ValidationResult:
    Note: Validate list elements and overall list constraints
    Note: Element validator specifies validation rule for each element
    Note: Constraints include min/max size, uniqueness, ordering
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as "List[" concatenated with length of value concatenated with " elements]"
    
    Note: Parse constraints if provided
    Let min_size be 0
    Let max_size be 2147483647
    Let require_unique as false
    Let require_sorted as false
    
    If constraints is not null:
        Note: Extract minimum size constraint
        If "min_size" is in constraints:
            Let min_size_str be get value "min_size" from constraints
            Note: Parse integer from string
            Let parsed_min be 0
            Let parse_success be true
            
            Loop with i from 0 to length of min_size_str minus 1:
                Let digit_char be character at position i in min_size_str
                If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                    Let digit_value be 0
                    If digit_char equals "0":
                        Let digit_value be 0
                    Otherwise If digit_char equals "1":
                        Let digit_value be 1
                    Otherwise If digit_char equals "2":
                        Let digit_value be 2
                    Otherwise If digit_char equals "3":
                        Let digit_value be 3
                    Otherwise If digit_char equals "4":
                        Let digit_value be 4
                    Otherwise If digit_char equals "5":
                        Let digit_value be 5
                    Otherwise If digit_char equals "6":
                        Let digit_value be 6
                    Otherwise If digit_char equals "7":
                        Let digit_value be 7
                    Otherwise If digit_char equals "8":
                        Let digit_value be 8
                    Otherwise If digit_char equals "9":
                        Let digit_value be 9
                    
                    Let parsed_min be parsed_min multiplied by 10 plus digit_value
                Otherwise:
                    Let parse_success be false
                    Break
            
            If parse_success:
                Let min_size be parsed_min
        
        Note: Extract maximum size constraint
        If "max_size" is in constraints:
            Let max_size_str be get value "max_size" from constraints
            Note: Parse integer from string
            Let parsed_max be 0
            Let parse_success be true
            
            Loop with i from 0 to length of max_size_str minus 1:
                Let digit_char be character at position i in max_size_str
                If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                    Let digit_value be 0
                    If digit_char equals "0":
                        Let digit_value be 0
                    Otherwise If digit_char equals "1":
                        Let digit_value be 1
                    Otherwise If digit_char equals "2":
                        Let digit_value be 2
                    Otherwise If digit_char equals "3":
                        Let digit_value be 3
                    Otherwise If digit_char equals "4":
                        Let digit_value be 4
                    Otherwise If digit_char equals "5":
                        Let digit_value be 5
                    Otherwise If digit_char equals "6":
                        Let digit_value be 6
                    Otherwise If digit_char equals "7":
                        Let digit_value be 7
                    Otherwise If digit_char equals "8":
                        Let digit_value be 8
                    Otherwise If digit_char equals "9":
                        Let digit_value be 9
                    
                    Let parsed_max be parsed_max multiplied by 10 plus digit_value
                Otherwise:
                    Let parse_success be false
                    Break
            
            If parse_success:
                Let max_size be parsed_max
        
        Note: Extract uniqueness constraint
        If "unique" is in constraints:
            Let unique_str be get value "unique" from constraints
            If unique_str equals "true" Or unique_str equals "True" Or unique_str equals "TRUE" Or unique_str equals "1" Or unique_str equals "yes":
                Let require_unique be true
        
        Note: Extract sorting constraint
        If "sorted" is in constraints:
            Let sorted_str be get value "sorted" from constraints
            If sorted_str equals "true" Or sorted_str equals "True" Or sorted_str equals "TRUE" Or sorted_str equals "1" Or sorted_str equals "yes":
                Let require_sorted be true
    
    Note: Validate list size constraints
    Let list_size be length of value
    
    If list_size is less than min_size:
        Let result.error_code be "LIST_TOO_SMALL"
        Let result.error_message be "List size " concatenated with list_size concatenated with " is less than minimum required size " concatenated with min_size
        Let result.expected_value be "List with at least " concatenated with min_size concatenated with " elements"
        Return result
    
    If list_size is greater than max_size:
        Let result.error_code be "LIST_TOO_LARGE"
        Let result.error_message be "List size " concatenated with list_size concatenated with " exceeds maximum allowed size " concatenated with max_size
        Let result.expected_value be "List with at most " concatenated with max_size concatenated with " elements"
        Return result
    
    Note: Validate each element using the specified validator
    Loop with i from 0 to list_size minus 1:
        Let element be element at position i in value
        Let element_result be null
        
        Note: Apply appropriate validation based on validator type
        If element_validator equals "integer":
            Let element_result be validate_integer with element, null, null
        Otherwise If element_validator equals "float":
            Let element_result be validate_float with element, null, null
        Otherwise If element_validator equals "boolean":
            Let element_result be validate_boolean with element, null
        Otherwise If element_validator equals "character":
            Let element_result be validate_character with element, null
        Otherwise If element_validator equals "string":
            Let element_result be validate_string_length with element, null, null
        Otherwise If element_validator equals "identifier":
            Let element_result be validate_identifier with element, null
        Otherwise:
            Note: Default to string validation
            Let element_result be validate_string_length with element, null, null
        
        If not element_result.is_valid:
            Let result.error_code be "INVALID_LIST_ELEMENT"
            Let result.error_message be "Element at position " concatenated with i concatenated with " failed validation: " concatenated with element_result.error_message
            Let result.expected_value be "All elements must be valid " concatenated with element_validator concatenated with " values"
            Return result
    
    Note: Validate uniqueness constraint if required
    If require_unique:
        Loop with i from 0 to list_size minus 1:
            Let current_element be element at position i in value
            
            Note: Check against all subsequent elements
            Loop with j from i plus 1 to list_size minus 1:
                Let other_element be element at position j in value
                If current_element equals other_element:
                    Let result.error_code be "DUPLICATE_LIST_ELEMENT"
                    Let result.error_message be "Duplicate element '" concatenated with current_element concatenated with "' found at positions " concatenated with i concatenated with " and " concatenated with j
                    Let result.expected_value be "All list elements must be unique"
                    Return result
    
    Note: Validate sorting constraint if required
    If require_sorted:
        Loop with i from 0 to list_size minus 2:
            Let current_element be element at position i in value
            Let next_element be element at position i plus 1 in value
            
            Note: Simple string comparison for sorting validation
            Let current_length be length of current_element
            Let next_length be length of next_element
            Let min_length be current_length
            If next_length is less than min_length:
                Let min_length be next_length
            
            Let comparison_result be 0
            Loop with k from 0 to min_length minus 1:
                Let current_char be character at position k in current_element
                Let next_char be character at position k in next_element
                
                Note: Get character codes for comparison
                Let current_code be get_character_code with current_char
                Let next_code be get_character_code with next_char
                
                If current_code is less than next_code:
                    Let comparison_result be -1
                    Break
                Otherwise If current_code is greater than next_code:
                    Let comparison_result be 1
                    Break
            
            Note: If all compared characters are equal, compare lengths
            If comparison_result equals 0:
                If current_length is greater than next_length:
                    Let comparison_result be 1
                Otherwise If current_length is less than next_length:
                    Let comparison_result be -1
            
            Note: Check if current element comes after next element (not sorted)
            If comparison_result is greater than 0:
                Let result.error_code be "LIST_NOT_SORTED"
                Let result.error_message be "List is not sorted: element '" concatenated with current_element concatenated with "' at position " concatenated with i concatenated with " comes after '" concatenated with next_element concatenated with "' at position " concatenated with i plus 1
                Let result.expected_value be "List elements must be in ascending order"
                Return result
    
    Note: All validations passed
    Let result.is_valid be true
    Return result

Process called "validate_dictionary" that takes value as Dictionary[String, String], key_validator as Optional[String], value_validator as Optional[String] returns ValidationResult:
    Note: Validate dictionary keys and values
    Note: Applies validation rules to all keys and values
    Note: Supports required keys, optional keys, and forbidden keys
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as "Dictionary[" concatenated with size of value concatenated with " entries]"
    
    Note: Set default validators if not provided
    Let effective_key_validator be "string"
    Let effective_value_validator be "string"
    
    If key_validator is not null:
        Let effective_key_validator be key_validator
    
    If value_validator is not null:
        Let effective_value_validator be value_validator
    
    Note: Get dictionary size for validation
    Let dict_size be size of value
    
    Note: Validate each key-value pair
    Loop for each key, value_str in value:
        Note: Validate key using specified validator
        Let key_result be null
        
        If effective_key_validator equals "integer":
            Let key_result be validate_integer with key, null, null
        Otherwise If effective_key_validator equals "float":
            Let key_result be validate_float with key, null, null
        Otherwise If effective_key_validator equals "boolean":
            Let key_result be validate_boolean with key, null
        Otherwise If effective_key_validator equals "character":
            Let key_result be validate_character with key, null
        Otherwise If effective_key_validator equals "identifier":
            Let key_result be validate_identifier with key, null
        Otherwise If effective_key_validator equals "string":
            Let key_result be validate_string_length with key, null, null
        Otherwise:
            Note: Default to string validation for unknown validators
            Let key_result be validate_string_length with key, null, null
        
        If not key_result.is_valid:
            Let result.error_code be "INVALID_DICTIONARY_KEY"
            Let result.error_message be "Dictionary key '" concatenated with key concatenated with "' failed validation: " concatenated with key_result.error_message
            Let result.expected_value be "All keys must be valid " concatenated with effective_key_validator concatenated with " values"
            Return result
        
        Note: Validate value using specified validator
        Let value_result be null
        
        If effective_value_validator equals "integer":
            Let value_result be validate_integer with value_str, null, null
        Otherwise If effective_value_validator equals "float":
            Let value_result be validate_float with value_str, null, null
        Otherwise If effective_value_validator equals "boolean":
            Let value_result be validate_boolean with value_str, null
        Otherwise If effective_value_validator equals "character":
            Let value_result be validate_character with value_str, null
        Otherwise If effective_value_validator equals "identifier":
            Let value_result be validate_identifier with value_str, null
        Otherwise If effective_value_validator equals "string":
            Let value_result be validate_string_length with value_str, null, null
        Otherwise:
            Note: Default to string validation for unknown validators
            Let value_result be validate_string_length with value_str, null, null
        
        If not value_result.is_valid:
            Let result.error_code be "INVALID_DICTIONARY_VALUE"
            Let result.error_message be "Dictionary value for key '" concatenated with key concatenated with "' failed validation: " concatenated with value_result.error_message
            Let result.expected_value be "All values must be valid " concatenated with effective_value_validator concatenated with " values"
            Return result
    
    Note: All key-value pairs are valid
    Let result.is_valid be true
    Return result

Note: =====================================================================
Note: COMPOSITE VALIDATION OPERATIONS
Note: =====================================================================

Process called "validate_with_rules" that takes value as String, rules as List[ValidationRule], context as Optional[ValidationContext] returns List[ValidationResult]:
    Note: Apply multiple validation rules to a single value
    Note: Returns all validation results (failures and successes)
    Note: Context provides additional information for complex validations
    
    Let results be empty List[ValidationResult]
    Let rules_count be length of rules
    
    Note: Return empty results if no rules provided
    If rules_count equals 0:
        Let empty_result be ValidationResult with:
            is_valid as false
            error_code as "NO_RULES"
            error_message as "No validation rules provided"
            field_name as null
            expected_value as null
            actual_value as value
        Let results be add empty_result to results
        Return results
    
    Note: Get validation mode from context (default to strict)
    Let validation_mode be "strict"
    Let field_path be ""
    
    If context is not null:
        Let validation_mode be context.validation_mode
        
        Note: Build field path string from path list
        If length of context.field_path is greater than 0:
            Loop with i from 0 to length of context.field_path minus 1:
                Let path_segment be element at position i in context.field_path
                If i is greater than 0:
                    Let field_path be field_path concatenated with "."
                Let field_path be field_path concatenated with path_segment
    
    Note: Apply each validation rule
    Loop with rule_index from 0 to rules_count minus 1:
        Let rule be element at position rule_index in rules
        Let rule_result be ValidationResult with:
            is_valid as false
            error_code as null
            error_message as null
            field_name as null
            expected_value as null
            actual_value as value
        
        Note: Set field name from context if available
        If length of field_path is greater than 0:
            Let rule_result.field_name be field_path
        
        Note: Check if rule is required and value is empty
        Let is_empty_value be false
        If value equals "" Or value equals null:
            Let is_empty_value be true
        
        Note: Skip optional rules for empty values in lenient mode
        If is_empty_value And not rule.is_required And validation_mode equals "lenient":
            Let rule_result.is_valid be true
            Let results be add rule_result to results
            Continue
        
        Note: Apply rule based on rule type
        If rule.rule_type equals "required":
            Note: Required rule - check for non-empty value
            If not is_empty_value:
                Let rule_result.is_valid be true
            Otherwise:
                Let rule_result.error_code be "REQUIRED_VALUE_MISSING"
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be "Non-empty value"
        
        Otherwise If rule.rule_type equals "type":
            Note: Type validation rule
            Let expected_type be "string"
            If "type" is in rule.parameters:
                Let expected_type be get value "type" from rule.parameters
            
            Let type_validation_result be null
            
            If expected_type equals "integer":
                Let type_validation_result be validate_integer with value, null, null
            Otherwise If expected_type equals "float":
                Let type_validation_result be validate_float with value, null, null
            Otherwise If expected_type equals "boolean":
                Let type_validation_result be validate_boolean with value, null
            Otherwise If expected_type equals "character":
                Let type_validation_result be validate_character with value, null
            Otherwise If expected_type equals "identifier":
                Let type_validation_result be validate_identifier with value, null
            Otherwise:
                Let type_validation_result be validate_string_length with value, null, null
            
            Let rule_result.is_valid be type_validation_result.is_valid
            If not rule_result.is_valid:
                Let rule_result.error_code be type_validation_result.error_code
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be "Valid " concatenated with expected_type concatenated with " value"
        
        Otherwise If rule.rule_type equals "range":
            Note: Range validation rule for numeric types
            Let min_value be null
            Let max_value be null
            
            If "min_value" is in rule.parameters:
                Let min_str be get value "min_value" from rule.parameters
                Note: Parse integer from min_value string
                Let parsed_min be 0
                Loop with i from 0 to length of min_str minus 1:
                    Let digit_char be character at position i in min_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_min be parsed_min multiplied by 10 plus digit_value
                Let min_value be parsed_min
            
            If "max_value" is in rule.parameters:
                Let max_str be get value "max_value" from rule.parameters
                Note: Parse integer from max_value string
                Let parsed_max be 0
                Loop with i from 0 to length of max_str minus 1:
                    Let digit_char be character at position i in max_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_max be parsed_max multiplied by 10 plus digit_value
                Let max_value be parsed_max
            
            Note: Validate value is integer first, then check range
            Let int_validation_result be validate_integer with value, min_value, max_value
            Let rule_result.is_valid be int_validation_result.is_valid
            If not rule_result.is_valid:
                Let rule_result.error_code be int_validation_result.error_code
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be int_validation_result.expected_value
        
        Otherwise If rule.rule_type equals "length":
            Note: Length validation rule for strings
            Let min_length be null
            Let max_length be null
            
            If "min_length" is in rule.parameters:
                Let min_str be get value "min_length" from rule.parameters
                Let parsed_min be 0
                Loop with i from 0 to length of min_str minus 1:
                    Let digit_char be character at position i in min_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_min be parsed_min multiplied by 10 plus digit_value
                Let min_length be parsed_min
            
            If "max_length" is in rule.parameters:
                Let max_str be get value "max_length" from rule.parameters
                Let parsed_max be 0
                Loop with i from 0 to length of max_str minus 1:
                    Let digit_char be character at position i in max_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_max be parsed_max multiplied by 10 plus digit_value
                Let max_length be parsed_max
            
            Let length_validation_result be validate_string_length with value, min_length, max_length
            Let rule_result.is_valid be length_validation_result.is_valid
            If not rule_result.is_valid:
                Let rule_result.error_code be length_validation_result.error_code
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be length_validation_result.expected_value
        
        Otherwise If rule.rule_type equals "format":
            Note: Format validation rule
            Let format_type be "string"
            If "format_type" is in rule.parameters:
                Let format_type be get value "format_type" from rule.parameters
            
            Let format_validation_result be null
            
            If format_type equals "identifier":
                Let format_validation_result be validate_identifier with value, null
            Otherwise If format_type equals "integer":
                Let format_validation_result be validate_integer with value, null, null
            Otherwise If format_type equals "float":
                Let format_validation_result be validate_float with value, null, null
            Otherwise If format_type equals "boolean":
                Let format_validation_result be validate_boolean with value, null
            Otherwise If format_type equals "character":
                Let format_validation_result be validate_character with value, null
            Otherwise:
                Let format_validation_result be validate_string_length with value, null, null
            
            Let rule_result.is_valid be format_validation_result.is_valid
            If not rule_result.is_valid:
                Let rule_result.error_code be format_validation_result.error_code
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be "Valid " concatenated with format_type concatenated with " format"
        
        Otherwise If rule.rule_type equals "pattern":
            Note: Pattern validation rule - enhanced implementation
            Let pattern be ".*"
            Let pattern_type be "literal"
            
            If "pattern" is in rule.parameters:
                Let pattern be get value "pattern" from rule.parameters
            
            If "pattern_type" is in rule.parameters:
                Let pattern_type be get value "pattern_type" from rule.parameters
            
            Note: Support different pattern types
            If pattern equals ".*" Or pattern equals "*":
                Note: Wildcard pattern matches everything
                Let rule_result.is_valid be true
            Otherwise If pattern_type equals "wildcard":
                Note: Simple wildcard pattern matching (* and ?)
                Let pattern_valid be validate_wildcard_pattern with value, pattern
                Let rule_result.is_valid be pattern_valid
            Otherwise If pattern_type equals "prefix":
                Note: Check if value starts with pattern
                Let pattern_valid be false
                Let pattern_length be length of pattern
                Let value_length be length of value
                
                If pattern_length is less than or equal to value_length:
                    Let prefix_match be true
                    Loop with i from 0 to pattern_length minus 1:
                        Let value_char be character at position i in value
                        Let pattern_char be character at position i in pattern
                        If not (value_char equals pattern_char):
                            Let prefix_match be false
                            Break
                    Let pattern_valid be prefix_match
                
                Let rule_result.is_valid be pattern_valid
            Otherwise If pattern_type equals "suffix":
                Note: Check if value ends with pattern
                Let pattern_valid be false
                Let pattern_length be length of pattern
                Let value_length be length of value
                
                If pattern_length is less than or equal to value_length:
                    Let start_pos be value_length minus pattern_length
                    Let suffix_match be true
                    Loop with i from 0 to pattern_length minus 1:
                        Let value_char be character at position start_pos plus i in value
                        Let pattern_char be character at position i in pattern
                        If not (value_char equals pattern_char):
                            Let suffix_match be false
                            Break
                    Let pattern_valid be suffix_match
                
                Let rule_result.is_valid be pattern_valid
            Otherwise If pattern_type equals "exact":
                Note: Exact string matching
                Let rule_result.is_valid be (value equals pattern)
            Otherwise If pattern_type equals "contains":
                Note: Check if value contains pattern as substring
                Let pattern_found be false
                Let value_length be length of value
                Let pattern_length be length of pattern
                
                If pattern_length is less than or equal to value_length:
                    Loop with i from 0 to value_length minus pattern_length:
                        Let substring_match be true
                        Loop with j from 0 to pattern_length minus 1:
                            Let value_char be character at position i plus j in value
                            Let pattern_char be character at position j in pattern
                            If not (value_char equals pattern_char):
                                Let substring_match be false
                                Break
                        
                        If substring_match:
                            Let pattern_found be true
                            Break
                
                Let rule_result.is_valid be pattern_found
            Otherwise If pattern_type equals "format":
                Note: Format-based pattern matching
                If pattern equals "email":
                    Note: Basic email validation
                    Let has_at be false
                    Let has_dot_after_at be false
                    Let at_position be -1
                    
                    Loop with i from 0 to length of value minus 1:
                        Let char be character at position i in value
                        If char equals "@":
                            If has_at:
                                Note: Multiple @ symbols not allowed
                                Let rule_result.is_valid be false
                                Break
                            Let has_at be true
                            Let at_position be i
                        Otherwise If char equals "." And has_at And i is greater than at_position:
                            Let has_dot_after_at be true
                    
                    Let rule_result.is_valid be (has_at And has_dot_after_at And at_position is greater than 0 And at_position is less than length of value minus 2)
                Otherwise If pattern equals "phone":
                    Note: Basic phone number validation (digits, spaces, hyphens, parentheses)
                    Let phone_valid be true
                    Let digit_count be 0
                    
                    Loop with i from 0 to length of value minus 1:
                        Let char be character at position i in value
                        If char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9":
                            Let digit_count be digit_count plus 1
                        Otherwise If not (char equals " " Or char equals "-" Or char equals "(" Or char equals ")" Or char equals "+"):
                            Let phone_valid be false
                            Break
                    
                    Let rule_result.is_valid be (phone_valid And digit_count is greater than or equal to 7 And digit_count is less than or equal to 15)
                Otherwise If pattern equals "url":
                    Note: Basic URL validation (starts with http:// or https://)
                    Let url_valid be false
                    If length of value is greater than or equal to 7:
                        Let http_prefix be substring of value from 0 to 7
                        If http_prefix equals "http://":
                            Let url_valid be true
                        Otherwise If length of value is greater than or equal to 8:
                            Let https_prefix be substring of value from 0 to 8
                            If https_prefix equals "https://":
                                Let url_valid be true
                    
                    Let rule_result.is_valid be url_valid
                Otherwise If pattern equals "date":
                    Note: Basic date validation (YYYY-MM-DD format)
                    Let date_valid be false
                    If length of value equals 10:
                        Let char4 be character at position 4 in value
                        Let char7 be character at position 7 in value
                        If char4 equals "-" And char7 equals "-":
                            Let all_digits_valid be true
                            Note: Check year digits (0-3)
                            Loop with i from 0 to 3:
                                Let char be character at position i in value
                                If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                    Let all_digits_valid be false
                                    Break
                            Note: Check month digits (5-6)
                            If all_digits_valid:
                                Loop with i from 5 to 6:
                                    Let char be character at position i in value
                                    If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                        Let all_digits_valid be false
                                        Break
                            Note: Check day digits (8-9)
                            If all_digits_valid:
                                Loop with i from 8 to 9:
                                    Let char be character at position i in value
                                    If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                        Let all_digits_valid be false
                                        Break
                            Let date_valid be all_digits_valid
                    
                    Let rule_result.is_valid be date_valid
                Otherwise:
                    Note: Unknown format pattern
                    Let rule_result.is_valid be false
                    Let rule_result.error_code be "UNKNOWN_FORMAT_PATTERN"
                    Let rule_result.error_message be "Unknown format pattern: " concatenated with pattern
            Otherwise:
                Note: Default to literal pattern matching for unknown pattern types
                Let pattern_found be false
                Let value_length be length of value
                Let pattern_length be length of pattern
                
                If pattern_length is less than or equal to value_length:
                    Loop with i from 0 to value_length minus pattern_length:
                        Let substring_match be true
                        Loop with j from 0 to pattern_length minus 1:
                            Let value_char be character at position i plus j in value
                            Let pattern_char be character at position j in pattern
                            If not (value_char equals pattern_char):
                                Let substring_match be false
                                Break
                        
                        If substring_match:
                            Let pattern_found be true
                            Break
                
                Let rule_result.is_valid be pattern_found
            
            Note: Set error information for failed pattern validation
            If not rule_result.is_valid And rule_result.error_code is null:
                Let rule_result.error_code be "PATTERN_MISMATCH"
                Let rule_result.error_message be rule.error_message
                Let rule_result.expected_value be "Value matching " concatenated with pattern_type concatenated with " pattern: " concatenated with pattern
        
        Otherwise If rule.rule_type equals "custom":
            Note: Custom validation rule - evaluate custom validation logic
            Note: Parse and execute custom validation expressions
            Let custom_result be evaluate_custom_validation_rule(rule, target_value)
            Set rule_result.is_valid to custom_result.is_valid
            
            If not rule_result.is_valid:
                Set rule_result.error_code to "CUSTOM_VALIDATION_FAILED"
                Set rule_result.error_message to custom_result.error_message
                Set rule_result.expected_value to rule.expected_value
        
        Otherwise:
            Note: Unknown rule type
            Let rule_result.is_valid be false
            Let rule_result.error_code be "UNKNOWN_RULE_TYPE"
            Let rule_result.error_message be "Unknown validation rule type: " concatenated with rule.rule_type
            Let rule_result.expected_value be "Valid rule type (required, type, range, length, format, pattern, custom)"
        
        Note: Add result to results list
        Let results be add rule_result to results
        
        Note: In strict mode, stop on first failure
        If validation_mode equals "strict" And not rule_result.is_valid:
            Break
    
    Return results

Process called "evaluate_custom_validation_rule" that takes rule as ValidationRule, value as String returns ValidationResult:
    Note: Evaluate custom validation expressions
    Note: Supports basic expressions like "length > 5", "startsWith('test')", etc.
    
    Let result be ValidationResult
    Set result.is_valid to false
    Set result.error_code to null
    Set result.error_message to null
    Set result.field_name to null
    Set result.expected_value to null
    Set result.actual_value to value
    
    Note: Parse the custom validation expression from rule parameters
    Let expression be StringCore.dict_get(rule.parameters, "expression")
    If expression is null or expression equals "":
        Set result.error_message to "Custom validation rule missing expression parameter"
        Return result
    
    Note: Handle common validation expressions (simplified evaluation engine)
    If StringCore.contains(expression, "length >"):
        Let min_length_str be StringCore.substring_after(expression, "length > ")
        Let min_length be Parse min_length_str as Integer
        
        If Length(value) > min_length:
            Set result.is_valid to true
        Otherwise:
            Set result.error_message to "Value must be longer than " joined with String(min_length) joined with " characters"
    
    Otherwise If StringCore.contains(expression, "length <"):
        Let max_length_str be StringCore.substring_after(expression, "length < ")
        Let max_length be Parse max_length_str as Integer
        
        If Length(value) < max_length:
            Set result.is_valid to true
        Otherwise:
            Set result.error_message to "Value must be shorter than " joined with String(max_length) joined with " characters"
    
    Otherwise If StringCore.contains(expression, "startsWith"):
        Let prefix be extract_string_parameter(expression, "startsWith")
        
        If StringCore.starts_with(value, prefix):
            Set result.is_valid to true
        Otherwise:
            Set result.error_message to "Value must start with '" joined with prefix joined with "'"
    
    Otherwise If StringCore.contains(expression, "endsWith"):
        Let suffix be extract_string_parameter(expression, "endsWith")
        
        If StringCore.ends_with(value, suffix):
            Set result.is_valid to true
        Otherwise:
            Set result.error_message to "Value must end with '" joined with suffix joined with "'"
    
    Otherwise If StringCore.contains(expression, "contains"):
        Let substring be extract_string_parameter(expression, "contains")
        
        If StringCore.contains(value, substring):
            Set result.is_valid to true
        Otherwise:
            Set result.error_message to "Value must contain '" joined with substring joined with "'"
    
    Otherwise:
        Note: Unsupported custom expression
        Set result.error_message to "Unsupported custom validation expression: " joined with expression
        Set result.expected_value to "Supported expressions: length >, length <, startsWith(), endsWith(), contains()"
    
    Return result

Process called "extract_string_parameter" that takes expression as String, function_name as String returns String:
    Note: Extract string parameter from function call like "startsWith('test')"
    
    Let start_marker be function_name joined with "('"
    Let end_marker be "')"
    
    Let start_pos be StringCore.index_of(expression, start_marker)
    If start_pos equals -1:
        Return ""
    
    Set start_pos to start_pos + Length(start_marker)
    Let end_pos be StringCore.index_of_from(expression, end_marker, start_pos)
    If end_pos equals -1:
        Return ""
    
    Return StringCore.substring(expression, start_pos, end_pos - start_pos)

Process called "validate_type_compatibility" that takes source_type as String, target_type as String, conversion_mode as Optional[String] returns ValidationResult:
    Note: Check if source type can be converted to target type
    Note: Conversion modes: strict, lossy, safe (default: safe)
    Note: Considers implicit and explicit conversion rules
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as target_type
        actual_value as source_type
    
    Note: Set default conversion mode
    Let mode be "safe"
    If conversion_mode is not null:
        Let mode be conversion_mode
    
    Note: Identical types are always compatible
    If source_type equals target_type:
        Let result.is_valid be true
        Return result
    
    Note: Define type compatibility matrix based on conversion mode
    Note: Check conversions from source_type to target_type
    
    If source_type equals "integer":
        Note: Integer conversion rules
        If target_type equals "float":
            Note: Integer to float is safe (no data loss)
            Let result.is_valid be true
        Otherwise If target_type equals "string":
            Note: Integer to string is safe
            Let result.is_valid be true
        Otherwise If target_type equals "boolean":
            Note: Integer to boolean (0=false, non-zero=true)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids integer to boolean conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "character":
            Note: Integer to character (ASCII code conversion)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids integer to character conversion"
            Otherwise If mode equals "safe":
                Let result.is_valid be false
                Let result.error_code be "UNSAFE_CONVERSION"
                Let result.error_message be "Integer to character conversion may lose data (values > 127)"
            Otherwise:
                Note: Lossy mode allows conversion
                Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert integer to " concatenated with target_type
    
    Otherwise If source_type equals "float":
        Note: Float conversion rules
        If target_type equals "integer":
            Note: Float to integer loses fractional part
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids float to integer conversion (loses precision)"
            Otherwise If mode equals "safe":
                Let result.is_valid be false
                Let result.error_code be "PRECISION_LOSS"
                Let result.error_message be "Float to integer conversion loses fractional part"
            Otherwise:
                Note: Lossy mode allows conversion
                Let result.is_valid be true
        Otherwise If target_type equals "string":
            Note: Float to string is safe
            Let result.is_valid be true
        Otherwise If target_type equals "boolean":
            Note: Float to boolean (0.0=false, non-zero=true)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids float to boolean conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert float to " concatenated with target_type
    
    Otherwise If source_type equals "boolean":
        Note: Boolean conversion rules
        If target_type equals "integer":
            Note: Boolean to integer (false=0, true=1)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids boolean to integer conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "float":
            Note: Boolean to float (false=0.0, true=1.0)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids boolean to float conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "string":
            Note: Boolean to string is safe
            Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert boolean to " concatenated with target_type
    
    Otherwise If source_type equals "character":
        Note: Character conversion rules
        If target_type equals "integer":
            Note: Character to integer (ASCII/Unicode code)
            Let result.is_valid be true
        Otherwise If target_type equals "string":
            Note: Character to string is safe
            Let result.is_valid be true
        Otherwise If target_type equals "boolean":
            Note: Character to boolean (non-null=true, null=false)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids character to boolean conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert character to " concatenated with target_type
    
    Otherwise If source_type equals "string":
        Note: String conversion rules
        If target_type equals "integer":
            Note: String to integer (parse numeric string)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids string to integer conversion (parsing required)"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "float":
            Note: String to float (parse numeric string)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids string to float conversion (parsing required)"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "boolean":
            Note: String to boolean (parse boolean string)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids string to boolean conversion (parsing required)"
            Otherwise:
                Let result.is_valid be true
        Otherwise If target_type equals "character":
            Note: String to character (first character or single character)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids string to character conversion"
            Otherwise If mode equals "safe":
                Let result.is_valid be false
                Let result.error_code be "POTENTIAL_DATA_LOSS"
                Let result.error_message be "String to character conversion may lose data (strings > 1 character)"
            Otherwise:
                Note: Lossy mode allows conversion
                Let result.is_valid be true
        Otherwise If target_type equals "identifier":
            Note: String to identifier (validate identifier format)
            Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert string to " concatenated with target_type
    
    Otherwise If source_type equals "identifier":
        Note: Identifier conversion rules
        If target_type equals "string":
            Note: Identifier to string is always safe
            Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert identifier to " concatenated with target_type
    
    Note: Handle collection types
    Otherwise If source_type equals "List":
        If target_type equals "string":
            Note: List to string (serialization)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids list to string conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert List to " concatenated with target_type
    
    Otherwise If source_type equals "Dictionary":
        If target_type equals "string":
            Note: Dictionary to string (serialization)
            If mode equals "strict":
                Let result.is_valid be false
                Let result.error_code be "STRICT_CONVERSION_FORBIDDEN"
                Let result.error_message be "Strict mode forbids dictionary to string conversion"
            Otherwise:
                Let result.is_valid be true
        Otherwise:
            Let result.is_valid be false
            Let result.error_code be "INCOMPATIBLE_TYPES"
            Let result.error_message be "Cannot convert Dictionary to " concatenated with target_type
    
    Note: Handle unknown source types
    Otherwise:
        Let result.is_valid be false
        Let result.error_code be "UNKNOWN_SOURCE_TYPE"
        Let result.error_message be "Unknown source type: " concatenated with source_type
    
    Return result

Note: =====================================================================
Note: SCHEMA VALIDATION OPERATIONS
Note: =====================================================================

Process called "validate_against_schema" that takes value as Dictionary[String, String], schema as Dictionary[String, String] returns ValidationResult:
    Note: Validate structured data against a schema definition
    Note: Schema defines required fields, types, and constraints
    Note: Supports nested validation for complex structures
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as "Dictionary[" concatenated with size of value concatenated with " fields]"
    
    Note: Check if schema is empty
    If size of schema equals 0:
        Let result.error_code be "EMPTY_SCHEMA"
        Let result.error_message be "Schema definition is empty"
        Let result.expected_value be "Non-empty schema definition"
        Return result
    
    Note: Parse schema metadata
    Let schema_version be "1.0"
    Let schema_strict be true
    Let required_fields be empty List[String]
    Let optional_fields be empty List[String]
    
    Note: Extract schema configuration
    If "$version" is in schema:
        Let schema_version be get value "$version" from schema
    
    If "$strict" is in schema:
        Let strict_str be get value "$strict" from schema
        If strict_str equals "false" Or strict_str equals "False" Or strict_str equals "FALSE" Or strict_str equals "0":
            Let schema_strict be false
    
    If "$required" is in schema:
        Let required_str be get value "$required" from schema
        Note: Parse comma-separated list of required fields
        Let current_field be ""
        Loop with i from 0 to length of required_str minus 1:
            Let char be character at position i in required_str
            If char equals ",":
                Note: Trim whitespace from field name
                Let trimmed_field be ""
                Let start_idx be 0
                Let end_idx be length of current_field minus 1
                
                Note: Find first non-whitespace
                Loop while start_idx is less than length of current_field:
                    Let start_char be character at position start_idx in current_field
                    If start_char equals " " Or start_char equals "\t":
                        Let start_idx be start_idx plus 1
                    Otherwise:
                        Break
                
                Note: Find last non-whitespace
                Loop while end_idx is greater than start_idx:
                    Let end_char be character at position end_idx in current_field
                    If end_char equals " " Or end_char equals "\t":
                        Let end_idx be end_idx minus 1
                    Otherwise:
                        Break
                
                If start_idx is less than or equal to end_idx:
                    Let trimmed_field be substring of current_field from start_idx to end_idx plus 1
                    Let required_fields be add trimmed_field to required_fields
                
                Let current_field be ""
            Otherwise:
                Let current_field be current_field concatenated with char
        
        Note: Add final field
        If length of current_field is greater than 0:
            Let required_fields be add current_field to required_fields
    
    If "$optional" is in schema:
        Let optional_str be get value "$optional" from schema
        Note: Parse comma-separated list of optional fields
        Let current_field be ""
        Loop with i from 0 to length of optional_str minus 1:
            Let char be character at position i in optional_str
            If char equals ",":
                If length of current_field is greater than 0:
                    Let optional_fields be add current_field to optional_fields
                Let current_field be ""
            Otherwise:
                Let current_field be current_field concatenated with char
        
        If length of current_field is greater than 0:
            Let optional_fields be add current_field to optional_fields
    
    Note: Validate all required fields are present
    Loop with i from 0 to length of required_fields minus 1:
        Let required_field be element at position i in required_fields
        If not (required_field is in value):
            Let result.error_code be "REQUIRED_FIELD_MISSING"
            Let result.error_message be "Required field '" concatenated with required_field concatenated with "' is missing from data"
            Let result.expected_value be "All required fields: " concatenated with get value "$required" from schema
            Let result.field_name be required_field
            Return result
    
    Note: Validate field types and constraints
    Loop for each field_name, field_value in value:
        Note: Skip schema metadata fields
        If field_name equals "$version" Or field_name equals "$strict" Or field_name equals "$required" Or field_name equals "$optional":
            Continue
        
        Note: Check if field is allowed in schema
        Let field_allowed be false
        Let field_schema_key be ""
        
        Note: Look for direct field definition
        If field_name is in schema:
            Let field_allowed be true
            Let field_schema_key be field_name
        Otherwise:
            Note: Look for type-prefixed field definition
            Loop for each schema_key, schema_value in schema:
                If schema_key equals field_name concatenated with ".type":
                    Let field_allowed be true
                    Let field_schema_key be field_name
                    Break
                Otherwise If schema_key equals field_name concatenated with ".required":
                    Let field_allowed be true
                    Let field_schema_key be field_name
                    Break
                Otherwise If schema_key equals field_name concatenated with ".format":
                    Let field_allowed be true
                    Let field_schema_key be field_name
                    Break
        
        Note: Check if field is in required or optional lists
        If not field_allowed:
            Loop with i from 0 to length of required_fields minus 1:
                Let req_field be element at position i in required_fields
                If req_field equals field_name:
                    Let field_allowed be true
                    Let field_schema_key be field_name
                    Break
            
            If not field_allowed:
                Loop with i from 0 to length of optional_fields minus 1:
                    Let opt_field be element at position i in optional_fields
                    If opt_field equals field_name:
                        Let field_allowed be true
                        Let field_schema_key be field_name
                        Break
        
        Note: In strict mode, reject unknown fields
        If not field_allowed And schema_strict:
            Let result.error_code be "UNKNOWN_FIELD"
            Let result.error_message be "Field '" concatenated with field_name concatenated with "' is not defined in schema"
            Let result.expected_value be "Only fields defined in schema are allowed in strict mode"
            Let result.field_name be field_name
            Return result
        
        Note: Skip validation for unknown fields in non-strict mode
        If not field_allowed:
            Continue
        
        Note: Validate field type if specified
        Let expected_type_key be field_schema_key concatenated with ".type"
        If expected_type_key is in schema:
            Let expected_type be get value expected_type_key from schema
            
            Let type_validation_result be null
            
            If expected_type equals "integer":
                Let type_validation_result be validate_integer with field_value, null, null
            Otherwise If expected_type equals "float":
                Let type_validation_result be validate_float with field_value, null, null
            Otherwise If expected_type equals "boolean":
                Let type_validation_result be validate_boolean with field_value, null
            Otherwise If expected_type equals "character":
                Let type_validation_result be validate_character with field_value, null
            Otherwise If expected_type equals "identifier":
                Let type_validation_result be validate_identifier with field_value, null
            Otherwise If expected_type equals "string":
                Let type_validation_result be validate_string_length with field_value, null, null
            Otherwise:
                Note: Default to string validation for unknown types
                Let type_validation_result be validate_string_length with field_value, null, null
            
            If not type_validation_result.is_valid:
                Let result.error_code be "FIELD_TYPE_MISMATCH"
                Let result.error_message be "Field '" concatenated with field_name concatenated with "' has invalid " concatenated with expected_type concatenated with " value: " concatenated with type_validation_result.error_message
                Let result.expected_value be "Valid " concatenated with expected_type concatenated with " value"
                Let result.field_name be field_name
                Return result
        
        Note: Validate field format if specified
        Let format_key be field_schema_key concatenated with ".format"
        If format_key is in schema:
            Let format_type be get value format_key from schema
            
            Let format_validation_result be null
            
            If format_type equals "identifier":
                Let format_validation_result be validate_identifier with field_value, null
            Otherwise If format_type equals "email":
                Note: Basic email format validation (contains @ and .)
                Let has_at be false
                Let has_dot be false
                Loop with i from 0 to length of field_value minus 1:
                    Let char be character at position i in field_value
                    If char equals "@":
                        Let has_at be true
                    Otherwise If char equals ".":
                        Let has_dot be true
                
                Let format_validation_result be ValidationResult with:
                    is_valid as (has_at And has_dot)
                    error_code as null
                    error_message as null
                    field_name as null
                    expected_value as null
                    actual_value as field_value
                
                If not format_validation_result.is_valid:
                    Let format_validation_result.error_code be "INVALID_EMAIL_FORMAT"
                    Let format_validation_result.error_message be "Invalid email format (must contain @ and .)"
            Otherwise:
                Note: Default to string validation for unknown formats
                Let format_validation_result be validate_string_length with field_value, null, null
            
            If not format_validation_result.is_valid:
                Let result.error_code be "FIELD_FORMAT_INVALID"
                Let result.error_message be "Field '" concatenated with field_name concatenated with "' has invalid format: " concatenated with format_validation_result.error_message
                Let result.expected_value be "Value matching " concatenated with format_type concatenated with " format"
                Let result.field_name be field_name
                Return result
        
        Note: Validate field constraints if specified
        Let min_length_key be field_schema_key concatenated with ".min_length"
        Let max_length_key be field_schema_key concatenated with ".max_length"
        
        If min_length_key is in schema Or max_length_key is in schema:
            Let min_length be null
            Let max_length be null
            
            If min_length_key is in schema:
                Let min_str be get value min_length_key from schema
                Let parsed_min be 0
                Loop with i from 0 to length of min_str minus 1:
                    Let digit_char be character at position i in min_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_min be parsed_min multiplied by 10 plus digit_value
                Let min_length be parsed_min
            
            If max_length_key is in schema:
                Let max_str be get value max_length_key from schema
                Let parsed_max be 0
                Loop with i from 0 to length of max_str minus 1:
                    Let digit_char be character at position i in max_str
                    If digit_char equals "0" Or digit_char equals "1" Or digit_char equals "2" Or digit_char equals "3" Or digit_char equals "4" Or digit_char equals "5" Or digit_char equals "6" Or digit_char equals "7" Or digit_char equals "8" Or digit_char equals "9":
                        Let digit_value be get_character_code with digit_char minus 48
                        Let parsed_max be parsed_max multiplied by 10 plus digit_value
                Let max_length be parsed_max
            
            Let length_validation_result be validate_string_length with field_value, min_length, max_length
            If not length_validation_result.is_valid:
                Let result.error_code be "FIELD_CONSTRAINT_VIOLATION"
                Let result.error_message be "Field '" concatenated with field_name concatenated with "' violates length constraint: " concatenated with length_validation_result.error_message
                Let result.expected_value be length_validation_result.expected_value
                Let result.field_name be field_name
                Return result
    
    Note: All validation passed
    Let result.is_valid be true
    Return result

Process called "validate_constraint" that takes value as String, constraint_expression as String, variables as Optional[Dictionary[String, String]] returns ValidationResult:
    Note: Validate value against a custom constraint expression
    Note: Constraint expressions use domain-specific validation language
    Note: Variables provide context for constraint evaluation
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: Check for empty constraint expression
    If length of constraint_expression equals 0:
        Let result.error_code be "EMPTY_CONSTRAINT"
        Let result.error_message be "Constraint expression cannot be empty"
        Let result.expected_value be "Non-empty constraint expression"
        Return result
    
    Note: Parse constraint expression - simplified implementation
    Note: Supports basic constraint patterns: value OP literal
    Note: Example: "value > 10", "length <= 255", "value == 'admin'"
    
    Let constraint_parts be empty List[String]
    Let current_part be ""
    Let in_quotes be false
    Let quote_char be ""
    
    Note: Tokenize constraint expression
    Loop with i from 0 to length of constraint_expression minus 1:
        Let char be character at position i in constraint_expression
        
        If in_quotes:
            If char equals quote_char:
                Let in_quotes be false
                Let current_part be current_part concatenated with char
            Otherwise:
                Let current_part be current_part concatenated with char
        Otherwise:
            If char equals "'" Or char equals "\"":
                Let in_quotes be true
                Let quote_char be char
                Let current_part be current_part concatenated with char
            Otherwise If char equals " " Or char equals "\t":
                If length of current_part is greater than 0:
                    Let constraint_parts be add current_part to constraint_parts
                    Let current_part be ""
            Otherwise:
                Let current_part be current_part concatenated with char
    
    Note: Add final part
    If length of current_part is greater than 0:
        Let constraint_parts be add current_part to constraint_parts
    
    Note: Check if we have enough parts for a constraint
    Let parts_count be length of constraint_parts
    If parts_count is less than 3:
        Let result.error_code be "INVALID_CONSTRAINT_FORMAT"
        Let result.error_message be "Constraint must have format: 'variable operator value'"
        Let result.expected_value be "Format like: 'value > 10' or 'length <= 255'"
        Return result
    
    Note: Extract constraint components
    Let left_operand be element at position 0 in constraint_parts
    Let operator be element at position 1 in constraint_parts
    Let right_operand be element at position 2 in constraint_parts
    
    Note: Resolve left operand value
    Let left_value be ""
    
    If left_operand equals "value":
        Let left_value be value
    Otherwise If left_operand equals "length":
        Let length_str be ""
        Let value_length be length of value
        Let temp_length be value_length
        
        Note: Convert length to string
        If temp_length equals 0:
            Let length_str be "0"
        Otherwise:
            Let digits be empty List[String]
            Loop while temp_length is greater than 0:
                Let digit be temp_length modulo 10
                Let digit_char be ""
                If digit equals 0:
                    Let digit_char be "0"
                Otherwise If digit equals 1:
                    Let digit_char be "1"
                Otherwise If digit equals 2:
                    Let digit_char be "2"
                Otherwise If digit equals 3:
                    Let digit_char be "3"
                Otherwise If digit equals 4:
                    Let digit_char be "4"
                Otherwise If digit equals 5:
                    Let digit_char be "5"
                Otherwise If digit equals 6:
                    Let digit_char be "6"
                Otherwise If digit equals 7:
                    Let digit_char be "7"
                Otherwise If digit equals 8:
                    Let digit_char be "8"
                Otherwise If digit equals 9:
                    Let digit_char be "9"
                
                Let digits be add digit_char to digits
                Let temp_length be temp_length divided by 10
            
            Note: Reverse digits to get correct order
            Loop with i from length of digits minus 1 down to 0:
                Let digit_char be element at position i in digits
                Let length_str be length_str concatenated with digit_char
        
        Let left_value be length_str
    Otherwise:
        Note: Check if left operand is a variable
        If variables is not null And left_operand is in variables:
            Let left_value be get value left_operand from variables
        Otherwise:
            Let result.error_code be "UNKNOWN_VARIABLE"
            Let result.error_message be "Unknown variable in constraint: " concatenated with left_operand
            Let result.expected_value be "Use 'value', 'length', or define variable"
            Return result
    
    Note: Remove quotes from right operand if present
    Let right_value be right_operand
    If length of right_operand is greater than 1:
        Let first_char be character at position 0 in right_operand
        Let last_char be character at position length of right_operand minus 1 in right_operand
        If (first_char equals "'" And last_char equals "'") Or (first_char equals "\"" And last_char equals "\""):
            Let right_value be substring of right_operand from 1 to length of right_operand minus 1
    
    Note: Evaluate constraint based on operator
    If operator equals "==":
        Let result.is_valid be (left_value equals right_value)
        If not result.is_valid:
            Let result.error_code be "CONSTRAINT_NOT_EQUAL"
            Let result.error_message be "Value '" concatenated with left_value concatenated with "' is not equal to '" concatenated with right_value concatenated with "'"
    
    Otherwise If operator equals "!=":
        Let result.is_valid be not (left_value equals right_value)
        If not result.is_valid:
            Let result.error_code be "CONSTRAINT_EQUAL"
            Let result.error_message be "Value '" concatenated with left_value concatenated with "' should not equal '" concatenated with right_value concatenated with "'"
    
    Otherwise If operator equals ">" Or operator equals "<" Or operator equals ">=" Or operator equals "<=":
        Note: Numeric comparison - parse both values as integers
        Let left_numeric be 0
        Let right_numeric be 0
        Let left_parse_success be true
        Let right_parse_success be true
        
        Note: Parse left value
        Loop with i from 0 to length of left_value minus 1:
            Let char be character at position i in left_value
            If char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9":
                Let digit_value be get_character_code with char minus 48
                Let left_numeric be left_numeric multiplied by 10 plus digit_value
            Otherwise:
                Let left_parse_success be false
                Break
        
        Note: Parse right value
        Loop with i from 0 to length of right_value minus 1:
            Let char be character at position i in right_value
            If char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9":
                Let digit_value be get_character_code with char minus 48
                Let right_numeric be right_numeric multiplied by 10 plus digit_value
            Otherwise:
                Let right_parse_success be false
                Break
        
        If not left_parse_success Or not right_parse_success:
            Let result.error_code be "NON_NUMERIC_COMPARISON"
            Let result.error_message be "Cannot perform numeric comparison with non-numeric values"
            Let result.expected_value be "Numeric values for comparison operators"
            Return result
        
        Note: Perform numeric comparison
        If operator equals ">":
            Let result.is_valid be (left_numeric is greater than right_numeric)
            If not result.is_valid:
                Let result.error_code be "CONSTRAINT_NOT_GREATER"
                Let result.error_message be "Value " concatenated with left_value concatenated with " is not greater than " concatenated with right_value
        Otherwise If operator equals "<":
            Let result.is_valid be (left_numeric is less than right_numeric)
            If not result.is_valid:
                Let result.error_code be "CONSTRAINT_NOT_LESS"
                Let result.error_message be "Value " concatenated with left_value concatenated with " is not less than " concatenated with right_value
        Otherwise If operator equals ">=":
            Let result.is_valid be (left_numeric is greater than or equal to right_numeric)
            If not result.is_valid:
                Let result.error_code be "CONSTRAINT_NOT_GREATER_EQUAL"
                Let result.error_message be "Value " concatenated with left_value concatenated with " is not greater than or equal to " concatenated with right_value
        Otherwise If operator equals "<=":
            Let result.is_valid be (left_numeric is less than or equal to right_numeric)
            If not result.is_valid:
                Let result.error_code be "CONSTRAINT_NOT_LESS_EQUAL"
                Let result.error_message be "Value " concatenated with left_value concatenated with " is not less than or equal to " concatenated with right_value
    
    Otherwise If operator equals "contains":
        Note: String containment check
        Let contains_found be false
        Let left_length be length of left_value
        Let right_length be length of right_value
        
        If right_length is less than or equal to left_length:
            Loop with i from 0 to left_length minus right_length:
                Let substring_match be true
                Loop with j from 0 to right_length minus 1:
                    Let left_char be character at position i plus j in left_value
                    Let right_char be character at position j in right_value
                    If not (left_char equals right_char):
                        Let substring_match be false
                        Break
                
                If substring_match:
                    Let contains_found be true
                    Break
        
        Let result.is_valid be contains_found
        If not result.is_valid:
            Let result.error_code be "CONSTRAINT_NOT_CONTAINS"
            Let result.error_message be "Value '" concatenated with left_value concatenated with "' does not contain '" concatenated with right_value concatenated with "'"
    
    Otherwise If operator equals "matches":
        Note: Enhanced pattern matching with wildcard support
        Let pattern_matches be false
        
        Note: Check if pattern contains wildcard characters
        Let has_wildcard be false
        Loop with i from 0 to length of right_value minus 1:
            Let char be character at position i in right_value
            If char equals "*" Or char equals "?":
                Let has_wildcard be true
                Break
        
        Note: Check for format pattern prefixes
        Let is_format_pattern be false
        If length of right_value is greater than 7:
            Let format_prefix be substring of right_value from 0 to 7
            If format_prefix equals "format:":
                Let is_format_pattern be true
        
        If has_wildcard:
            Note: Use wildcard pattern matching
            Let pattern_matches be validate_wildcard_pattern with left_value, right_value
        Otherwise If is_format_pattern:
            Note: Extract format type from pattern (format:email, format:phone, etc.)
            Let format_type be substring of right_value from 7 to length of right_value
            
            If format_type equals "email":
                Note: Email format validation
                Let has_at be false
                Let has_dot_after_at be false
                Let at_position be -1
                
                Loop with i from 0 to length of left_value minus 1:
                    Let char be character at position i in left_value
                    If char equals "@":
                        If has_at:
                            Note: Multiple @ symbols not allowed
                            Let pattern_matches be false
                            Break
                        Let has_at be true
                        Let at_position be i
                    Otherwise If char equals "." And has_at And i is greater than at_position:
                        Let has_dot_after_at be true
                
                Let pattern_matches be (has_at And has_dot_after_at And at_position is greater than 0 And at_position is less than length of left_value minus 2)
            
            Otherwise If format_type equals "phone":
                Note: Phone number format validation
                Let phone_valid be true
                Let digit_count be 0
                
                Loop with i from 0 to length of left_value minus 1:
                    Let char be character at position i in left_value
                    If char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9":
                        Let digit_count be digit_count plus 1
                    Otherwise If not (char equals " " Or char equals "-" Or char equals "(" Or char equals ")" Or char equals "+"):
                        Let phone_valid be false
                        Break
                
                Let pattern_matches be (phone_valid And digit_count is greater than or equal to 7 And digit_count is less than or equal to 15)
            
            Otherwise If format_type equals "url":
                Note: URL format validation
                Let url_valid be false
                If length of left_value is greater than or equal to 7:
                    Let http_prefix be substring of left_value from 0 to 7
                    If http_prefix equals "http://":
                        Let url_valid be true
                    Otherwise If length of left_value is greater than or equal to 8:
                        Let https_prefix be substring of left_value from 0 to 8
                        If https_prefix equals "https://":
                            Let url_valid be true
                
                Let pattern_matches be url_valid
            
            Otherwise If format_type equals "date":
                Note: Date format validation (YYYY-MM-DD)
                Let date_valid be false
                If length of left_value equals 10:
                    Let char4 be character at position 4 in left_value
                    Let char7 be character at position 7 in left_value
                    If char4 equals "-" And char7 equals "-":
                        Let all_digits_valid be true
                        Note: Check year digits (0-3)
                        Loop with i from 0 to 3:
                            Let char be character at position i in left_value
                            If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                Let all_digits_valid be false
                                Break
                        Note: Check month digits (5-6)
                        If all_digits_valid:
                            Loop with i from 5 to 6:
                                Let char be character at position i in left_value
                                If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                    Let all_digits_valid be false
                                    Break
                        Note: Check day digits (8-9)
                        If all_digits_valid:
                            Loop with i from 8 to 9:
                                Let char be character at position i in left_value
                                If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9"):
                                    Let all_digits_valid be false
                                    Break
                        Let date_valid be all_digits_valid
                
                Let pattern_matches be date_valid
            
            Otherwise If format_type equals "identifier":
                Note: Identifier format validation using existing function
                Let identifier_result be validate_identifier with left_value, null
                Let pattern_matches be identifier_result.is_valid
            
            Otherwise If format_type equals "integer":
                Note: Integer format validation using existing function
                Let integer_result be validate_integer with left_value, null, null
                Let pattern_matches be integer_result.is_valid
            
            Otherwise If format_type equals "float":
                Note: Float format validation using existing function
                Let float_result be validate_float with left_value, null, null
                Let pattern_matches be float_result.is_valid
            
            Otherwise If format_type equals "boolean":
                Note: Boolean format validation using existing function
                Let boolean_result be validate_boolean with left_value, null
                Let pattern_matches be boolean_result.is_valid
            
            Otherwise If format_type equals "hex":
                Note: Hexadecimal format validation
                Let hex_valid be true
                If length of left_value is greater than 2:
                    Let prefix be substring of left_value from 0 to 2
                    Let start_pos be 0
                    If prefix equals "0x" Or prefix equals "0X":
                        Let start_pos be 2
                    
                    Loop with i from start_pos to length of left_value minus 1:
                        Let char be character at position i in left_value
                        If not (char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9" Or char equals "A" Or char equals "B" Or char equals "C" Or char equals "D" Or char equals "E" Or char equals "F" Or char equals "a" Or char equals "b" Or char equals "c" Or char equals "d" Or char equals "e" Or char equals "f"):
                            Let hex_valid be false
                            Break
                
                Let pattern_matches be hex_valid
            
            Otherwise:
                Note: Unknown format type, fall back to literal matching
                Let pattern_matches be (left_value equals right_value)
        
        Otherwise:
            Note: Literal pattern matching (no wildcards, no format prefix)
            Let pattern_matches be (left_value equals right_value)
        
        Let result.is_valid be pattern_matches
        If not result.is_valid:
            Let result.error_code be "CONSTRAINT_NOT_MATCHES"
            If has_wildcard:
                Let result.error_message be "Value '" concatenated with left_value concatenated with "' does not match wildcard pattern '" concatenated with right_value concatenated with "'"
            Otherwise If is_format_pattern:
                Let format_type be substring of right_value from 7 to length of right_value
                Let result.error_message be "Value '" concatenated with left_value concatenated with "' does not match " concatenated with format_type concatenated with " format"
            Otherwise:
                Let result.error_message be "Value '" concatenated with left_value concatenated with "' does not match literal pattern '" concatenated with right_value concatenated with "'"
    
    Otherwise:
        Let result.error_code be "UNKNOWN_OPERATOR"
        Let result.error_message be "Unknown constraint operator: " concatenated with operator
        Let result.expected_value be "Supported operators: ==, !=, >, <, >=, <=, contains, matches (supports wildcards and format: patterns)"
        Return result
    
    Note: Set expected value for failed constraints
    If not result.is_valid And result.expected_value is null:
        Let result.expected_value be "Value satisfying constraint: " concatenated with constraint_expression
    
    Return result

Note: =====================================================================
Note: VALIDATION UTILITY OPERATIONS
Note: =====================================================================

Process called "create_validation_rule" that takes rule_name as String, rule_type as String, parameters as Dictionary[String, String] returns ValidationRule:
    Note: Factory method for creating validation rules
    Note: Validates rule parameters and ensures consistency
    Note: Provides defaults for common validation scenarios
    
    Let rule be ValidationRule with:
        rule_name as rule_name
        rule_type as rule_type
        parameters as parameters
        error_message as ""
        is_required as true
    
    Note: Set default error messages based on rule type
    If rule_type equals "range":
        Let rule.error_message be "Value must be within specified range"
    Otherwise If rule_type equals "format":
        Let rule.error_message be "Value must match required format"
    Otherwise If rule_type equals "length":
        Let rule.error_message be "Value length must meet requirements"
    Otherwise If rule_type equals "pattern":
        Let rule.error_message be "Value must match specified pattern"
    Otherwise If rule_type equals "required":
        Let rule.error_message be "Value is required and cannot be empty"
    Otherwise If rule_type equals "type":
        Let rule.error_message be "Value must be of correct type"
    Otherwise If rule_type equals "unique":
        Let rule.error_message be "Value must be unique"
    Otherwise If rule_type equals "custom":
        Let rule.error_message be "Value failed custom validation"
    Otherwise:
        Let rule.error_message be "Value failed validation for " concatenated with rule_type
    
    Note: Override error message if provided in parameters
    If "error_message" is in parameters:
        Let rule.error_message be get value "error_message" from parameters
    
    Note: Set required flag if specified
    If "required" is in parameters:
        Let required_str be get value "required" from parameters
        If required_str equals "false" Or required_str equals "False" Or required_str equals "FALSE" Or required_str equals "0" Or required_str equals "no":
            Let rule.is_required be false
    
    Note: Validate rule-specific parameters
    If rule_type equals "range":
        Note: Range rules should have min_value and/or max_value
        If not ("min_value" is in parameters) And not ("max_value" is in parameters):
            Note: Add default range parameters
            Let rule.parameters be add "min_value" with value "0" to rule.parameters
            Let rule.parameters be add "max_value" with value "100" to rule.parameters
    
    Otherwise If rule_type equals "length":
        Note: Length rules should have min_length and/or max_length
        If not ("min_length" is in parameters) And not ("max_length" is in parameters):
            Note: Add default length parameters
            Let rule.parameters be add "min_length" with value "0" to rule.parameters
            Let rule.parameters be add "max_length" with value "255" to rule.parameters
    
    Otherwise If rule_type equals "format":
        Note: Format rules should specify format type
        If not ("format_type" is in parameters):
            Let rule.parameters be add "format_type" with value "string" to rule.parameters
    
    Otherwise If rule_type equals "pattern":
        Note: Pattern rules should specify pattern
        If not ("pattern" is in parameters):
            Let rule.parameters be add "pattern" with value ".*" to rule.parameters
            Let rule.parameters be add "pattern_type" with value "regex" to rule.parameters
    
    Return rule

Process called "combine_validation_results" that takes results as List[ValidationResult] returns ValidationResult:
    Note: Combine multiple validation results into single result
    Note: Determines overall success/failure status
    Note: Aggregates error messages and codes appropriately
    
    Let combined_result be ValidationResult with:
        is_valid as true
        error_code as null
        error_message as ""
        field_name as null
        expected_value as null
        actual_value as null
    
    Note: Check if results list is empty
    If length of results equals 0:
        Let combined_result.error_code be "NO_RESULTS"
        Let combined_result.error_message be "No validation results to combine"
        Let combined_result.is_valid be false
        Return combined_result
    
    Note: Track validation statistics
    Let total_results be length of results
    Let failed_count be 0
    Let error_messages be ""
    Let error_codes be ""
    
    Note: Process each validation result
    Loop with i from 0 to total_results minus 1:
        Let current_result be element at position i in results
        
        Note: Count failures and collect error information
        If not current_result.is_valid:
            Let failed_count be failed_count plus 1
            Let combined_result.is_valid be false
            
            Note: Collect error codes
            If current_result.error_code is not null:
                If length of error_codes is greater than 0:
                    Let error_codes be error_codes concatenated with ", "
                Let error_codes be error_codes concatenated with current_result.error_code
            
            Note: Collect error messages
            If current_result.error_message is not null:
                If length of error_messages is greater than 0:
                    Let error_messages be error_messages concatenated with "; "
                
                Note: Add field name context if available
                If current_result.field_name is not null:
                    Let error_messages be error_messages concatenated with "[" concatenated with current_result.field_name concatenated with "] "
                
                Let error_messages be error_messages concatenated with current_result.error_message
    
    Note: Set combined error information
    If failed_count is greater than 0:
        If length of error_codes is greater than 0:
            Let combined_result.error_code be error_codes
        Otherwise:
            Let combined_result.error_code be "VALIDATION_FAILED"
        
        If length of error_messages is greater than 0:
            Let combined_result.error_message be error_messages
        Otherwise:
            Let combined_result.error_message be failed_count concatenated with " of " concatenated with total_results concatenated with " validations failed"
        
        Note: Create summary of expected values
        Let expected_summary be ""
        Loop with i from 0 to total_results minus 1:
            Let current_result be element at position i in results
            If not current_result.is_valid And current_result.expected_value is not null:
                If length of expected_summary is greater than 0:
                    Let expected_summary be expected_summary concatenated with "; "
                Let expected_summary be expected_summary concatenated with current_result.expected_value
        
        If length of expected_summary is greater than 0:
            Let combined_result.expected_value be expected_summary
    
    Return combined_result

Process called "validate_and_suggest" that takes value as String, expected_type as String returns ValidationResult:
    Note: Validate value and provide correction suggestions
    Note: Uses heuristics to suggest likely intended values
    Note: Helpful for interactive validation and error recovery
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: First attempt standard validation
    Let validation_result be null
    
    If expected_type equals "integer":
        Let validation_result be validate_integer with value, null, null
    Otherwise If expected_type equals "float":
        Let validation_result be validate_float with value, null, null
    Otherwise If expected_type equals "boolean":
        Let validation_result be validate_boolean with value, null
    Otherwise If expected_type equals "character":
        Let validation_result be validate_character with value, null
    Otherwise If expected_type equals "identifier":
        Let validation_result be validate_identifier with value, null
    Otherwise If expected_type equals "string":
        Let validation_result be validate_string_length with value, null, null
    Otherwise:
        Note: Unknown type, default to string validation
        Let validation_result be validate_string_length with value, null, null
    
    Note: If validation passes, return success
    If validation_result.is_valid:
        Return validation_result
    
    Note: Validation failed, provide suggestions based on type and common errors
    Let result.error_code be validation_result.error_code
    Let result.error_message be validation_result.error_message
    Let suggestions be ""
    
    If expected_type equals "integer":
        Note: Common integer issues and suggestions
        If validation_result.error_code equals "INVALID_CHARACTER":
            Let suggestions be "Remove non-numeric characters; Use only digits 0-9 with optional sign"
        Otherwise If validation_result.error_code equals "LEADING_ZEROS":
            Let suggestions be "Remove leading zeros (e.g., '007' → '7')"
        Otherwise If validation_result.error_code equals "EMPTY_VALUE":
            Let suggestions be "Provide a numeric value (e.g., '0', '42', '-5')"
        Otherwise If validation_result.error_code equals "OVERFLOW" Or validation_result.error_code equals "UNDERFLOW":
            Let suggestions be "Use a smaller number within integer range (-2147483648 to 2147483647)"
        Otherwise:
            Let suggestions be "Ensure value contains only digits with optional + or - sign"
    
    Otherwise If expected_type equals "float":
        Note: Common float issues and suggestions  
        If validation_result.error_code equals "MULTIPLE_DECIMALS":
            Let suggestions be "Use only one decimal point (e.g., '3.14' not '3.1.4')"
        Otherwise If validation_result.error_code equals "INVALID_CHARACTER":
            Let suggestions be "Use only digits, decimal point, and scientific notation (e.g., '3.14', '1.5e10')"
        Otherwise If validation_result.error_code equals "MISSING_EXPONENT":
            Let suggestions be "Complete scientific notation (e.g., '1e10' not '1e')"
        Otherwise If validation_result.error_code equals "EMPTY_VALUE":
            Let suggestions be "Provide a numeric value (e.g., '0.0', '3.14', '1.5e10')"
        Otherwise:
            Let suggestions be "Use decimal format (e.g., '3.14') or scientific notation (e.g., '1.5e10')"
    
    Otherwise If expected_type equals "boolean":
        Note: Common boolean issues and suggestions
        Let lowercase_value be ""
        Loop with i from 0 to length of value minus 1:
            Let char be character at position i in value
            If char equals "A" Or char equals "B" Or char equals "C" Or char equals "D" Or char equals "E" Or char equals "F" Or char equals "G" Or char equals "H" Or char equals "I" Or char equals "J" Or char equals "K" Or char equals "L" Or char equals "M" Or char equals "N" Or char equals "O" Or char equals "P" Or char equals "Q" Or char equals "R" Or char equals "S" Or char equals "T" Or char equals "U" Or char equals "V" Or char equals "W" Or char equals "X" Or char equals "Y" Or char equals "Z":
                Let lowercase_char be ""
                If char equals "A":
                    Let lowercase_char be "a"
                Otherwise If char equals "B":
                    Let lowercase_char be "b"
                Otherwise If char equals "C":
                    Let lowercase_char be "c"
                Otherwise If char equals "D":
                    Let lowercase_char be "d"
                Otherwise If char equals "E":
                    Let lowercase_char be "e"
                Otherwise If char equals "F":
                    Let lowercase_char be "f"
                Otherwise If char equals "G":
                    Let lowercase_char be "g"
                Otherwise If char equals "H":
                    Let lowercase_char be "h"
                Otherwise If char equals "I":
                    Let lowercase_char be "i"
                Otherwise If char equals "J":
                    Let lowercase_char be "j"
                Otherwise If char equals "K":
                    Let lowercase_char be "k"
                Otherwise If char equals "L":
                    Let lowercase_char be "l"
                Otherwise If char equals "M":
                    Let lowercase_char be "m"
                Otherwise If char equals "N":
                    Let lowercase_char be "n"
                Otherwise If char equals "O":
                    Let lowercase_char be "o"
                Otherwise If char equals "P":
                    Let lowercase_char be "p"
                Otherwise If char equals "Q":
                    Let lowercase_char be "q"
                Otherwise If char equals "R":
                    Let lowercase_char be "r"
                Otherwise If char equals "S":
                    Let lowercase_char be "s"
                Otherwise If char equals "T":
                    Let lowercase_char be "t"
                Otherwise If char equals "U":
                    Let lowercase_char be "u"
                Otherwise If char equals "V":
                    Let lowercase_char be "v"
                Otherwise If char equals "W":
                    Let lowercase_char be "w"
                Otherwise If char equals "X":
                    Let lowercase_char be "x"
                Otherwise If char equals "Y":
                    Let lowercase_char be "y"
                Otherwise If char equals "Z":
                    Let lowercase_char be "z"
                Let lowercase_value be lowercase_value concatenated with lowercase_char
            Otherwise:
                Let lowercase_value be lowercase_value concatenated with char
        
        Note: Suggest common boolean corrections
        If lowercase_value equals "t" Or lowercase_value equals "tr" Or lowercase_value equals "tru":
            Let suggestions be "Did you mean 'true'?"
        Otherwise If lowercase_value equals "f" Or lowercase_value equals "fa" Or lowercase_value equals "fal" Or lowercase_value equals "fals":
            Let suggestions be "Did you mean 'false'?"
        Otherwise If lowercase_value equals "y" Or lowercase_value equals "ye":
            Let suggestions be "Did you mean 'yes'?"
        Otherwise If lowercase_value equals "n":
            Let suggestions be "Did you mean 'no'?"
        Otherwise:
            Let suggestions be "Use 'true'/'false', 'yes'/'no', '1'/'0', or 'on'/'off'"
    
    Otherwise If expected_type equals "identifier":
        Note: Common identifier issues and suggestions
        If validation_result.error_code equals "INVALID_IDENTIFIER_START":
            Let suggestions be "Start identifier with letter or underscore (e.g., 'myVar' or '_private')"
        Otherwise If validation_result.error_code equals "INVALID_IDENTIFIER_CHARACTER":
            Let suggestions be "Use only letters, digits, and underscores (e.g., 'my_var_123')"
        Otherwise If validation_result.error_code equals "EMPTY_IDENTIFIER":
            Let suggestions be "Provide a non-empty identifier name"
        Otherwise:
            Let suggestions be "Use valid identifier format: letters, digits, underscores only, starting with letter/underscore"
    
    Otherwise:
        Let suggestions be "Check value format and try again"
    
    Note: Add suggestions to error message
    If length of suggestions is greater than 0:
        Let result.error_message be result.error_message concatenated with " | Suggestions: " concatenated with suggestions
    
    Return result