            Let second_byte_code be -1
            
            Note: Get actual byte values from characters
            Let first_byte_code be get_character_code with first_byte
            Let second_byte_code be get_character_code with second_byte
            
            Note: Validate first byte is 110xxxxx pattern (192-223 decimal)
            Note: Check that top 3 bits are 110 and remaining 5 bits can be anything
            If first_byte_code is less than 192 Or first_byte_code is greater than 223:
                Let result.error_code be "INVALID_UTF8_2BYTE_FIRST"
                Let result.error_message be "Invalid first byte in 2-byte UTF-8 sequence (must be 110xxxxx pattern)"
                Return result
            
            Note: Validate second byte is 10xxxxxx pattern (128-191 decimal)
            Note: Check that top 2 bits are 10 and remaining 6 bits can be anything
            If second_byte_code is less than 128 Or second_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_2BYTE_SECOND"
                Let result.error_message be "Invalid second byte in 2-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            Note: Check for overlong encoding - extract the Unicode code point
            Note: Combine the bits: 5 bits from first byte + 6 bits from second byte
            Let first_byte_bits be first_byte_code minus 192
            Let second_byte_bits be second_byte_code minus 128
            Let unicode_point be first_byte_bits multiplied by 64 plus second_byte_bits
            
            Note: 2-byte sequences must encode values >= U+0080 (128)
            If unicode_point is less than 128:
                Let result.error_code be "INVALID_UTF8_OVERLONG"
                Let result.error_message be "Overlong UTF-8 encoding (2-byte sequence for ASCII character)"
                Return result
            
            
            Let result.is_valid be true
            Return result
        
        Otherwise If byte_count equals 3:
            Note: 3-byte UTF-8: 1110xxxx 10xxxxxx 10xxxxxx (U+0800 to U+FFFF)
            Let first_byte be character at position 0 in processed_value
            Let second_byte be character at position 1 in processed_value
            Let third_byte be character at position 2 in processed_value
            
            Note: Get actual byte values from characters
            Let first_byte_code be get_character_code with first_byte
            Let second_byte_code be get_character_code with second_byte
            Let third_byte_code be get_character_code with third_byte
            
            Note: Validate first byte is 1110xxxx pattern (224-239 decimal)
            If first_byte_code is less than 224 Or first_byte_code is greater than 239:
                Let result.error_code be "INVALID_UTF8_3BYTE_FIRST"
                Let result.error_message be "Invalid first byte in 3-byte UTF-8 sequence (must be 1110xxxx pattern)"
                Return result
            
            Note: Validate second byte is 10xxxxxx pattern (128-191 decimal)
            If second_byte_code is less than 128 Or second_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_3BYTE_SECOND"
                Let result.error_message be "Invalid second byte in 3-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            Note: Validate third byte is 10xxxxxx pattern (128-191 decimal)
            If third_byte_code is less than 128 Or third_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_3BYTE_THIRD"
                Let result.error_message be "Invalid third byte in 3-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            Note: Check for overlong encoding and surrogate pairs
            Note: Extract Unicode code point from 4 bits + 6 bits + 6 bits
            Let first_byte_bits be first_byte_code minus 224
            Let second_byte_bits be second_byte_code minus 128
            Let third_byte_bits be third_byte_code minus 128
            Let unicode_point be first_byte_bits multiplied by 4096 plus second_byte_bits multiplied by 64 plus third_byte_bits
            
            Note: 3-byte sequences must encode values >= U+0800 (2048)
            If unicode_point is less than 2048:
                Let result.error_code be "INVALID_UTF8_OVERLONG"
                Let result.error_message be "Overlong UTF-8 encoding (3-byte sequence for smaller character)"
                Return result
            
            Note: Check for surrogate pairs (U+D800-U+DFFF) which are invalid in UTF-8
            If unicode_point is greater than or equal to 55296 And unicode_point is less than or equal to 57343:
                Let result.error_code be "INVALID_UTF8_SURROGATE"
                Let result.error_message be "Invalid UTF-8 surrogate pair (U+D800-U+DFFF not allowed)"
                Return result
            
            Let result.is_valid be true
            Return result
        
        Otherwise If byte_count equals 4:
            Note: 4-byte UTF-8: 11110xxx 10xxxxxx 10xxxxxx 10xxxxxx (U+10000 to U+10FFFF)
            Let first_byte be character at position 0 in processed_value
            Let second_byte be character at position 1 in processed_value
            Let third_byte be character at position 2 in processed_value
            Let fourth_byte be character at position 3 in processed_value
            
            Note: Get actual byte values from characters
            Let first_byte_code be get_character_code with first_byte
            Let second_byte_code be get_character_code with second_byte
            Let third_byte_code be get_character_code with third_byte
            Let fourth_byte_code be get_character_code with fourth_byte
            
            Note: Validate first byte is 11110xxx pattern (240-247 decimal)
            If first_byte_code is less than 240 Or first_byte_code is greater than 247:
                Let result.error_code be "INVALID_UTF8_4BYTE_FIRST"
                Let result.error_message be "Invalid first byte in 4-byte UTF-8 sequence (must be 11110xxx pattern)"
                Return result
            
            Note: Validate all continuation bytes are 10xxxxxx pattern (128-191 decimal)
            If second_byte_code is less than 128 Or second_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_4BYTE_SECOND"
                Let result.error_message be "Invalid second byte in 4-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            If third_byte_code is less than 128 Or third_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_4BYTE_THIRD"
                Let result.error_message be "Invalid third byte in 4-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            If fourth_byte_code is less than 128 Or fourth_byte_code is greater than 191:
                Let result.error_code be "INVALID_UTF8_4BYTE_FOURTH"
                Let result.error_message be "Invalid fourth byte in 4-byte UTF-8 sequence (must be 10xxxxxx pattern)"
                Return result
            
            Note: Check for overlong encoding and values beyond Unicode range
            Note: Extract Unicode code point from 3 bits + 6 bits + 6 bits + 6 bits
            Let first_byte_bits be first_byte_code minus 240
            Let second_byte_bits be second_byte_code minus 128
            Let third_byte_bits be third_byte_code minus 128
            Let fourth_byte_bits be fourth_byte_code minus 128
            Let unicode_point be first_byte_bits multiplied by 262144 plus second_byte_bits multiplied by 4096 plus third_byte_bits multiplied by 64 plus fourth_byte_bits
            
            Note: 4-byte sequences must encode values >= U+10000 (65536) and <= U+10FFFF (1114111)
            If unicode_point is less than 65536:
                Let result.error_code be "INVALID_UTF8_OVERLONG"
                Let result.error_message be "Overlong UTF-8 encoding (4-byte sequence for smaller character)"
                Return result
            
            If unicode_point is greater than 1114111:
                Let result.error_code be "INVALID_UTF8_TOO_LARGE"
                Let result.error_message be "UTF-8 code point exceeds maximum Unicode value (U+10FFFF)"
                Return result
            
            Let result.is_valid be true
            Return result
        
        Otherwise:
            Let result.error_code be "INVALID_UTF8_LENGTH"
            Let result.error_message be "UTF-8 sequence length " concatenated with byte_count concatenated with " is invalid (must be 1-4 bytes)"
            Return result
        
        Note: UTF-8 validation successful
        Let result.is_valid be true
        Return result
        
    Otherwise If target_encoding equals "Latin-1" Or target_encoding equals "ISO-8859-1":
        Note: Latin-1 validation - extended ASCII (0-255)
        If length of processed_value is not equal to 1:
            Let result.error_code be "MULTIPLE_CHARACTERS"
            Let result.error_message be "Latin-1 encoding requires exactly one byte, found " concatenated with length of processed_value
            Return result
        
        Note: Latin-1 accepts all single bytes (0-255)
        Note: For production, we could validate specific Latin-1 character mappings
        Note: This implementation accepts any single byte as valid Latin-1
        Let result.is_valid be true
        Return result
        
    Otherwise:
        Let result.error_code be "UNSUPPORTED_ENCODING"
        Let result.error_message be "Unsupported character encoding: " concatenated with target_encoding
        Let result.expected_value be "ASCII, UTF-8, Latin-1, or ISO-8859-1"
        Return result
    
    Note: Should never reach here
    Let result.error_code be "VALIDATION_ERROR"
    Let result.error_message be "Unexpected error in character validation"
    Return result

Note: =====================================================================
Note: STRING VALIDATION OPERATIONS
Note: =====================================================================

Process called "validate_string_length" that takes value as String, min_length as Optional[Integer], max_length as Optional[Integer] returns ValidationResult:
    Note: Validate string length falls within specified bounds
    Note: Handles Unicode character counting vs byte counting
    Note: Supports minimum and maximum length constraints
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: Count actual characters (not bytes) for Unicode support
    Let character_count be length of value
    
    Note: Check minimum length constraint
    If min_length is not null:
        If character_count is less than min_length:
            Let result.error_code be "STRING_TOO_SHORT"
            Let result.error_message be "String length " concatenated with character_count concatenated with " is less than minimum required length " concatenated with min_length
            Let result.expected_value be "Length >= " concatenated with min_length
            Return result
    
    Note: Check maximum length constraint
    If max_length is not null:
        If character_count is greater than max_length:
            Let result.error_code be "STRING_TOO_LONG"
            Let result.error_message be "String length " concatenated with character_count concatenated with " exceeds maximum allowed length " concatenated with max_length
            Let result.expected_value be "Length <= " concatenated with max_length
            Return result
    
    Note: String length is within bounds
    Let result.is_valid be true
    Return result

Process called "validate_string_pattern" that takes value as String, pattern as String, pattern_type as Optional[String] returns ValidationResult:
    Note: Validate string matches specified pattern
    Note: Pattern types: regex, glob, wildcard (default: regex)
    Note: Supports case-sensitive and case-insensitive matching
    
    Let result be ValidationResult
    Set result.is_valid to false
    Set result.error_code to null
    Set result.error_message to null
    Set result.field_name to null
    Set result.expected_value to "String matching pattern: " joined with pattern
    Set result.actual_value to value
    
    Note: Determine pattern type (default to regex)
    Let type_to_use be "regex"
    If pattern_type is not null:
        Set type_to_use to pattern_type
    
    Note: Handle different pattern types
    If type_to_use equals "regex":
        Note: Use regex pattern matching
        Let regex_options be Regex.create_default_options()
        Let compiled_pattern be Regex.compile_regex(pattern, regex_options)
        Let match_result be Regex.match_regex(compiled_pattern, value)
        
        If match_result.success:
            Set result.is_valid to true
        Otherwise:
            Set result.error_code to "REGEX_PATTERN_MISMATCH"
            Set result.error_message to "String does not match regex pattern"
    
    Otherwise If type_to_use equals "wildcard":
        Note: Use wildcard pattern matching
        Let matches_wildcard be PatternMatch.match_wildcard_pattern(pattern, value)
        
        If matches_wildcard:
            Set result.is_valid to true
        Otherwise:
            Set result.error_code to "WILDCARD_PATTERN_MISMATCH"
            Set result.error_message to "String does not match wildcard pattern"
    
    Otherwise If type_to_use equals "glob":
        Note: Convert glob pattern to wildcard and match
        Let glob_as_wildcard be convert_glob_to_wildcard(pattern)
        Let matches_glob be PatternMatch.match_wildcard_pattern(glob_as_wildcard, value)
        
        If matches_glob:
            Set result.is_valid to true
        Otherwise:
            Set result.error_code to "GLOB_PATTERN_MISMATCH"
            Set result.error_message to "String does not match glob pattern"
    
    Otherwise:
        Note: Unsupported pattern type
        Set result.error_code to "UNSUPPORTED_PATTERN_TYPE"
        Set result.error_message to "Unsupported pattern type: " joined with type_to_use joined with ". Supported types: regex, wildcard, glob"
        Set result.expected_value to "Valid pattern type (regex, wildcard, glob)"
    
    Return result

Process called "convert_glob_to_wildcard" that takes glob_pattern as String returns String:
    Note: Convert glob pattern to wildcard pattern for matching
    Note: Glob: *.txt -> Wildcard: *.txt, **/*.txt -> */*.txt
    
    Let wildcard_pattern be glob_pattern
    
    Note: Convert double asterisk to single (simplified conversion)
    Set wildcard_pattern to StringCore.replace_all(wildcard_pattern, "**", "*")
    
    Return wildcard_pattern

Process called "validate_identifier" that takes value as String, style as Optional[String] returns ValidationResult:
    Note: Validate string is a valid identifier
    Note: Styles: camelCase, snake_case, PascalCase, kebab-case
    Note: Checks language-specific identifier rules
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: Check for empty identifier
    If length of value equals 0:
        Let result.error_code be "EMPTY_IDENTIFIER"
        Let result.error_message be "Identifier cannot be empty"
        Let result.expected_value be "Non-empty identifier string"
        Return result
    
    Note: Set default style
    Let target_style be "camelCase"
    If style is not null:
        Let target_style be style
    
    Note: Get first character for validation
    Let first_char be character at position 0 in value
    
    Note: First character must be letter or underscore (not digit)
    Let first_char_valid be false
    
    Note: Check if first character is a letter (A-Z, a-z)
    If first_char equals "A" Or first_char equals "B" Or first_char equals "C" Or first_char equals "D" Or first_char equals "E" Or first_char equals "F" Or first_char equals "G" Or first_char equals "H" Or first_char equals "I" Or first_char equals "J" Or first_char equals "K" Or first_char equals "L" Or first_char equals "M" Or first_char equals "N" Or first_char equals "O" Or first_char equals "P" Or first_char equals "Q" Or first_char equals "R" Or first_char equals "S" Or first_char equals "T" Or first_char equals "U" Or first_char equals "V" Or first_char equals "W" Or first_char equals "X" Or first_char equals "Y" Or first_char equals "Z":
        Let first_char_valid be true
    Otherwise If first_char equals "a" Or first_char equals "b" Or first_char equals "c" Or first_char equals "d" Or first_char equals "e" Or first_char equals "f" Or first_char equals "g" Or first_char equals "h" Or first_char equals "i" Or first_char equals "j" Or first_char equals "k" Or first_char equals "l" Or first_char equals "m" Or first_char equals "n" Or first_char equals "o" Or first_char equals "p" Or first_char equals "q" Or first_char equals "r" Or first_char equals "s" Or first_char equals "t" Or first_char equals "u" Or first_char equals "v" Or first_char equals "w" Or first_char equals "x" Or first_char equals "y" Or first_char equals "z":
        Let first_char_valid be true
    Otherwise If first_char equals "_":
        Let first_char_valid be true
    
    If not first_char_valid:
        Let result.error_code be "INVALID_IDENTIFIER_START"
        Let result.error_message be "Identifier must start with letter or underscore, not '" concatenated with first_char concatenated with "'"
        Let result.expected_value be "Identifier starting with letter or underscore"
        Return result
    
    Note: Validate remaining characters are alphanumeric or underscore
    Loop with i from 1 to length of value minus 1:
        Let char be character at position i in value
        Let char_valid be false
        
        Note: Check letters (A-Z, a-z)
        If char equals "A" Or char equals "B" Or char equals "C" Or char equals "D" Or char equals "E" Or char equals "F" Or char equals "G" Or char equals "H" Or char equals "I" Or char equals "J" Or char equals "K" Or char equals "L" Or char equals "M" Or char equals "N" Or char equals "O" Or char equals "P" Or char equals "Q" Or char equals "R" Or char equals "S" Or char equals "T" Or char equals "U" Or char equals "V" Or char equals "W" Or char equals "X" Or char equals "Y" Or char equals "Z":
            Let char_valid be true
        Otherwise If char equals "a" Or char equals "b" Or char equals "c" Or char equals "d" Or char equals "e" Or char equals "f" Or char equals "g" Or char equals "h" Or char equals "i" Or char equals "j" Or char equals "k" Or char equals "l" Or char equals "m" Or char equals "n" Or char equals "o" Or char equals "p" Or char equals "q" Or char equals "r" Or char equals "s" Or char equals "t" Or char equals "u" Or char equals "v" Or char equals "w" Or char equals "x" Or char equals "y" Or char equals "z":
            Let char_valid be true
        Note: Check digits (0-9)
        Otherwise If char equals "0" Or char equals "1" Or char equals "2" Or char equals "3" Or char equals "4" Or char equals "5" Or char equals "6" Or char equals "7" Or char equals "8" Or char equals "9":
            Let char_valid be true
        Note: Check underscore
        Otherwise If char equals "_":
            Let char_valid be true
        Note: Check hyphen for kebab-case
        Otherwise If char equals "-" And target_style equals "kebab-case":
            Let char_valid be true
        
        If not char_valid:
            Let result.error_code be "INVALID_IDENTIFIER_CHARACTER"
            Let result.error_message be "Invalid character '" concatenated with char concatenated with "' in identifier at position " concatenated with i
            Let result.expected_value be "Alphanumeric characters and underscore only"
            Return result
    
    Note: Validate style-specific rules
    If target_style equals "camelCase":
        Note: camelCase: first letter lowercase, no underscores/hyphens
        If first_char equals "A" Or first_char equals "B" Or first_char equals "C" Or first_char equals "D" Or first_char equals "E" Or first_char equals "F" Or first_char equals "G" Or first_char equals "H" Or first_char equals "I" Or first_char equals "J" Or first_char equals "K" Or first_char equals "L" Or first_char equals "M" Or first_char equals "N" Or first_char equals "O" Or first_char equals "P" Or first_char equals "Q" Or first_char equals "R" Or first_char equals "S" Or first_char equals "T" Or first_char equals "U" Or first_char equals "V" Or first_char equals "W" Or first_char equals "X" Or first_char equals "Y" Or first_char equals "Z":
            Let result.error_code be "INVALID_CAMEL_CASE"
            Let result.error_message be "camelCase identifiers must start with lowercase letter"
            Let result.expected_value be "camelCase format (e.g., 'myVariable')"
            Return result
        
        Note: Check for underscores/hyphens (not allowed in camelCase)
        Loop with i from 0 to length of value minus 1:
            Let char be character at position i in value
            If char equals "_" Or char equals "-":
                Let result.error_code be "INVALID_CAMEL_CASE"
                Let result.error_message be "camelCase identifiers cannot contain underscores or hyphens"
                Let result.expected_value be "camelCase format (e.g., 'myVariable')"
                Return result
    
    Otherwise If target_style equals "PascalCase":
        Note: PascalCase: first letter uppercase, no underscores/hyphens
        If not (first_char equals "A" Or first_char equals "B" Or first_char equals "C" Or first_char equals "D" Or first_char equals "E" Or first_char equals "F" Or first_char equals "G" Or first_char equals "H" Or first_char equals "I" Or first_char equals "J" Or first_char equals "K" Or first_char equals "L" Or first_char equals "M" Or first_char equals "N" Or first_char equals "O" Or first_char equals "P" Or first_char equals "Q" Or first_char equals "R" Or first_char equals "S" Or first_char equals "T" Or first_char equals "U" Or first_char equals "V" Or first_char equals "W" Or first_char equals "X" Or first_char equals "Y" Or first_char equals "Z"):
            Let result.error_code be "INVALID_PASCAL_CASE"
            Let result.error_message be "PascalCase identifiers must start with uppercase letter"
            Let result.expected_value be "PascalCase format (e.g., 'MyClass')"
            Return result
        
        Note: Check for underscores/hyphens (not allowed in PascalCase)
        Loop with i from 0 to length of value minus 1:
            Let char be character at position i in value
            If char equals "_" Or char equals "-":
                Let result.error_code be "INVALID_PASCAL_CASE"
                Let result.error_message be "PascalCase identifiers cannot contain underscores or hyphens"
                Let result.expected_value be "PascalCase format (e.g., 'MyClass')"
                Return result
    
    Otherwise If target_style equals "snake_case":
        Note: snake_case: lowercase letters, underscores allowed, no hyphens
        Loop with i from 0 to length of value minus 1:
            Let char be character at position i in value
            If char equals "A" Or char equals "B" Or char equals "C" Or char equals "D" Or char equals "E" Or char equals "F" Or char equals "G" Or char equals "H" Or char equals "I" Or char equals "J" Or char equals "K" Or char equals "L" Or char equals "M" Or char equals "N" Or char equals "O" Or char equals "P" Or char equals "Q" Or char equals "R" Or char equals "S" Or char equals "T" Or char equals "U" Or char equals "V" Or char equals "W" Or char equals "X" Or char equals "Y" Or char equals "Z":
                Let result.error_code be "INVALID_SNAKE_CASE"
                Let result.error_message be "snake_case identifiers must be lowercase"
                Let result.expected_value be "snake_case format (e.g., 'my_variable')"
                Return result
            Otherwise If char equals "-":
                Let result.error_code be "INVALID_SNAKE_CASE"
                Let result.error_message be "snake_case identifiers cannot contain hyphens"
                Let result.expected_value be "snake_case format (e.g., 'my_variable')"
                Return result
    
    Otherwise If target_style equals "kebab-case":
        Note: kebab-case: lowercase letters, hyphens allowed, no underscores
        Loop with i from 0 to length of value minus 1:
            Let char be character at position i in value
            If char equals "A" Or char equals "B" Or char equals "C" Or char equals "D" Or char equals "E" Or char equals "F" Or char equals "G" Or char equals "H" Or char equals "I" Or char equals "J" Or char equals "K" Or char equals "L" Or char equals "M" Or char equals "N" Or char equals "O" Or char equals "P" Or char equals "Q" Or char equals "R" Or char equals "S" Or char equals "T" Or char equals "U" Or char equals "V" Or char equals "W" Or char equals "X" Or char equals "Y" Or char equals "Z":
                Let result.error_code be "INVALID_KEBAB_CASE"
                Let result.error_message be "kebab-case identifiers must be lowercase"
                Let result.expected_value be "kebab-case format (e.g., 'my-variable')"
                Return result
            Otherwise If char equals "_":
                Let result.error_code be "INVALID_KEBAB_CASE"
                Let result.error_message be "kebab-case identifiers cannot contain underscores"
                Let result.expected_value be "kebab-case format (e.g., 'my-variable')"
                Return result
    
    Note: Identifier is valid
    Let result.is_valid be true
    Return result

Process called "validate_string_encoding" that takes value as String, required_encoding as String returns ValidationResult:
    Note: Validate string uses specified character encoding
    Note: Supported encodings: UTF-8, UTF-16, ASCII, Latin-1
    Note: Detects encoding violations and suggests corrections
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: Validate each character in the string based on required encoding
    Loop with i from 0 to length of value minus 1:
        Let char be character at position i in value
        
        Note: Use existing validate_character function to check encoding compliance
        Let char_result be validate_character with char, null, required_encoding
        
        If not char_result.is_valid:
            Let result.error_code be "ENCODING_VIOLATION"
            Let result.error_message be "Character at position " concatenated with i concatenated with " violates " concatenated with required_encoding concatenated with " encoding: " concatenated with char_result.error_message
            Let result.expected_value be required_encoding concatenated with " compliant characters only"
            Return result
    
    Note: All characters are valid for the required encoding
    Let result.is_valid be true
    Return result

