            Let lowercase_value be lowercase_value concatenated with "i"
        Otherwise If char equals "J":
            Let lowercase_value be lowercase_value concatenated with "j"
        Otherwise If char equals "K":
            Let lowercase_value be lowercase_value concatenated with "k"
        Otherwise If char equals "L":
            Let lowercase_value be lowercase_value concatenated with "l"
        Otherwise If char equals "M":
            Let lowercase_value be lowercase_value concatenated with "m"
        Otherwise If char equals "N":
            Let lowercase_value be lowercase_value concatenated with "n"
        Otherwise If char equals "O":
            Let lowercase_value be lowercase_value concatenated with "o"
        Otherwise If char equals "P":
            Let lowercase_value be lowercase_value concatenated with "p"
        Otherwise If char equals "Q":
            Let lowercase_value be lowercase_value concatenated with "q"
        Otherwise If char equals "R":
            Let lowercase_value be lowercase_value concatenated with "r"
        Otherwise If char equals "S":
            Let lowercase_value be lowercase_value concatenated with "s"
        Otherwise If char equals "T":
            Let lowercase_value be lowercase_value concatenated with "t"
        Otherwise If char equals "U":
            Let lowercase_value be lowercase_value concatenated with "u"
        Otherwise If char equals "V":
            Let lowercase_value be lowercase_value concatenated with "v"
        Otherwise If char equals "W":
            Let lowercase_value be lowercase_value concatenated with "w"
        Otherwise If char equals "X":
            Let lowercase_value be lowercase_value concatenated with "x"
        Otherwise If char equals "Y":
            Let lowercase_value be lowercase_value concatenated with "y"
        Otherwise If char equals "Z":
            Let lowercase_value be lowercase_value concatenated with "z"
        Otherwise:
            Let lowercase_value be lowercase_value concatenated with char
    
    Note: Determine allowed formats
    Let allow_true_false be true
    Let allow_yes_no be true
    Let allow_one_zero be true
    Let allow_on_off be true
    
    If accepted_formats is not null:
        Let allow_true_false be false
        Let allow_yes_no be false
        Let allow_one_zero be false
        Let allow_on_off be false
        
        Note: Check each accepted format
        Loop with i from 0 to length of accepted_formats minus 1:
            Let format be element at position i in accepted_formats
            If format equals "true/false" Or format equals "true_false":
                Let allow_true_false be true
            Otherwise If format equals "yes/no" Or format equals "yes_no":
                Let allow_yes_no be true
            Otherwise If format equals "1/0" Or format equals "one_zero":
                Let allow_one_zero be true
            Otherwise If format equals "on/off" Or format equals "on_off":
                Let allow_on_off be true
    
    Note: Check true values
    If allow_true_false:
        If lowercase_value equals "true":
            Let result.is_valid be true
            Return result
        If lowercase_value equals "false":
            Let result.is_valid be true
            Return result
    
    If allow_yes_no:
        If lowercase_value equals "yes":
            Let result.is_valid be true
            Return result
        If lowercase_value equals "no":
            Let result.is_valid be true
            Return result
    
    If allow_one_zero:
        If lowercase_value equals "1":
            Let result.is_valid be true
            Return result
        If lowercase_value equals "0":
            Let result.is_valid be true
            Return result
    
    If allow_on_off:
        If lowercase_value equals "on":
            Let result.is_valid be true
            Return result
        If lowercase_value equals "off":
            Let result.is_valid be true
            Return result
    
    Note: No valid boolean format found
    Let result.error_code be "INVALID_BOOLEAN"
    Let result.error_message be "'" concatenated with trimmed_value concatenated with "' is not a valid boolean value"
    
    Note: Build expected values list
    Let expected_list be ""
    If allow_true_false:
        Let expected_list be expected_list concatenated with "true, false"
    If allow_yes_no:
        If length of expected_list is greater than 0:
            Let expected_list be expected_list concatenated with ", "
        Let expected_list be expected_list concatenated with "yes, no"
    If allow_one_zero:
        If length of expected_list is greater than 0:
            Let expected_list be expected_list concatenated with ", "
        Let expected_list be expected_list concatenated with "1, 0"
    If allow_on_off:
        If length of expected_list is greater than 0:
            Let expected_list be expected_list concatenated with ", "
        Let expected_list be expected_list concatenated with "on, off"
    
    Let result.expected_value be expected_list
    Return result

Process called "validate_character" that takes value as String, encoding as Optional[String] returns ValidationResult:
    Note: Validate string contains exactly one valid character
    Note: Encoding specifies character set (UTF-8, ASCII, etc.)
    Note: Handles Unicode code points and escape sequences
    
    Let result be ValidationResult with:
        is_valid as false
        error_code as null
        error_message as null
        field_name as null
        expected_value as null
        actual_value as value
    
    Note: Check for empty or null string
    If value equals "" Or value equals null:
        Let result.error_code be "EMPTY_VALUE"
        Let result.error_message be "Value cannot be empty for character validation"
        Return result
    
    Note: Determine target encoding (default to UTF-8)
    Let target_encoding be "UTF-8"
    If encoding is not null:
        Let target_encoding be encoding
    
    Note: Handle escape sequences first
    Let processed_value be value
    Let escape_found be false
    
    If length of processed_value is greater than 1:
        Let first_char be character at position 0 in processed_value
        If first_char equals "\\":
            Let escape_found be true
            If length of processed_value equals 2:
                Let second_char be character at position 1 in processed_value
                If second_char equals "n":
                    Let processed_value be "\n"
                Otherwise If second_char equals "t":
                    Let processed_value be "\t"
                Otherwise If second_char equals "r":
                    Let processed_value be "\r"
                Otherwise If second_char equals "\\":
                    Let processed_value be "\\"
                Otherwise If second_char equals "\"":
                    Let processed_value be "\""
                Otherwise If second_char equals "'":
                    Let processed_value be "'"
                Otherwise If second_char equals "0":
                    Let processed_value be "\0"
                Otherwise:
                    Let result.error_code be "INVALID_ESCAPE"
                    Let result.error_message be "Invalid escape sequence '\\" concatenated with second_char concatenated with "'"
                    Return result
            Otherwise If length of processed_value equals 4:
                Note: Check for hex escape sequence \xHH
                Let second_char be character at position 1 in processed_value
                If second_char equals "x":
                    Let hex1 be character at position 2 in processed_value
                    Let hex2 be character at position 3 in processed_value
                    
                    Note: Validate hex digits
                    Let hex1_valid be false
                    Let hex2_valid be false
                    
                    If hex1 equals "0" Or hex1 equals "1" Or hex1 equals "2" Or hex1 equals "3" Or hex1 equals "4" Or hex1 equals "5" Or hex1 equals "6" Or hex1 equals "7" Or hex1 equals "8" Or hex1 equals "9" Or hex1 equals "A" Or hex1 equals "B" Or hex1 equals "C" Or hex1 equals "D" Or hex1 equals "E" Or hex1 equals "F" Or hex1 equals "a" Or hex1 equals "b" Or hex1 equals "c" Or hex1 equals "d" Or hex1 equals "e" Or hex1 equals "f":
                        Let hex1_valid be true
                    
                    If hex2 equals "0" Or hex2 equals "1" Or hex2 equals "2" Or hex2 equals "3" Or hex2 equals "4" Or hex2 equals "5" Or hex2 equals "6" Or hex2 equals "7" Or hex2 equals "8" Or hex2 equals "9" Or hex2 equals "A" Or hex2 equals "B" Or hex2 equals "C" Or hex2 equals "D" Or hex2 equals "E" Or hex2 equals "F" Or hex2 equals "a" Or hex2 equals "b" Or hex2 equals "c" Or hex2 equals "d" Or hex2 equals "e" Or hex2 equals "f":
                        Let hex2_valid be true
                    
                    If hex1_valid And hex2_valid:
                        Note: Valid hex escape - represent as single character
                        Let processed_value be "X"
                    Otherwise:
                        Let result.error_code be "INVALID_HEX_ESCAPE"
                        Let result.error_message be "Invalid hex escape sequence: expected \\xHH format"
                        Return result
                Otherwise:
                    Let result.error_code be "INVALID_ESCAPE"
                    Let result.error_message be "Invalid escape sequence: " concatenated with processed_value
                    Return result
            Otherwise If length of processed_value equals 6:
                Note: Check for Unicode escape sequence \uHHHH
                Let second_char be character at position 1 in processed_value
                If second_char equals "u":
                    Let all_hex_valid be true
                    Loop with i from 2 to 5:
                        Let hex_char be character at position i in processed_value
                        If not (hex_char equals "0" Or hex_char equals "1" Or hex_char equals "2" Or hex_char equals "3" Or hex_char equals "4" Or hex_char equals "5" Or hex_char equals "6" Or hex_char equals "7" Or hex_char equals "8" Or hex_char equals "9" Or hex_char equals "A" Or hex_char equals "B" Or hex_char equals "C" Or hex_char equals "D" Or hex_char equals "E" Or hex_char equals "F" Or hex_char equals "a" Or hex_char equals "b" Or hex_char equals "c" Or hex_char equals "d" Or hex_char equals "e" Or hex_char equals "f"):
                            Let all_hex_valid be false
                            Break
                    
                    If all_hex_valid:
                        Note: Valid Unicode escape - represent as single character
                        Let processed_value be "U"
                    Otherwise:
                        Let result.error_code be "INVALID_UNICODE_ESCAPE"
                        Let result.error_message be "Invalid Unicode escape sequence: expected \\uHHHH format"
                        Return result
                Otherwise:
                    Let result.error_code be "INVALID_ESCAPE"
                    Let result.error_message be "Invalid escape sequence: " concatenated with processed_value
                    Return result
            Otherwise:
                Let result.error_code be "INVALID_ESCAPE"
                Let result.error_message be "Invalid escape sequence length: " concatenated with processed_value
                Return result
    
    Note: Validate character count and encoding based on target encoding
    If target_encoding equals "ASCII":
