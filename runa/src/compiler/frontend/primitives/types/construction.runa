    Let input_str be value.unwrap().to_lowercase()
    Let parsed_value be parse_boolean_from_string(input_str)
    
    If parsed_value is not None:
        Set result.constructed_value to Some(parsed_value.unwrap().to_string())
        Set result.success to true
        Set result.memory_allocated to Some(1)
