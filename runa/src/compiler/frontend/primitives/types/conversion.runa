Note:
compiler/frontend/primitives/types/conversion.runa
Type Conversion Primitives

This module provides fundamental type conversion operations for all Runa primitive types.

Key features and capabilities:
- String conversion from all primitive types
- Numeric type conversions (integer, float, decimal)
- Boolean conversions and parsing
- Safe conversion with error handling
- Format-preserving conversions
- Locale-aware number formatting
- Performance-optimized for common conversions
- Zero-allocation conversions where possible
- Integration with compiler type system
- Error reporting for invalid conversions
- Memory-efficient string building
- Thread-safe conversion operations
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: CONVERSION RESULT TYPES
Note: =====================================================================

Type called "ConversionResult":
    success as Boolean                          Note: Whether conversion succeeded
    value as String                            Note: Converted value (as string for type safety)
    original_type as String                    Note: Source type information
    target_type as String                      Note: Target type information
    error_message as Optional[String]          Note: Error details if conversion failed

Type called "ParseResult":
    success as Boolean                          Note: Whether parsing succeeded
    parsed_value as String                     Note: Parsed value representation
    remainder as Optional[String]              Note: Unparsed portion if partial parse
    error_position as Optional[Integer]        Note: Character position of parse error

Note: =====================================================================
Note: STRING CONVERSION OPERATIONS
Note: =====================================================================

Process called "to_string" that takes value as Any returns String:
    Note: Convert any primitive type to its string representation
    Note: Handles: Integer, Float, Boolean, Char, null/nil
    Note: Time complexity: O(log n) for numbers, O(1) for others
    Note: Uses minimal allocation strategy for common cases
    
    Let type_name be value.get_type_name()
    
    If type_name equals "Integer":
        Let integer_val be value as Integer
        Return integer_to_string(integer_val, None)
    
    If type_name equals "Float":
        Let float_val be value as Float
        Return float_to_string(float_val, None, None)
    
    If type_name equals "Boolean":
        Let bool_val be value as Boolean
        Return boolean_to_string(bool_val, None)
    
    If type_name equals "Char":
        Let char_val be value as Char
        Return String.from_char(char_val)
    
    If type_name equals "String":
        Return value as String
    
    If value is None:
        Return "null"
    
    Return "unknown"

Process called "integer_to_string" that takes value as Integer, base as Optional[Integer] returns String:
    Note: Convert integer to string with optional base (2-36)
    Note: Default base is 10 (decimal)
    Note: Handles negative numbers with sign preservation
    Note: Optimized for common bases (2, 8, 10, 16)
    
    Let conversion_base be 10
    If base is not None:
        Let base_val be base.unwrap()
        If base_val < 2 or base_val > 36:
            Throw Errors.InvalidArgument with "Base must be between 2 and 36"
        Let conversion_base be base_val
    
    If value equals 0:
        Return "0"
    
    Let is_negative be value < 0
    Let abs_value be value
    If is_negative:
        Let abs_value be -value
    
    Let digits be "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    Let result_chars be List[Char].new()
    
    While abs_value > 0:
        Let remainder be abs_value % conversion_base
        Let digit_char be digits.char_at(remainder)
        result_chars.prepend(digit_char)
        Let abs_value be abs_value / conversion_base
    
    If is_negative:
        result_chars.prepend('-')
    
    Return String.from_chars(result_chars)

Process called "float_to_string" that takes value as Float, precision as Optional[Integer], format as Optional[String] returns String:
    Note: Convert floating-point to string with formatting options
    Note: Precision controls decimal places (default: 6)
    Note: Format options: "fixed", "scientific", "general" (default: "general")
    Note: Handles special values: Infinity, -Infinity, NaN
    
    If value.is_nan():
        Return "NaN"
    
    If value.is_infinite():
        If value < 0.0:
            Return "-Infinity"
        Return "Infinity"
    
    Let decimal_precision be 6
    If precision is not None:
        Let prec_val be precision.unwrap()
        If prec_val >= 0 and prec_val <= 15:
            Let decimal_precision be prec_val
    
    Let format_type be "general"
    If format is not None:
        Let fmt_val be format.unwrap()
        If fmt_val equals "fixed" or fmt_val equals "scientific" or fmt_val equals "general":
            Let format_type be fmt_val
    
    Let is_negative be value < 0.0
    Let abs_value be value
    If is_negative:
        Let abs_value be -value
    
    If format_type equals "scientific":
        Let exponent be 0
        Let mantissa be abs_value
        
        If abs_value >= 1.0:
            While mantissa >= 10.0:
                Let mantissa be mantissa / 10.0
                Let exponent be exponent + 1
        Else:
            If abs_value > 0.0:
                While mantissa < 1.0:
                    Let mantissa be mantissa * 10.0
                    Let exponent be exponent - 1
        
        Let mantissa_str be format_fixed_float(mantissa, decimal_precision)
        Let exp_sign be ""
        If exponent >= 0:
            Let exp_sign be "+"
        
        Let result be mantissa_str + "e" + exp_sign + integer_to_string(exponent, None)
        If is_negative:
            Return "-" + result
        Return result
    
    If format_type equals "fixed":
        Let result be format_fixed_float(abs_value, decimal_precision)
        If is_negative:
            Return "-" + result
        Return result
    
    Note: General format - choose best representation
    If abs_value >= 0.0001 and abs_value < 1000000.0:
        Let result be format_fixed_float(abs_value, decimal_precision)
        If is_negative:
            Return "-" + result
        Return result
    Else:
        Return float_to_string(value, precision, Some("scientific"))

Process called "format_fixed_float" that takes value as Float, precision as Integer returns String:
    Note: Helper function to format float with fixed decimal places
    
    Let integer_part be value.floor() as Integer
    Let fractional_part be value - (integer_part as Float)
    
    Let integer_str be integer_to_string(integer_part, None)
    
    If precision equals 0:
        Return integer_str
    
    Let result be integer_str + "."
    Let current_fraction be fractional_part
    
    For i from 1 to precision:
        Let current_fraction be current_fraction * 10.0
        Let digit be current_fraction.floor() as Integer
        Let result be result + integer_to_string(digit, None)
        Let current_fraction be current_fraction - (digit as Float)
    
    Return result

Process called "boolean_to_string" that takes value as Boolean, format as Optional[String] returns String:
    Note: Convert boolean to string representation
    Note: Format options: "true/false" (default), "yes/no", "1/0", "on/off"
    Note: Case-sensitive output based on format specification
    
    Let format_type be "true/false"
    If format is not None:
        Let fmt_val be format.unwrap()
        If fmt_val equals "yes/no" or fmt_val equals "1/0" or fmt_val equals "on/off":
            Let format_type be fmt_val
    
    If format_type equals "yes/no":
        If value:
            Return "yes"
        Return "no"
    
    If format_type equals "1/0":
        If value:
            Return "1"
        Return "0"
    
    If format_type equals "on/off":
        If value:
            Return "on"
        Return "off"
    
    Note: Default "true/false" format
    If value:
        Return "true"
    Return "false"

Note: =====================================================================
Note: NUMERIC CONVERSION OPERATIONS
Note: =====================================================================

Process called "to_integer" that takes value as String, base as Optional[Integer] returns Integer:
    Note: Parse string to integer with optional base (2-36)
    Note: Handles leading/trailing whitespace
    Note: Supports prefix notation: 0x (hex), 0o (octal), 0b (binary)
    Note: Validates range for target integer type
    
    Let trimmed be value.trim()
    If trimmed.length() equals 0:
        Throw Errors.InvalidFormat with "Empty string cannot be converted to integer"
    
    Let parse_base be 10
    Let start_index be 0
    Let is_negative be false
    
    If trimmed.starts_with("-"):
        Let is_negative be true
        Let start_index be 1
    Else:
        If trimmed.starts_with("+"):
            Let start_index be 1
    
    If start_index >= trimmed.length():
        Throw Errors.InvalidFormat with "Invalid integer format"
    
    Let remaining be trimmed.substring(start_index)
    
    Note: Auto-detect base from prefix
    If base is None:
        If remaining.starts_with("0x") or remaining.starts_with("0X"):
            Let parse_base be 16
            Let remaining be remaining.substring(2)
        Else:
            If remaining.starts_with("0o") or remaining.starts_with("0O"):
                Let parse_base be 8
                Let remaining be remaining.substring(2)
            Else:
                If remaining.starts_with("0b") or remaining.starts_with("0B"):
                    Let parse_base be 2
                    Let remaining be remaining.substring(2)
    Else:
        Let base_val be base.unwrap()
        If base_val < 2 or base_val > 36:
            Throw Errors.InvalidArgument with "Base must be between 2 and 36"
        Let parse_base be base_val
    
    If remaining.length() equals 0:
        Throw Errors.InvalidFormat with "No digits found after prefix"
    
    Let result be 0
    Let valid_chars be "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    
    For each char in remaining.chars():
        Let upper_char be char.to_uppercase()
        Let digit_index be valid_chars.find_index(upper_char)
        
        If digit_index is None or digit_index.unwrap() >= parse_base:
            Throw Errors.InvalidFormat with "Invalid digit for specified base"
        
        Let digit_value be digit_index.unwrap()
        Let result be result * parse_base + digit_value
    
    If is_negative:
        Return -result
    Return result

Process called "to_float" that takes value as String returns Float:
    Note: Parse string to floating-point number
    Note: Handles scientific notation (1.23e-4)
    Note: Recognizes special values: Infinity, -Infinity, NaN
    Note: Supports decimal point and comma based on locale
    
    Let trimmed be value.trim().to_lowercase()
    If trimmed.length() equals 0:
        Throw Errors.InvalidFormat with "Empty string cannot be converted to float"
    
    Note: Handle special values
    If trimmed equals "nan":
        Return Float.NaN
    
    If trimmed equals "infinity" or trimmed equals "inf":
        Return Float.Infinity
    
    If trimmed equals "-infinity" or trimmed equals "-inf":
        Return Float.NegativeInfinity
    
    Let is_negative be false
    Let working_str be trimmed
    
    If working_str.starts_with("-"):
        Let is_negative be true
        Let working_str be working_str.substring(1)
    Else:
        If working_str.starts_with("+"):
            Let working_str be working_str.substring(1)
    
    If working_str.length() equals 0:
        Throw Errors.InvalidFormat with "Invalid float format"
    
    Note: Handle scientific notation
    Let exponent be 0
    Let exponent_parts be working_str.split("e")
    If exponent_parts.length() equals 2:
        Let working_str be exponent_parts.get(0)
        Let exp_str be exponent_parts.get(1)
        Let exponent be to_integer(exp_str, None)
    Else:
        If exponent_parts.length() > 2:
            Throw Errors.InvalidFormat with "Multiple 'e' characters in float"
    
    Note: Parse mantissa
    Let decimal_parts be working_str.split(".")
    If decimal_parts.length() > 2:
        Throw Errors.InvalidFormat with "Multiple decimal points in float"
    
    Let integer_part be 0.0
    Let fractional_part be 0.0
    
    If decimal_parts.length() >= 1:
        Let int_str be decimal_parts.get(0)
        If int_str.length() > 0:
            Let integer_part be to_integer(int_str, None) as Float
    
    If decimal_parts.length() equals 2:
        Let frac_str be decimal_parts.get(1)
        If frac_str.length() > 0:
            Let frac_int be to_integer(frac_str, None) as Float
            Let divisor be 1.0
            For i from 1 to frac_str.length():
                Let divisor be divisor * 10.0
            Let fractional_part be frac_int / divisor
    
    Let result be integer_part + fractional_part
    
    Note: Apply scientific notation exponent
    If exponent != 0:
        Let multiplier be 1.0
        If exponent > 0:
            For i from 1 to exponent:
                Let multiplier be multiplier * 10.0
        Else:
            For i from 1 to (-exponent):
                Let multiplier be multiplier / 10.0
        Let result be result * multiplier
    
    If is_negative:
        Return -result
    Return result

Process called "integer_to_float" that takes value as Integer returns Float:
    Note: Convert integer to floating-point
    Note: Preserves value exactly if within float precision range
    Note: Handles large integers with appropriate rounding
    
    Return value as Float

Process called "float_to_integer" that takes value as Float, rounding_mode as Optional[String] returns Integer:
    Note: Convert float to integer with rounding control
    Note: Rounding modes: "truncate" (default), "round", "floor", "ceiling"
    Note: Checks for overflow/underflow conditions
    Note: Handles special float values appropriately
    
    If value.is_nan():
        Throw Errors.InvalidOperation with "Cannot convert NaN to integer"
    
    If value.is_infinite():
        Throw Errors.InvalidOperation with "Cannot convert infinite value to integer"
    
    Let mode be "truncate"
    If rounding_mode is not None:
        Let mode_val be rounding_mode.unwrap()
        If mode_val equals "round" or mode_val equals "floor" or mode_val equals "ceiling":
            Let mode be mode_val
    
    If mode equals "truncate":
        If value >= 0.0:
            Return value.floor() as Integer
        Else:
            Return value.ceiling() as Integer
    
    If mode equals "round":
        Return (value + 0.5).floor() as Integer
    
    If mode equals "floor":
        Return value.floor() as Integer
    
    If mode equals "ceiling":
        Return value.ceiling() as Integer
    
    Return value.floor() as Integer

Note: =====================================================================
Note: BOOLEAN CONVERSION OPERATIONS
Note: =====================================================================

Process called "to_boolean" that takes value as String returns Boolean:
    Note: Parse string to boolean value
    Note: Recognizes: true/false, yes/no, 1/0, on/off (case-insensitive)
    Note: Empty string converts to false
    Note: Non-empty numeric strings: 0 is false, others are true
    
    Let trimmed be value.trim().to_lowercase()
    
    If trimmed.length() equals 0:
        Return false
    
    Note: Handle explicit boolean strings
    If trimmed equals "true" or trimmed equals "yes" or trimmed equals "on":
        Return true
    
    If trimmed equals "false" or trimmed equals "no" or trimmed equals "off":
        Return false
    
    Note: Handle numeric strings
    If trimmed equals "1":
        Return true
    
    If trimmed equals "0":
        Return false
    
    Note: Try parsing as number for numeric logic
    Let is_valid_number be true
    Let numeric_value be 0.0
    
    Try:
        Let numeric_value be to_float(trimmed)
    Catch error:
        Let is_valid_number be false
    
    If is_valid_number:
        If numeric_value equals 0.0:
            Return false
        Return true
    
    Note: Non-empty, non-boolean, non-numeric strings are true
    Return true

Process called "integer_to_boolean" that takes value as Integer returns Boolean:
    Note: Convert integer to boolean
    Note: Zero is false, all other values are true
    Note: Consistent with C-style boolean semantics
    
    Return value != 0

Note: =====================================================================
Note: SAFE CONVERSION OPERATIONS
Note: =====================================================================

Process called "try_convert" that takes value as Any, target_type as String returns ConversionResult:
    Note: Attempt type conversion with error handling
    Note: Never throws exceptions, returns success/failure status
    Note: Provides detailed error information for debugging
    Note: Supports all primitive type conversions
    
    Let source_type be value.get_type_name()
    Let result be ConversionResult.new()
    Let result.original_type be source_type
    Let result.target_type be target_type
    
    Try:
        If target_type equals "String":
            Let result.value be to_string(value)
            Let result.success be true
            Return result
        
        If target_type equals "Integer":
            If source_type equals "String":
                Let converted be to_integer(value as String, None)
                Let result.value be integer_to_string(converted, None)
                Let result.success be true
                Return result
            
            If source_type equals "Float":
                Let converted be float_to_integer(value as Float, None)
                Let result.value be integer_to_string(converted, None)
                Let result.success be true
                Return result
            
            If source_type equals "Boolean":
                Let converted be 0
                If value as Boolean:
                    Let converted be 1
                Let result.value be integer_to_string(converted, None)
                Let result.success be true
                Return result
        
        If target_type equals "Float":
            If source_type equals "String":
                Let converted be to_float(value as String)
                Let result.value be float_to_string(converted, None, None)
                Let result.success be true
                Return result
            
            If source_type equals "Integer":
                Let converted be integer_to_float(value as Integer)
                Let result.value be float_to_string(converted, None, None)
                Let result.success be true
                Return result
        
        If target_type equals "Boolean":
            If source_type equals "String":
                Let converted be to_boolean(value as String)
                Let result.value be boolean_to_string(converted, None)
                Let result.success be true
                Return result
            
            If source_type equals "Integer":
                Let converted be integer_to_boolean(value as Integer)
                Let result.value be boolean_to_string(converted, None)
                Let result.success be true
                Return result
        
        Let result.success be false
        Let result.error_message be Some("Unsupported conversion from " + source_type + " to " + target_type)
        Return result
    
    Catch error:
        Let result.success be false
        Let result.error_message be Some(error.message)
        Return result

Process called "can_convert" that takes value as Any, target_type as String returns Boolean:
    Note: Check if conversion is possible without attempting it
    Note: Faster than trying conversion and checking result
    Note: Used for validation before expensive operations
    
    Let source_type be value.get_type_name()
    
    Note: String conversion is always possible
    If target_type equals "String":
        Return true
    
    Note: Integer conversions
    If target_type equals "Integer":
        If source_type equals "String":
            Let str_val be value as String
            Let trimmed be str_val.trim()
            If trimmed.length() equals 0:
                Return false
            Try:
                Let _ be to_integer(str_val, None)
                Return true
            Catch error:
                Return false
        
        If source_type equals "Float":
            Let float_val be value as Float
            Return not float_val.is_nan() and not float_val.is_infinite()
        
        If source_type equals "Boolean":
            Return true
    
    Note: Float conversions
    If target_type equals "Float":
        If source_type equals "String":
            Let str_val be value as String
            Try:
                Let _ be to_float(str_val)
                Return true
            Catch error:
                Return false
        
        If source_type equals "Integer":
            Return true
    
    Note: Boolean conversions
    If target_type equals "Boolean":
        If source_type equals "String" or source_type equals "Integer":
            Return true
    
    Return false

Note: =====================================================================
Note: ARRAY/COLLECTION CONVERSION OPERATIONS
Note: =====================================================================

Process called "string_to_char_array" that takes value as String returns List[Char]:
    Note: Convert string to array of characters
    Note: Handles Unicode properly (code points, not bytes)
    Note: Preserves string encoding information
    
    Let result be List[Char].new()
    For each char in value.chars():
        result.append(char)
    Return result

Process called "char_array_to_string" that takes chars as List[Char] returns String:
    Note: Build string from character array
    Note: Efficient concatenation without intermediate allocations
    Note: Validates character encoding consistency
    
    Return String.from_chars(chars)

Note: =====================================================================
Note: FORMATTING AND LOCALE OPERATIONS
Note: =====================================================================

Process called "format_with_locale" that takes value as Any, locale as String, format_spec as Optional[String] returns String:
    Note: Convert value to string using locale-specific formatting
    Note: Handles number separators, decimal points, date formats
    Note: Supports standard locale identifiers (en-US, fr-FR, etc.)
    
    Let type_name be value.get_type_name()
    Let decimal_separator be "."
    Let thousands_separator be ","
    
    Note: Determine locale-specific separators
    If locale.starts_with("fr") or locale.starts_with("de") or locale.starts_with("es") or locale.starts_with("it"):
        Let decimal_separator be ","
        Let thousands_separator be " "
    
    If locale.starts_with("en-IN") or locale.starts_with("hi"):
        Let thousands_separator be ","
    
    If type_name equals "Integer":
        Let int_val be value as Integer
        Let result be integer_to_string(int_val, None)
        
        Note: Add thousands separators for large numbers
        If int_val >= 1000 or int_val <= -1000:
            Let abs_str be result
            Let is_negative be false
            If result.starts_with("-"):
                Let abs_str be result.substring(1)
                Let is_negative be true
            
            Let formatted_parts be List[String].new()
            Let remaining be abs_str
            
            While remaining.length() > 3:
                Let part_start be remaining.length() - 3
                Let part be remaining.substring(part_start)
                formatted_parts.prepend(part)
                Let remaining be remaining.substring(0, part_start)
            
            If remaining.length() > 0:
                formatted_parts.prepend(remaining)
            
            Let result be formatted_parts.join(thousands_separator)
            If is_negative:
                Let result be "-" + result
        
        Return result
    
    If type_name equals "Float":
        Let float_val be value as Float
        Let precision be 2
        
        If format_spec is not None:
            Let spec_val be format_spec.unwrap()
            If spec_val.starts_with("f"):
                Let precision_str be spec_val.substring(1)
                If precision_str.length() > 0:
                    Let precision be to_integer(precision_str, None)
        
        Let result be float_to_string(float_val, Some(precision), Some("fixed"))
        
        Note: Replace decimal separator
        If decimal_separator != ".":
            Let result be result.replace(".", decimal_separator)
        
        Note: Add thousands separators to integer part
        Let parts be result.split(decimal_separator)
        If parts.length() >= 1:
            Let integer_part be parts.get(0)
            Let int_val be to_integer(integer_part, None)
            
            If int_val >= 1000 or int_val <= -1000:
                Let formatted_int be format_with_locale(int_val, locale, None)
                Let result be formatted_int
                
                If parts.length() > 1:
                    Let fractional_part be parts.get(1)
                    Let result be result + decimal_separator + fractional_part
        
        Return result
    
    If type_name equals "Boolean":
        Let bool_val be value as Boolean
        
        Note: Locale-specific boolean representations
        If locale.starts_with("fr"):
            If bool_val:
                Return "vrai"
            Return "faux"
        
        If locale.starts_with("de"):
            If bool_val:
                Return "wahr"
            Return "falsch"
        
        If locale.starts_with("es"):
            If bool_val:
                Return "verdadero"
            Return "falso"
        
        Return boolean_to_string(bool_val, None)
    
    Return to_string(value)

Process called "parse_with_locale" that takes value as String, target_type as String, locale as String returns ParseResult:
    Note: Parse string using locale-specific rules
    Note: Handles locale-specific number formats, date formats
    Note: Provides detailed parse error information
    
    Let result be ParseResult.new()
    Let working_value be value
    
    Note: Handle locale-specific decimal separator
    If target_type equals "Float":
        If locale.starts_with("fr") or locale.starts_with("de"):
            Let working_value be working_value.replace(",", ".")
    
    Try:
        If target_type equals "Integer":
            Let parsed be to_integer(working_value, None)
            Let result.success be true
            Let result.parsed_value be integer_to_string(parsed, None)
            Return result
        
        If target_type equals "Float":
            Let parsed be to_float(working_value)
            Let result.success be true
            Let result.parsed_value be float_to_string(parsed, None, None)
            Return result
        
        If target_type equals "Boolean":
            Let parsed be to_boolean(working_value)
            Let result.success be true
            Let result.parsed_value be boolean_to_string(parsed, None)
            Return result
        
        Let result.success be false
        Let result.error_position be Some(0)
        Return result
    
    Catch error:
        Let result.success be false
        Let result.error_position be Some(0)
        Return result

Note: =====================================================================
Note: ADDITIONAL STRING UTILITY FUNCTIONS
Note: =====================================================================

Process called "string_to_integer" that takes value as String returns Integer:
    Note: Convert string to integer (comprehensive version for math operations)
    Note: This delegates to the comprehensive to_integer function
    Return to_integer(value, None)

Process called "is_numeric_string" that takes value as String returns Boolean:
    Note: Check if string represents a valid number (integer or float)
    If value equals "":
        Return false
    
    Let trimmed be value.trim()
    If trimmed equals "":
        Return false
    
    Try:
        Let temp be to_integer(trimmed, None)
        Return true
    Catch integer_error:
        Try:
            Let temp be to_float(trimmed)
            Return true
        Catch float_error:
            Return false