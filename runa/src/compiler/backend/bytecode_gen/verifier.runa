    verification_level as String
    checked_properties as List[String]
    performance_impact as Float

Type called "VerificationContext":
    verification_mode as String
    security_level as String
    performance_requirements as Dictionary[String, Float]
    type_environment as Dictionary[String, String]
    validation_rules as List[String]

