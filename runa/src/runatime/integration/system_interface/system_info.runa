Note:
runatime/integration/system_interface/system_info.runa
System Information Query and Hardware Detection

This module provides comprehensive system information functionality including:
- Hardware detection and capability enumeration
- Operating system information and version details
- CPU architecture and instruction set detection
- Memory configuration and availability monitoring
- Storage device enumeration and capacity reporting
- Network interface discovery and configuration
- System performance metrics and resource usage
- Platform-specific feature detection and capabilities
- Runtime environment information and configuration
- System topology and NUMA node information
- Power management and thermal information
- Device driver and kernel module information
- System uptime and boot information
- Cross-platform system information abstraction
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: SYSTEM INFORMATION DATA STRUCTURES
Note: =====================================================================

Type called "SystemInfo":
    hostname as String
    operating_system as String
    os_version as String
    kernel_version as String
    architecture as String
    cpu_count as Integer
    total_memory_bytes as Integer
    boot_time as Integer
    uptime_seconds as Integer
    platform_type as String

Type called "CPUInfo":
    model_name as String
    vendor as String
    architecture as String
    instruction_sets as List[String]
    core_count as Integer
    thread_count as Integer
    base_frequency_mhz as Integer
    max_frequency_mhz as Integer
    cache_sizes as Dictionary[String, Integer]
    features as List[String]

Type called "MemoryInfo":
    total_physical_bytes as Integer
    available_physical_bytes as Integer
    used_physical_bytes as Integer
    total_virtual_bytes as Integer
    available_virtual_bytes as Integer
    page_size_bytes as Integer
    swap_total_bytes as Integer
    swap_free_bytes as Integer
    memory_pressure_level as String

Type called "StorageInfo":
    device_path as String
    device_type as String
    total_space_bytes as Integer
    free_space_bytes as Integer
    used_space_bytes as Integer
    filesystem_type as String
    mount_point as String
    is_removable as Boolean
    read_only as Boolean

