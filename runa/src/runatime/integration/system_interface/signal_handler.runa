Note:
runatime/integration/system_interface/signal_handler.runa
Signal Handling and Dispatching System

This module provides comprehensive signal handling functionality including:
- System signal registration and handling mechanisms
- Custom signal handler registration with priority management
- Signal masking and blocking operations for critical sections
- Asynchronous signal delivery and handling
- Signal chaining and propagation control
- Real-time signal support with queued delivery
- Signal safety and reentrancy management
- Integration with process lifecycle and cleanup
- Cross-platform signal abstraction and mapping
- Signal-based inter-process communication
- Graceful shutdown handling with cleanup sequences
- Signal debugging and tracing capabilities
- Integration with AOTT system for signal-aware optimization
- Thread-safe signal handling in multi-threaded environments
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: SIGNAL HANDLING DATA STRUCTURES
Note: =====================================================================

Type called "SignalInfo":
    signal_number as Integer
    signal_name as String
    signal_description as String
    is_real_time as Boolean
    default_action as String
    can_be_caught as Boolean
    can_be_ignored as Boolean
    can_be_blocked as Boolean
    priority_level as Integer
    platform_specific as Boolean

Type called "SignalHandler":
    handler_id as String
    signal_number as Integer
    handler_function as String
    handler_priority as Integer
    is_async_safe as Boolean
    is_thread_safe as Boolean
    registration_timestamp as Integer
    invocation_count as Integer
    error_count as Integer
    execution_time_total_ns as Integer

Type called "SignalContext":
    signal_number as Integer
    sender_process_id as Integer
    signal_value as Dictionary[String, String]
    delivery_timestamp as Integer
    handler_stack_depth as Integer
    interrupted_function as String
    register_state as Dictionary[String, String]
    memory_context as Dictionary[String, String]
    thread_id as String

Type called "SignalManager":
    registered_handlers as Dictionary[Integer, List[SignalHandler]]
    signal_masks as Dictionary[String, List[Integer]]
    pending_signals as List[SignalContext]
    blocked_signals as List[Integer]
    signal_statistics as Dictionary[Integer, Dictionary[String, Integer]]
    cleanup_handlers as List[String]

