Note:
runatime/integration/system_interface/process_manager.runa
Process Management and Control System

This module provides comprehensive process management functionality including:
- Process creation, execution, and lifecycle management
- Child process spawning with various execution modes
- Process monitoring and resource usage tracking
- Inter-process communication (IPC) mechanisms
- Process termination handling with graceful shutdown
- Process group management and session control
- Resource limit enforcement and quota management
- Process scheduling priority control
- Environment variable propagation and isolation
- Standard I/O redirection and pipe management
- Process tree navigation and relationship tracking
- Zombie process cleanup and orphan handling
- Integration with system process schedulers
- Cross-platform process management abstractions
:End Note

Import "dev/debug/errors/core" as Errors

Note: =====================================================================
Note: PROCESS MANAGEMENT DATA STRUCTURES
Note: =====================================================================

Type called "ProcessInfo":
    process_id as Integer
    parent_process_id as Integer
    process_name as String
    executable_path as String
    command_line_args as List[String]
    working_directory as String
    creation_timestamp as Integer
    cpu_time_used_ms as Integer
    memory_usage_bytes as Integer
    process_state as String
    exit_code as Integer
    priority as Integer

Type called "ProcessCreationConfig":
    executable_path as String
    arguments as List[String]
    environment_variables as Dictionary[String, String]
    working_directory as String
    inherit_environment as Boolean
    redirect_stdout as Boolean
    redirect_stderr as Boolean
    redirect_stdin as Boolean
    create_process_group as Boolean
    detach_from_parent as Boolean
    resource_limits as Dictionary[String, Integer]

Type called "ProcessMonitoringData":
    cpu_usage_percent as Float
    memory_rss_bytes as Integer
    memory_virtual_bytes as Integer
    file_handles_open as Integer
    network_connections as Integer
    threads_count as Integer
    context_switches as Integer
    page_faults as Integer
    io_read_bytes as Integer
    io_write_bytes as Integer

Type called "ProcessManager":
    active_processes as Dictionary[Integer, ProcessInfo]
    process_groups as Dictionary[Integer, List[Integer]]
    monitoring_data as Dictionary[Integer, ProcessMonitoringData]
    resource_limits as Dictionary[Integer, Dictionary[String, Integer]]
    cleanup_handlers as Dictionary[Integer, String]
    ipc_channels as Dictionary[Integer, List[String]]

