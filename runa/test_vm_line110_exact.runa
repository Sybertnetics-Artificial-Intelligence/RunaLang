"""
Exact recreation of VM line 110 context
"""

# Recreate the exact conditions from the VM at line 110
Let instructions be list containing 
    Dictionary with opcode as "LOAD_CONST" and value as 10,
    Dictionary with opcode as "BINARY_OP" and operator as "plus"

# Simulate being in the loop at index 1
Let i be 1
Let instruction be instructions at index i
Let opcode be instruction at key "opcode"

Display "At index:" followed by i
Display "Opcode:" followed by opcode

# Test the exact condition from line 109
If opcode is equal to "BINARY_OP" and i is greater than 0:
    Display "Condition matched - executing line 110"
    
    # This is the exact line 110 that's failing
    Let prev_instruction be instructions at index i minus 1
    
    Display "Success! prev_instruction:" followed by prev_instruction at key "opcode"

Display "Exact line 110 test complete!" 