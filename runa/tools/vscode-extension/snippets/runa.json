{
  "Function Definition": {
    "prefix": "function",
    "body": [
      "function ${1:function_name}(${2:parameters}):",
      "    ${3:# Function implementation}",
      "    return ${4:result}",
      "end"
    ],
    "description": "Create a function definition"
  },
  "Variable Declaration": {
    "prefix": "let",
    "body": [
      "let ${1:variable_name} = ${2:value}"
    ],
    "description": "Declare a variable"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition}:",
      "    ${2:# Code block}",
      "end"
    ],
    "description": "Create an if statement"
  },
  "If-Else Statement": {
    "prefix": "ifelse",
    "body": [
      "if ${1:condition}:",
      "    ${2:# If block}",
      "else:",
      "    ${3:# Else block}",
      "end"
    ],
    "description": "Create an if-else statement"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:collection}:",
      "    ${3:# Loop body}",
      "end"
    ],
    "description": "Create a for loop"
  },
  "While Loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition}:",
      "    ${2:# Loop body}",
      "end"
    ],
    "description": "Create a while loop"
  },
  "Match Statement": {
    "prefix": "match",
    "body": [
      "match ${1:expression}:",
      "    case ${2:pattern}:",
      "        ${3:# Case body}",
      "    case ${4:pattern}:",
      "        ${5:# Case body}",
      "    else:",
      "        ${6:# Default case}",
      "end"
    ],
    "description": "Create a match statement"
  },
  "Try-Catch": {
    "prefix": "try",
    "body": [
      "try:",
      "    ${1:# Try block}",
      "catch ${2:exception}:",
      "    ${3:# Catch block}",
      "finally:",
      "    ${4:# Finally block}",
      "end"
    ],
    "description": "Create a try-catch-finally block"
  },
  "Async Function": {
    "prefix": "async",
    "body": [
      "async function ${1:function_name}(${2:parameters}):",
      "    ${3:# Async function implementation}",
      "    return ${4:result}",
      "end"
    ],
    "description": "Create an async function"
  },
  "Process Definition": {
    "prefix": "process",
    "body": [
      "process ${1:process_name}:",
      "    ${2:# Process implementation}",
      "end"
    ],
    "description": "Create a process definition"
  },
  "Module Definition": {
    "prefix": "module",
    "body": [
      "module ${1:module_name}:",
      "    ${2:# Module implementation}",
      "end"
    ],
    "description": "Create a module definition"
  },
  "Import Statement": {
    "prefix": "import",
    "body": [
      "import ${1:module_name}"
    ],
    "description": "Import a module"
  },
  "Import From": {
    "prefix": "from",
    "body": [
      "from ${1:module_name} import ${2:items}"
    ],
    "description": "Import specific items from a module"
  },
  "Print Statement": {
    "prefix": "print",
    "body": [
      "print(${1:message})"
    ],
    "description": "Print a message"
  },
  "Comment Block": {
    "prefix": "comment",
    "body": [
      "# ${1:Comment description}",
      "# ${2:Additional details}"
    ],
    "description": "Create a comment block"
  },
  "Type Annotation": {
    "prefix": "type",
    "body": [
      ": ${1:type}"
    ],
    "description": "Add type annotation"
  },
  "Optional Type": {
    "prefix": "optional",
    "body": [
      "optional ${1:type}"
    ],
    "description": "Create an optional type"
  },
  "Union Type": {
    "prefix": "union",
    "body": [
      "${1:type1} or ${2:type2}"
    ],
    "description": "Create a union type"
  },
  "List Type": {
    "prefix": "list",
    "body": [
      "list of ${1:type}"
    ],
    "description": "Create a list type"
  },
  "Dictionary Type": {
    "prefix": "dict",
    "body": [
      "dictionary of ${1:key_type} to ${2:value_type}"
    ],
    "description": "Create a dictionary type"
  }
}