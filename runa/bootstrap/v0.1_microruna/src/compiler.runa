Note: v0.1 MicroRuna Compiler - MVL Runa Implementation
Note: A single-file compiler that can compile itself

Note: ========================================
Note: TOKEN TYPES (as integers)
Note: ========================================
Note: 1 = Let, 2 = Be, 3 = If, 4 = Is, 5 = Otherwise
Note: 6 = End, 7 = While, 8 = Less, 9 = Than, 10 = Greater
Note: 11 = Process, 12 = Called, 13 = Takes, 14 = Returns, 15 = Type
Note: 16 = As, 17 = Return, 18 = Add, 19 = To, 20 = Colon
Note: 21 = Comma, 22 = LeftParen, 23 = RightParen, 24 = LeftBracket, 25 = RightBracket
Note: 26 = Dot, 27 = Newline, 28 = Eof
Note: 100 = Integer, 101 = String, 102 = Identifier

Type called "Token":
    token_type as Integer
    value as String
    line as Integer
    column as Integer
End Type

Type called "Lexer":
    input as String
    position as Integer
    current_char as String
    line as Integer
    column as Integer
End Type

Note: ========================================
Note: LEXER IMPLEMENTATION
Note: ========================================

Process called "create_lexer" takes input as String returns Lexer:
    Let lex be a Lexer
    lex.input = input
    lex.position = 0
    lex.line = 1
    lex.column = 1

    If length_of(input) is greater than 0:
        lex.current_char = char_at(input, 0)
    Otherwise:
        lex.current_char = ""
    End If

    Return lex
End Process

Process called "advance_lexer" takes lex as Lexer returns Lexer:
    lex.position = add(lex.position, 1)

    If lex.current_char is "\n":
        lex.line = add(lex.line, 1)
        lex.column = 1
    Otherwise:
        lex.column = add(lex.column, 1)
    End If

    If lex.position is less than length_of(lex.input):
        lex.current_char = char_at(lex.input, lex.position)
    Otherwise:
        lex.current_char = ""
    End If

    Return lex
End Process

Process called "peek_char" takes lex as Lexer, offset as Integer returns String:
    Let pos be add(lex.position, offset)
    If pos is less than length_of(lex.input):
        Return char_at(lex.input, pos)
    Otherwise:
        Return ""
    End If
End Process

Process called "skip_whitespace" takes lex as Lexer returns Lexer:
    While length_of(lex.current_char) is greater than 0:
        If lex.current_char is " ":
            lex = advance_lexer(lex)
        Otherwise If lex.current_char is "\t":
            lex = advance_lexer(lex)
        Otherwise If lex.current_char is "\r":
            lex = advance_lexer(lex)
        Otherwise:
            Return lex
        End If
    End While
    Return lex
End Process

Process called "skip_comment" takes lex as Lexer returns Lexer:
    If lex.current_char is "N":
        If peek_char(lex, 1) is "o":
            If peek_char(lex, 2) is "t":
                If peek_char(lex, 3) is "e":
                    If peek_char(lex, 4) is ":":
                        While length_of(lex.current_char) is greater than 0:
                            If lex.current_char is "\n":
                                Return lex
                            End If
                            lex = advance_lexer(lex)
                        End While
                    End If
                End If
            End If
        End If
    End If
    Return lex
End Process

Process called "read_number" takes lex as Lexer returns Token:
    Let tok be a Token
    tok.token_type = 100
    tok.value = ""
    tok.line = lex.line
    tok.column = lex.column

    Let is_negative be 0
    If lex.current_char is "-":
        is_negative = 1
        tok.value = concat(tok.value, lex.current_char)
        lex = advance_lexer(lex)
    End If

    While is_digit(lex.current_char) is 1:
        tok.value = concat(tok.value, lex.current_char)
        lex = advance_lexer(lex)
    End While

    Return tok
End Process

Process called "read_string" takes lex as Lexer returns Token:
    Let tok be a Token
    tok.token_type = 101
    tok.value = ""
    tok.line = lex.line
    tok.column = lex.column

    lex = advance_lexer(lex)  Note: Skip opening quote

    While length_of(lex.current_char) is greater than 0:
        If lex.current_char is "\"":
            lex = advance_lexer(lex)  Note: Skip closing quote
            Return tok
        Otherwise If lex.current_char is "\\":
            lex = advance_lexer(lex)
            If lex.current_char is "n":
                tok.value = concat(tok.value, "\n")
            Otherwise If lex.current_char is "t":
                tok.value = concat(tok.value, "\t")
            Otherwise If lex.current_char is "r":
                tok.value = concat(tok.value, "\r")
            Otherwise If lex.current_char is "\\":
                tok.value = concat(tok.value, "\\")
            Otherwise If lex.current_char is "\"":
                tok.value = concat(tok.value, "\"")
            Otherwise:
                tok.value = concat(tok.value, lex.current_char)
            End If
            lex = advance_lexer(lex)
        Otherwise:
            tok.value = concat(tok.value, lex.current_char)
            lex = advance_lexer(lex)
        End If
    End While

    Return tok
End Process

Process called "read_identifier" takes lex as Lexer returns Token:
    Let tok be a Token
    tok.token_type = 102
    tok.value = ""
    tok.line = lex.line
    tok.column = lex.column

    While length_of(lex.current_char) is greater than 0:
        If is_alpha(lex.current_char) is 1:
            tok.value = concat(tok.value, lex.current_char)
            lex = advance_lexer(lex)
        Otherwise If is_digit(lex.current_char) is 1:
            tok.value = concat(tok.value, lex.current_char)
            lex = advance_lexer(lex)
        Otherwise If lex.current_char is "_":
            tok.value = concat(tok.value, lex.current_char)
            lex = advance_lexer(lex)
        Otherwise:
            Return tok
        End If
    End While

    Return tok
End Process

Process called "check_keyword" takes tok as Token returns Token:
    If tok.value is "Let":
        tok.token_type = 1
    Otherwise If tok.value is "be":
        tok.token_type = 2
    Otherwise If tok.value is "If":
        tok.token_type = 3
    Otherwise If tok.value is "is":
        tok.token_type = 4
    Otherwise If tok.value is "Otherwise":
        tok.token_type = 5
    Otherwise If tok.value is "End":
        tok.token_type = 6
    Otherwise If tok.value is "While":
        tok.token_type = 7
    Otherwise If tok.value is "less":
        tok.token_type = 8
    Otherwise If tok.value is "than":
        tok.token_type = 9
    Otherwise If tok.value is "greater":
        tok.token_type = 10
    Otherwise If tok.value is "Process":
        tok.token_type = 11
    Otherwise If tok.value is "called":
        tok.token_type = 12
    Otherwise If tok.value is "takes":
        tok.token_type = 13
    Otherwise If tok.value is "returns":
        tok.token_type = 14
    Otherwise If tok.value is "Type":
        tok.token_type = 15
    Otherwise If tok.value is "as":
        tok.token_type = 16
    Otherwise If tok.value is "Return":
        tok.token_type = 17
    Otherwise If tok.value is "add":
        tok.token_type = 18
    Otherwise If tok.value is "to":
        tok.token_type = 19
    End If

    Return tok
End Process

Process called "next_token" takes lex as Lexer returns Token:
    lex = skip_whitespace(lex)
    lex = skip_comment(lex)

    Let tok be a Token
    tok.line = lex.line
    tok.column = lex.column

    If length_of(lex.current_char) is 0:
        tok.token_type = 28  Note: EOF
        tok.value = ""
        Return tok
    End If

    If lex.current_char is "\n":
        tok.token_type = 27  Note: Newline
        tok.value = "\n"
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is ":":
        tok.token_type = 20  Note: Colon
        tok.value = ":"
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is ",":
        tok.token_type = 21  Note: Comma
        tok.value = ","
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is "(":
        tok.token_type = 22  Note: LeftParen
        tok.value = "("
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is ")":
        tok.token_type = 23  Note: RightParen
        tok.value = ")"
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is "[":
        tok.token_type = 24  Note: LeftBracket
        tok.value = "["
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is "]":
        tok.token_type = 25  Note: RightBracket
        tok.value = "]"
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is ".":
        tok.token_type = 26  Note: Dot
        tok.value = "."
        lex = advance_lexer(lex)
        Return tok
    End If

    If lex.current_char is "\"":
        Return read_string(lex)
    End If

    If lex.current_char is "-":
        If is_digit(peek_char(lex, 1)) is 1:
            Return read_number(lex)
        End If
    End If

    If is_digit(lex.current_char) is 1:
        Return read_number(lex)
    End If

    If is_alpha(lex.current_char) is 1:
        tok = read_identifier(lex)
        Return check_keyword(tok)
    End If

    If lex.current_char is "_":
        Return read_identifier(lex)
    End If

    Note: Unknown character - skip it
    lex = advance_lexer(lex)
    Return next_token(lex)
End Process

Process called "tokenize" takes source as String returns List:
    Let tokens be a list containing
    Let lex be create_lexer(source)

    While 1 is 1:
        Let tok be next_token(lex)
        add_to_list(tokens, tok)

        If tok.token_type is 28:  Note: EOF
            Return tokens
        End If
    End While

    Return tokens
End Process

Note: ========================================
Note: MAIN ENTRY POINT (for testing lexer)
Note: ========================================

Process called "main" takes args as List returns Integer:
    If length_of(args) is less than 2:
        write_file("stderr", "Usage: compiler <source.runa>\n")
        Return 1
    End If

    Let source_file be char_at(args, 1)
    Let source be read_file(source_file)

    Let tokens be tokenize(source)

    Note: For now, just print token count to verify lexer works
    Let token_count be length_of(tokens)
    write_file("stdout", "Lexer found ")
    write_file("stdout", to_string(token_count))
    write_file("stdout", " tokens\n")

    Return 0
End Process