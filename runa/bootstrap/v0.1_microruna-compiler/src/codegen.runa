Note: MicroRunaCodeGenerator

Note: Global codegen state
Let cg_string_pool be ""
Let cg_string_counter be 0
Let cg_var_map be ""
Let cg_stack_offset be 0
Let cg_label_counter be 0
Let cg_var_types be ""
Let cg_func_ret_map be ""
Let cg_loop_start_labels be ""
Let cg_loop_end_labels be ""

Process called "find_char" that takes text as String, char_code as Integer, start_pos as Integer returns Integer:
    Note: Find character position starting at offset
    Let text_length be length_of(text)
    Let i be start_pos
    While i is less than text_length:
        If char_at(text, i) is equal to char_code:
            Return i
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "ingest_type_info" that takes mapping as String:
    Note: Accept external type map (var|type;var2|type2;...)
    Set cg_var_types to mapping
End Process

Process called "fresh_label" that takes prefix as String returns String:
    Note: Generate a unique local label
    Let lbl be ".Lcg_"
    Set lbl to concat(lbl, prefix)
    Set lbl to concat(lbl, "_")
    Set lbl to concat(lbl, to_string(cg_label_counter))
    Set cg_label_counter to cg_label_counter plus 1
    Return lbl
End Process

Process called "record_function_return" that takes name as String, rtype as String:
    If length_of(cg_func_ret_map) is greater than 0:
        Set cg_func_ret_map to concat(cg_func_ret_map, ";")
    End If
    Set cg_func_ret_map to concat(cg_func_ret_map, name)
    Set cg_func_ret_map to concat(cg_func_ret_map, "|")
    Set cg_func_ret_map to concat(cg_func_ret_map, rtype)
End Process

Process called "lookup_function_return" that takes name as String returns String:
    If length_of(cg_func_ret_map) is equal to 0:
        Return "Unknown"
    End If
    Let i be 0
    Let start be 0
    Let n be length_of(cg_func_ret_map)
    While i is less than n plus 1:
        Let ch be 0
        If i is less than n:
            Set ch to char_at(cg_func_ret_map, i)
        End If
        If ch is equal to 59 Or i is equal to n:
            Let ent be substring(cg_func_ret_map, start, i)
            Let ppos be find_char(ent, 124, 0)
            If ppos is greater than 0:
                Let nm be substring(ent, 0, ppos)
                If nm is equal to name:
                    Return substring(ent, ppos plus 1, length_of(ent))
                End If
            End If
            Set start to i plus 1
        End If
        Set i to i plus 1
    End While
    Return "Unknown"
End Process

Process called "push_loop_labels" that takes start_lbl as String, end_lbl as String:
    If length_of(cg_loop_start_labels) is greater than 0:
        Set cg_loop_start_labels to concat(cg_loop_start_labels, ";")
        Set cg_loop_end_labels to concat(cg_loop_end_labels, ";")
    End If
    Set cg_loop_start_labels to concat(cg_loop_start_labels, start_lbl)
    Set cg_loop_end_labels to concat(cg_loop_end_labels, end_lbl)
End Process

Process called "pop_loop_labels":
    Let n be length_of(cg_loop_start_labels)
    If n is equal to 0:
        Return
    End If
    Let i be n minus 1
    While i is greater than 0 Or i is equal to 0:
        If char_at(cg_loop_start_labels, i) is equal to 59:
            Set cg_loop_start_labels to substring(cg_loop_start_labels, 0, i)
            Set i to 0 minus 1
        End If
        If i is greater than 0 Or i is equal to 0:
            Set i to i minus 1
        End If
    End While
    Let m be length_of(cg_loop_end_labels)
    If m is equal to 0:
        Return
    End If
    Let j be m minus 1
    While j is greater than 0 Or j is equal to 0:
        If char_at(cg_loop_end_labels, j) is equal to 59:
            Set cg_loop_end_labels to substring(cg_loop_end_labels, 0, j)
            Set j to 0 minus 1
        End If
        If j is greater than 0 Or j is equal to 0:
            Set j to j minus 1
        End If
    End While
End Process

Process called "current_loop_start" returns String:
    Let n be length_of(cg_loop_start_labels)
    If n is equal to 0:
        Return ""
    End If
    Let i be n minus 1
    Let last_sep be 0 minus 1
    While i is greater than 0 Or i is equal to 0:
        If char_at(cg_loop_start_labels, i) is equal to 59:
            Set last_sep to i
            Set i to 0 minus 1
        End If
        If i is greater than 0 Or i is equal to 0:
            Set i to i minus 1
        End If
    End While
    If last_sep is equal to 0 minus 1:
        Return cg_loop_start_labels
    End If
    Return substring(cg_loop_start_labels, last_sep plus 1, n)
End Process

Process called "current_loop_end" returns String:
    Let n be length_of(cg_loop_end_labels)
    If n is equal to 0:
        Return ""
    End If
    Let i be n minus 1
    Let last_sep be 0 minus 1
    While i is greater than 0 Or i is equal to 0:
        If char_at(cg_loop_end_labels, i) is equal to 59:
            Set last_sep to i
            Set i to 0 minus 1
        End If
        If i is greater than 0 Or i is equal to 0:
            Set i to i minus 1
        End If
    End While
    If last_sep is equal to 0 minus 1:
        Return cg_loop_end_labels
    End If
    Return substring(cg_loop_end_labels, last_sep plus 1, n)
End Process

Process called "record_var_type" that takes name as String, vtype as String:
    Note: Track variable types for type-aware printing
    If length_of(cg_var_types) is greater than 0:
        Set cg_var_types to concat(cg_var_types, ";")
    End If
    Set cg_var_types to concat(cg_var_types, name)
    Set cg_var_types to concat(cg_var_types, "|")
    Set cg_var_types to concat(cg_var_types, vtype)
End Process

Process called "lookup_var_type" that takes name as String returns String:
    If length_of(cg_var_types) is equal to 0:
        Return "Unknown"
    End If
    Let i be 0
    Let start be 0
    Let n be length_of(cg_var_types)
    While i is less than n plus 1:
        Let ch be 0
        If i is less than n:
            Set ch to char_at(cg_var_types, i)
        End If
        If ch is equal to 59 Or i is equal to n:
            Let ent be substring(cg_var_types, start, i)
            Let ppos be find_char(ent, 124, 0)
            If ppos is greater than 0:
                Let nm be substring(ent, 0, ppos)
                If nm is equal to name:
                    Return substring(ent, ppos plus 1, length_of(ent))
                End If
            End If
            Set start to i plus 1
        End If
        Set i to i plus 1
    End While
    Return "Unknown"
End Process

Process called "escape_rodata_string" that takes value as String returns String:
    Note: Escape quotes, backslashes and control chars for .string
    Let out be ""
    Let i be 0
    Let n be length_of(value)
    While i is less than n:
        Let c be char_at(value, i)
        If c is equal to 92:
            Set out to concat(out, "\\\\")
        End If
        If c is equal to 34:
            Set out to concat(out, "\\\"")
        End If
        If c is equal to 10:
            Set out to concat(out, "\\n")
        End If
        If c is equal to 9:
            Set out to concat(out, "\\t")
        End If
        If c is equal to 13:
            Set out to concat(out, "\\r")
        End If
        If c is not equal to 92:
            If c is not equal to 34:
                If c is not equal to 10:
                    If c is not equal to 9:
                        If c is not equal to 13:
                            Set out to concat(out, substring(value, i, i plus 1))
                        End If
                    End If
                End If
            End If
        End If
        Set i to i plus 1
    End While
    Return out
End Process

Process called "parse_integer" that takes text as String returns Integer:
    Note: Parse non-negative decimal integer
    Let result be 0
    Let i be 0
    Let n be length_of(text)
    While i is less than n:
        Let c be char_at(text, i)
        If c is greater than 0 Or c is equal to 0:
            If c is less than 0 Or c is equal to 0:
                Let digit be c minus 48
                Let tmp be result multiplied by 10
                Set result to tmp plus digit
            End If
        End If
        Set i to i plus 1
    End While
    Return result
End Process

Process called "pool_string_literal" that takes value as String returns String:
    Note: Add string to pool and return label
    Let label be ".LS"
    Set label to concat(label, to_string(cg_string_counter))
    Set cg_string_counter to cg_string_counter plus 1

    Let entry be label
    Set entry to concat(entry, "|")
    Set entry to concat(entry, value)
    If length_of(cg_string_pool) is equal to 0:
        Set cg_string_pool to entry
    Otherwise:
        Set cg_string_pool to concat(cg_string_pool, ";")
        Set cg_string_pool to concat(cg_string_pool, entry)
    End If
    Return label
End Process

Process called "begin_function_codegen":
    Note: Reset function-local state
    Set cg_var_map to ""
    Set cg_stack_offset to 0
End Process

Process called "lookup_var_offset" that takes name as String returns Integer:
    Note: Lookup variable offset in cg_var_map formatted as name|offset;...
    If length_of(cg_var_map) is equal to 0:
        Return 0
    End If
    Let i be 0
    Let start_pos be 0
    Let map_len be length_of(cg_var_map)
    While i is less than map_len plus 1:
        Let ch be 0
        If i is less than map_len:
            Set ch to char_at(cg_var_map, i)
        End If
        If ch is equal to 59 Or i is equal to map_len:
            Let entry be substring(cg_var_map, start_pos, i)
            Let ppos be find_char(entry, 124, 0)
            If ppos is greater than 0:
                Let entry_name be substring(entry, 0, ppos)
                If entry_name is equal to name:
                    Let offs_str be substring(entry, ppos plus 1, length_of(entry))
                    Return parse_integer(offs_str)
                End If
            End If
            Set start_pos to i plus 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "record_var_offset" that takes name as String, offset as Integer:
    Note: Record mapping name->offset
    Let entry be name
    Set entry to concat(entry, "|")
    Set entry to concat(entry, to_string(offset))
    If length_of(cg_var_map) is equal to 0:
        Set cg_var_map to entry
    Otherwise:
        Set cg_var_map to concat(cg_var_map, ";")
        Set cg_var_map to concat(cg_var_map, entry)
    End If
End Process

Process called "extract_ast_part" that takes ast_data as String, part_index as Integer returns String:
    Note: ExtractASTComponent
    Let current_part be 0
    Let start_pos be 0
    Let i be 0
    Let ast_length be length_of(ast_data)

    While i is less than ast_length:
        Let char_code be char_at(ast_data, i)
        If char_code is equal to 124:
            If current_part is equal to part_index:
                Return substring(ast_data, start_pos, i)
            End If
            Set current_part to current_part plus 1
            Set start_pos to i plus 1
        End If
        Set i to i plus 1
    End While

    If current_part is equal to part_index:
        Return substring(ast_data, start_pos, ast_length)
    End If
    Return ""
End Process

Process called "generate_assembly_header" that returns String:
    Note: GenerateAssemblyHeader
    Let header be ".text\n"
    Return header
End Process

Process called "generate_assembly_footer" that returns String:
    Note: GenerateAssemblyFooter
    Return ""
End Process

Process called "generate_function_call" that takes ast as String returns String:
    Note: GenerateFunctionCall (SysV x86-64)
    Let func_name be extract_ast_part(ast, 1)
    Let args_blob be extract_ast_part(ast, 2)

    Let code be "    # Function call: "
    Set code to concat(code, func_name)
    Set code to concat(code, "\n")

    Note: Split args_blob on '|' into individual arg ASTs (simple scan)
    Let args be ""
    Let i be 0
    Let n be length_of(args_blob)
    Let start be 0
    While i is less than n plus 1:
        Let ch be 0
        If i is less than n:
            Set ch to char_at(args_blob, i)
        End If
        If ch is equal to 124 Or i is equal to n:
            Let one_arg be substring(args_blob, start, i)
            If length_of(one_arg) is greater than 0:
                Set args to append_string_with_separator(args, one_arg, "|")
            End If
            Set start to i plus 1
        End If
        Set i to i plus 1
    End While

    Note: Count arguments
    Let argc be 0
    Let j be 0
    Let m be length_of(args)
    Let seg_start be 0
    While j is less than m plus 1:
        Let ch2 be 0
        If j is less than m:
            Set ch2 to char_at(args, j)
        End If
        If ch2 is equal to 124 Or j is equal to m:
            If j is greater than seg_start:
                Set argc to argc plus 1
            End If
            Set seg_start to j plus 1
        End If
        Set j to j plus 1
    End While

    Note: Evaluate each arg left-to-right and push its value (in %rax)
    Let k be 0
    Let cur_start be 0
    Let emitted be ""
    Let yy be 0
    While yy is less than m plus 1:
        Let ch3 be 0
        If yy is less than m:
            Set ch3 to char_at(args, yy)
        End If
        If ch3 is equal to 124 Or yy is equal to m:
            If yy is greater than cur_start:
                Let arg_ast be substring(args, cur_start, yy)
                Let eval be generate_expression_code(arg_ast)
                Set code to concat(code, eval)
                Set code to concat(code, "    pushq %rax\n")
                Set k to k plus 1
            End If
            Set cur_start to yy plus 1
        End If
        Set yy to yy plus 1
    End While

    Note: Move first 6 args into registers in reverse order
    Let reg_count be argc
    If reg_count is greater than 6:
        Set reg_count to 6
    End If

    Let r be 0
    While r is less than reg_count:
        Let idx be reg_count minus r minus 1
        Let which be 0
        If idx is equal to 0:
            Let which be 0
        End If
        If idx is equal to 1:
            Let which be 1
        End If
        If idx is equal to 2:
            Let which be 2
        End If
        If idx is equal to 3:
            Let which be 3
        End If
        If idx is equal to 4:
            Let which be 4
        End If
        If idx is equal to 5:
            Let which be 5
        End If

        Set code to concat(code, "    popq %rax\n")
        If which is equal to 0:
            Set code to concat(code, "    movq %rax, %rdi\n")
        End If
        If which is equal to 1:
            Set code to concat(code, "    movq %rax, %rsi\n")
        End If
        If which is equal to 2:
            Set code to concat(code, "    movq %rax, %rdx\n")
        End If
        If which is equal to 3:
            Set code to concat(code, "    movq %rax, %rcx\n")
        End If
        If which is equal to 4:
            Set code to concat(code, "    movq %rax, %r8\n")
        End If
        If which is equal to 5:
            Set code to concat(code, "    movq %rax, %r9\n")
        End If

        Set r to r plus 1
    End While

    Note: Any remaining args (>6) need to be kept on the stack in reverse order
    Let stack_count be argc minus reg_count
    If stack_count is less than 0:
        Set stack_count to 0
    End If

    Note: Align stack to 16 before call (rsp % 16 == 0)
    Set code to concat(code, "    movq %rsp, %rax\n")
    Set code to concat(code, "    andq $15, %rax\n")
    Set code to concat(code, "    jz .L_call_align_ok\n")
    Set code to concat(code, "    subq $8, %rsp\n")
    Set code to concat(code, ".L_call_align_ok:\n")

    Note: Emit call. Symbol convention: runa_function_<name>
    Let sym be "runa_function_"
    Set sym to concat(sym, func_name)
    Set code to concat(code, "    call ")
    Set code to concat(code, sym)
    Set code to concat(code, "\n")

    Note: If we aligned by -8, fix it back (test again)
    Set code to concat(code, "    movq %rsp, %rax\n")
    Set code to concat(code, "    andq $15, %rax\n")
    Set code to concat(code, "    jz .L_call_align_done\n")
    Set code to concat(code, "    addq $8, %rsp\n")
    Set code to concat(code, ".L_call_align_done:\n")

    Note: Clean up stack arguments (>6) after call
    If argc is greater than 6:
        Let extra be argc minus 6
        Let bytes be extra multiplied by 8
        Set code to concat(code, "    addq $")
        Set code to concat(code, to_string(bytes))
        Set code to concat(code, ", %rsp\n")
    End If

    Return code
End Process

Process called "generate_expression_code" that takes expr_ast as String returns String:
    Note: GenerateExpressionCode
    Let expr_type be extract_ast_part(expr_ast, 0)

    If expr_type is equal to "integer_literal":
        Let value be extract_ast_part(expr_ast, 1)
        Let code be "    movq $"
        Set code to concat(code, value)
        Set code to concat(code, ", %rax\n")
        Return code
    End If

    If expr_type is equal to "string_literal":
        Let value be extract_ast_part(expr_ast, 1)
        Let label be pool_string_literal(value)
        Let code be "    leaq "
        Set code to concat(code, label)
        Set code to concat(code, "(%rip), %rax\n")
        Return code
    End If

    If expr_type is equal to "identifier":
        Let var_name be extract_ast_part(expr_ast, 1)
        Let offset be lookup_var_offset(var_name)
        If offset is greater than 0:
            Let code be "    movq -"
            Set code to concat(code, to_string(offset))
            Set code to concat(code, "(%rbp), %rax\n")
            Return code
        End If
        Return "    # Unknown identifier\n"
    End If

    If expr_type is equal to "binary_expression":
        Let left_expr be extract_ast_part(expr_ast, 1)
        Let operator be extract_ast_part(expr_ast, 2)
        Let right_expr be extract_ast_part(expr_ast, 3)

        Let code be generate_expression_code(left_expr)
        Set code to concat(code, "    pushq %rax\n")
        Let right_code be generate_expression_code(right_expr)
        Set code to concat(code, right_code)
        Set code to concat(code, "    movq %rax, %rbx\n")
        Set code to concat(code, "    popq %rax\n")

        If operator is equal to "Plus":
            Set code to concat(code, "    addq %rbx, %rax\n")
        End If
        If operator is equal to "Minus":
            Set code to concat(code, "    subq %rbx, %rax\n")
        End If
        If operator is equal to "Multiply":
            Set code to concat(code, "    imulq %rbx, %rax\n")
        End If
        If operator is equal to "Divide":
            Set code to concat(code, "    xorq %rdx, %rdx\n")
            Set code to concat(code, "    divq %rbx\n")
        End If

        Return code
    End If

    If expr_type is equal to "comparison_expression":
        Let left_expr be extract_ast_part(expr_ast, 1)
        Let operator be extract_ast_part(expr_ast, 2)
        Let right_expr be extract_ast_part(expr_ast, 3)

        Let code be generate_expression_code(left_expr)
        Set code to concat(code, "    pushq %rax\n")
        Let right_code be generate_expression_code(right_expr)
        Set code to concat(code, right_code)
        Set code to concat(code, "    movq %rax, %rbx\n")
        Set code to concat(code, "    popq %rax\n")
        Set code to concat(code, "    cmpq %rbx, %rax\n")

        If operator is equal to "IsEqualTo":
            Set code to concat(code, "    sete %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If
        If operator is equal to "IsLessThan":
            Set code to concat(code, "    setl %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If
        If operator is equal to "IsGreaterThan":
            Set code to concat(code, "    setg %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If
        If operator is equal to "IsLessOrEqual":
            Set code to concat(code, "    setle %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If
        If operator is equal to "IsGreaterOrEqual":
            Set code to concat(code, "    setge %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If
        If operator is equal to "IsNotEqualTo":
            Set code to concat(code, "    setne %al\n")
            Set code to concat(code, "    movzbl %al, %eax\n")
        End If

        Return code
    End If

    If expr_type is equal to "function_call":
        Let fname be extract_ast_part(expr_ast, 1)
        Let args_ast be extract_ast_part(expr_ast, 2)

        If fname is equal to "length_of":
            Let arg1 be extract_ast_part(args_ast, 0)
            Let code be generate_expression_code(arg1)
            Set code to concat(code, "    # length_of: inline strlen loop\n")
            Set code to concat(code, "    movq %rax, %rdi\n    movq %rdi, %rbx\n")
            Let loop be fresh_label("len_loop")
            Let done be fresh_label("len_done")
            Set code to concat(code, loop)
            Set code to concat(code, ":\n    movb (%rdi), %cl\n    cmpb $0, %cl\n    je ")
            Set code to concat(code, done)
            Set code to concat(code, "\n    incq %rdi\n    jmp ")
            Set code to concat(code, loop)
            Set code to concat(code, "\n")
            Set code to concat(code, done)
            Set code to concat(code, ":\n    subq %rbx, %rdi\n    movq %rdi, %rax\n")
            Return code
        End If

        If fname is equal to "char_at":
            Let s_arg be extract_ast_part(args_ast, 0)
            Let i_arg be extract_ast_part(args_ast, 1)
            Let code be generate_expression_code(s_arg)
            Set code to concat(code, "    movq %rax, %rsi\n")
            Let idx_code be generate_expression_code(i_arg)
            Set code to concat(code, idx_code)
            Set code to concat(code, "    movq %rax, %rcx\n")
            Set code to concat(code, "    # bounds: idx >= 0 assumed; compute len\n")
            Set code to concat(code, "    movq %rsi, %rdi\n    call strlen@PLT\n    movq %rax, %rdx\n")
            Let safe be fresh_label("char_safe")
            Let done be fresh_label("char_done")
            Set code to concat(code, "    cmpq %rdx, %rcx\n    jae ")
            Set code to concat(code, done)
            Set code to concat(code, "\n    movzbl (%rsi,%rcx,1), %eax\n    jmp ")
            Set code to concat(code, done)
            Set code to concat(code, "\n")
            Set code to concat(code, done)
            Set code to concat(code, ":\n")
            Return code
        End If

        If fname is equal to "substring":
            Let s_arg be extract_ast_part(args_ast, 0)
            Let st_arg be extract_ast_part(args_ast, 1)
            Let ln_arg be extract_ast_part(args_ast, 2)
            Let code be generate_expression_code(s_arg)
            Set code to concat(code, "    movq %rax, %rsi\n")
            Let stc be generate_expression_code(st_arg)
            Set code to concat(code, stc)
            Set code to concat(code, "    movq %rax, %rcx\n")
            Let lnc be generate_expression_code(ln_arg)
            Set code to concat(code, lnc)
            Set code to concat(code, "    movq %rax, %rdx\n")
            Set code to concat(code, "    # allocate length+1\n    movq %rdx, %rdi\n    addq $1, %rdi\n    call malloc@PLT\n    movq %rax, %rdi\n    movq %rdi, %r9\n")
            Set code to concat(code, "    # inline memcpy: copy %rdx bytes from %rsi+%rcx to %rdi\n    movq %rsi, %r8\n    addq %rcx, %r8\n    movq %r8, %rsi\n    movq %rdx, %rcx\n")
            Let cpy_loop be fresh_label("cpy_loop")
            Let cpy_done be fresh_label("cpy_done")
            Set code to concat(code, cpy_loop)
            Set code to concat(code, ":\n    cmpq $0, %rcx\n    je ")
            Set code to concat(code, cpy_done)
            Set code to concat(code, "\n    movb (%rsi), %al\n    movb %al, (%rdi)\n    incq %rsi\n    incq %rdi\n    decq %rcx\n    jmp ")
            Set code to concat(code, cpy_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, cpy_done)
            Set code to concat(code, ":\n    movb $0, (%rdi)\n    movq %r9, %rax\n")
            Return code
        End If

        If fname is equal to "concat":
            Let a1 be extract_ast_part(args_ast, 0)
            Let a2 be extract_ast_part(args_ast, 1)
            Let code be generate_expression_code(a1)
            Set code to concat(code, "    movq %rax, %rsi\n")
            Let b2 be generate_expression_code(a2)
            Set code to concat(code, b2)
            Set code to concat(code, "    movq %rax, %rdx\n")
            Set code to concat(code, "    # len1 inline\n    movq %rsi, %r9\n    movq %rsi, %rdi\n")
            Let l1_loop be fresh_label("l1_loop")
            Let l1_done be fresh_label("l1_done")
            Set code to concat(code, l1_loop)
            Set code to concat(code, ":\n    movb (%rdi), %al\n    cmpb $0, %al\n    je ")
            Set code to concat(code, l1_done)
            Set code to concat(code, "\n    incq %rdi\n    jmp ")
            Set code to concat(code, l1_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, l1_done)
            Set code to concat(code, ":\n    subq %r9, %rdi\n    movq %rdi, %r8\n")
            Set code to concat(code, "    # len2 inline\n    movq %rdx, %r10\n    movq %rdx, %rdi\n")
            Let l2_loop be fresh_label("l2_loop")
            Let l2_done be fresh_label("l2_done")
            Set code to concat(code, l2_loop)
            Set code to concat(code, ":\n    movb (%rdi), %al\n    cmpb $0, %al\n    je ")
            Set code to concat(code, l2_done)
            Set code to concat(code, "\n    incq %rdi\n    jmp ")
            Set code to concat(code, l2_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, l2_done)
            Set code to concat(code, ":\n    subq %r10, %rdi\n    movq %rdi, %rax\n")
            Set code to concat(code, "    # allocate total len + 1\n    addq %r8, %rax\n    incq %rax\n    movq %rax, %rdi\n    call malloc@PLT\n    movq %rax, %rdi\n    movq %rdi, %r11\n")
            Set code to concat(code, "    # copy str1 inline\n    movq %rsi, %r12\n    movq %r8, %rcx\n")
            Let c1_loop be fresh_label("c1_loop")
            Let c1_done be fresh_label("c1_done")
            Set code to concat(code, c1_loop)
            Set code to concat(code, ":\n    cmpq $0, %rcx\n    je ")
            Set code to concat(code, c1_done)
            Set code to concat(code, "\n    movb (%r12), %al\n    movb %al, (%rdi)\n    incq %r12\n    incq %rdi\n    decq %rcx\n    jmp ")
            Set code to concat(code, c1_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, c1_done)
            Set code to concat(code, ":\n")
            Set code to concat(code, "    # copy str2 inline\n    movq %rdx, %r12\n    movq %rdi, %r13\n")
            Let c2_loop be fresh_label("c2_loop")
            Let c2_done be fresh_label("c2_done")
            Set code to concat(code, c2_loop)
            Set code to concat(code, ":\n    movb (%r12), %al\n    cmpb $0, %al\n    je ")
            Set code to concat(code, c2_done)
            Set code to concat(code, "\n    movb %al, (%r13)\n    incq %r12\n    incq %r13\n    jmp ")
            Set code to concat(code, c2_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, c2_done)
            Set code to concat(code, ":\n    movb $0, (%r13)\n    movq %r11, %rax\n")
            Return code
        End If

        If fname is equal to "to_string":
            Let a1 be extract_ast_part(args_ast, 0)
            Let code be generate_expression_code(a1)
            Set code to concat(code, "    # to_string: inline itoa into new buffer\n")
            Set code to concat(code, "    movq %rax, %rbx            # value\n")
            Set code to concat(code, "    movl $32, %edi\n    call malloc@PLT\n")
            Set code to concat(code, "    movq %rax, %rdi            # buffer base\n    movq %rdi, %r8    # save base\n    movq %rdi, %rsi    # write ptr\n")
            Let zero_lbl be fresh_label("itoa_zero")
            Let nonzero_lbl be fresh_label("itoa_nz")
            Let digits_loop be fresh_label("itoa_digits")
            Let digits_done be fresh_label("itoa_dend")
            Let reverse_loop be fresh_label("itoa_rev")
            Let reverse_done be fresh_label("itoa_rend")
            Set code to concat(code, "    cmpq $0, %rbx\n    jne ")
            Set code to concat(code, nonzero_lbl)
            Set code to concat(code, "\n    movb $'0', (%rsi)\n    incq %rsi\n    jmp ")
            Set code to concat(code, digits_done)
            Set code to concat(code, "\n")
            Set code to concat(code, nonzero_lbl)
            Set code to concat(code, ":\n    movq $0, %r9          # neg flag\n    testq %rbx, %rbx\n    jge ")
            Let itoa_pos be fresh_label("itoa_pos")
            Set code to concat(code, itoa_pos)
            Set code to concat(code, "\n    negq %rbx\n    movq $1, %r9\n")
            Set code to concat(code, itoa_pos)
            Set code to concat(code, ":\n")
            Set code to concat(code, digits_loop)
            Set code to concat(code, ":\n    xorq %rdx, %rdx\n    movq %rbx, %rax\n    movq $10, %rcx\n    divq %rcx               # rax=quot, rdx=rem\n    addb $'0', %dl\n    movb %dl, (%rsi)\n    incq %rsi\n    movq %rax, %rbx\n    testq %rbx, %rbx\n    jne ")
            Set code to concat(code, digits_loop)
            Set code to concat(code, "\n    cmpq $0, %r9\n    je ")
            Let no_neg_lbl be fresh_label("itoa_noneg")
            Set code to concat(code, no_neg_lbl)
            Set code to concat(code, "\n    movb $'-', (%rsi)\n    incq %rsi\n")
            Set code to concat(code, no_neg_lbl)
            Set code to concat(code, ":\n")
            Set code to concat(code, digits_done)
            Set code to concat(code, ":\n    # reverse buffer in-place [base, rsi)")
            Set code to concat(code, "\n    movq %r8, %rdi         # start\n    leaq -1(%rsi), %rcx    # end\n")
            Set code to concat(code, reverse_loop)
            Set code to concat(code, ":\n    cmpq %rcx, %rdi\n    jge ")
            Set code to concat(code, reverse_done)
            Set code to concat(code, "\n    movb (%rdi), %al\n    movb (%rcx), %ah\n    movb %ah, (%rdi)\n    movb %al, (%rcx)\n    incq %rdi\n    decq %rcx\n    jmp ")
            Set code to concat(code, reverse_loop)
            Set code to concat(code, "\n")
            Set code to concat(code, reverse_done)
            Set code to concat(code, ":\n    movb $0, (%rsi)\n    movq %r8, %rax\n")
            Return code
        End If

        Return generate_function_call(expr_ast)
    End If

    If expr_type is equal to "field_access":
        Let object_ast be extract_ast_part(expr_ast, 1)
        Let field_name be extract_ast_part(expr_ast, 2)
        Let code be "    # Field access: "
        Set code to concat(code, field_name)
        Set code to concat(code, "\n")
        Let object_code be generate_expression_code(object_ast)
        Set code to concat(code, object_code)
        Set code to concat(code, "    # Load field ")
        Set code to concat(code, field_name)
        Set code to concat(code, "\n")
        Return code
    End If

    If expr_type is equal to "index_access":
        Let array_ast be extract_ast_part(expr_ast, 1)
        Let index_ast be extract_ast_part(expr_ast, 2)
        Let code be "    # Index access\n"
        Let array_code be generate_expression_code(array_ast)
        Set code to concat(code, array_code)
        Set code to concat(code, "    pushq %rax\n")
        Let index_code be generate_expression_code(index_ast)
        Set code to concat(code, index_code)
        Set code to concat(code, "    movq %rax, %rbx\n")
        Set code to concat(code, "    popq %rax\n")
        Set code to concat(code, "    # Load element at index\n")
        Return code
    End If

    If expr_type is equal to "list_literal":
        Let elements be extract_ast_part(expr_ast, 1)
        Let code be "    # List literal\n"
        Set code to concat(code, "    # Elements: ")
        Set code to concat(code, elements)
        Set code to concat(code, "\n")
        Set code to concat(code, "    # Allocate and initialize list\n")
        Return code
    End If

    If expr_type is equal to "struct_creation":
        Let type_name be extract_ast_part(expr_ast, 1)
        Let fields be extract_ast_part(expr_ast, 2)
        Let code be "    # Struct creation: "
        Set code to concat(code, type_name)
        Set code to concat(code, "\n")
        Set code to concat(code, "    # Fields: ")
        Set code to concat(code, fields)
        Set code to concat(code, "\n")
        Set code to concat(code, "    # Allocate and initialize struct\n")
        Return code
    End If

    Return "    # Unknown expression\n"
End Process

Process called "generate_let_statement" that takes ast as String returns String:
    Note: GenerateLetStatement
    Let var_name be extract_ast_part(ast, 1)
    Let expr_ast be extract_ast_part(ast, 2)
    Let expr_code be generate_expression_code(expr_ast)
    Note: Allocate stack slot and store
    If lookup_var_offset(var_name) is equal to 0:
        Set cg_stack_offset to cg_stack_offset plus 8
        record_var_offset(var_name, cg_stack_offset)
    End If
    Let code be "    # Let "
    Set code to concat(code, var_name)
    Set code to concat(code, " be expression\n")
    Set code to concat(code, expr_code)
    Set code to concat(code, "    movq %rax, -")
    Set code to concat(code, to_string(lookup_var_offset(var_name)))
    Set code to concat(code, "(%rbp)\n")
    Note: Heuristic variable type tracking using expression shape
    Let etype be extract_ast_part(expr_ast, 0)
    If etype is equal to "string_literal":
        record_var_type(var_name, "String")
    End If
    If etype is equal to "integer_literal":
        record_var_type(var_name, "Integer")
    End If
    Return code
End Process

Process called "generate_set_statement" that takes ast as String returns String:
    Note: GenerateSetStatement
    Let var_name be extract_ast_part(ast, 1)
    Let expr_ast be extract_ast_part(ast, 2)
    Let expr_code be generate_expression_code(expr_ast)
    Let code be "    # Set "
    Set code to concat(code, var_name)
    Set code to concat(code, " to expression\n")
    Set code to concat(code, expr_code)
    Let offs be lookup_var_offset(var_name)
    If offs is equal to 0:
        Set cg_stack_offset to cg_stack_offset plus 8
        record_var_offset(var_name, cg_stack_offset)
        Set offs to cg_stack_offset
    End If
    Set code to concat(code, "    movq %rax, -")
    Set code to concat(code, to_string(offs))
    Set code to concat(code, "(%rbp)\n")
    Let etype2 be extract_ast_part(expr_ast, 0)
    If etype2 is equal to "string_literal":
        record_var_type(var_name, "String")
    End If
    If etype2 is equal to "integer_literal":
        record_var_type(var_name, "Integer")
    End If
    Return code
End Process

Process called "generate_display_statement" that takes ast as String returns String:
    Note: GenerateDisplayStatement
    Let expr_ast be extract_ast_part(ast, 1)
    Let expr_code be generate_expression_code(expr_ast)
    Let code be "    # Display expression\n"
    Set code to concat(code, expr_code)
    Let etype be extract_ast_part(expr_ast, 0)
    If etype is equal to "identifier":
        Let vname be extract_ast_part(expr_ast, 1)
        Let vtype be lookup_var_type(vname)
        If vtype is equal to "String":
            Set code to concat(code, "    movq %rax, %rsi\n")
            Set code to concat(code, "    leaq .LC_fmt_s(%rip), %rdi\n")
            Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 10f\n    subq $8, %rsp\n10:\n")
            Set code to concat(code, "    call printf@PLT\n")
            Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 11f\n    addq $8, %rsp\n11:\n")
            Return code
        End If
        Set etype to "integer_literal"
    End If
    If etype is equal to "function_call":
        Let fname be extract_ast_part(extract_ast_part(expr_ast, 1), 0)
        Let fret be lookup_function_return(fname)
        If fret is equal to "String":
            Set code to concat(code, "    movq %rax, %rsi\n")
            Set code to concat(code, "    leaq .LC_fmt_s(%rip), %rdi\n")
            Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 12f\n    subq $8, %rsp\n12:\n")
            Set code to concat(code, "    call printf@PLT\n")
            Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 13f\n    addq $8, %rsp\n13:\n")
            Return code
        End If
        Set etype to "integer_literal"
    End If
    If etype is equal to "string_literal":
        Set code to concat(code, "    movq %rax, %rsi\n")
        Set code to concat(code, "    leaq .LC_fmt_s(%rip), %rdi\n")
        Note: Ensure 16-byte alignment before call
        Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 1f\n    subq $8, %rsp\n1:\n")
        Set code to concat(code, "    call printf@PLT\n")
        Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 2f\n    addq $8, %rsp\n2:\n")
    End If
    If etype is not equal to "string_literal":
        Set code to concat(code, "    movl %eax, %esi\n")
        Set code to concat(code, "    leaq .LC_fmt_d(%rip), %rdi\n")
        Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 3f\n    subq $8, %rsp\n3:\n")
        Set code to concat(code, "    call printf@PLT\n")
        Set code to concat(code, "    movq %rsp, %rax\n    andq $15, %rax\n    jz 4f\n    addq $8, %rsp\n4:\n")
    End If
    Return code
End Process

Process called "generate_return_statement" that takes ast as String returns String:
    Note: GenerateReturnStatement
    Let expr_ast be extract_ast_part(ast, 1)
    Let expr_code be generate_expression_code(expr_ast)
    Let code be "    # Return expression\n"
    Set code to concat(code, expr_code)
    Set code to concat(code, "    # Return value in %rax\n")
    Set code to concat(code, "    ret\n")
    Return code
End Process

Process called "generate_if_statement" that takes ast as String returns String:
    Note: GenerateIfStatement
    Let condition_ast be extract_ast_part(ast, 1)
    Let body_ast be extract_ast_part(ast, 2)

    Let code be "    # If statement\n"
    Set code to concat(code, "    # Evaluate condition\n")
    Let condition_code be generate_expression_code(condition_ast)
    Set code to concat(code, condition_code)
    Set code to concat(code, "    testq %rax, %rax\n")
    Let endif_lbl be fresh_label("if_end")
    Set code to concat(code, "    jz ")
    Set code to concat(code, endif_lbl)
    Set code to concat(code, "\n")
    Note: Then block emission if any
    If length_of(body_ast) is greater than 0:
        Let blen be length_of(body_ast)
        Let bi be 0
        Let bs be 0
        While bi is less than blen plus 1:
            Let chb be 0
            If bi is less than blen:
                Set chb to char_at(body_ast, bi)
            End If
            If chb is equal to 59 Or bi is equal to blen:
                Let bstmt be substring(body_ast, bs, bi)
                If length_of(bstmt) is greater than 0:
                    Let bcode be generate_statement_code(bstmt)
                    Set code to concat(code, bcode)
                End If
                Set bs to bi plus 1
            End If
            Set bi to bi plus 1
        End While
    End If
    Set code to concat(code, endif_lbl)
    Set code to concat(code, ":\n")
    Return code
End Process

Process called "generate_while_statement" that takes ast as String returns String:
    Note: GenerateWhileStatement
    Let condition_ast be extract_ast_part(ast, 1)
    Let body_ast be extract_ast_part(ast, 2)

    Let code be "    # While statement\n"
    Let wstart be fresh_label("while_start")
    Let wend be fresh_label("while_end")
    push_loop_labels(wstart, wend)
    Set code to concat(code, wstart)
    Set code to concat(code, ":\n")
    Set code to concat(code, "    # Evaluate condition\n")
    Let condition_code be generate_expression_code(condition_ast)
    Set code to concat(code, condition_code)
    Set code to concat(code, "    testq %rax, %rax\n")
    Set code to concat(code, "    jz ")
    Set code to concat(code, wend)
    Set code to concat(code, "\n")
    Note: Loop body
    If length_of(body_ast) is greater than 0:
        Let blen be length_of(body_ast)
        Let bi be 0
        Let bs be 0
        While bi is less than blen plus 1:
            Let chb be 0
            If bi is less than blen:
                Set chb to char_at(body_ast, bi)
            End If
            If chb is equal to 59 Or bi is equal to blen:
                Let bstmt be substring(body_ast, bs, bi)
                If length_of(bstmt) is greater than 0:
                    Let bcode be generate_statement_code(bstmt)
                    Set code to concat(code, bcode)
                End If
                Set bs to bi plus 1
            End If
            Set bi to bi plus 1
        End While
    End If
    Set code to concat(code, "    jmp ")
    Set code to concat(code, wstart)
    Set code to concat(code, "\n")
    Set code to concat(code, wend)
    Set code to concat(code, ":\n")
    pop_loop_labels()
    Return code
End Process

Process called "generate_process_definition" that takes ast as String returns String:
    Note: GenerateProcessDefinition
    Let proc_name be extract_ast_part(ast, 1)
    Let params_ast be extract_ast_part(ast, 2)
    Let return_type be extract_ast_part(ast, 3)
    Let body_ast be extract_ast_part(ast, 4)

    begin_function_codegen()

    Note: Build prologue separately
    Let prologue be proc_name
    Set prologue to concat(prologue, ":\n")
    Set prologue to concat(prologue, "    pushq %rbp\n")
    Set prologue to concat(prologue, "    movq %rsp, %rbp\n")
    Set prologue to concat(prologue, "    pushq %rbx\n")
    Set prologue to concat(prologue, "    pushq %r12\n")
    Set prologue to concat(prologue, "    pushq %r13\n")
    Set prologue to concat(prologue, "    pushq %r14\n")
    Set prologue to concat(prologue, "    pushq %r15\n")

    Note: First pass over parameters: assign stack slots and remember their indices
    Let param_info be ""
    Let p_len be length_of(params_ast)
    If p_len is greater than 0:
        Let p_i be 0
        Let p_start be 0
        Let param_index be 0
        While p_i is less than p_len plus 1:
            Let ch be 0
            If p_i is less than p_len:
                Set ch to char_at(params_ast, p_i)
            End If
            If ch is equal to 124 Or p_i is equal to p_len:
                Let ent be substring(params_ast, p_start, p_i)
                If length_of(ent) is greater than 0:
                    Let cpos be find_char(ent, 58, 0)
                    If cpos is greater than 0:
                        Let p_name be substring(ent, 0, cpos)
                        Set cg_stack_offset to cg_stack_offset plus 8
                        record_var_offset(p_name, cg_stack_offset)
                        If length_of(param_info) is greater than 0:
                            Set param_info to concat(param_info, ";")
                        End If
                        Set param_info to concat(param_info, p_name)
                        Set param_info to concat(param_info, "|")
                        Set param_info to concat(param_info, to_string(param_index))
                        Set param_index to param_index plus 1
                    End If
                End If
                Set p_start to p_i plus 1
            End If
            Set p_i to p_i plus 1
        End While
    End If

    Note: Emit function body statements into body_code to determine total local size
    Let body_code be ""
    Let b_len be length_of(body_ast)
    If b_len is greater than 0:
        Let i be 0
        Let start be 0
        While i is less than b_len plus 1:
            Let ch2 be 0
            If i is less than b_len:
                Set ch2 to char_at(body_ast, i)
            End If
            If ch2 is equal to 59 Or i is equal to b_len:
                Let stmt_ast be substring(body_ast, start, i)
                If length_of(stmt_ast) is greater than 0:
                    Let s_code be generate_statement_code(stmt_ast)
                    Set body_code to concat(body_code, s_code)
                End If
                Set start to i plus 1
            End If
            Set i to i plus 1
        End While
    End If

    Note: Allocate stack frame space for locals/params recorded in cg_stack_offset
    Let alloc be ""
    If cg_stack_offset is greater than 0:
        Set alloc to concat("    subq $", to_string(cg_stack_offset))
        Set alloc to concat(alloc, ", %rsp\n")
    End If

    Note: Now that slots exist, store parameter registers to their stack slots
    Let param_store_code be ""
    If length_of(param_info) is greater than 0:
        Let pi be 0
        Let ps be 0
        Let pn be length_of(param_info)
        While pi is less than pn plus 1:
            Let chp be 0
            If pi is less than pn:
                Set chp to char_at(param_info, pi)
            End If
            If chp is equal to 59 Or pi is equal to pn:
                Let pent be substring(param_info, ps, pi)
                If length_of(pent) is greater than 0:
                    Let bar be find_char(pent, 124, 0)
                    If bar is greater than 0:
                        Let nm be substring(pent, 0, bar)
                        Let idx_str be substring(pent, bar plus 1, length_of(pent))
                        Let offs_str be to_string(lookup_var_offset(nm))
                        Let which be parse_integer(idx_str)
                        If which is equal to 0:
                            Set param_store_code to concat(param_store_code, "    movq %rdi, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                        If which is equal to 1:
                            Set param_store_code to concat(param_store_code, "    movq %rsi, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                        If which is equal to 2:
                            Set param_store_code to concat(param_store_code, "    movq %rdx, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                        If which is equal to 3:
                            Set param_store_code to concat(param_store_code, "    movq %rcx, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                        If which is equal to 4:
                            Set param_store_code to concat(param_store_code, "    movq %r8, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                        If which is equal to 5:
                            Set param_store_code to concat(param_store_code, "    movq %r9, -")
                            Set param_store_code to concat(param_store_code, offs_str)
                            Set param_store_code to concat(param_store_code, "(%rbp)\n")
                        End If
                    End If
                End If
                Set ps to pi plus 1
            End If
            Set pi to pi plus 1
        End While
    End If

    Note: Epilogue
    Let epilogue be ""
    Set epilogue to concat(epilogue, "    popq %r15\n")
    Set epilogue to concat(epilogue, "    popq %r14\n")
    Set epilogue to concat(epilogue, "    popq %r13\n")
    Set epilogue to concat(epilogue, "    popq %r12\n")
    Set epilogue to concat(epilogue, "    popq %rbx\n")
    Set epilogue to concat(epilogue, "    leave\n")
    Set epilogue to concat(epilogue, "    ret\n")

    Let code be prologue
    Set code to concat(code, alloc)
    Set code to concat(code, param_store_code)
    Set code to concat(code, body_code)
    Set code to concat(code, epilogue)
    Return code
End Process

Process called "generate_statement_code" that takes ast as String returns String:
    Note: GenerateStatementCode
    Let stmt_type be extract_ast_part(ast, 0)

    If stmt_type is equal to "let_statement":
        Return generate_let_statement(ast)
    End If
    If stmt_type is equal to "set_statement":
        Return generate_set_statement(ast)
    End If
    If stmt_type is equal to "display_statement":
        Return generate_display_statement(ast)
    End If
    If stmt_type is equal to "return_statement":
        Return generate_return_statement(ast)
    End If
    If stmt_type is equal to "if_statement":
        Return generate_if_statement(ast)
    End If
    If stmt_type is equal to "while_statement":
        Return generate_while_statement(ast)
    End If
    If stmt_type is equal to "break_statement":
        Let end_lbl be current_loop_end()
        If length_of(end_lbl) is equal to 0:
            Return "    # ERROR: 'break' outside loop\n"
        End If
        Return concat("    jmp ", concat(end_lbl, "\n"))
    End If
    If stmt_type is equal to "continue_statement":
        Let start_lbl be current_loop_start()
        If length_of(start_lbl) is equal to 0:
            Return "    # ERROR: 'continue' outside loop\n"
        End If
        Return concat("    jmp ", concat(start_lbl, "\n"))
    End If
    If stmt_type is equal to "process_definition":
        Return generate_process_definition(ast)
    End If
    If stmt_type is equal to "function_call":
        Return generate_function_call(ast)
    End If
    If stmt_type is equal to "note_statement":
        Return "    # Note comment\n"
    End If

    Return "    # Unknown statement\n"
End Process

Process called "generate_main_body" that takes ast as String returns String:
    Note: GenerateMainBody
    begin_function_codegen()
    Let code be ".text\n"
    Set code to concat(code, ".global main\n")
    Set code to concat(code, "main:\n")
    Set code to concat(code, "    pushq %rbp\n")
    Set code to concat(code, "    movq %rsp, %rbp\n")
    Set code to concat(code, "    # Main function body\n")
    Let body_code be generate_statement_code(ast)
    Set code to concat(code, body_code)
    Set code to concat(code, "    movl $0, %eax\n")
    Set code to concat(code, "    leave\n")
    Set code to concat(code, "    ret\n")
    Return code
End Process

Process called "generate_code" that takes ast as String returns String:
    Note: MainCodeGenerationEntry
    Let ast_type be extract_ast_part(ast, 0)
    Let header be generate_assembly_header()
    Let footer be generate_assembly_footer()

    If ast_type is equal to "program":
        Set cg_string_pool to ""
        Set cg_string_counter to 0
        begin_function_codegen()
        Let statements be extract_ast_part(ast, 1)

        Note: Build main prologue separately
        Let prologue be ".text\n"
        Set prologue to concat(prologue, ".global main\n")
        Set prologue to concat(prologue, "main:\n")
        Set prologue to concat(prologue, "    pushq %rbp\n")
        Set prologue to concat(prologue, "    movq %rsp, %rbp\n")
        Set prologue to concat(prologue, "    pushq %rbx\n")
        Set prologue to concat(prologue, "    pushq %r12\n")
        Set prologue to concat(prologue, "    pushq %r13\n")
        Set prologue to concat(prologue, "    pushq %r14\n")
        Set prologue to concat(prologue, "    pushq %r15\n")

        Note: Generate body first to discover required local size
        Let body_code be ""
        Let start_pos be 0
        Let i be 0
        Let len be length_of(statements)
        While i is less than len:
            Let ch be char_at(statements, i)
            If ch is equal to 59:
                Let stmt be substring(statements, start_pos, i)
                If length_of(stmt) is greater than 0:
                    Let stmt_code be generate_statement_code(stmt)
                    Set body_code to concat(body_code, stmt_code)
                End If
                Set start_pos to i plus 1
            End If
            Set i to i plus 1
        End While

        If start_pos is less than len:
            Let tail_stmt be substring(statements, start_pos, len)
            If length_of(tail_stmt) is greater than 0:
                Let tail_code be generate_statement_code(tail_stmt)
                Set body_code to concat(body_code, tail_code)
            End If
        End If

        Note: Allocate stack frame for discovered locals
        Let alloc be ""
        If cg_stack_offset is greater than 0:
            Set alloc to concat("    subq $", to_string(cg_stack_offset))
            Set alloc to concat(alloc, ", %rsp\n")
        End If

        Let epilogue be "    movl $0, %eax\n"
        Set epilogue to concat(epilogue, "    popq %r15\n")
        Set epilogue to concat(epilogue, "    popq %r14\n")
        Set epilogue to concat(epilogue, "    popq %r13\n")
        Set epilogue to concat(epilogue, "    popq %r12\n")
        Set epilogue to concat(epilogue, "    popq %rbx\n")
        Set epilogue to concat(epilogue, "    leave\n")
        Set epilogue to concat(epilogue, "    ret\n")

        Let code be prologue
        Set code to concat(code, alloc)
        Set code to concat(code, body_code)
        Set code to concat(code, epilogue)

        Let rodata be "\n    .section .rodata\n"
        Set rodata to concat(rodata, ".LC_fmt_s:\n    .string \"%s\\n\"\n")
        Set rodata to concat(rodata, ".LC_fmt_d:\n    .string \"%d\\n\"\n")
        Set rodata to concat(rodata, ".LC_fmt_ld:\n    .string \"%ld\"\n")

        Let pool_len be length_of(cg_string_pool)
        If pool_len is greater than 0:
            Let i2 be 0
            Let start2 be 0
            While i2 is less than pool_len plus 1:
                Let ch2 be 0
                If i2 is less than pool_len:
                    Set ch2 to char_at(cg_string_pool, i2)
                End If
                If ch2 is equal to 59 Or i2 is equal to pool_len:
                    Let entry be substring(cg_string_pool, start2, i2)
                    Let ppos be find_char(entry, 124, 0)
                    If ppos is greater than 0:
                        Let label be substring(entry, 0, ppos)
                        Let raw be substring(entry, ppos plus 1, length_of(entry))
                        Let esc be escape_rodata_string(raw)
                        Set rodata to concat(rodata, label)
                        Set rodata to concat(rodata, ":\n    .string \"")
                        Set rodata to concat(rodata, esc)
                        Set rodata to concat(rodata, "\"\n")
                    End If
                    Set start2 to i2 plus 1
                End If
                Set i2 to i2 plus 1
            End While
        End If

        Return concat(code, rodata)
    End If

    Let stmt_code be generate_statement_code(ast)
    Let result be concat(header, stmt_code)
    Set result to concat(result, footer)
    Return result
End Process