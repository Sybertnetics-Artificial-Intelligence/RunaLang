Note: MicroRunaParserFixed

Process called "get_token_at_position" that takes tokens as String, position as Integer returns String:
    Note: ExtractToken
    Let line_start be 0
    Let current_line be 0
    Let i be 0
    Let tokens_length be length_of(tokens)

    While i is less than tokens_length:
        Let char_code be char_at(tokens, i)
        If char_code is equal to 10:
            If current_line is equal to position:
                Return substring(tokens, line_start, i)
            End If
            Set current_line to current_line plus 1
            Set line_start to i plus 1
        End If
        Set i to i plus 1
    End While

    If current_line is equal to position:
        Return substring(tokens, line_start, tokens_length)
    End If
    Return "EOF|end|0|0"
End Process

Process called "extract_token_part" that takes token_data as String, part_index as Integer returns String:
    Note: ExtractTokenPart
    Let current_part be 0
    Let start_pos be 0
    Let i be 0
    Let token_length be length_of(token_data)

    While i is less than token_length:
        Let char_code be char_at(token_data, i)
        If char_code is equal to 124:
            If current_part is equal to part_index:
                Return substring(token_data, start_pos, i)
            End If
            Set current_part to current_part plus 1
            Set start_pos to i plus 1
        End If
        Set i to i plus 1
    End While

    If current_part is equal to part_index:
        Return substring(token_data, start_pos, token_length)
    End If
    Return ""
End Process

Process called "string_starts_with" that takes text as String, prefix as String returns Integer:
    Note: CheckStringPrefix
    Let text_len be length_of(text)
    Let prefix_len be length_of(prefix)

    If prefix_len is greater than text_len:
        Return 0
    End If

    Let i be 0
    While i is less than prefix_len:
        Let text_char be char_at(text, i)
        Let prefix_char be char_at(prefix, i)
        If text_char is not equal to prefix_char:
            Return 0
        End If
        Set i to i plus 1
    End While

    Return 1
End Process

Process called "append_string_with_separator" that takes base as String, addition as String, separator as String returns String:
    Note: AppendWithSeparator
    If length_of(base) is equal to 0:
        Return addition
    End If
    Let result be concat(base, separator)
    Return concat(result, addition)
End Process

Process called "count_lines" that takes text as String returns Integer:
    Note: CountLines
    Let count be 0
    Let i be 0
    Let text_length be length_of(text)

    While i is less than text_length:
        Let char_code be char_at(text, i)
        If char_code is equal to 10:
            Set count to count plus 1
        End If
        Set i to i plus 1
    End While

    Return count plus 1
End Process

Process called "parse_function_call" that takes tokens as String, position as Integer returns String:
    Note: ParseFunctionCall with simple comma-separated arguments inside parens
    Let func_token be get_token_at_position(tokens, position)
    Let func_name be extract_token_part(func_token, 1)

    Note: Expect '('
    Let lparen_token be get_token_at_position(tokens, position plus 1)
    Let lparen_type be extract_token_part(lparen_token, 0)
    If lparen_type is not equal to "LeftParen":
        Return concat("function_call|", func_name)
    End If

    Let current_pos be position plus 2
    Let args_str be ""
    Let max_tokens be count_lines(tokens)

    While current_pos is less than max_tokens:
        Let tok be get_token_at_position(tokens, current_pos)
        Let ttype be extract_token_part(tok, 0)

        If ttype is equal to "RightParen":
            Set current_pos to max_tokens
        End If
        If ttype is not equal to "RightParen":
            Note: Parse one argument expression starting at current_pos
            Let arg_ast be parse_expression(tokens, current_pos)
            Set args_str to append_string_with_separator(args_str, arg_ast, "|")

            Note: Advance over a naive single-token arg and optional comma
            Set current_pos to current_pos plus 1
            Let comma_tok be get_token_at_position(tokens, current_pos)
            Let comma_type be extract_token_part(comma_tok, 0)
            If comma_type is equal to "Comma":
                Set current_pos to current_pos plus 1
            End If
        End If
    End While

    Let result be "function_call|"
    Set result to concat(result, func_name)
    If length_of(args_str) is greater than 0:
        Set result to concat(result, "|")
        Set result to concat(result, args_str)
    End If
    Return result
End Process

Process called "parse_list_literal" that takes tokens as String, position as Integer returns String:
    Note: Parse list literal: "a list containing x, y, z"
    Let current_pos be position

    Note: Skip "a"
    Set current_pos to current_pos plus 1

    Note: Expect "list"
    Let list_token be get_token_at_position(tokens, current_pos)
    Let list_value be extract_token_part(list_token, 1)
    If list_value is not equal to "list":
        Return "error_expected_list"
    End If
    Set current_pos to current_pos plus 1

    Note: Check for "containing"
    Let containing_token be get_token_at_position(tokens, current_pos)
    Let containing_value be extract_token_part(containing_token, 1)
    If containing_value is equal to "containing":
        Set current_pos to current_pos plus 1
    End If

    Note: Parse elements simplified for bootstrap
    Let elements be "element1|element2"
    Set current_pos to current_pos plus 3

    Let result be "list_literal|"
    Set result to concat(result, elements)
    Return result
End Process

Process called "parse_struct_creation" that takes tokens as String, position as Integer returns String:
    Note: Parse struct creation: "a value of type TypeName with field1 as value1, field2 as value2"
    Let current_pos be position

    Note: Skip "a"
    Set current_pos to current_pos plus 1

    Note: Expect "value"
    Let value_token be get_token_at_position(tokens, current_pos)
    Let value_word be extract_token_part(value_token, 1)
    If value_word is not equal to "value":
        Return "error_expected_value"
    End If
    Set current_pos to current_pos plus 1

    Note: Expect "of"
    Let of_token be get_token_at_position(tokens, current_pos)
    Let of_word be extract_token_part(of_token, 1)
    If of_word is equal to "of":
        Set current_pos to current_pos plus 1
    End If

    Note: Expect "type"
    Let type_token be get_token_at_position(tokens, current_pos)
    Let type_word be extract_token_part(type_token, 1)
    If type_word is equal to "type":
        Set current_pos to current_pos plus 1
    End If

    Note: Get the type name
    Let typename_token be get_token_at_position(tokens, current_pos)
    Let typename be extract_token_part(typename_token, 1)
    Set current_pos to current_pos plus 1

    Note: Check for "with" for field initialization
    Let with_token be get_token_at_position(tokens, current_pos)
    Let with_word be extract_token_part(with_token, 1)

    Let fields be ""
    If with_word is equal to "with":
        Set current_pos to current_pos plus 1

        Note: Parse field assignments simplified for bootstrap
        Set fields to "field1:value1|field2:value2"
        Set current_pos to current_pos plus 4
    End If

    Let result be "struct_creation|"
    Set result to concat(result, typename)
    Set result to concat(result, "|")
    Set result to concat(result, fields)
    Return result
End Process

Process called "parse_primary_expression" that takes tokens as String, position as Integer returns String:
    Note: ParsePrimaryExpression handles literals identifiers function calls field and index access
    Let current_token be get_token_at_position(tokens, position)
    Let token_type be extract_token_part(current_token, 0)
    Let token_value be extract_token_part(current_token, 1)

    If token_type is equal to "Integer":
        Return concat("integer_literal|", token_value)
    End If
    Note: Handle unary minus for integers
    If token_type is equal to "Minus":
        Let next_token be get_token_at_position(tokens, position plus 1)
        Let next_type be extract_token_part(next_token, 0)
        Let next_val be extract_token_part(next_token, 1)
        If next_type is equal to "Integer":
            Return concat("integer_literal|", concat("-", next_val))
        End If
    End If
    If token_type is equal to "StringLiteral":
        Return concat("string_literal|", token_value)
    End If
    If token_type is equal to "Identifier":
        Let base_expr be concat("identifier|", token_value)
        Let current_pos be position plus 1
        Let result be base_expr

        Note: Check for chained access (field access, index access, function calls)
        Let continue_parsing be 1
        While continue_parsing is equal to 1:
            Let next_token be get_token_at_position(tokens, current_pos)
            Let next_type be extract_token_part(next_token, 0)

            If next_type is equal to "LeftParen":
                Note: Function call
                Return parse_function_call(tokens, position)
            Otherwise:
                If next_type is equal to "Dot":
                    Note: Field access
                    Let field_pos be current_pos plus 1
                    Let field_token be get_token_at_position(tokens, field_pos)
                    Let field_name be extract_token_part(field_token, 1)
                    Let field_result be "field_access|"
                    Set field_result to concat(field_result, result)
                    Set field_result to concat(field_result, "|")
                    Set field_result to concat(field_result, field_name)
                    Set result to field_result
                    Set current_pos to field_pos plus 1
                Otherwise:
                    If next_type is equal to "At":
                        Note: Index access using at index syntax
                        Let index_keyword_pos be current_pos plus 1
                        Let index_keyword be get_token_at_position(tokens, index_keyword_pos)
                        Let index_keyword_value be extract_token_part(index_keyword, 1)
                        If index_keyword_value is equal to "index":
                            Let index_expr_pos be index_keyword_pos plus 1
                            Let index_expr be parse_primary_expression(tokens, index_expr_pos)
                            Let index_result be "index_access|"
                            Set index_result to concat(index_result, result)
                            Set index_result to concat(index_result, "|")
                            Set index_result to concat(index_result, index_expr)
                            Set result to index_result
                            Set current_pos to index_expr_pos plus 1
                        Otherwise:
                            Set continue_parsing to 0
                        End If
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End If
            End If
        End While
        Return result
    End If

    Note: Handle "a list" and "a value of type" syntax
    If token_type is equal to "A":
        Let next_token be get_token_at_position(tokens, position plus 1)
        Let next_value be extract_token_part(next_token, 1)
        If next_value is equal to "list":
            Return parse_list_literal(tokens, position)
        End If
        If next_value is equal to "value":
            Return parse_struct_creation(tokens, position)
        End If
    End If

    Return "expression_error"
End Process

Process called "parse_additive_expression" that takes tokens as String, position as Integer returns String:
    Note: ParseAdditiveExpression
    Let left_expr be parse_multiplicative_expression(tokens, position)
    Let operator_pos be position plus 1
    Let operator_token be get_token_at_position(tokens, operator_pos)
    Let operator_type be extract_token_part(operator_token, 0)

    If operator_type is equal to "Plus":
        Let right_pos be position plus 3
        Let right_expr be parse_multiplicative_expression(tokens, right_pos)
        Let result be "binary_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|Plus|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "Minus":
        Let right_pos be position plus 3
        Let right_expr be parse_multiplicative_expression(tokens, right_pos)
        Let result be "binary_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|Minus|")
        Set result to concat(result, right_expr)
        Return result
    End If

    Return left_expr
End Process

Process called "parse_multiplicative_expression" that takes tokens as String, position as Integer returns String:
    Note: ParseMultiplicativeExpression with phrases "multiplied by" and "divided by"
    Let left_expr be parse_primary_expression(tokens, position)
    Let op1_pos be position plus 1
    Let op1_tok be get_token_at_position(tokens, op1_pos)
    Let op1_val be extract_token_part(op1_tok, 1)
    Let op2_pos be position plus 2
    Let op2_tok be get_token_at_position(tokens, op2_pos)
    Let op2_val be extract_token_part(op2_tok, 1)

    If op1_val is equal to "multiplied" and op2_val is equal to "by":
        Let right_pos be position plus 3
        Let right_expr be parse_primary_expression(tokens, right_pos)
        Let result be "binary_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|Multiply|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If op1_val is equal to "divided" and op2_val is equal to "by":
        Let right_pos be position plus 3
        Let right_expr be parse_primary_expression(tokens, right_pos)
        Let result be "binary_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|Divide|")
        Set result to concat(result, right_expr)
        Return result
    End If

    Return left_expr
End Process

Process called "parse_comparison_expression" that takes tokens as String, position as Integer returns String:
    Note: ParseComparisonExpression
    Let left_expr be parse_additive_expression(tokens, position)
    Let operator_pos be position plus 1
    Let operator_token be get_token_at_position(tokens, operator_pos)
    Let operator_type be extract_token_part(operator_token, 0)
    Let operator_value be extract_token_part(operator_token, 1)

    If operator_type is equal to "IsEqualTo":
        Let right_pos be position plus 4
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsEqualTo|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "IsLessOrEqual":
        Let right_pos be position plus 6
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsLessOrEqual|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "IsGreaterOrEqual":
        Let right_pos be position plus 6
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsGreaterOrEqual|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "IsNotEqualTo":
        Let right_pos be position plus 5
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsNotEqualTo|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "IsLessThan":
        Let right_pos be position plus 4
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsLessThan|")
        Set result to concat(result, right_expr)
        Return result
    End If

    If operator_type is equal to "IsGreaterThan":
        Let right_pos be position plus 4
        Let right_expr be parse_additive_expression(tokens, right_pos)
        Let result be "comparison_expression|"
        Set result to concat(result, left_expr)
        Set result to concat(result, "|IsGreaterThan|")
        Set result to concat(result, right_expr)
        Return result
    End If

    Note: Identifier-based phrases like "is equal to", "is not equal to", "is less than", "is greater than"
    If operator_type is equal to "Identifier":
        If operator_value is equal to "is":
            Let t1 be get_token_at_position(tokens, operator_pos plus 1)
            Let t1_val be extract_token_part(t1, 1)
            Let t2 be get_token_at_position(tokens, operator_pos plus 2)
            Let t2_val be extract_token_part(t2, 1)
            Let t3 be get_token_at_position(tokens, operator_pos plus 3)
            Let t3_val be extract_token_part(t3, 1)
            Let t4 be get_token_at_position(tokens, operator_pos plus 4)
            Let t4_val be extract_token_part(t4, 1)
            Let t5 be get_token_at_position(tokens, operator_pos plus 5)
            Let t5_val be extract_token_part(t5, 1)

            If t1_val is equal to "not":
                If t2_val is equal to "equal" and t3_val is equal to "to":
                    Let right_pos be position plus 5
                    Let right_expr be parse_additive_expression(tokens, right_pos)
                    Let result be "comparison_expression|"
                    Set result to concat(result, left_expr)
                    Set result to concat(result, "|IsNotEqualTo|")
                    Set result to concat(result, right_expr)
                    Return result
                End If
            End If

            If t1_val is equal to "greater" and t2_val is equal to "than" and t3_val is equal to "or" and t4_val is equal to "equal" and t5_val is equal to "to":
                Let right_pos be position plus 6
                Let right_expr be parse_additive_expression(tokens, right_pos)
                Let result be "comparison_expression|"
                Set result to concat(result, left_expr)
                Set result to concat(result, "|IsGreaterOrEqual|")
                Set result to concat(result, right_expr)
                Return result
            End If

            If t1_val is equal to "less" and t2_val is equal to "than" and t3_val is equal to "or" and t4_val is equal to "equal" and t5_val is equal to "to":
                Let right_pos be position plus 6
                Let right_expr be parse_additive_expression(tokens, right_pos)
                Let result be "comparison_expression|"
                Set result to concat(result, left_expr)
                Set result to concat(result, "|IsLessOrEqual|")
                Set result to concat(result, right_expr)
                Return result
            End If

            If t1_val is equal to "equal" and t2_val is equal to "to":
                Let right_pos be position plus 4
                Let right_expr be parse_additive_expression(tokens, right_pos)
                Let result be "comparison_expression|"
                Set result to concat(result, left_expr)
                Set result to concat(result, "|IsEqualTo|")
                Set result to concat(result, right_expr)
                Return result
            End If

            If t1_val is equal to "less" and t2_val is equal to "than":
                Let right_pos be position plus 4
                Let right_expr be parse_additive_expression(tokens, right_pos)
                Let result be "comparison_expression|"
                Set result to concat(result, left_expr)
                Set result to concat(result, "|IsLessThan|")
                Set result to concat(result, right_expr)
                Return result
            End If

            If t1_val is equal to "greater" and t2_val is equal to "than":
                Let right_pos be position plus 4
                Let right_expr be parse_additive_expression(tokens, right_pos)
                Let result be "comparison_expression|"
                Set result to concat(result, left_expr)
                Set result to concat(result, "|IsGreaterThan|")
                Set result to concat(result, right_expr)
                Return result
            End If
        End If
    End If

    Return left_expr
End Process

Process called "parse_expression" that takes tokens as String, position as Integer returns String:
    Note: ParseExpressionWithPrecedence
    Let res be parse_expression2(tokens, position)
    Return get_result_ast(res)
End Process

Process called "make_parse_result" that takes ast as String, next_pos as Integer returns String:
    Let s be ast
    Set s to concat(s, "||")
    Set s to concat(s, to_string(next_pos))
    Return s
End Process

Process called "get_result_ast" that takes result as String returns String:
    Let sep be find_char(result, 124, 0)
    Let sep2 be find_char(result, 124, sep plus 1)
    If sep2 is greater than 0:
        Return substring(result, 0, sep2 minus 1)
    End If
    Return result
End Process

Process called "get_result_pos" that takes result as String returns Integer:
    Let sep be find_char(result, 124, 0)
    Let sep2 be find_char(result, 124, sep plus 1)
    If sep2 is greater than 0:
        Let pos_str be substring(result, sep2 plus 1, length_of(result))
        Return parse_integer(pos_str)
    End If
    Return 0
End Process

Process called "parse_primary2" that takes tokens as String, position as Integer returns String:
    Let current_token be get_token_at_position(tokens, position)
    Let token_type be extract_token_part(current_token, 0)
    Let token_value be extract_token_part(current_token, 1)

    If token_type is equal to "Integer":
        Return make_parse_result(concat("integer_literal|", token_value), position plus 1)
    End If
    If token_type is equal to "StringLiteral":
        Return make_parse_result(concat("string_literal|", token_value), position plus 1)
    End If
    If token_type is equal to "Identifier":
        Return make_parse_result(concat("identifier|", token_value), position plus 1)
    End If
    If token_type is equal to "LeftParen":
        Let inner be parse_expression2(tokens, position plus 1)
        Let np be get_result_pos(inner)
        Let rparen_tok be get_token_at_position(tokens, np)
        Let rparen_type be extract_token_part(rparen_tok, 0)
        If rparen_type is equal to "RightParen":
            Return make_parse_result(get_result_ast(inner), np plus 1)
        End If
        Return make_parse_result(get_result_ast(inner), np)
    End If
    Return make_parse_result("expression_error", position)
End Process

Process called "parse_unary2" that takes tokens as String, position as Integer returns String:
    Let tok be get_token_at_position(tokens, position)
    Let ttype be extract_token_part(tok, 0)
    If ttype is equal to "Minus":
        Let next_tok be get_token_at_position(tokens, position plus 1)
        Let ntype be extract_token_part(next_tok, 0)
        Let nval be extract_token_part(next_tok, 1)
        If ntype is equal to "Integer":
            Return make_parse_result(concat("integer_literal|", concat("-", nval)), position plus 2)
        End If
    End If
    Return parse_primary2(tokens, position)
End Process

Process called "parse_multiplicative2" that takes tokens as String, position as Integer returns String:
    Let left_res be parse_unary2(tokens, position)
    Let left_ast be get_result_ast(left_res)
    Let pos be get_result_pos(left_res)

    Let done be 0
    While done is equal to 0:
        Let t1 be get_token_at_position(tokens, pos)
        Let v1 be extract_token_part(t1, 1)
        Let t2 be get_token_at_position(tokens, pos plus 1)
        Let v2 be extract_token_part(t2, 1)
        If v1 is equal to "multiplied" and v2 is equal to "by":
            Let rhs_res be parse_unary2(tokens, pos plus 2)
            Let rhs_ast be get_result_ast(rhs_res)
            Set pos to get_result_pos(rhs_res)
            Let tmp be "binary_expression|"
            Set tmp to concat(tmp, left_ast)
            Set tmp to concat(tmp, "|Multiply|")
            Set tmp to concat(tmp, rhs_ast)
            Set left_ast to tmp
        Otherwise:
            If v1 is equal to "divided" and v2 is equal to "by":
                Let rhs_res be parse_unary2(tokens, pos plus 2)
                Let rhs_ast be get_result_ast(rhs_res)
                Set pos to get_result_pos(rhs_res)
                Let tmp be "binary_expression|"
                Set tmp to concat(tmp, left_ast)
                Set tmp to concat(tmp, "|Divide|")
                Set tmp to concat(tmp, rhs_ast)
                Set left_ast to tmp
            Otherwise:
                Set done to 1
            End If
        End If
    End While

    Return make_parse_result(left_ast, pos)
End Process

Process called "parse_additive2" that takes tokens as String, position as Integer returns String:
    Let left_res be parse_multiplicative2(tokens, position)
    Let left_ast be get_result_ast(left_res)
    Let pos be get_result_pos(left_res)

    While 1 is equal to 1:
        Let tok be get_token_at_position(tokens, pos)
        Let ttype be extract_token_part(tok, 0)
        If ttype is equal to "Plus":
            Let rhs_res be parse_multiplicative2(tokens, pos plus 1)
            Let rhs_ast be get_result_ast(rhs_res)
            Set pos to get_result_pos(rhs_res)
            Let tmp be "binary_expression|"
            Set tmp to concat(tmp, left_ast)
            Set tmp to concat(tmp, "|Plus|")
            Set tmp to concat(tmp, rhs_ast)
            Set left_ast to tmp
        Otherwise:
            If ttype is equal to "Minus":
                Let rhs_res be parse_multiplicative2(tokens, pos plus 1)
                Let rhs_ast be get_result_ast(rhs_res)
                Set pos to get_result_pos(rhs_res)
                Let tmp be "binary_expression|"
                Set tmp to concat(tmp, left_ast)
                Set tmp to concat(tmp, "|Minus|")
                Set tmp to concat(tmp, rhs_ast)
                Set left_ast to tmp
            Otherwise:
                Break
            End If
        End If
    End While

    Return make_parse_result(left_ast, pos)
End Process

Process called "parse_comparison2" that takes tokens as String, position as Integer returns String:
    Let left_res be parse_additive2(tokens, position)
    Let left_ast be get_result_ast(left_res)
    Let pos be get_result_pos(left_res)

    Let t0 be get_token_at_position(tokens, pos)
    Let t0_type be extract_token_part(t0, 0)
    Let t0_val be extract_token_part(t0, 1)

    Let op_tag be ""
    Let adv be 0

    If t0_type is equal to "IsEqualTo":
        Set op_tag to "IsEqualTo"
        Set adv to 3
    End If
    If t0_type is equal to "IsNotEqualTo":
        Set op_tag to "IsNotEqualTo"
        Set adv to 4
    End If
    If t0_type is equal to "IsLessThan":
        Set op_tag to "IsLessThan"
        Set adv to 3
    End If
    If t0_type is equal to "IsGreaterThan":
        Set op_tag to "IsGreaterThan"
        Set adv to 3
    End If

    If length_of(op_tag) is equal to 0 and t0_type is equal to "Identifier" and t0_val is equal to "is":
        Let t1 be get_token_at_position(tokens, pos plus 1)
        Let v1 be extract_token_part(t1, 1)
        Let t2 be get_token_at_position(tokens, pos plus 2)
        Let v2 be extract_token_part(t2, 1)
        Let t3 be get_token_at_position(tokens, pos plus 3)
        Let v3 be extract_token_part(t3, 1)
        If v1 is equal to "not" and v2 is equal to "equal" and v3 is equal to "to":
            Set op_tag to "IsNotEqualTo"
            Set adv to 4
        End If
        If length_of(op_tag) is equal to 0 and v1 is equal to "equal" and v2 is equal to "to":
            Set op_tag to "IsEqualTo"
            Set adv to 3
        End If
        If length_of(op_tag) is equal to 0 and v1 is equal to "less" and v2 is equal to "than":
            Set op_tag to "IsLessThan"
            Set adv to 3
        End If
        If length_of(op_tag) is equal to 0 and v1 is equal to "greater" and v2 is equal to "than":
            Set op_tag to "IsGreaterThan"
            Set adv to 3
        End If
    End If

    If length_of(op_tag) is equal to 0:
        Return make_parse_result(left_ast, pos)
    End If

    Let rhs_res be parse_additive2(tokens, pos plus adv)
    Let rhs_ast be get_result_ast(rhs_res)
    Let rpos be get_result_pos(rhs_res)

    Let res be "comparison_expression|"
    Set res to concat(res, left_ast)
    Set res to concat(res, "|")
    Set res to concat(res, op_tag)
    Set res to concat(res, "|")
    Set res to concat(res, rhs_ast)
    Return make_parse_result(res, rpos)
End Process

Process called "parse_expression2" that takes tokens as String, position as Integer returns String:
    Return parse_comparison2(tokens, position)
End Process

Process called "parse_condition" that takes tokens as String, position as Integer returns String:
    Note: ParseCondition
    Let left_expr be parse_additive_expression(tokens, position)
    Let op_pos be position plus 1
    Let t0 be get_token_at_position(tokens, op_pos)
    Let t0_type be extract_token_part(t0, 0)
    Let t0_val be extract_token_part(t0, 1)

    Let op_tag be ""
    Let right_pos be op_pos plus 1

    If t0_type is equal to "IsEqualTo":
        Set op_tag to "IsEqualTo"
        Set right_pos to op_pos plus 3
    End If
    If t0_type is equal to "IsNotEqualTo":
        Set op_tag to "IsNotEqualTo"
        Set right_pos to op_pos plus 4
    End If
    If t0_type is equal to "IsLessThan":
        Set op_tag to "IsLessThan"
        Set right_pos to op_pos plus 3
    End If
    If t0_type is equal to "IsGreaterThan":
        Set op_tag to "IsGreaterThan"
        Set right_pos to op_pos plus 3
    End If
    If t0_type is equal to "IsLessThanOrEqualTo":
        Set op_tag to "IsLessThanOrEqualTo"
        Set right_pos to op_pos plus 6
    End If
    If t0_type is equal to "IsGreaterThanOrEqualTo":
        Set op_tag to "IsGreaterThanOrEqualTo"
        Set right_pos to op_pos plus 6
    End If

    If length_of(op_tag) is equal to 0:
        If t0_type is equal to "Identifier":
            If t0_val is equal to "is":
                Let t1 be get_token_at_position(tokens, op_pos plus 1)
                Let t2 be get_token_at_position(tokens, op_pos plus 2)
                Let t3 be get_token_at_position(tokens, op_pos plus 3)
                Let t4 be get_token_at_position(tokens, op_pos plus 4)
                Let t5 be get_token_at_position(tokens, op_pos plus 5)
                Let v1 be extract_token_part(t1, 1)
                Let v2 be extract_token_part(t2, 1)
                Let v3 be extract_token_part(t3, 1)
                Let v4 be extract_token_part(t4, 1)
                Let v5 be extract_token_part(t5, 1)

                If v1 is equal to "not" and v2 is equal to "equal" and v3 is equal to "to":
                    Set op_tag to "IsNotEqualTo"
                    Set right_pos to op_pos plus 4
                End If
                If length_of(op_tag) is equal to 0 and v1 is equal to "equal" and v2 is equal to "to":
                    Set op_tag to "IsEqualTo"
                    Set right_pos to op_pos plus 3
                End If
                If length_of(op_tag) is equal to 0 and v1 is equal to "less" and v2 is equal to "than":
                    If v3 is equal to "or" and v4 is equal to "equal" and v5 is equal to "to":
                        Set op_tag to "IsLessThanOrEqualTo"
                        Set right_pos to op_pos plus 6
                    Otherwise:
                        Set op_tag to "IsLessThan"
                        Set right_pos to op_pos plus 3
                    End If
                End If
                If length_of(op_tag) is equal to 0 and v1 is equal to "greater" and v2 is equal to "than":
                    If v3 is equal to "or" and v4 is equal to "equal" and v5 is equal to "to":
                        Set op_tag to "IsGreaterThanOrEqualTo"
                        Set right_pos to op_pos plus 6
                    Otherwise:
                        Set op_tag to "IsGreaterThan"
                        Set right_pos to op_pos plus 3
                    End If
                End If
            End If
        End If
    End If

    If length_of(op_tag) is equal to 0:
        Return left_expr
    End If

    Let right_expr be parse_additive_expression(tokens, right_pos)

    Let result be "comparison_expression|"
    Set result to concat(result, left_expr)
    Set result to concat(result, "|")
    Set result to concat(result, op_tag)
    Set result to concat(result, "|")
    Set result to concat(result, right_expr)
    Return result
End Process

Process called "parse_note_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseNoteStatement
    Let note_token be get_token_at_position(tokens, position)
    Let note_value be extract_token_part(note_token, 1)
    Let result be "note_statement|"
    Set result to concat(result, note_value)
    Return result
End Process

Process called "parse_import_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseImportStatement - import module "path" as name
    Let module_token be get_token_at_position(tokens, position plus 2)
    Let module_path be extract_token_part(module_token, 1)
    Let alias_token be get_token_at_position(tokens, position plus 4)
    Let alias_name be extract_token_part(alias_token, 1)
    Let result be "import_statement|"
    Set result to concat(result, module_path)
    Set result to concat(result, "|")
    Set result to concat(result, alias_name)
    Return result
End Process

Process called "parse_let_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseLetStatement
    Let var_token be get_token_at_position(tokens, position plus 1)
    Let var_name be extract_token_part(var_token, 1)
    Let expr_position be position plus 3
    Let expr_ast be parse_expression(tokens, expr_position)
    Let result be "let_statement|"
    Set result to concat(result, var_name)
    Set result to concat(result, "|")
    Set result to concat(result, expr_ast)
    Return result
End Process

Process called "parse_set_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseSetStatement
    Let var_token be get_token_at_position(tokens, position plus 1)
    Let var_name be extract_token_part(var_token, 1)
    Let expr_position be position plus 3
    Let expr_ast be parse_expression(tokens, expr_position)
    Let result be "set_statement|"
    Set result to concat(result, var_name)
    Set result to concat(result, "|")
    Set result to concat(result, expr_ast)
    Return result
End Process

Process called "parse_display_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseDisplayStatement
    Let expr_position be position plus 1
    Let expr_ast be parse_expression(tokens, expr_position)
    Let result be "display_statement|"
    Set result to concat(result, expr_ast)
    Return result
End Process

Process called "parse_return_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseReturnStatement
    Let expr_position be position plus 1
    Let expr_ast be parse_expression(tokens, expr_position)
    Let result be "return_statement|"
    Set result to concat(result, expr_ast)
    Return result
End Process

Process called "parse_if_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseIfStatement
    Let condition_position be position plus 1
    Let cres be parse_expression2(tokens, condition_position)
    Let condition_ast be get_result_ast(cres)
    Let after_cond be get_result_pos(cres)
    Let colon_tok be get_token_at_position(tokens, after_cond)
    Let colon_type be extract_token_part(colon_tok, 0)
    If colon_type is not equal to "Colon":
        Return "error_expected_colon"
    End If
    Let result be "if_statement|"
    Set result to concat(result, condition_ast)
    Set result to concat(result, "|body_statements")
    Return result
End Process

Process called "parse_while_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseWhileStatement
    Let condition_position be position plus 1
    Let cres be parse_expression2(tokens, condition_position)
    Let condition_ast be get_result_ast(cres)
    Let after_cond be get_result_pos(cres)
    Let colon_tok be get_token_at_position(tokens, after_cond)
    Let colon_type be extract_token_part(colon_tok, 0)
    If colon_type is not equal to "Colon":
        Return "error_expected_colon"
    End If
    Let result be "while_statement|"
    Set result to concat(result, condition_ast)
    Set result to concat(result, "|body_statements")
    Return result
End Process

Process called "parse_process_definition" that takes tokens as String, position as Integer returns String:
    Note: ParseProcessDefinition
    Let name_token be get_token_at_position(tokens, position plus 2)
    Let process_name be extract_token_part(name_token, 1)
    Let result be "process_definition|"
    Set result to concat(result, process_name)
    Set result to concat(result, "|parameters|return_type|body_statements")
    Return result
End Process

Process called "parse_type_definition" that takes tokens as String, position as Integer returns String:
    Note: ParseTypeDefinition
    Let name_token be get_token_at_position(tokens, position plus 2)
    Let type_name be extract_token_part(name_token, 1)
    Let result be "type_definition|"
    Set result to concat(result, type_name)
    Set result to concat(result, "|fields")
    Return result
End Process


Process called "parse_statement" that takes tokens as String, position as Integer returns String:
    Note: ParseStatement
    Let current_token be get_token_at_position(tokens, position)
    Let token_type be extract_token_part(current_token, 0)

    If token_type is equal to "Let":
        Return parse_let_statement(tokens, position)
    End If
    If token_type is equal to "Set":
        Return parse_set_statement(tokens, position)
    End If
    If token_type is equal to "Display":
        Return parse_display_statement(tokens, position)
    End If
    If token_type is equal to "Return":
        Return parse_return_statement(tokens, position)
    End If
    If token_type is equal to "If":
        Return parse_if_statement(tokens, position)
    End If
    If token_type is equal to "While":
        Return parse_while_statement(tokens, position)
    End If
    If token_type is equal to "Process":
        Return parse_process_definition(tokens, position)
    End If
    If token_type is equal to "Type":
        Return parse_type_definition(tokens, position)
    End If
    If token_type is equal to "Note":
        Return parse_note_statement(tokens, position)
    End If
    If token_type is equal to "Import":
        Return parse_import_statement(tokens, position)
    End If

    Note: Support bare function call statements like test_compiler()
    If token_type is equal to "Identifier":
        Let next_token be get_token_at_position(tokens, position plus 1)
        Let next_type be extract_token_part(next_token, 0)
        If next_type is equal to "LeftParen":
            Return parse_expression(tokens, position)
        End If
    End If

    Return "unknown_statement"
End Process

Process called "parse_program" that takes tokens as String returns String:
    Note: ParseProgram
    Let parsed_statements be ""
    Let current_position be 0
    Let max_tokens be count_lines(tokens)

    While current_position is less than max_tokens:
        Let current_token be get_token_at_position(tokens, current_position)
        Let token_type be extract_token_part(current_token, 0)

        If token_type is equal to "EOF":
            Set current_position to max_tokens
        End If
        If token_type is not equal to "EOF":
            If token_type is equal to "Process":
                Note: Parse a full process block and advance to its End
                Let name_token be get_token_at_position(tokens, current_position plus 2)
                Let process_name be extract_token_part(name_token, 1)

                Let body_start be current_position plus 1
                Let scan_pos be body_start
                Let body_stmts be ""
                Let scanning be 1
                While scan_pos is less than max_tokens:
                    Let tok be get_token_at_position(tokens, scan_pos)
                    Let ttype be extract_token_part(tok, 0)
                    If ttype is equal to "End":
                        Set scanning to 0
                    End If
                    If scanning is equal to 1:
                        Let stmt_ast be parse_statement(tokens, scan_pos)
                        Set body_stmts to append_string_with_separator(body_stmts, stmt_ast, ";")
                    End If
                    Set scan_pos to scan_pos plus 1
                End While

                Let proc_ast be "process_definition|"
                Set proc_ast to concat(proc_ast, process_name)
                Set proc_ast to concat(proc_ast, "|parameters|return_type|")
                Set proc_ast to concat(proc_ast, body_stmts)
                Set parsed_statements to append_string_with_separator(parsed_statements, proc_ast, ";")

                Note: Advance current_position to after End
                Set current_position to scan_pos
            End If

            If token_type is not equal to "Process":
                Let stmt_result be parse_statement(tokens, current_position)
                Set parsed_statements to append_string_with_separator(parsed_statements, stmt_result, ";")
                Set current_position to current_position plus 1
            End If
        End If
    End While

    Return concat("program|", parsed_statements)
End Process