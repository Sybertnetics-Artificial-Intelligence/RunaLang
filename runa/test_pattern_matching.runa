Let user status be "active"
Let user level be 5

Display "Testing pattern matching:"

Match user status:
    When "active":
        Display "User is currently active"
        Display "Processing active user tasks"
    When "inactive":
        Display "User is inactive"
    When "suspended":
        Display "User account is suspended"  
    Otherwise:
        Display "Unknown user status"

Display ""
Display "Testing numeric pattern matching:"

Match user level:
    When 1:
        Display "Beginner user"
    When 5:
        Display "Intermediate user"
    When 10:
        Display "Expert user"
    Otherwise:
        Display "Custom user level"

Let grade be "A"

Display ""
Display "Testing grade pattern matching:"

Match grade:
    When "A":
        Display "Excellent work!"
    When "B":
        Display "Good job!"
    When "C":
        Display "Average performance"
    Otherwise:
        Display "Needs improvement"

Display "Pattern matching tests completed!"