"""
Debug dictionary creation
"""

# Test basic dictionary creation
Let simple_dict be Dictionary with opcode as "TEST"
Display "Simple dict:" followed by simple_dict

# Test dictionary creation with multiple keys
Let complex_dict be Dictionary with opcode as "LOAD_CONST" and value as 42
Display "Complex dict:" followed by complex_dict

# Test accessing keys from created dictionary
If simple_dict is not None:
    Display "Simple dict opcode:" followed by simple_dict at key "opcode"
Otherwise:
    Display "Simple dict is None - creation failed"

Display "Dictionary creation debug complete!" 