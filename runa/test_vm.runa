"""
Test Runa VM - Simple Test File
==============================

A simple test file to validate our bootstrap runner.
"""

# Import required modules using Runa syntax
Let required_modules be list containing "time", "logging"
Let imported_modules be empty dictionary

For each module_name in required_modules:
    Try:
        Let imported_modules at key module_name be import module_name
    Catch ImportError as error:
        Display "Failed to import" followed by module_name with message error

# Define a simple type
Type TestType is "success" OR "failure" OR "pending"

# Create a simple VM
Let test_vm be create RunaVM with memory_size as 1024

# Test arithmetic operations
Let width be 10
Let height be 5
Let area be width multiplied by height

# Test string operations
Let user_name be "Alex"
Let full_name be user_name followed by " Smith"

# Test list operations
Let colors be list containing "red", "green", "blue"
Let color_count be length of colors

# Test dictionary operations
Let user_data be dictionary with:

# Display results
Display area with message "Area calculation"
Display full_name with message "Full name"
Display color_count with message "Number of colors"
Display test_vm with message "VM created successfully"

# Return success
Return "Test completed successfully" 