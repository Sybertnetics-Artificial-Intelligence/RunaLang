"""
Debug stack operation
"""

# Create VM and stack
Let vm be empty dictionary
Let vm at key "stack" be empty list

Display "Initial stack:" followed by vm at key "stack"

# Test getting the stack value
Let current_stack be vm at key "stack"
Display "Retrieved stack:" followed by current_stack

# Test adding to the stack
Let value be 42
Let new_stack be current_stack plus value

Display "New stack:" followed by new_stack

# Test setting it back
Let vm at key "stack" be new_stack
Display "Final stack:" followed by vm at key "stack" 