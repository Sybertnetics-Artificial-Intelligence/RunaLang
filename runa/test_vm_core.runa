"""
Simplified VM core test - focusing on the patterns that are failing
"""

# Test dictionary operations that the VM uses
Let instruction be Dictionary with opcode as "LOAD_CONST" and value as 42
Display "Created instruction:" followed by instruction at key "opcode"

# Test the problematic arithmetic pattern
Let i be 2
Display "Original i:" followed by i
Display "Type of i:" followed by type of i

Let prev_index be i minus 1
Display "Calculated prev_index:" followed by prev_index
Display "Type of prev_index:" followed by type of prev_index

# Test array indexing with calculated index
Let instructions be list containing 
    Dictionary with opcode as "LOAD_CONST" and value as 10,
    Dictionary with opcode as "BINARY_OP" and operator as "plus"

Let prev_instruction be instructions at index prev_index
Display "Retrieved instruction:" followed by prev_instruction at key "opcode"

# Test the OR pattern
Let test_value be instruction at key "value" OR None
Display "OR pattern result:" followed by test_value

# Test complex conditional
If instruction at key "opcode" is equal to "LOAD_CONST" and i is greater than 0:
    Display "Complex conditional passed!"

Display "Core VM patterns test complete!" 