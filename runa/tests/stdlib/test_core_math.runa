Note:
Runa Standard Library Test: Math Core
:End Note

Test "add works":
    Let result be add with a as 2 and b as 3
    Assert result is equal to 5

Test "subtract works":
    Let result be subtract with a as 5 and b as 2
    Assert result is equal to 3

Test "multiply works":
    Let result be multiply with a as 4 and b as 2
    Assert result is equal to 8

Test "divide works":
    Let result be divide with a as 10 and b as 2
    Assert result is equal to 5
    Let result be divide with a as 0 and b as 1
    Assert result is equal to 0

Test "divide by zero raises error":
    Try:
        Let _ be divide with a as 1 and b as 0
        Assert False with message "Expected error when dividing by zero"
    Catch Error:
        Assert True

Test "min works":
    Assert min(2, 3) is equal to 2
    Assert min(3, 2) is equal to 2
    Assert min(-1, 0) is equal to -1

Test "max works":
    Assert max(2, 3) is equal to 3
    Assert max(3, 2) is equal to 3
    Assert max(-1, 0) is equal to 0

Test "abs works":
    Assert abs(5) is equal to 5
    Assert abs(-5) is equal to 5
    Assert abs(0) is equal to 0

Test "pow works":
    Assert pow(2, 3) is equal to 8
    Assert pow(5, 0) is equal to 1
    Assert pow(2, 1) is equal to 2 