Note:
Runa Standard Library Test: Deque
Comprehensive test suite for Deque functionality including advanced features.
:End Note

Note: Basic Deque Operations
Test "create and basic operations work":
    Let d be create_deque()
    Let d be add_to_front with deque as d and value as "first"
    Let d be add_to_back with deque as d and value as "last"
    Assert deque_length with deque as d is equal to 2
    Assert peek_front with deque as d is equal to "first"
    Assert peek_back with deque as d is equal to "last"

Test "remove operations work":
    Let d be create_deque()
    Let d be add_to_back with deque as d and value as "a"
    Let d be add_to_back with deque as d and value as "b"
    Let (d, front_val) be remove_from_front with deque as d
    Let (d, back_val) be remove_from_back with deque as d
    Assert front_val is equal to "a"
    Assert back_val is equal to "b"
    Assert deque_is_empty with deque as d is equal to true

Test "empty deque operations raise errors":
    Let d be create_deque()
    Try:
        Let _ be peek_front with deque as d
        Assert False with message "Expected error when peeking empty deque"
    Catch IndexError:
        Assert True
    Try:
        Let _ be remove_from_front with deque as d
        Assert False with message "Expected error when removing from empty deque"
    Catch IndexError:
        Assert True

Note: Bounded Deque Operations
Test "bounded deque with maxlen works":
    Let d be create_deque_with_maxlen with maxlen as 3
    Let d be add_to_back with deque as d and value as "a"
    Let d be add_to_back with deque as d and value as "b"
    Let d be add_to_back with deque as d and value as "c"
    Let d be add_to_back with deque as d and value as "d"
    Assert deque_length with deque as d is equal to 3
    Assert peek_front with deque as d is equal to "b"
    Assert peek_back with deque as d is equal to "d"

Test "bounded deque front operations respect maxlen":
    Let d be create_deque_with_maxlen with maxlen as 2
    Let d be add_to_front with deque as d and value as "a"
    Let d be add_to_front with deque as d and value as "b"
    Let d be add_to_front with deque as d and value as "c"
    Assert deque_length with deque as d is equal to 2
    Assert peek_front with deque as d is equal to "c"
    Assert peek_back with deque as d is equal to "b"

Test "deque_is_full works":
    Let d be create_deque_with_maxlen with maxlen as 2
    Assert deque_is_full with deque as d is equal to false
    Let d be add_to_back with deque as d and value as "a"
    Let d be add_to_back with deque as d and value as "b"
    Assert deque_is_full with deque as d is equal to true

Test "get_maxlen and set_maxlen work":
    Let d be create_deque()
    Assert get_maxlen with deque as d is equal to None
    Let d be set_maxlen with deque as d and maxlen as 5
    Let maxlen be get_maxlen with deque as d
    Assert maxlen is equal to Some with value as 5

Note: Rotation and Shifting Operations
Test "rotate operations work":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be rotate with deque as d and n as 2
    Let items be to_list with deque as d
    Assert items[0] is equal to 4
    Assert items[1] is equal to 5
    Assert items[2] is equal to 1
    Assert items[3] is equal to 2
    Assert items[4] is equal to 3

Test "rotate_left and rotate_right work":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be rotate_left with deque as d and n as 2
    Let items be to_list with deque as d
    Assert items[0] is equal to 3
    Assert items[1] is equal to 4
    Assert items[2] is equal to 5
    Assert items[3] is equal to 1
    Assert items[4] is equal to 2

Test "shift operations work":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be shift_left with deque as d and n as 2
    Let items be to_list with deque as d
    Assert length of items is equal to 3
    Assert items[0] is equal to 3
    Assert items[1] is equal to 4
    Assert items[2] is equal to 5

Test "shift_right works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be shift_right with deque as d and n as 2
    Let items be to_list with deque as d
    Assert length of items is equal to 3
    Assert items[0] is equal to 1
    Assert items[1] is equal to 2
    Assert items[2] is equal to 3

Note: Bulk Operations
Test "extend_front works":
    Let d be create_deque()
    Let d be extend_front with deque as d and values as list containing "a", "b", "c"
    Let items be to_list with deque as d
    Assert items[0] is equal to "a"
    Assert items[1] is equal to "b"
    Assert items[2] is equal to "c"

Test "extend_back works":
    Let d be create_deque()
    Let d be extend_back with deque as d and values as list containing "x", "y", "z"
    Let items be to_list with deque as d
    Assert items[0] is equal to "x"
    Assert items[1] is equal to "y"
    Assert items[2] is equal to "z"

Test "clear works":
    Let d be from_list with items as list containing 1, 2, 3
    Let d be clear with deque as d
    Assert deque_is_empty with deque as d is equal to true

Test "copy works":
    Let d be from_list with items as list containing 1, 2, 3
    Let copied be copy with deque as d
    Assert deque_length with deque as copied is equal to 3
    Let d be add_to_back with deque as d and value as 4
    Assert deque_length with deque as copied is equal to 3

Note: Slicing and Indexing
Test "get_at_index works":
    Let d be from_list with items as list containing "a", "b", "c", "d"
    Assert get_at_index with deque as d and index as 1 is equal to "b"
    Assert get_at_index with deque as d and index as negative 1 is equal to "d"

Test "set_at_index works":
    Let d be from_list with items as list containing "a", "b", "c", "d"
    Let d be set_at_index with deque as d and index as 1 and value as "x"
    Assert get_at_index with deque as d and index as 1 is equal to "x"

Test "slice_deque works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let sliced be slice_deque with deque as d and start as 1 and end as 4
    Let items be to_list with deque as sliced
    Assert length of items is equal to 3
    Assert items[0] is equal to 2
    Assert items[1] is equal to 3
    Assert items[2] is equal to 4

Test "reverse works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be reverse with deque as d
    Let items be to_list with deque as d
    Assert items[0] is equal to 5
    Assert items[1] is equal to 4
    Assert items[2] is equal to 3
    Assert items[3] is equal to 2
    Assert items[4] is equal to 1

Note: Searching and Filtering
Test "index_of works":
    Let d be from_list with items as list containing "apple", "banana", "apple", "cherry"
    Assert index_of with deque as d and value as "banana" is equal to 1
    Assert index_of with deque as d and value as "apple" is equal to 0

Test "index_of_from works":
    Let d be from_list with items as list containing "apple", "banana", "apple", "cherry"
    Assert index_of_from with deque as d and value as "apple" and start as 1 is equal to 2

Test "count works":
    Let d be from_list with items as list containing "apple", "banana", "apple", "cherry"
    Assert count with deque as d and value as "apple" is equal to 2
    Assert count with deque as d and value as "cherry" is equal to 1
    Assert count with deque as d and value as "orange" is equal to 0

Test "contains works":
    Let d be from_list with items as list containing "apple", "banana", "cherry"
    Assert contains with deque as d and value as "banana" is equal to true
    Assert contains with deque as d and value as "orange" is equal to false

Test "filter works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5, 6
    Let predicate be lambda x: x modulo 2 is equal to 0
    Let filtered be filter with deque as d and predicate as predicate
    Let items be to_list with deque as filtered
    Assert length of items is equal to 3
    Assert items[0] is equal to 2
    Assert items[1] is equal to 4
    Assert items[2] is equal to 6

Test "map works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let transform be lambda x: x multiplied by 2
    Let mapped be map with deque as d and transform as transform
    Let items be to_list with deque as mapped
    Assert items[0] is equal to 2
    Assert items[1] is equal to 4
    Assert items[2] is equal to 6
    Assert items[3] is equal to 8
    Assert items[4] is equal to 10

Note: Sorting and Ordering
Test "sort works":
    Let d be from_list with items as list containing 3, 1, 4, 1, 5
    Let d be sort with deque as d
    Let items be to_list with deque as d
    Assert items[0] is equal to 1
    Assert items[1] is equal to 1
    Assert items[2] is equal to 3
    Assert items[3] is equal to 4
    Assert items[4] is equal to 5

Test "sort_reverse works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let d be sort_reverse with deque as d
    Let items be to_list with deque as d
    Assert items[0] is equal to 5
    Assert items[1] is equal to 4
    Assert items[2] is equal to 3
    Assert items[3] is equal to 2
    Assert items[4] is equal to 1

Test "is_sorted works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Assert is_sorted with deque as d is equal to true
    Let d be from_list with items as list containing 5, 4, 3, 2, 1
    Assert is_sorted with deque as d is equal to false

Test "is_sorted_reverse works":
    Let d be from_list with items as list containing 5, 4, 3, 2, 1
    Assert is_sorted_reverse with deque as d is equal to true
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Assert is_sorted_reverse with deque as d is equal to false

Note: Statistical Operations
Test "min_element works":
    Let d be from_list with items as list containing 3, 1, 4, 1, 5
    Assert min_element with deque as d is equal to 1

Test "max_element works":
    Let d be from_list with items as list containing 3, 1, 4, 1, 5
    Assert max_element with deque as d is equal to 5

Test "sum_elements works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Assert sum_elements with deque as d is equal to 15

Test "average works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Assert average with deque as d is equal to 3

Test "empty deque statistical operations raise errors":
    Let d be create_deque()
    Try:
        Let _ be min_element with deque as d
        Assert False with message "Expected error for min_element on empty deque"
    Catch ValueError:
        Assert True
    Try:
        Let _ be average with deque as d
        Assert False with message "Expected error for average on empty deque"
    Catch ValueError:
        Assert True

Note: Memory and Performance Optimizations
Test "compact works":
    Let d be from_list with items as list containing 1, None, 2, None, 3
    Let compacted be compact with deque as d
    Let items be to_list with deque as compacted
    Assert length of items is equal to 3
    Assert items[0] is equal to 1
    Assert items[1] is equal to 2
    Assert items[2] is equal to 3

Test "deduplicate works":
    Let d be from_list with items as list containing 1, 2, 1, 3, 2, 4
    Let unique be deduplicate with deque as d
    Let items be to_list with deque as unique
    Assert length of items is equal to 4
    Assert items[0] is equal to 1
    Assert items[1] is equal to 2
    Assert items[2] is equal to 3
    Assert items[3] is equal to 4

Test "shuffle works":
    Let d be from_list with items as list containing 1, 2, 3, 4, 5
    Let shuffled be shuffle with deque as d
    Let items be to_list with deque as shuffled
    Assert length of items is equal to 5
    Assert contains with deque as shuffled and value as 1 is equal to true
    Assert contains with deque as shuffled and value as 2 is equal to true
    Assert contains with deque as shuffled and value as 3 is equal to true
    Assert contains with deque as shuffled and value as 4 is equal to true
    Assert contains with deque as shuffled and value as 5 is equal to true

Note: Utility Operations
Test "to_list works":
    Let d be from_list with items as list containing "a", "b", "c"
    Let items be to_list with deque as d
    Assert length of items is equal to 3
    Assert items[0] is equal to "a"
    Assert items[1] is equal to "b"
    Assert items[2] is equal to "c"

Test "from_list works":
    Let items be list containing 1, 2, 3, 4, 5
    Let d be from_list with items as items
    Assert deque_length with deque as d is equal to 5
    Assert get_at_index with deque as d and index as 0 is equal to 1
    Assert get_at_index with deque as d and index as 4 is equal to 5

Test "from_list_with_maxlen works":
    Let items be list containing 1, 2, 3, 4, 5
    Let d be from_list_with_maxlen with items as items and maxlen as 3
    Assert deque_length with deque as d is equal to 3
    Assert get_at_index with deque as d and index as 0 is equal to 3
    Assert get_at_index with deque as d and index as 2 is equal to 5

Note: Edge Cases and Error Handling
Test "index out of bounds raises error":
    Let d be from_list with items as list containing 1, 2, 3
    Try:
        Let _ be get_at_index with deque as d and index as 5
        Assert False with message "Expected error for index out of bounds"
    Catch IndexError:
        Assert True
    Try:
        Let _ be get_at_index with deque as d and index as negative 5
        Assert False with message "Expected error for negative index out of bounds"
    Catch IndexError:
        Assert True

Test "value not found raises error":
    Let d be from_list with items as list containing 1, 2, 3
    Try:
        Let _ be index_of with deque as d and value as 99
        Assert False with message "Expected error for value not found"
    Catch ValueError:
        Assert True

Test "rotation with empty deque works":
    Let d be create_deque()
    Let d be rotate with deque as d and n as 5
    Assert deque_is_empty with deque as d is equal to true

Test "shift beyond length works":
    Let d be from_list with items as list containing 1, 2, 3
    Let d be shift_left with deque as d and n as 5
    Assert deque_is_empty with deque as d is equal to true
    Let d be from_list with items as list containing 1, 2, 3
    Let d be shift_right with deque as d and n as 5
    Assert deque_is_empty with deque as d is equal to true

Test "large numbers work correctly":
    Let d be create_deque()
    For i from 1 to 1000:
        Let d be add_to_back with deque as d and value as i
    Assert deque_length with deque as d is equal to 1000
    Assert get_at_index with deque as d and index as 999 is equal to 1000 