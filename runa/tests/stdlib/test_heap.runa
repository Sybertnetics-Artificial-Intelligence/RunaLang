Note:
Runa Standard Library Test: Heap
Comprehensive test suite for Heap functionality including advanced features.
:End Note

Note: Basic Heap Operations
Test "create and basic operations work":
    Let h be create_heap()
    Let h be push with heap as h and value as 5
    Let h be push with heap as h and value as 3
    Let h be push with heap as h and value as 7
    Assert heap_length with heap as h is equal to 3
    Assert peek with heap as h is equal to 3

Test "pop operations work":
    Let h be create_heap()
    Let h be push with heap as h and value as 5
    Let h be push with heap as h and value as 3
    Let h be push with heap as h and value as 7
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 3
    Let (h, min_val2) be pop with heap as h
    Assert min_val2 is equal to 5
    Let (h, min_val3) be pop with heap as h
    Assert min_val3 is equal to 7
    Assert heap_is_empty with heap as h is equal to true

Test "empty heap operations raise errors":
    Let h be create_heap()
    Try:
        Let _ be peek with heap as h
        Assert False with message "Expected error when peeking empty heap"
    Catch IndexError:
        Assert True
    Try:
        Let _ be pop with heap as h
        Assert False with message "Expected error when popping empty heap"
    Catch IndexError:
        Assert True

Note: Max Heap Operations
Test "max heap operations work":
    Let h be create_max_heap()
    Let h be push with heap as h and value as 5
    Let h be push with heap as h and value as 3
    Let h be push with heap as h and value as 7
    Assert peek with heap as h is equal to 7
    Let (h, max_val) be pop with heap as h
    Assert max_val is equal to 7
    Let (h, max_val2) be pop with heap as h
    Assert max_val2 is equal to 5

Test "max heap type is correct":
    Let h be create_max_heap()
    Assert get_heap_type with heap as h is equal to "max"

Note: Priority-Based Heap Operations
Test "push_with_priority works":
    Let h be create_heap()
    Let h be push_with_priority with heap as h and value as "task1" and priority as 3
    Let h be push_with_priority with heap as h and value as "task2" and priority as 1
    Let h be push_with_priority with heap as h and value as "task3" and priority as 2
    Let (h, value, priority) be pop_with_priority with heap as h
    Assert value is equal to "task2"
    Assert priority is equal to 1

Test "peek_with_priority works":
    Let h be create_heap()
    Let h be push_with_priority with heap as h and value as "task1" and priority as 3
    Let h be push_with_priority with heap as h and value as "task2" and priority as 1
    Let (value, priority) be peek_with_priority with heap as h
    Assert value is equal to "task2"
    Assert priority is equal to 1

Note: Custom Comparator Operations
Test "custom comparator heap works":
    Let comparator be lambda a and b: length of a is less than length of b
    Let h be create_heap_with_comparator with comparator as comparator
    Let h be push with heap as h and value as "longer"
    Let h be push with heap as h and value as "short"
    Let h be push with heap as h and value as "medium"
    Let (h, shortest) be pop with heap as h
    Assert shortest is equal to "short"
    Let (h, medium) be pop with heap as h
    Assert medium is equal to "medium"

Test "custom heap type is correct":
    Let comparator be lambda a and b: a is less than b
    Let h be create_heap_with_comparator with comparator as comparator
    Assert get_heap_type with heap as h is equal to "custom"

Note: Bulk Operations
Test "heapify works":
    Let items be list containing 5, 3, 7, 1, 9, 2
    Let h be heapify with items as items
    Assert heap_length with heap as h is equal to 6
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 1

Test "heapify_max works":
    Let items be list containing 5, 3, 7, 1, 9, 2
    Let h be heapify_max with items as items
    Assert heap_length with heap as h is equal to 6
    Let (h, max_val) be pop with heap as h
    Assert max_val is equal to 9

Test "heapify_with_comparator works":
    Let items be list containing "long", "short", "medium", "tiny"
    Let comparator be lambda a and b: length of a is less than length of b
    Let h be heapify_with_comparator with items as items and comparator as comparator
    Let (h, shortest) be pop with heap as h
    Assert shortest is equal to "tiny"

Test "merge_heaps works":
    Let h1 be heapify with items as list containing 1, 3, 5
    Let h2 be heapify with items as list containing 2, 4, 6
    Let merged be merge_heaps with heap1 as h1 and heap2 as h2
    Assert heap_length with heap as merged is equal to 6
    Let (merged, min_val) be pop with heap as merged
    Assert min_val is equal to 1

Test "extend works":
    Let h be heapify with items as list containing 1, 3, 5
    Let h be extend with heap as h and values as list containing 2, 4, 6
    Assert heap_length with heap as h is equal to 6
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 1

Note: K-Element Operations
Test "k_largest works":
    Let h be heapify with items as list containing 5, 3, 7, 1, 9, 2, 8, 4, 6
    Let largest_3 be k_largest with heap as h and k as 3
    Assert length of largest_3 is equal to 3
    Assert largest_3[0] is equal to 9
    Assert largest_3[1] is equal to 8
    Assert largest_3[2] is equal to 7

Test "k_smallest works":
    Let h be heapify_max with items as list containing 5, 3, 7, 1, 9, 2, 8, 4, 6
    Let smallest_3 be k_smallest with heap as h and k as 3
    Assert length of smallest_3 is equal to 3
    Assert smallest_3[0] is equal to 1
    Assert smallest_3[1] is equal to 2
    Assert smallest_3[2] is equal to 3

Test "nlargest works":
    Let items be list containing 5, 3, 7, 1, 9, 2, 8, 4, 6
    Let largest_3 be nlargest with items as items and n as 3
    Assert length of largest_3 is equal to 3
    Assert largest_3[0] is equal to 9
    Assert largest_3[1] is equal to 8
    Assert largest_3[2] is equal to 7

Test "nsmallest works":
    Let items be list containing 5, 3, 7, 1, 9, 2, 8, 4, 6
    Let smallest_3 be nsmallest with items as items and n as 3
    Assert length of smallest_3 is equal to 3
    Assert smallest_3[0] is equal to 1
    Assert smallest_3[1] is equal to 2
    Assert smallest_3[2] is equal to 3

Note: Heap Validation and Debugging
Test "is_valid_heap works":
    Let h be heapify with items as list containing 1, 3, 5, 7, 9
    Assert is_valid_heap with heap as h is equal to true

Test "heap_to_list works":
    Let items be list containing 1, 3, 5
    Let h be heapify with items as items
    Let heap_list be heap_to_list with heap as h
    Assert length of heap_list is equal to 3
    Assert heap_list[0] is equal to 1

Test "heap_to_sorted_list works":
    Let items be list containing 5, 3, 1, 7, 9
    Let h be heapify with items as items
    Let sorted_list be heap_to_sorted_list with heap as h
    Assert length of sorted_list is equal to 5
    Assert sorted_list[0] is equal to 1
    Assert sorted_list[1] is equal to 3
    Assert sorted_list[2] is equal to 5
    Assert sorted_list[3] is equal to 7
    Assert sorted_list[4] is equal to 9

Test "copy_heap works":
    Let h be heapify with items as list containing 1, 3, 5
    Let copied be copy_heap with heap as h
    Assert heap_length with heap as copied is equal to 3
    Let (h, _) be pop with heap as h
    Assert heap_length with heap as copied is equal to 3

Note: Advanced Operations
Test "replace works":
    Let h be heapify with items as list containing 1, 3, 5, 7, 9
    Let (h, old_val) be replace with heap as h and value as 2
    Assert old_val is equal to 1
    Let (h, new_min) be pop with heap as h
    Assert new_min is equal to 2

Test "pushpop works":
    Let h be heapify with items as list containing 1, 3, 5
    Let (h, result) be pushpop with heap as h and value as 0
    Assert result is equal to 0
    Let (h, result2) be pushpop with heap as h and value as 10
    Assert result2 is equal to 1

Test "update_priority works":
    Let h be create_heap()
    Let h be push_with_priority with heap as h and value as "task1" and priority as 3
    Let h be push_with_priority with heap as h and value as "task2" and priority as 1
    Let h be push_with_priority with heap as h and value as "task3" and priority as 2
    Let h be update_priority with heap as h and index as 2 and new_priority as 0
    Let (h, value, priority) be pop_with_priority with heap as h
    Assert value is equal to "task3"
    Assert priority is equal to 0

Test "remove_at_index works":
    Let h be heapify with items as list containing 1, 3, 5, 7, 9
    Let h be remove_at_index with heap as h and index as 2
    Assert heap_length with heap as h is equal to 4
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 1

Test "remove_at_index root works":
    Let h be heapify with items as list containing 1, 3, 5
    Let h be remove_at_index with heap as h and index as 0
    Assert heap_length with heap as h is equal to 2
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 3

Note: Utility Operations
Test "clear works":
    Let h be heapify with items as list containing 1, 3, 5
    Let h be clear with heap as h
    Assert heap_is_empty with heap as h is equal to true

Test "get_comparator works":
    Let h be create_heap()
    Let comparator be get_comparator with heap as h
    Assert comparator with a as 1 and b as 2 is equal to true
    Assert comparator with a as 3 and b as 2 is equal to false

Note: Edge Cases and Error Handling
Test "index out of bounds raises error":
    Let h be heapify with items as list containing 1, 2, 3
    Try:
        Let _ be update_priority with heap as h and index as 5 and new_priority as 0
        Assert False with message "Expected error for index out of bounds"
    Catch IndexError:
        Assert True
    Try:
        Let _ be remove_at_index with heap as h and index as 5
        Assert False with message "Expected error for index out of bounds"
    Catch IndexError:
        Assert True

Test "k larger than heap size works":
    Let h be heapify with items as list containing 1, 2, 3
    Let largest_5 be k_largest with heap as h and k as 5
    Assert length of largest_5 is equal to 3

Test "empty heap k operations work":
    Let h be create_heap()
    Let largest_3 be k_largest with heap as h and k as 3
    Assert length of largest_3 is equal to 0

Test "large numbers work correctly":
    Let h be create_heap()
    For i from 1 to 100:
        Let h be push with heap as h and value as i
    Assert heap_length with heap as h is equal to 100
    Let (h, min_val) be pop with heap as h
    Assert min_val is equal to 1

Test "negative priorities work":
    Let h be create_heap()
    Let h be push_with_priority with heap as h and value as "task1" and priority as negative 5
    Let h be push_with_priority with heap as h and value as "task2" and priority as 3
    Let h be push_with_priority with heap as h and value as "task3" and priority as negative 1
    Let (h, value, priority) be pop_with_priority with heap as h
    Assert value is equal to "task1"
    Assert priority is equal to negative 5

Test "duplicate priorities work":
    Let h be create_heap()
    Let h be push_with_priority with heap as h and value as "task1" and priority as 1
    Let h be push_with_priority with heap as h and value as "task2" and priority as 1
    Let h be push_with_priority with heap as h and value as "task3" and priority as 1
    Let (h, value1, _) be pop_with_priority with heap as h
    Let (h, value2, _) be pop_with_priority with heap as h
    Let (h, value3, _) be pop_with_priority with heap as h
    Assert value1 is not equal to value2 or value1 is not equal to value3 or value2 is not equal to value3 