Note:
Runa Standard Library Test: Dict
Comprehensive test suite for the expanded dict module functionality
:End Note

Note: Basic Dictionary Operations
Test "dict creation works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 25
    Assert ages["Charlie"] is equal to 35

Test "create_empty_dict works":
    Let empty be create_empty_dict
    Assert length of empty is equal to 0
    Assert is_empty with d as empty

Test "dict from_pairs works":
    Let pairs be list containing:
        ("Alice", 30)
        ("Bob", 25)
        ("Charlie", 35)
    Let ages be from_pairs with pairs as pairs
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 25
    Assert ages["Charlie"] is equal to 35

Test "dict get works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Assert get with d as ages and key as "Alice" is equal to 30
    Assert get with d as ages and key as "Bob" is equal to 25

Test "dict get_safe works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Assert get_safe with d as ages and key as "Alice" and default as 0 is equal to 30
    Assert get_safe with d as ages and key as "Charlie" and default as 0 is equal to 0

Test "dict get_or_create works":
    Let ages be dictionary with:
        "Alice" as 30
    Let age be get_or_create with d as ages and key as "Bob" and factory as 25
    Assert age is equal to 25
    Assert ages["Bob"] is equal to 25
    Let age be get_or_create with d as ages and key as "Alice" and factory as 0
    Assert age is equal to 30

Test "dict set works":
    Let ages be dictionary with:
        "Alice" as 30
    Let ages be set with d as ages and key as "Bob" and value as 25
    Assert length of ages is equal to 2
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 25

Test "dict set_multiple works":
    Let ages be dictionary with:
        "Alice" as 30
    Let updates be dictionary with:
        "Bob" as 25
        "Charlie" as 35
    Let ages be set_multiple with d as ages and updates as updates
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 25
    Assert ages["Charlie"] is equal to 35

Test "dict remove works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let ages be remove with d as ages and key as "Bob"
    Assert length of ages is equal to 2
    Assert ages["Alice"] is equal to 30
    Assert ages["Charlie"] is equal to 35
    Assert not contains with d as ages and key as "Bob"

Test "dict remove_safe works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages be remove_safe with d as ages and key as "Bob"
    Assert length of ages is equal to 1
    Assert ages["Alice"] is equal to 30
    Let ages be remove_safe with d as ages and key as "Charlie"
    Assert length of ages is equal to 1

Test "dict pop works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let (ages, age) be pop with d as ages and key as "Bob"
    Assert length of ages is equal to 1
    Assert age is equal to 25
    Assert ages["Alice"] is equal to 30
    Assert not contains with d as ages and key as "Bob"

Test "dict pop raises error for missing key":
    Let ages be dictionary with:
        "Alice" as 30
    Try:
        Let (ages, age) be pop with d as ages and key as "Bob"
        Assert False with message "Expected error for missing key"
    Catch Error:
        Assert True

Test "dict pop_safe works":
    Let ages be dictionary with:
        "Alice" as 30
    Let (ages, age) be pop_safe with d as ages and key as "Bob" and default as 0
    Assert length of ages is equal to 1
    Assert age is equal to 0
    Let (ages, age) be pop_safe with d as ages and key as "Alice" and default as 0
    Assert length of ages is equal to 0
    Assert age is equal to 30

Test "dict clear works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages be clear with d as ages
    Assert length of ages is equal to 0

Test "dict copy works":
    Let original be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let copied be copy with d as original
    Assert length of copied is equal to 2
    Assert copied["Alice"] is equal to 30
    Assert copied["Bob"] is equal to 25
    Let copied be set with d as copied and key as "Alice" and value as 40
    Assert original["Alice"] is equal to 30

Note: Query and Analysis Operations
Test "dict contains works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Assert contains with d as ages and key as "Alice"
    Assert not contains with d as ages and key as "Charlie"

Test "dict size works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Assert size with d as ages is equal to 3

Test "dict is_empty works":
    Let empty be dictionary with:
    Assert is_empty with d as empty
    Let ages be dictionary with:
        "Alice" as 30
    Assert not is_empty with d as ages

Test "dict keys works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let keys_list be keys with d as ages
    Assert length of keys_list is equal to 3
    Assert keys_list contains "Alice"
    Assert keys_list contains "Bob"
    Assert keys_list contains "Charlie"

Test "dict values works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let values_list be values with d as ages
    Assert length of values_list is equal to 3
    Assert values_list contains 30
    Assert values_list contains 25
    Assert values_list contains 35

Test "dict items works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let items_list be items with d as ages
    Assert length of items_list is equal to 2
    Assert items_list contains ("Alice", 30)
    Assert items_list contains ("Bob", 25)

Test "dict has_key works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Assert has_key with d as ages and key as "Alice"
    Assert not has_key with d as ages and key as "Charlie"

Test "dict has_value works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 30
    Assert has_value with d as ages and value as 30
    Assert has_value with d as ages and value as 25
    Assert not has_value with d as ages and value as 40

Test "dict find_key works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 30
    Let key be find_key with d as ages and value as 30
    Assert key is Some with value as "Alice"
    Let key be find_key with d as ages and value as 40
    Assert key is None

Test "dict find_all_keys works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 30
        "David" as 25
    Let keys be find_all_keys with d as ages and value as 30
    Assert length of keys is equal to 2
    Assert keys contains "Alice"
    Assert keys contains "Charlie"

Note: Bulk Operations
Test "dict update works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let updates be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let ages be update with d as ages and other as updates
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 26
    Assert ages["Charlie"] is equal to 35

Test "dict update_multiple works":
    Let ages be dictionary with:
        "Alice" as 30
    Let updates1 be dictionary with:
        "Bob" as 25
    Let updates2 be dictionary with:
        "Charlie" as 35
        "David" as 40
    Let ages be update_multiple with d as ages and others as list containing updates1, updates2
    Assert length of ages is equal to 4
    Assert ages["Alice"] is equal to 30
    Assert ages["Bob"] is equal to 25
    Assert ages["Charlie"] is equal to 35
    Assert ages["David"] is equal to 40

Test "dict merge works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let merged be merge with d1 as ages1 and d2 as ages2
    Assert length of merged is equal to 3
    Assert merged["Alice"] is equal to 30
    Assert merged["Bob"] is equal to 26
    Assert merged["Charlie"] is equal to 35

Test "dict merge_multiple works":
    Let ages1 be dictionary with:
        "Alice" as 30
    Let ages2 be dictionary with:
        "Bob" as 25
    Let ages3 be dictionary with:
        "Charlie" as 35
    Let merged be merge_multiple with dicts as list containing ages1, ages2, ages3
    Assert length of merged is equal to 3
    Assert merged["Alice"] is equal to 30
    Assert merged["Bob"] is equal to 25
    Assert merged["Charlie"] is equal to 35

Test "dict merge_with works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let merge_func be lambda key, v1, v2: max with a as v1 and b as v2
    Let merged be merge_with with d1 as ages1 and d2 as ages2 and merge_func as merge_func
    Assert length of merged is equal to 3
    Assert merged["Alice"] is equal to 30
    Assert merged["Bob"] is equal to 26
    Assert merged["Charlie"] is equal to 35

Note: Filtering and Transformation Operations
Test "dict filter_keys works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
        "David" as 40
    Let filtered be filter_keys with d as ages and predicate as lambda key: length of key is greater than 4
    Assert length of filtered is equal to 2
    Assert filtered["Alice"] is equal to 30
    Assert filtered["Charlie"] is equal to 35

Test "dict filter_values works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
        "David" as 40
    Let filtered be filter_values with d as ages and predicate as lambda value: value is greater than 30
    Assert length of filtered is equal to 2
    Assert filtered["Charlie"] is equal to 35
    Assert filtered["David"] is equal to 40

Test "dict filter_items works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
        "David" as 40
    Let filtered be filter_items with d as ages and predicate as lambda key, value: length of key is greater than 4 and value is greater than 30
    Assert length of filtered is equal to 1
    Assert filtered["Charlie"] is equal to 35

Test "dict map_keys works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let mapped be map_keys with d as ages and transform as lambda key: key plus "_user"
    Assert length of mapped is equal to 2
    Assert mapped["Alice_user"] is equal to 30
    Assert mapped["Bob_user"] is equal to 25

Test "dict map_values works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let mapped be map_values with d as ages and transform as lambda value: value plus 5
    Assert length of mapped is equal to 2
    Assert mapped["Alice"] is equal to 35
    Assert mapped["Bob"] is equal to 30

Test "dict map_items works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let mapped be map_items with d as ages and transform as lambda key, value: (key plus "_user", value plus 5)
    Assert length of mapped is equal to 2
    Assert mapped["Alice_user"] is equal to 35
    Assert mapped["Bob_user"] is equal to 30

Test "dict invert works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 30
    Let inverted be invert with d as ages
    Assert length of inverted is equal to 2
    Assert inverted[30] is equal to "Charlie"
    Assert inverted[25] is equal to "Bob"

Test "dict invert_safe works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 30
    Let inverted be invert_safe with d as ages
    Assert length of inverted is equal to 2
    Assert inverted[30] is list containing "Alice", "Charlie"
    Assert inverted[25] is equal to "Bob"

Note: Set-like Operations
Test "dict intersection works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
        "David" as 40
    Let intersection_dict be intersection with d1 as ages1 and d2 as ages2
    Assert length of intersection_dict is equal to 2
    Assert intersection_dict["Bob"] is equal to 25
    Assert intersection_dict["Charlie"] is equal to 35

Test "dict union works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let union_dict be union with d1 as ages1 and d2 as ages2
    Assert length of union_dict is equal to 3
    Assert union_dict["Alice"] is equal to 30
    Assert union_dict["Bob"] is equal to 26
    Assert union_dict["Charlie"] is equal to 35

Test "dict difference works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let difference_dict be difference with d1 as ages1 and d2 as ages2
    Assert length of difference_dict is equal to 1
    Assert difference_dict["Alice"] is equal to 30

Test "dict symmetric_difference works":
    Let ages1 be dictionary with:
        "Alice" as 30
        "Bob" as 25
    Let ages2 be dictionary with:
        "Bob" as 26
        "Charlie" as 35
    Let symmetric_diff be symmetric_difference with d1 as ages1 and d2 as ages2
    Assert length of symmetric_diff is equal to 2
    Assert symmetric_diff["Alice"] is equal to 30
    Assert symmetric_diff["Charlie"] is equal to 35

Note: Utility Operations
Test "dict from_keys works":
    Let keys be list containing "Alice", "Bob", "Charlie"
    Let ages be from_keys with keys as keys and default_value as 0
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 0
    Assert ages["Bob"] is equal to 0
    Assert ages["Charlie"] is equal to 0

Test "dict from_keys_with_factory works":
    Let keys be list containing "Alice", "Bob", "Charlie"
    Let counter be 0
    Let factory be lambda: counter plus 1
    Let ages be from_keys_with_factory with keys as keys and factory as factory
    Assert length of ages is equal to 3
    Assert ages["Alice"] is equal to 1
    Assert ages["Bob"] is equal to 2
    Assert ages["Charlie"] is equal to 3

Test "dict group_by works":
    Let users be list containing:
        dictionary with "name" as "Alice" and "age" as 30
        dictionary with "name" as "Bob" and "age" as 25
        dictionary with "name" as "Charlie" and "age" as 30
    Let grouped be group_by with items as users and key_func as lambda user: user["age"]
    Assert length of grouped is equal to 2
    Assert length of grouped[25] is equal to 1
    Assert length of grouped[30] is equal to 2

Test "dict count_by works":
    Let users be list containing:
        dictionary with "name" as "Alice" and "age" as 30
        dictionary with "name" as "Bob" and "age" as 25
        dictionary with "name" as "Charlie" and "age" as 30
    Let counts be count_by with items as users and key_func as lambda user: user["age"]
    Assert length of counts is equal to 2
    Assert counts[25] is equal to 1
    Assert counts[30] is equal to 2

Test "dict any, all, none work":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Assert any with d as ages and predicate as lambda key, value: value is greater than 30
    Assert all with d as ages and predicate as lambda key, value: value is greater than 20
    Assert none with d as ages and predicate as lambda key, value: value is greater than 40

Test "dict find works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let result be find with d as ages and predicate as lambda key, value: value is greater than 30
    Assert result is Some with value as ("Charlie", 35)

Test "dict find_all works":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let results be find_all with d as ages and predicate as lambda key, value: value is greater than 25
    Assert length of results is equal to 2
    Assert results contains ("Alice", 30)
    Assert results contains ("Charlie", 35)

Test "dict min_key and max_key work":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let min_key_result be min_key with d as ages
    Assert min_key_result is Some with value as "Alice"
    Let max_key_result be max_key with d as ages
    Assert max_key_result is Some with value as "Charlie"

Test "dict min_value and max_value work":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Let min_value_result be min_value with d as ages
    Assert min_value_result is Some with value as 25
    Let max_value_result be max_value work with d as ages
    Assert max_value_result is Some with value as 35

Test "dict sum_values and average_values work":
    Let ages be dictionary with:
        "Alice" as 30
        "Bob" as 25
        "Charlie" as 35
    Assert sum_values with d as ages is equal to 90
    Assert average_values with d as ages is equal to 30 