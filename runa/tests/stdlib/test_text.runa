Note:
Runa Standard Library Test: Text
:End Note

Test "text wrapping works":
    Let wrapper be TextWrapper with width as 10
    Let text be "This is a long text."
    Let wrapped be wrapper.wrap(text)
    Assert wrapped[0] is equal to "This is a"
    Assert wrapped[1] is equal to "long text."

Test "text analysis works":
    Let text be "Hello world! This is a test."
    Assert word_count(text) is equal to 6
    Assert char_count(text) is equal to 27
    Assert line_count(text) is equal to 1
    Assert sentence_count(text) is equal to 2
    Assert paragraph_count(text) is equal to 1

Test "text formatting works":
    Let code_block be "def hello():\n    print(\"Hello, world!\")\n    return True"
    Let formatted be indent(dedent(code_block), "  ")
    Assert formatted contains "  def hello():"
    Assert formatted contains "  print(\"Hello, world!\")"
    Assert formatted contains "  return True"

Test "text justification works":
    Let text be "Hello"
    Assert ljust(text, 10) is equal to "Hello     "
    Assert rjust(text, 10) is equal to "     Hello"
    Assert center(text, 9) is equal to "  Hello  "

Test "readability score works":
    Let text be "Hello world. This is simple."
    Let score be readability_score(text)
    Assert score is greater than 0 