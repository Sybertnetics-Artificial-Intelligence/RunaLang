Note:
Runa Standard Library Test: Primitives
:End Note

Test "type checking with 'is of type' works":
    Let a be 42
    Assert a is of type Integer
    Let b be 3.14
    Assert b is of type Float
    Let c be "hello"
    Assert c is of type String
    Let d be true
    Assert d is of type Boolean
    Let e be None
    Assert e is of type None

Test "type retrieval with 'type of' works":
    Let a be 42
    Let t1 be type of a
    Assert t1 is equal to "Integer"
    Let b be 3.14
    Let t2 be type of b
    Assert t2 is equal to "Float"
    Let c be "hello"
    Let t3 be type of c
    Assert t3 is equal to "String"
    Let d be true
    Let t4 be type of d
    Assert t4 is equal to "Boolean"
    Let e be None
    Let t5 be type of e
    Assert t5 is equal to "None" 