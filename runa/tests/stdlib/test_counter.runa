Note:
Runa Standard Library Test: Counter
Comprehensive test suite for Counter and WeightedCounter functionality including advanced features.
:End Note

Note: Basic Counter Operations
Test "create and increment counter works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Assert get_count with counter as c and key as "apple" is equal to 2
    Assert get_count with counter as c and key as "banana" is equal to 1
    Assert get_count with counter as c and key as "cherry" is equal to 0

Test "decrement counter works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "apple"
    Call decrement with counter as c and key as "apple"
    Assert get_count with counter as c and key as "apple" is equal to 1
    Call decrement with counter as c and key as "apple"
    Assert get_count with counter as c and key as "apple" is equal to 0

Test "increment_by and decrement_by work":
    Let c be create_counter()
    Call increment_by with counter as c and key as "apple" and amount as 5
    Assert get_count with counter as c and key as "apple" is equal to 5
    Call decrement_by with counter as c and key as "apple" and amount as 3
    Assert get_count with counter as c and key as "apple" is equal to 2
    Call decrement_by with counter as c and key as "apple" and amount as 5
    Assert get_count with counter as c and key as "apple" is equal to 0

Test "set_count works":
    Let c be create_counter()
    Call set_count with counter as c and key as "apple" and count as 10
    Assert get_count with counter as c and key as "apple" is equal to 10
    Call set_count with counter as c and key as "apple" and count as 0
    Assert get_count with counter as c and key as "apple" is equal to 0

Test "most_common works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "cherry"
    Call increment with counter as c and key as "banana"
    Let common be most_common with counter as c and n as 2
    Assert common[0] is equal to "apple"
    Assert common[1] is equal to "banana"

Test "most_common_with_counts works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let common be most_common_with_counts with counter as c and n as 2
    Assert common[0][0] is equal to "apple"
    Assert common[0][1] is equal to 2
    Assert common[1][0] is equal to "banana"
    Assert common[1][1] is equal to 1

Test "least_common works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "cherry"
    Let least be least_common with counter as c and n as 2
    Assert least[0] is equal to "banana"
    Assert least[1] is equal to "cherry"

Test "total_count and unique_elements work":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Assert total_count with counter as c is equal to 3
    Assert unique_elements with counter as c is equal to 2

Test "is_empty and has_element work":
    Let c be create_counter()
    Assert is_empty with counter as c is equal to true
    Assert has_element with counter as c and key as "apple" is equal to false
    Call increment with counter as c and key as "apple"
    Assert is_empty with counter as c is equal to false
    Assert has_element with counter as c and key as "apple" is equal to true

Note: Weighted Counter Operations
Test "weighted counter operations work":
    Let wc be create_weighted_counter()
    Call increment_weighted with counter as wc and key as "A" and weight as 1.5
    Call increment_weighted with counter as wc and key as "B" and weight as 2.3
    Assert get_weight with counter as wc and key as "A" is equal to 1.5
    Assert get_weight with counter as wc and key as "B" is equal to 2.3
    Assert total_weight with counter as wc is equal to 3.8

Test "set_weight works":
    Let wc be create_weighted_counter()
    Call set_weight with counter as wc and key as "A" and weight as 2.5
    Assert get_weight with counter as wc and key as "A" is equal to 2.5
    Call set_weight with counter as wc and key as "A" and weight as 0
    Assert get_weight with counter as wc and key as "A" is equal to 0

Note: Statistical Operations
Test "mean_count works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let mean be mean_count with counter as c
    Assert mean is equal to 1.5

Test "median_count works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "cherry"
    Let median be median_count with counter as c
    Assert median is equal to 1

Test "mode_count works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let mode be mode_count with counter as c
    Assert mode is equal to 2

Test "count_variance and count_std_dev work":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let variance be count_variance with counter as c
    Let std_dev be count_std_dev with counter as c
    Assert variance is greater than 0
    Assert std_dev is greater than 0

Test "entropy calculations work":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Let entropy_val be entropy with counter as c
    Let normalized_entropy_val be normalized_entropy with counter as c
    Assert entropy_val is greater than 0
    Assert normalized_entropy_val is greater than 0 and normalized_entropy_val is less than or equal to 1

Test "gini_coefficient works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let gini be gini_coefficient with counter as c
    Assert gini is greater than or equal to 0 and gini is less than or equal to 1

Test "diversity_index works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let diversity be diversity_index with counter as c
    Assert diversity is greater than or equal to 0 and diversity is less than or equal to 1

Note: Normalization and Scaling
Test "normalize works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let normalized be normalize with counter as c
    Assert total_weight with counter as normalized is equal to 1.0

Test "scale_by works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Let scaled be scale_by with counter as c and factor as 2.5
    Assert get_count with counter as scaled and key as "apple" is equal to 2.5
    Assert get_count with counter as scaled and key as "banana" is equal to 2.5

Test "log_scale works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Let log_scaled be log_scale with counter as c
    Assert get_count with counter as log_scaled and key as "apple" is greater than 0

Note: Similarity and Distance Metrics
Test "cosine_similarity works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let similarity be cosine_similarity with counter1 as c1 and counter2 as c2
    Assert similarity is greater than or equal to 0 and similarity is less than or equal to 1

Test "jaccard_similarity works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let similarity be jaccard_similarity with counter1 as c1 and counter2 as c2
    Assert similarity is greater than or equal to 0 and similarity is less than or equal to 1

Test "euclidean_distance works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let distance be euclidean_distance with counter1 as c1 and counter2 as c2
    Assert distance is greater than or equal to 0

Test "manhattan_distance works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let distance be manhattan_distance with counter1 as c1 and counter2 as c2
    Assert distance is greater than or equal to 0

Note: Mathematical Operations
Test "add_counters works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "banana"
    Let sum_counter be add_counters with counter1 as c1 and counter2 as c2
    Assert get_count with counter as sum_counter and key as "apple" is equal to 2
    Assert get_count with counter as sum_counter and key as "banana" is equal to 1

Test "subtract_counters works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Let diff_counter be subtract_counters with counter1 as c1 and counter2 as c2
    Assert get_count with counter as diff_counter and key as "apple" is equal to 0
    Assert get_count with counter as diff_counter and key as "banana" is equal to 1

Test "intersection works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let intersection_counter be intersection with counter1 as c1 and counter2 as c2
    Assert get_count with counter as intersection_counter and key as "apple" is equal to 1
    Assert has_element with counter as intersection_counter and key as "banana" is equal to false

Test "union works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "banana"
    Call increment with counter as c2 and key as "apple"
    Call increment with counter as c2 and key as "cherry"
    Let union_counter be union with counter1 as c1 and counter2 as c2
    Assert get_count with counter as union_counter and key as "apple" is equal to 1
    Assert get_count with counter as union_counter and key as "banana" is equal to 1
    Assert get_count with counter as union_counter and key as "cherry" is equal to 1

Test "multiply_counters works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c2 and key as "apple"
    Let product_counter be multiply_counters with counter1 as c1 and counter2 as c2
    Assert get_count with counter as product_counter and key as "apple" is equal to 2

Test "divide_counters works":
    Let c1 be create_counter()
    Let c2 be create_counter()
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c1 and key as "apple"
    Call increment with counter as c2 and key as "apple"
    Let quotient_counter be divide_counters with counter1 as c1 and counter2 as c2
    Assert get_count with counter as quotient_counter and key as "apple" is equal to 2

Note: Advanced Filtering and Selection
Test "filter_by_count works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Let filtered be filter_by_count with counter as c and min_count as 2
    Assert get_count with counter as filtered and key as "apple" is equal to 2
    Assert has_element with counter as filtered and key as "banana" is equal to false

Test "top_k and bottom_k work":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "cherry"
    Let top_2 be top_k with counter as c and k as 2
    Let bottom_2 be bottom_k with counter as c and k as 2
    Assert unique_elements with counter as top_2 is equal to 2
    Assert unique_elements with counter as bottom_2 is equal to 2

Test "filter_by_percentile works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "cherry"
    Let filtered be filter_by_percentile with counter as c and percentile as 75
    Assert unique_elements with counter as filtered is greater than 0

Note: Transformation Operations
Test "map_keys works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Let transform be lambda key: "fruit_" followed by key
    Let mapped be map_keys with counter as c and transform as transform
    Assert has_element with counter as mapped and key as "fruit_apple" is equal to true
    Assert has_element with counter as mapped and key as "fruit_banana" is equal to true

Test "map_values works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Let transform be lambda value: value multiplied by 2
    Let mapped be map_values with counter as c and transform as transform
    Assert get_count with counter as mapped and key as "apple" is equal to 2
    Assert get_count with counter as mapped and key as "banana" is equal to 2

Test "group_by works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "cherry"
    Let group_func be lambda key: "fruit"
    Let grouped be group_by with counter as c and group_func as group_func
    Assert get_count with counter as grouped and key as "fruit" is equal to 3

Note: Memory and Performance Optimizations
Test "compact works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call set_count with counter as c and key as "banana" and count as 0
    Let compacted be compact with counter as c
    Assert has_element with counter as compacted and key as "apple" is equal to true
    Assert has_element with counter as compacted and key as "banana" is equal to false

Test "prune_small_counts works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Call increment with counter as c and key as "banana"
    Call increment with counter as c and key as "cherry"
    Let pruned be prune_small_counts with counter as c and threshold as 2
    Assert has_element with counter as pruned and key as "apple" is equal to false
    Assert has_element with counter as pruned and key as "banana" is equal to false
    Assert has_element with counter as pruned and key as "cherry" is equal to false

Note: Utility Operations
Test "clear works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Let cleared be clear with counter as c
    Assert is_empty with counter as cleared is equal to true

Test "copy works":
    Let c be create_counter()
    Call increment with counter as c and key as "apple"
    Let copied be copy with counter as c
    Assert get_count with counter as copied and key as "apple" is equal to 1
    Call increment with counter as c and key as "apple"
    Assert get_count with counter as copied and key as "apple" is equal to 1

Test "from_list and to_dict work":
    Let items be list containing "apple", "banana", "apple", "cherry"
    Let c be from_list with items as items
    Assert get_count with counter as c and key as "apple" is equal to 2
    Let dict_result be to_dict with counter as c
    Assert dict_result["apple"] is equal to 2
    Assert dict_result["banana"] is equal to 1

Test "from_dict works":
    Let dict_input be dictionary with:
        "apple" as 3
        "banana" as 1
    Let c be from_dict with counts_dict as dict_input
    Assert get_count with counter as c and key as "apple" is equal to 3
    Assert get_count with counter as c and key as "banana" is equal to 1

Note: Edge Cases and Error Handling
Test "empty counter operations work":
    Let c be create_counter()
    Assert total_count with counter as c is equal to 0
    Assert unique_elements with counter as c is equal to 0
    Assert is_empty with counter as c is equal to true
    Let common be most_common with counter as c and n as 5
    Assert length of common is equal to 0

Test "zero counts are handled correctly":
    Let c be create_counter()
    Call set_count with counter as c and key as "apple" and count as 0
    Assert has_element with counter as c and key as "apple" is equal to false
    Assert get_count with counter as c and key as "apple" is equal to 0

Test "negative counts are handled correctly":
    Let c be create_counter()
    Call decrement_by with counter as c and key as "apple" and amount as 5
    Assert get_count with counter as c and key as "apple" is equal to 0
    Assert has_element with counter as c and key as "apple" is equal to false

Test "large numbers work correctly":
    Let c be create_counter()
    Call increment_by with counter as c and key as "large" and amount as 1000000
    Assert get_count with counter as c and key as "large" is equal to 1000000
    Let total be total_count with counter as c
    Assert total is equal to 1000000 