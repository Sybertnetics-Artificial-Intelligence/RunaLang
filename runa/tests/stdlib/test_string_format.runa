Note:
Runa Standard Library Test: String Format
:End Note

Test "basic string operations work":
    Let s1 be "hello"
    Let s2 be "world"
    Let result be concat with a as s1 and b as s2
    Assert result is equal to "helloworld"
    Assert upper with s as s1 is equal to "HELLO"
    Assert lower with s as "WORLD" is equal to "world"
    Assert title with s as "hello world" is equal to "Hello World"
    Assert capitalize with s as "hello" is equal to "Hello"
    Assert swapcase with s as "Hello World" is equal to "hELLO wORLD"

Test "string trimming works":
    Let s be "  hello world  "
    Assert trim with s as s is equal to "hello world"
    Assert trim_left with s as s is equal to "hello world  "
    Assert trim_right with s as s is equal to "  hello world"

Test "string replacement works":
    Let s be "hello world hello"
    Assert replace with s as s and old as "hello" and new as "hi" is equal to "hi world hello"
    Assert replace_all with s as s and old as "hello" and new as "hi" is equal to "hi world hi"

Test "string splitting works":
    Let s be "a,b,c"
    Let result be split with s as s and sep as ","
    Assert result[0] is equal to "a"
    Assert result[1] is equal to "b"
    Assert result[2] is equal to "c"
    
    Let lines be "line1\nline2\nline3"
    Let line_result be split_lines with s as lines
    Assert line_result[0] is equal to "line1"
    Assert line_result[1] is equal to "line2"
    Assert line_result[2] is equal to "line3"
    
    Let words be "hello   world   test"
    Let word_result be split_whitespace with s as words
    Assert word_result[0] is equal to "hello"
    Assert word_result[1] is equal to "world"
    Assert word_result[2] is equal to "test"

Test "string joining works":
    Let items be list containing "a", "b", "c"
    Let result be join with items as items and sep as ","
    Assert result is equal to "a,b,c"

Test "string validation works":
    Assert is_empty with s as "" is equal to true
    Assert is_empty with s as "hello" is equal to false
    Assert is_blank with s as "   " is equal to true
    Assert is_blank with s as "hello" is equal to false
    Assert starts_with with s as "hello world" and prefix as "hello" is equal to true
    Assert ends_with with s as "hello world" and suffix as "world" is equal to true
    Assert contains with s as "hello world" and substr as "world" is equal to true
    Assert is_alpha with s as "hello" is equal to true
    Assert is_alpha with s as "hello123" is equal to false
    Assert is_digit with s as "123" is equal to true
    Assert is_digit with s as "123abc" is equal to false
    Assert is_alphanumeric with s as "hello123" is equal to true
    Assert is_alphanumeric with s as "hello 123" is equal to false
    Assert is_whitespace with s as "   " is equal to true
    Assert is_whitespace with s as "hello" is equal to false

Test "string formatting works":
    Let template be "Hello {name}, you are {age} years old"
    Let values be dictionary with:
        "name" as "Alice"
        "age" as 30
    Let result be format_string with template as template and values as values
    Assert result is equal to "Hello Alice, you are 30 years old"

Test "string padding and justification works":
    Let s be "hello"
    Assert pad_left with s as s and width as 10 is equal to "     hello"
    Assert pad_right with s as s and width as 10 is equal to "hello     "
    Assert center with s as s and width as 9 is equal to "  hello  "
    Assert justify_left with s as s and width as 10 is equal to "hello     "
    Assert justify_right with s as s and width as 10 is equal to "     hello"
    Assert justify_center with s as s and width as 9 is equal to "  hello  "

Test "string analysis works":
    Let s be "hello world hello"
    Assert count with s as s and substr as "hello" is equal to 2
    Assert find with s as s and substr as "world" is equal to 6
    Assert find_last with s as s and substr as "hello" is equal to 12
    Assert index_of with s as s and substr as "world" is equal to 6
    Assert last_index_of with s as s and substr as "hello" is equal to 12

Test "string transformation works":
    Let s be "hello"
    Assert reverse with s as s is equal to "olleh"
    Assert repeat with s as s and count as 3 is equal to "hellohellohello"
    Assert substring with s as s and start as 1 and end as 4 is equal to "ell"
    Assert remove with s as s and substr as "ll" is equal to "heo"
    Assert remove_all with s as "hello hello" and substr as "hello" is equal to " "

Test "string encoding and escaping works":
    Let s be "<hello>"
    Assert escape_html with s as s is equal to "&lt;hello&gt;"
    Assert quote with s as "hello" is equal to "\"hello\""
    Assert unquote with s as "\"hello\"" is equal to "hello"

Test "StringTemplate class works":
    Let template be StringTemplate with template as "Hello $name, you are $age years old"
    Let values be dictionary with:
        "name" as "Bob"
        "age" as 25
    Let result be substitute with self as template and values as values
    Assert result is equal to "Hello Bob, you are 25 years old"
    
    Let safe_result be safe_substitute with self as template and values as dictionary with "name" as "Bob"
    Assert safe_result is equal to "Hello Bob, you are $age years old"

Test "StringBuilder class works":
    Let builder be StringBuilder with parts as list containing
    Call append with self as builder and s as "hello"
    Call append with self as builder and s as " "
    Call append with self as builder and s as "world"
    Let result be build with self as builder
    Assert result is equal to "hello world"
    Assert length with self as builder is equal to 11
    
    Call clear with self as builder
    Assert length with self as builder is equal to 0

Test "string constants are available":
    Assert ascii_letters contains "a"
    Assert ascii_letters contains "Z"
    Assert ascii_lowercase contains "a"
    Assert ascii_uppercase contains "Z"
    Assert digits contains "5"
    Assert hexdigits contains "f"
    Assert octdigits contains "7"
    Assert punctuation contains "!"
    Assert whitespace contains " "

Test "edge cases and error handling":
    Let empty be ""
    Assert is_empty with s as empty is equal to true
    Assert length of empty is equal to 0
    Assert concat with a as empty and b as "hello" is equal to "hello"
    Assert concat with a as "hello" and b as empty is equal to "hello"
    
    Let whitespace_only be "   "
    Assert is_blank with s as whitespace_only is equal to true
    Assert trim with s as whitespace_only is equal to ""
    
    Let single_char be "a"
    Assert reverse with s as single_char is equal to "a"
    Assert substring with s as single_char and start as 0 and end as 1 is equal to "a" 