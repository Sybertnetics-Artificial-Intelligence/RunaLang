Note:
Comprehensive test suite for the Date Time module

Tests cover:
- Basic datetime creation and parsing
- Nanosecond precision operations
- Timezone handling and conversions
- Arithmetic operations and edge cases
- Business logic and calendar operations
- Astronomical calculations
- AI-specific use cases
- Error handling and validation
- Performance and memory optimization
:End Note

Note: Test basic datetime creation and current time operations
:End Note

Let test_current_datetime_operations:
    Let now be get current datetime with precision as "nanosecond"
    Assert now is not empty
    Assert now contains "year"
    Assert now contains "month"
    Assert now contains "day"
    Assert now contains "hour"
    Assert now contains "minute"
    Assert now contains "second"
    Assert now contains "nanosecond"
    
    Let today be get current date
    Assert today is not empty
    Assert today contains "year"
    Assert today contains "month"
    Assert today contains "day"
    
    Let current_time be get current time with precision as "nanosecond"
    Assert current_time is not empty
    Assert current_time contains "hour"
    Assert current_time contains "minute"
    Assert current_time contains "second"
    Assert current_time contains "nanosecond"
End

Let test_datetime_creation:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Assert datetime is not empty
    Assert get datetime year datetime equals 2024
    Assert get datetime month datetime equals 1
    Assert get datetime day datetime equals 15
    Assert get datetime hour datetime equals 14
    Assert get datetime minute datetime equals 30
    Assert get datetime second datetime equals 25
    Assert get datetime nanosecond datetime equals 123456789
End

Let test_date_creation:
    Let date be create date with year as 2024 and month as 1 and day as 15
    Assert date is not empty
    Assert date contains "year"
    Assert date contains "month"
    Assert date contains "day"
    Assert date does not contain "hour"
End

Let test_time_creation:
    Let time be create time with hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Assert time is not empty
    Assert time contains "hour"
    Assert time contains "minute"
    Assert time contains "second"
    Assert time contains "nanosecond"
    Assert time does not contain "year"
End

Note: Test datetime parsing operations
:End Note

Let test_datetime_parsing:
    Let iso_string be "2024-01-15T14:30:25.123456789Z"
    Let parsed be parse datetime from iso_string with format as "iso"
    Assert parsed is not empty
    Assert get datetime year parsed equals 2024
    Assert get datetime month parsed equals 1
    Assert get datetime day parsed equals 15
    Assert get datetime hour parsed equals 14
    Assert get datetime minute parsed equals 30
    Assert get datetime second parsed equals 25
    Assert get datetime nanosecond parsed equals 123456789
End

Let test_flexible_datetime_parsing:
    Let formats be ["2024-01-15", "Jan 15, 2024", "15/01/2024", "January 15th, 2024"]
    
    For each format in formats:
        Let parsed be parse datetime flexible from format
        Assert parsed is not empty
        Assert get datetime year parsed equals 2024
        Assert get datetime month parsed equals 1
        Assert get datetime day parsed equals 15
    End For
End

Let test_date_parsing:
    Let date_string be "2024-01-15"
    Let parsed be parse date from date_string with format as "iso"
    Assert parsed is not empty
    Assert parsed contains "year"
    Assert parsed contains "month"
    Assert parsed contains "day"
End

Let test_time_parsing:
    Let time_string be "14:30:25.123456789"
    Let parsed be parse time from time_string with format as "iso"
    Assert parsed is not empty
    Assert parsed contains "hour"
    Assert parsed contains "minute"
    Assert parsed contains "second"
    Assert parsed contains "nanosecond"
End

Note: Test datetime formatting operations
:End Note

Let test_datetime_formatting:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let iso_formatted be format datetime datetime with format as "iso"
    Assert iso_formatted contains "2024-01-15T14:30:25.123456789"
    
    Let human_readable be format datetime human readable datetime with locale as "en_US"
    Assert human_readable contains "2024"
    Assert human_readable contains "January"
End

Let test_date_formatting:
    Let date be create date with year as 2024 and month as 1 and day as 15
    Let formatted be format date date with format as "iso"
    Assert formatted equals "2024-01-15"
End

Let test_time_formatting:
    Let time be create time with hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Let formatted be format time time with format as "iso"
    Assert formatted contains "14:30:25.123456789"
End

Note: Test datetime component access
:End Note

Let test_datetime_components:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Assert get datetime year datetime equals 2024
    Assert get datetime month datetime equals 1
    Assert get datetime day datetime equals 15
    Assert get datetime hour datetime equals 14
    Assert get datetime minute datetime equals 30
    Assert get datetime second datetime equals 25
    Assert get datetime nanosecond datetime equals 123456789
End

Let test_calendar_components:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 0
    
    Let weekday be get datetime weekday datetime
    Assert weekday is greater than 0
    Assert weekday is less than 8
    
    Let weekday_name be get datetime weekday name datetime
    Assert weekday_name is not empty
    
    Let week_number be get datetime week number datetime
    Assert week_number is greater than 0
    Assert week_number is less than 54
    
    Let day_of_year be get datetime day of year datetime
    Assert day_of_year equals 15
End

Let test_leap_year_detection:
    Let leap_year_datetime be create datetime with year as 2024 and month as 2 and day as 29 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let non_leap_year_datetime be create datetime with year as 2023 and month as 2 and day as 28 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    
    Assert is datetime leap year leap_year_datetime is true
    Assert is datetime leap year non_leap_year_datetime is false
End

Note: Test timezone operations
:End Note

Let test_timezone_operations:
    Let utc_datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 0 and nanosecond as 0
    
    Let ny_datetime be convert datetime timezone utc_datetime to "America/New_York"
    Assert ny_datetime is not empty
    
    Let tokyo_datetime be convert datetime timezone utc_datetime to "Asia/Tokyo"
    Assert tokyo_datetime is not empty
    
    Let current_tz be get current timezone
    Assert current_tz is not empty
    
    Let supported_tz be get supported timezones
    Assert supported_tz is not empty
    Assert "UTC" is in supported_tz
End

Let test_timezone_offset:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 0 and nanosecond as 0
    
    Let utc_offset be get datetime timezone offset datetime with timezone as "UTC"
    Assert utc_offset equals 0
    
    Let ny_offset be get datetime timezone offset datetime with timezone as "America/New_York"
    Assert ny_offset is not 0
End

Note: Test arithmetic operations
:End Note

Let test_datetime_arithmetic:
    Let base_datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let next_year be add years to datetime base_datetime with years as 1
    Assert get datetime year next_year equals 2025
    
    Let next_month be add months to datetime base_datetime with months as 1
    Assert get datetime month next_month equals 2
    
    Let next_day be add days to datetime base_datetime with days as 1
    Assert get datetime day next_day equals 16
    
    Let next_hour be add hours to datetime base_datetime with hours as 1
    Assert get datetime hour next_hour equals 15
    
    Let next_minute be add minutes to datetime base_datetime with minutes as 1
    Assert get datetime minute next_minute equals 31
    
    Let next_second be add seconds to datetime base_datetime with seconds as 1
    Assert get datetime second next_second equals 26
    
    Let next_nanosecond be add nanoseconds to datetime base_datetime with nanoseconds as 1
    Assert get datetime nanosecond next_nanosecond equals 123456790
End

Let test_datetime_subtraction:
    Let base_datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let prev_year be subtract years from datetime base_datetime with years as 1
    Assert get datetime year prev_year equals 2023
    
    Let prev_month be subtract months from datetime base_datetime with months as 1
    Assert get datetime month prev_month equals 12
    
    Let prev_day be subtract days from datetime base_datetime with days as 1
    Assert get datetime day prev_day equals 14
End

Let test_duration_operations:
    Let start_datetime be create datetime with year as 2024 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let end_datetime be create datetime with year as 2024 and month as 1 and day as 2 and hour as 12 and minute as 30 and second as 0 and nanosecond as 0
    
    Let duration be calculate duration between start_datetime and end_datetime with precision as "nanosecond"
    Assert duration is not empty
    Assert get duration days duration equals 1
    Assert get duration hours duration equals 12
    Assert get duration minutes duration equals 30
    
    Let human_duration be format duration human readable duration with locale as "en_US"
    Assert human_duration is not empty
End

Let test_duration_creation:
    Let duration be create duration with years as 1 and months as 2 and days as 3 and hours as 4 and minutes as 5 and seconds as 6 and nanoseconds as 7
    Assert duration is not empty
    Assert get duration years duration equals 1
    Assert get duration months duration equals 2
    Assert get duration days duration equals 3
    Assert get duration hours duration equals 4
    Assert get duration minutes duration equals 5
    Assert get duration seconds duration equals 6
    Assert get duration nanoseconds duration equals 7
End

Note: Test comparison operations
:End Note

Let test_datetime_comparisons:
    Let earlier be create datetime with year as 2024 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let later be create datetime with year as 2024 and month as 1 and day as 2 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    
    Assert is datetime before earlier and later is true
    Assert is datetime after later and earlier is true
    Assert is datetime equal earlier and earlier is true
    Assert is datetime between later and earlier and later is true
    
    Let minimum be get datetime minimum earlier and later
    Assert minimum equals earlier
    
    Let maximum be get datetime maximum earlier and later
    Assert maximum equals later
End

Let test_precision_comparison:
    Let datetime1 be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Let datetime2 be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456790
    
    Let second_comparison be compare datetime precision datetime1 and datetime2 with precision as "second"
    Assert second_comparison equals 0
    
    Let nanosecond_comparison be compare datetime precision datetime1 and datetime2 with precision as "nanosecond"
    Assert nanosecond_comparison is not 0
End

Note: Test calendar operations
:End Note

Let test_calendar_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 0
    
    Let quarter be get datetime quarter datetime
    Assert quarter equals 1
    
    Let semester be get datetime semester datetime
    Assert semester equals 1
    
    Let fiscal_year be get datetime fiscal year datetime with fiscal_start_month as 7
    Assert fiscal_year equals 2024
    
    Let week_boundaries be get datetime week boundaries datetime
    Assert week_boundaries is not empty
    
    Let month_boundaries be get datetime month boundaries datetime
    Assert month_boundaries is not empty
    
    Let quarter_boundaries be get datetime quarter boundaries datetime
    Assert quarter_boundaries is not empty
    
    Let year_boundaries be get datetime year boundaries datetime
    Assert year_boundaries is not empty
End

Let test_business_logic:
    Let start_date be create date with year as 2024 and month as 1 and day as 1
    Let end_date be create date with year as 2024 and month as 1 and day as 31
    Let holidays be [create date with year as 2024 and month as 1 and day as 1]
    
    Let business_days be get datetime business days between start_date and end_date with holidays as holidays
    Assert business_days is greater than 0
    
    Let base_date be create date with year as 2024 and month as 1 and day as 15
    Let future_business_date be add business days to datetime base_date with business_days as 5 and holidays as holidays
    Assert future_business_date is not empty
End

Let test_age_calculation:
    Let birth_datetime be create datetime with year as 1990 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let reference_datetime be create datetime with year as 2024 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    
    Let age be get datetime age birth_datetime and reference_datetime
    Assert age is not empty
    Assert age contains "years"
End

Note: Test astronomical operations
:End Note

Let test_astronomical_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 0
    
    Let moon_phase be get datetime moon phase datetime
    Assert moon_phase is not empty
    
    Let sunrise_sunset be get datetime sunrise sunset datetime with latitude as 40.7128 and longitude as -74.0060
    Assert sunrise_sunset is not empty
    Assert sunrise_sunset contains "sunrise"
    Assert sunrise_sunset contains "sunset"
End

Note: Test validation operations
:End Note

Let test_datetime_validation:
    Let valid_datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let validation be validate datetime valid_datetime
    Assert validation contains "valid"
    Assert validation["valid"] is true
    
    Let date_validation be validate date create date with year as 2024 and month as 1 and day as 15
    Assert date_validation["valid"] is true
    
    Let time_validation be validate time create time with hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Assert time_validation["valid"] is true
End

Let test_invalid_datetime_handling:
    Try:
        Let invalid_datetime be create datetime with year as 2024 and month as 13 and day as 32 and hour as 25 and minute as 60 and second as 61 and nanosecond as 1000000000
        Note: This should fail validation
    Catch error:
        Note: Expected validation error: error
    End Try
    
    Try:
        Let parsed be parse datetime from "invalid-date" with format as "iso"
        Note: This should fail parsing
    Catch error:
        Note: Expected parsing error: error
    End Try
End

Note: Test metadata operations
:End Note

Let test_metadata_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let metadata be get datetime metadata datetime
    Assert metadata is not empty
    Assert metadata contains "components"
    Assert metadata contains "calendar_info"
    Assert metadata contains "timezone_info"
    Assert metadata contains "validation_info"
    
    Let date_metadata be get date metadata create date with year as 2024 and month as 1 and day as 15
    Assert date_metadata is not empty
    
    Let time_metadata be get time metadata create time with hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    Assert time_metadata is not empty
    
    Let duration_metadata be get duration metadata create duration with years as 1 and months as 2 and days as 3 and hours as 4 and minutes as 5 and seconds as 6 and nanoseconds as 7
    Assert duration_metadata is not empty
End

Note: Test conversion operations
:End Note

Let test_conversion_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let unix_timestamp be get datetime unix timestamp datetime
    Assert unix_timestamp is greater than 0
    
    Let from_unix be create datetime from unix timestamp unix_timestamp
    Assert from_unix is not empty
    
    Let epoch_ms be get datetime epoch milliseconds datetime
    Assert epoch_ms is greater than 0
    
    Let from_epoch_ms be create datetime from epoch milliseconds epoch_ms
    Assert from_epoch_ms is not empty
    
    Let epoch_ns be get datetime epoch nanoseconds datetime
    Assert epoch_ns is greater than 0
    
    Let from_epoch_ns be create datetime from epoch nanoseconds epoch_ns
    Assert from_epoch_ns is not empty
    
    Let julian_day be get datetime julian day datetime
    Assert julian_day is greater than 0
    
    Let from_julian be create datetime from julian day julian_day
    Assert from_julian is not empty
End

Note: Test utility operations
:End Note

Let test_utility_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let rounded be round datetime to nearest datetime with unit as "hour"
    Assert rounded is not empty
    
    Let truncated be truncate datetime to datetime with unit as "day"
    Assert truncated is not empty
    Assert get datetime hour truncated equals 0
    Assert get datetime minute truncated equals 0
    Assert get datetime second truncated equals 0
    Assert get datetime nanosecond truncated equals 0
End

Let test_datetime_range:
    Let start be create datetime with year as 2024 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let end be create datetime with year as 2024 and month as 1 and day as 5 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Let step be create duration with years as 0 and months as 0 and days as 1 and hours as 0 and minutes as 0 and seconds as 0 and nanoseconds as 0
    
    Let range be create datetime range start and end with step_duration as step
    Assert range is not empty
    Assert length of range equals 5
End

Let test_serialization:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let serialized be serialize datetime datetime with format as "json"
    Assert serialized is not empty
    
    Let deserialized be deserialize datetime serialized with format as "json"
    Assert deserialized is not empty
    Assert get datetime year deserialized equals 2024
End

Let test_hash_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let hash_value be get datetime hash datetime with algorithm as "sha256"
    Assert hash_value is not empty
End

Note: Test performance operations
:End Note

Let test_performance_operations:
    Let datetime be create datetime with year as 2024 and month as 1 and day as 15 and hour as 14 and minute as 30 and second as 25 and nanosecond as 123456789
    
    Let memory_usage be get datetime memory usage datetime
    Assert memory_usage is greater than 0
    
    Let optimized be optimize datetime datetime
    Assert optimized is not empty
    
    Let metrics be get datetime performance metrics with operation as "creation"
    Assert metrics is not empty
    
    Let benchmark be benchmark datetime operations with operations as ["creation", "parsing", "formatting"]
    Assert benchmark is not empty
End

Note: Test AI-specific scenarios
:End Note

Let test_ai_context_analysis:
    Let now be get current datetime with precision as "nanosecond"
    Let metadata be get datetime metadata now
    
    Note: AI can analyze context from metadata
    Assert metadata contains "time_of_day"
    Assert metadata contains "day_of_week"
    Assert metadata contains "season"
    Assert metadata contains "is_business_hour"
    Assert metadata contains "is_weekend"
End

Let test_ai_flexible_parsing:
    Let ai_inputs be ["2024-01-15", "Jan 15, 2024", "15/01/2024", "January 15th, 2024", "2024-01-15T14:30:25"]
    Let parsed_results be []
    
    For each input in ai_inputs:
        Let parsed be parse datetime flexible from input
        Add parsed to parsed_results
        Assert parsed is not empty
    End For
    
    Note: AI can handle various input formats
    Assert length of parsed_results equals length of ai_inputs
End

Let test_ai_business_logic:
    Let start_date be create date with year as 2024 and month as 1 and day as 1
    Let end_date be create date with year as 2024 and month as 1 and day as 31
    Let holidays be [create date with year as 2024 and month as 1 and day as 1]
    
    Let business_days be get datetime business days between start_date and end_date with holidays as holidays
    
    Note: AI can calculate business timelines
    Assert business_days is greater than 0
    Assert business_days is less than 32
End

Let test_ai_precise_timing:
    Let start_time be get current datetime with precision as "nanosecond"
    Note: Simulate AI operation
    Let end_time be get current datetime with precision as "nanosecond"
    
    Let duration be calculate duration between start_time and end_time with precision as "nanosecond"
    Let human_duration be format duration human readable duration with locale as "en_US"
    
    Note: AI can measure precise operation timing
    Assert duration is not empty
    Assert human_duration is not empty
End

Let test_ai_timezone_handling:
    Let utc_time be get current datetime with precision as "nanosecond"
    Let ny_time be convert datetime timezone utc_time to "America/New_York"
    Let tokyo_time be convert datetime timezone utc_time to "Asia/Tokyo"
    
    Note: AI can provide timezone-aware responses
    Assert ny_time is not empty
    Assert tokyo_time is not empty
    Assert ny_time is not equal to utc_time
    Assert tokyo_time is not equal to utc_time
End

Note: Test edge cases and error handling
:End Note

Let test_edge_cases:
    Let leap_year_datetime be create datetime with year as 2024 and month as 2 and day as 29 and hour as 0 and minute as 0 and second as 0 and nanosecond as 0
    Assert is datetime leap year leap_year_datetime is true
    
    Let year_end be create datetime with year as 2024 and month as 12 and day as 31 and hour as 23 and minute as 59 and second as 59 and nanosecond as 999999999
    Let next_year be add seconds to datetime year_end with seconds as 1
    Assert get datetime year next_year equals 2025
    Assert get datetime month next_year equals 1
    Assert get datetime day next_year equals 1
    
    Let century_end be create datetime with year as 1999 and month as 12 and day as 31 and hour as 23 and minute as 59 and second as 59 and nanosecond as 999999999
    Let next_century be add seconds to datetime century_end with seconds as 1
    Assert get datetime year next_century equals 2000
End

Let test_error_handling:
    Try:
        Let invalid be create datetime with year as 2024 and month as 13 and day as 32 and hour as 25 and minute as 60 and second as 61 and nanosecond as 1000000000
        Assert false
    Catch error:
        Note: Expected error for invalid datetime: error
    End Try
    
    Try:
        Let parsed be parse datetime from "invalid" with format as "iso"
        Assert false
    Catch error:
        Note: Expected error for invalid parsing: error
    End Try
    
    Try:
        Let duration be calculate duration between "not_a_datetime" and "also_not_a_datetime" with precision as "second"
        Assert false
    Catch error:
        Note: Expected error for invalid duration calculation: error
    End Try
End

Note: Test performance scenarios
:End Note

Let test_performance_scenarios:
    Let datetimes be []
    
    For i from 1 to 1000:
        Let dt be create datetime with year as 2024 and month as 1 and day as 1 and hour as 0 and minute as 0 and second as 0 and nanosecond as i
        Add dt to datetimes
    End For
    
    Let start_time be get current datetime with precision as "nanosecond"
    
    For each dt in datetimes:
        Let formatted be format datetime dt with format as "iso"
        Let parsed be parse datetime from formatted with format as "iso"
        Let metadata be get datetime metadata dt
    End For
    
    Let end_time be get current datetime with precision as "nanosecond"
    Let total_duration be calculate duration between start_time and end_time with precision as "nanosecond"
    
    Note: Performance test completed in: format duration human readable total_duration with locale as "en_US"
End

Note: Run all tests
:End Note

Let run_all_datetime_tests:
    Note: Running comprehensive Date Time module tests
    
    test_current_datetime_operations()
    test_datetime_creation()
    test_date_creation()
    test_time_creation()
    
    test_datetime_parsing()
    test_flexible_datetime_parsing()
