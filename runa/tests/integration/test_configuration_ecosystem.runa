Note:
Runa Standard Library: Configuration Ecosystem Integration Tests

Comprehensive integration test suite that validates the entire configuration
ecosystem working together including configuration management, secrets,
environment variables, file loading, and real-world usage scenarios.

This test suite ensures that all components work together seamlessly in
production-like scenarios and validates enterprise-grade configuration
management workflows.

Test Categories:
- End-to-End Configuration Workflows
- Multi-Source Configuration Loading
- Secrets Integration in Configuration
- Environment Variable Integration
- Configuration File Loading and Parsing
- Security and Compliance Scenarios
- Real-World Application Configuration
- Performance Under Load
- Error Recovery and Resilience
:End Note

Import "stdlib/config/config" as config
Import "stdlib/config/secrets" as secrets
Import "stdlib/config/environment" as environment
Import "stdlib/config/loader" as loader
Import "stdlib/testing/framework" as test

Note: End-to-End Configuration Workflow Tests
Process called "test_complete_application_configuration_workflow" returns test.TestResult:
    Try:
        Note: Simulate a complete application configuration setup
        
        Note: Step 1 - Create secrets for sensitive data
        Let secret_store be secrets.get_default_secret_store
        
        Let db_password_result be secrets.create_secret with:
            name as "production_db_password"
            value as "super_secure_production_password_2024"
            secret_type as secrets.DATABASE_CREDENTIAL
            metadata as dictionary containing:
                "description" as "Production database password"
                "tags" as list containing "production", "database"
                "rotation_interval" as 2592000.0  Note: 30 days
            store as secret_store
        
        test.assert_match with 
            value as db_password_result 
            pattern as secrets.SecretSuccess
            message as "Database password secret creation should succeed"
        
        Let api_key_result be secrets.create_secret with:
            name as "external_api_key"
            value as "sk_live_abcdef123456789"
            secret_type as secrets.API_KEY
            metadata as dictionary containing:
                "description" as "External service API key"
                "tags" as list containing "production", "api"
            store as secret_store
        
        test.assert_match with 
            value as api_key_result 
            pattern as secrets.SecretSuccess
            message as "API key secret creation should succeed"
        
        Match db_password_result:
            When secrets.SecretSuccess:
                Match api_key_result:
                    When secrets.SecretSuccess:
                        Let db_secret_id be db_password_result.value
                        Let api_secret_id be api_key_result.value
                        
                        Note: Step 2 - Create configuration schema
                        Let app_schema be config.ConfigurationSchema with:
                            schema_version as "1.0"
                            schema_id as "production_app_schema"
                            required_keys as list containing:
                                "app.name"
                                "app.port"
                                "database.host"
                                "database.port"
                                "database.name"
                                "database.password_secret_id"
                                "api.external_key_secret_id"
                            optional_keys as list containing:
                                "app.debug"
                                "app.max_connections"
                                "cache.enabled"
                                "cache.ttl"
                                "logging.level"
                            key_types as dictionary containing:
                                "app.port" as "integer"
                                "database.port" as "integer"
                                "app.debug" as "boolean"
                                "app.max_connections" as "integer"
                                "cache.enabled" as "boolean"
                                "cache.ttl" as "integer"
                            key_constraints as dictionary containing:
                                "app.port" as dictionary containing:
                                    "min" as 1024
                                    "max" as 65535
                                "database.port" as dictionary containing:
                                    "min" as 1
                                    "max" as 65535
                                "app.max_connections" as dictionary containing:
                                    "min" as 1
                                    "max" as 10000
                            default_values as dictionary containing:
                                "app.debug" as false
                                "app.max_connections" as 100
                                "cache.enabled" as true
                                "cache.ttl" as 3600
                                "logging.level" as "INFO"
                            sensitive_keys as list containing:
                                "database.password_secret_id"
                                "api.external_key_secret_id"
                            metadata as dictionary containing
                        
                        Note: Step 3 - Create configuration with comprehensive options
                        Let config_options be config.ConfigurationOptions with:
                            profile as config.PRODUCTION
                            auto_discover_files as true
                            discovery_paths as list containing:
                                "./config"
                                "./configs"
                                "/etc/myapp"
                            environment_prefix as "MYAPP_"
                            enable_secrets_integration as true
                            secrets_store as secret_store
                            strict_mode as true
                            enable_interpolation as true
                            enable_validation as true
                            enable_caching as true
                            enable_file_watching as false
                            enable_audit_logging as true
                            performance_monitoring as true
                            max_cache_size as 1000
                            metadata as dictionary containing:
                                "application" as "MyProductionApp"
                                "environment" as "production"
                        
                        Let configuration be config.create_configuration with options as config_options
                        Set configuration.schema to app_schema
                        
                        Note: Step 4 - Configure application settings
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "app.name"
                            value as "MyProductionApp"
                            source as "manual"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "app.port"
                            value as "8080"
                            source as "default"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "database.host"
                            value as "prod-db.internal.company.com"
                            source as "production"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "database.port"
                            value as "5432"
                            source as "default"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "database.name"
                            value as "production_app_db"
                            source as "production"
                            metadata as None
                        
                        Note: Step 5 - Reference secrets in configuration
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "database.password_secret_id"
                            value as db_secret_id
                            source as "secrets"
                            metadata as dictionary containing:
                                "secret_reference" as true
                                "secret_type" as "database_credential"
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "api.external_key_secret_id"
                            value as api_secret_id
                            source as "secrets"
                            metadata as dictionary containing:
                                "secret_reference" as true
                                "secret_type" as "api_key"
                        
                        Note: Step 6 - Set up interpolated values
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "database.connection_string"
                            value as "postgresql://user@${database.host}:${database.port}/${database.name}"
                            source as "interpolated"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "api.base_url"
                            value as "https://api.external-service.com"
                            source as "default"
                            metadata as None
                        
                        config.set_configuration_value with:
                            configuration as configuration
                            key as "api.full_endpoint"
                            value as "${api.base_url}/v1/data"
                            source as "interpolated"
                            metadata as None
                        
                        Note: Step 7 - Validate complete configuration
                        Let validation_result be config.validate_configuration with:
                            configuration as configuration
                            schema as app_schema
                        
                        test.assert_true with 
                            value as validation_result.valid
                            message as "Complete application configuration should be valid"
                        
                        test.assert_equal with 
                            actual as length of validation_result.errors
                            expected as 0
                            message as "Valid configuration should have no errors"
                        
                        Note: Step 8 - Test configuration retrieval with type conversion
                        Let port_result be config.get_configuration_value with:
                            configuration as configuration
                            key as "app.port"
                            default_value as None
                            data_type as "integer"
                        
                        test.assert_match with 
                            value as port_result 
                            pattern as config.ConfigurationSuccess
                            message as "Port retrieval should succeed"
                        
                        Match port_result:
                            When config.ConfigurationSuccess:
                                test.assert_equal with 
                                    actual as port_result.value
                                    expected as 8080
                                    message as "Port should be converted to integer"
                            Otherwise:
                                Return test.TestFailure with message as "Port conversion failed"
                        
                        Note: Step 9 - Test interpolated value resolution
                        Let connection_string_result be config.get_configuration_value with:
                            configuration as configuration
                            key as "database.connection_string"
                            default_value as None
                            data_type as None
                        
                        test.assert_match with 
                            value as connection_string_result 
                            pattern as config.ConfigurationSuccess
                            message as "Connection string retrieval should succeed"
                        
                        Match connection_string_result:
                            When config.ConfigurationSuccess:
                                test.assert_equal with 
                                    actual as connection_string_result.value
                                    expected as "postgresql://user@prod-db.internal.company.com:5432/production_app_db"
                                    message as "Connection string should be properly interpolated"
                            Otherwise:
                                Return test.TestFailure with message as "Connection string interpolation failed"
                        
                        Note: Step 10 - Test secret retrieval through configuration
                        Let db_secret_id_result be config.get_configuration_value with:
                            configuration as configuration
                            key as "database.password_secret_id"
                            default_value as None
                            data_type as None
                        
                        test.assert_match with 
                            value as db_secret_id_result 
                            pattern as config.ConfigurationSuccess
                            message as "Database secret ID retrieval should succeed"
                        
                        Match db_secret_id_result:
                            When config.ConfigurationSuccess:
                                Let actual_password_result be secrets.get_secret with:
                                    secret_id as db_secret_id_result.value
                                    store as secret_store
                                
                                test.assert_match with 
                                    value as actual_password_result 
                                    pattern as secrets.SecretSuccess
                                    message as "Database password secret retrieval should succeed"
                                
                                Match actual_password_result:
                                    When secrets.SecretSuccess:
                                        test.assert_equal with 
                                            actual as actual_password_result.value
                                            expected as "super_secure_production_password_2024"
                                            message as "Retrieved password should match original"
                                    Otherwise:
                                        Return test.TestFailure with message as "Password secret retrieval failed"
                            Otherwise:
                                Return test.TestFailure with message as "Database secret ID retrieval failed"
                        
                        Note: Step 11 - Test configuration metadata
                        Let metadata_result be config.get_configuration_metadata with configuration as configuration
                        
                        test.assert_not_null with 
                            value as metadata_result
                            message as "Configuration metadata should be available"
                        
                        test.assert_equal with 
                            actual as metadata_result["profile"]
                            expected as "PRODUCTION"
                            message as "Profile should be production"
                        
                        test.assert_true with 
                            value as metadata_result["values_count"] is greater than 10
                            message as "Should have multiple configuration values"
                    Otherwise:
                        Return test.TestFailure with message as "API key secret creation failed"
            Otherwise:
                Return test.TestFailure with message as "Database password secret creation failed"
        
        Return test.TestSuccess with message as "Complete application configuration workflow test passed"
    
    Catch error:
        Return test.TestFailure with message as "Complete application configuration workflow failed: " plus error.message

Process called "test_multi_environment_configuration_management" returns test.TestResult:
    Try:
        Note: Test configuration management across different environments
        
        Let environments be list containing "DEVELOPMENT", "STAGING", "PRODUCTION"
        Let environment_configs be dictionary containing
        
        For each env in environments:
            Note: Create environment-specific configuration
            Let env_profile be Match env:
                When "DEVELOPMENT": config.DEVELOPMENT
                When "STAGING": config.STAGING  
                When "PRODUCTION": config.PRODUCTION
                Otherwise: config.DEVELOPMENT
            
            Let env_options be config.ConfigurationOptions with:
                profile as env_profile
                auto_discover_files as true
                discovery_paths as list containing "./config/" plus env plus "/"
                environment_prefix as env plus "_"
                enable_secrets_integration as env is equal to "PRODUCTION"
                strict_mode as env is equal to "PRODUCTION"
                enable_interpolation as true
                enable_validation as true
                enable_caching as true
                enable_audit_logging as env is not equal to "DEVELOPMENT"
                metadata as dictionary containing "environment" as env
            
            Let env_config be config.create_configuration with options as env_options
            
            Note: Set environment-specific values
            config.set_configuration_value with:
                configuration as env_config
                key as "app.name"
                value as "MyApp"
                source as "base"
                metadata as None
            
            config.set_configuration_value with:
                configuration as env_config
                key as "app.environment"
                value as env
                source as "environment"
                metadata as None
            
            Note: Environment-specific database settings
            Let db_host be Match env:
                When "DEVELOPMENT": "localhost"
                When "STAGING": "staging-db.internal.company.com"
                When "PRODUCTION": "prod-db.internal.company.com"
                Otherwise: "localhost"
            
            config.set_configuration_value with:
                configuration as env_config
                key as "database.host"
                value as db_host
                source as "environment"
                metadata as None
            
            Let db_port be Match env:
                When "DEVELOPMENT": "5432"
                When "STAGING": "5432"
                When "PRODUCTION": "5433"
                Otherwise: "5432"
            
            config.set_configuration_value with:
                configuration as env_config
                key as "database.port"
                value as db_port
                source as "environment"
                metadata as None
            
            Note: Environment-specific debug settings
            Let debug_enabled be Match env:
                When "DEVELOPMENT": "true"
                When "STAGING": "false"
                When "PRODUCTION": "false"
                Otherwise: "true"
            
            config.set_configuration_value with:
                configuration as env_config
                key as "app.debug"
                value as debug_enabled
                source as "environment"
                metadata as None
            
            Set environment_configs[env] to env_config
        
        Note: Validate each environment configuration
        For each env in environments:
            Let env_config be environment_configs[env]
            
            Note: Test that environment-specific values are set correctly
            Let env_value_result be config.get_configuration_value with:
                configuration as env_config
                key as "app.environment"
                default_value as None
                data_type as None
            
            test.assert_match with 
                value as env_value_result 
                pattern as config.ConfigurationSuccess
                message as "Environment value should be retrievable for " plus env
            
            Match env_value_result:
                When config.ConfigurationSuccess:
                    test.assert_equal with 
                        actual as env_value_result.value
                        expected as env
                        message as "Environment value should match for " plus env
                Otherwise:
                    Return test.TestFailure with message as "Environment value retrieval failed for " plus env
            
            Note: Test database host configuration
            Let db_host_result be config.get_configuration_value with:
                configuration as env_config
                key as "database.host"
                default_value as None
                data_type as None
            
            test.assert_match with 
                value as db_host_result 
                pattern as config.ConfigurationSuccess
                message as "Database host should be retrievable for " plus env
            
            Note: Test debug setting with type conversion
            Let debug_result be config.get_configuration_value with:
                configuration as env_config
                key as "app.debug"
                default_value as None
                data_type as "boolean"
            
            test.assert_match with 
                value as debug_result 
                pattern as config.ConfigurationSuccess
                message as "Debug setting should be retrievable for " plus env
            
            Match debug_result:
                When config.ConfigurationSuccess:
                    Let expected_debug be env is equal to "DEVELOPMENT"
                    test.assert_equal with 
                        actual as debug_result.value
                        expected as expected_debug
                        message as "Debug setting should be correct for " plus env
                Otherwise:
                    Return test.TestFailure with message as "Debug setting retrieval failed for " plus env
        
        Note: Test configuration metadata differences
        Let dev_metadata be config.get_configuration_metadata with configuration as environment_configs["DEVELOPMENT"]
        Let prod_metadata be config.get_configuration_metadata with configuration as environment_configs["PRODUCTION"]
        
        test.assert_equal with 
            actual as dev_metadata["profile"]
            expected as "DEVELOPMENT"
            message as "Development profile should be correct"
        
        test.assert_equal with 
            actual as prod_metadata["profile"]
            expected as "PRODUCTION"
            message as "Production profile should be correct"
        
        test.assert_not_equal with 
            actual as dev_metadata["audit_enabled"]
            expected as prod_metadata["audit_enabled"]
            message as "Audit settings should differ between environments"
        
        Return test.TestSuccess with message as "Multi-environment configuration management test passed"
    
    Catch error:
        Return test.TestFailure with message as "Multi-environment configuration management failed: " plus error.message

Note: Security and Compliance Integration Tests
Process called "test_security_compliance_workflow" returns test.TestResult:
    Try:
        Note: Test comprehensive security and compliance scenario
        
        Let secret_store be secrets.get_default_secret_store
        Let security_config be config.create_configuration with options as config.ConfigurationOptions with:
            profile as config.PRODUCTION
            enable_secrets_integration as true
            secrets_store as secret_store
            strict_mode as true
            enable_audit_logging as true
            performance_monitoring as true
            metadata as dictionary containing "security_test" as true
        
        Note: Create various types of secrets for compliance testing
        Let secret_types_and_values be list containing:
            dictionary containing "type" as secrets.DATABASE_CREDENTIAL and "value" as "db_admin_password_2024"
            dictionary containing "type" as secrets.API_KEY and "value" as "sk_live_1234567890abcdef"
            dictionary containing "type" as secrets.PRIVATE_KEY and "value" as "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC..."
            dictionary containing "type" as secrets.OAUTH_SECRET and "value" as "oauth_client_secret_xyz789"
            dictionary containing "type" as secrets.ENCRYPTION_KEY and "value" as "AES256_encryption_key_base64_encoded"
        
        Let created_secret_ids be list containing
        
        For i from 0 to length of secret_types_and_values minus 1:
            Let secret_info be secret_types_and_values[i]
            
            Let create_result be secrets.create_secret with:
                name as "compliance_test_" plus secret_info["type"] as String plus "_" plus i as String
                value as secret_info["value"]
                secret_type as secret_info["type"]
                metadata as dictionary containing:
                    "compliance_level" as "SOC2"
                    "data_classification" as "highly_confidential"
                    "retention_policy" as "365_days"
                    "audit_required" as true
                store as secret_store
            
            test.assert_match with 
                value as create_result 
                pattern as secrets.SecretSuccess
                message as "Compliance secret creation should succeed for " plus secret_info["type"] as String
            
            Match create_result:
                When secrets.SecretSuccess:
                    Add create_result.value to created_secret_ids
                Otherwise:
                    Return test.TestFailure with message as "Compliance secret creation failed for " plus secret_info["type"] as String
        
        Note: Set up configuration with security requirements
        Let security_schema be config.ConfigurationSchema with:
            schema_version as "1.0"
            schema_id as "security_compliance_schema"
            required_keys as list containing:
                "security.encryption_enabled"
                "security.audit_level"
                "database.password_secret_id"
                "api.key_secret_id"
            optional_keys as list containing:
                "security.session_timeout"
                "security.max_failed_attempts"
            key_types as dictionary containing:
                "security.encryption_enabled" as "boolean"
                "security.session_timeout" as "integer"
                "security.max_failed_attempts" as "integer"
            key_constraints as dictionary containing:
                "security.session_timeout" as dictionary containing:
                    "min" as 300  Note: 5 minutes minimum
                    "max" as 86400  Note: 24 hours maximum
                "security.max_failed_attempts" as dictionary containing:
                    "min" as 3
                    "max" as 10
            default_values as dictionary containing:
                "security.encryption_enabled" as true
                "security.session_timeout" as 3600
                "security.max_failed_attempts" as 5
            sensitive_keys as list containing:
                "database.password_secret_id"
                "api.key_secret_id"
            validation_rules as dictionary containing
            metadata as dictionary containing "compliance_required" as true
        
        Set security_config.schema to security_schema
        
        Note: Configure security settings
        config.set_configuration_value with:
            configuration as security_config
            key as "security.encryption_enabled"
            value as "true"
            source as "security_policy"
            metadata as dictionary containing "compliance_required" as true
        
        config.set_configuration_value with:
            configuration as security_config
            key as "security.audit_level"
            value as "FULL"
            source as "security_policy"
            metadata as dictionary containing "compliance_required" as true
        
        config.set_configuration_value with:
            configuration as security_config
            key as "database.password_secret_id"
            value as created_secret_ids[0]
            source as "secrets"
            metadata as dictionary containing:
                "secret_reference" as true
                "compliance_level" as "SOC2"
        
        config.set_configuration_value with:
            configuration as security_config
            key as "api.key_secret_id"
            value as created_secret_ids[1]
            source as "secrets"
            metadata as dictionary containing:
                "secret_reference" as true
                "compliance_level" as "SOC2"
        
        Note: Validate security configuration
        Let security_validation be config.validate_configuration with:
            configuration as security_config
            schema as security_schema
        
        test.assert_true with 
            value as security_validation.valid
            message as "Security configuration should be valid"
        
        Note: Test sensitive value detection and handling
        Let sensitive_keys be list containing "database.password_secret_id", "api.key_secret_id"
        
        For each sensitive_key in sensitive_keys:
            test.assert_true with 
                value as config.is_sensitive_configuration_key with key as sensitive_key
                message as sensitive_key plus " should be detected as sensitive"
            
            Note: Test that sensitive values are properly masked in audit logs
            Let sensitive_result be config.get_configuration_value with:
                configuration as security_config
                key as sensitive_key
                default_value as None
                data_type as None
            
            test.assert_match with 
                value as sensitive_result 
                pattern as config.ConfigurationSuccess
                message as "Sensitive value should be retrievable"
            
            Match sensitive_result:
                When config.ConfigurationSuccess:
                    test.assert_true with 
                        value as sensitive_result.metadata["sensitive"]
                        message as "Sensitive metadata should be set"
                Otherwise:
                    Return test.TestFailure with message as "Sensitive value retrieval failed for " plus sensitive_key
        
        Note: Test secret rotation for compliance
        For each secret_id in created_secret_ids:
            Let rotation_result be secrets.rotate_secret with:
                secret_id as secret_id
                new_value as None  Note: Auto-generate
                rotation_config as dictionary containing:
                    "compliance_rotation" as true
                    "audit_trail" as true
                store as secret_store
            
            test.assert_match with 
                value as rotation_result 
                pattern as secrets.SecretSuccess
                message as "Compliance rotation should succeed for secret"
        
        Note: Test access control for compliance
        For each secret_id in created_secret_ids:
            Let access_grant_result be secrets.grant_secret_access with:
                secret_id as secret_id
                principal as "compliance_auditor"
                permissions as list containing "metadata", "read"
                conditions as dictionary containing:
                    "audit_purpose" as true
                    "time_limited" as true
                expires_at as get_current_timestamp plus 86400.0  Note: 24 hours
                store as secret_store
            
            test.assert_match with 
                value as access_grant_result 
                pattern as secrets.SecretSuccess
                message as "Compliance access grant should succeed"
        
        Note: Test configuration audit trail
        Let config_metadata be config.get_configuration_metadata with configuration as security_config
        
        test.assert_true with 
            value as config_metadata["audit_enabled"]
            message as "Audit logging should be enabled for security configuration"
        
        test.assert_true with 
            value as config_metadata["values_count"] is greater than 0
            message as "Security configuration should have values"
        
        Return test.TestSuccess with message as "Security compliance workflow test passed"
    
    Catch error:
        Return test.TestFailure with message as "Security compliance workflow failed: " plus error.message

Note: Performance and Load Testing
Process called "test_configuration_ecosystem_performance" returns test.TestResult:
    Try:
        Note: Test performance under realistic load conditions
        
        Let start_time be get_current_timestamp
        Let secret_store be secrets.get_default_secret_store
        
        Note: Create multiple configurations simulating different applications
        Let app_count be 10
        Let config_per_app be 20
        Let secret_per_app be 5
        
        Let all_configurations be list containing
        Let all_secrets be list containing
        
        For app_index from 1 to app_count:
            Note: Create secrets for this app
            Let app_secrets be list containing
            
            For secret_index from 1 to secret_per_app:
                Let secret_result be secrets.create_secret with:
                    name as "app_" plus app_index as String plus "_secret_" plus secret_index as String
                    value as "secret_value_" plus app_index as String plus "_" plus secret_index as String plus "_with_additional_content_for_realistic_size"
                    secret_type as secrets.API_KEY
                    metadata as dictionary containing:
                        "app_id" as app_index
                        "secret_index" as secret_index
                    store as secret_store
                
                Match secret_result:
                    When secrets.SecretSuccess:
                        Add secret_result.value to app_secrets
                        Add secret_result.value to all_secrets
                    Otherwise:
                        Return test.TestFailure with message as "Secret creation failed for app " plus app_index as String
            
            Note: Create configuration for this app
            Let app_config_options be config.ConfigurationOptions with:
                profile as config.PRODUCTION
                enable_secrets_integration as true
                secrets_store as secret_store
                enable_interpolation as true
                enable_validation as true
                enable_caching as true
                enable_audit_logging as true
                metadata as dictionary containing "app_id" as app_index
            
            Let app_config be config.create_configuration with options as app_config_options
            
            Note: Add configuration values for this app
            For config_index from 1 to config_per_app:
                Let config_key be "app.setting_" plus config_index as String
                Let config_value be "value_" plus app_index as String plus "_" plus config_index as String
                
                config.set_configuration_value with:
                    configuration as app_config
                    key as config_key
                    value as config_value
                    source as "performance_test"
                    metadata as dictionary containing "config_index" as config_index
            
            Note: Add secret references
            For secret_index from 0 to length of app_secrets minus 1:
                Let secret_key be "secrets.secret_" plus secret_index as String plus "_id"
                config.set_configuration_value with:
                    configuration as app_config
                    key as secret_key
                    value as app_secrets[secret_index]
                    source as "secrets"
                    metadata as dictionary containing "secret_reference" as true
            
            Note: Add interpolated values
            config.set_configuration_value with:
                configuration as app_config
                key as "app.base_url"
                value as "https://api.example.com"
                source as "base"
                metadata as None
            
            config.set_configuration_value with:
                configuration as app_config
                key as "app.full_endpoint"
                value as "${app.base_url}/v1/app_" plus app_index as String
                source as "interpolated"
                metadata as None
            
            Add app_config to all_configurations
        
        Let setup_time be get_current_timestamp minus start_time
        
        Note: Test bulk configuration retrieval performance
        Let retrieval_start be get_current_timestamp
        Let total_retrievals be 0
        Let successful_retrievals be 0
        
        For each configuration in all_configurations:
            For config_index from 1 to config_per_app:
                Let config_key be "app.setting_" plus config_index as String
                Let retrieval_result be config.get_configuration_value with:
                    configuration as configuration
                    key as config_key
                    default_value as None
                    data_type as None
                
                Set total_retrievals to total_retrievals plus 1
                
                Match retrieval_result:
                    When config.ConfigurationSuccess:
                        Set successful_retrievals to successful_retrievals plus 1
                    Otherwise:
                        Note: Continue testing
        
        Let retrieval_time be get_current_timestamp minus retrieval_start
        
        Note: Test bulk secret retrieval performance
        Let secret_retrieval_start be get_current_timestamp
        Let total_secret_retrievals be 0
        Let successful_secret_retrievals be 0
        
        For each secret_id in all_secrets:
            Let secret_result be secrets.get_secret with:
                secret_id as secret_id
                store as secret_store
            
            Set total_secret_retrievals to total_secret_retrievals plus 1
            
            Match secret_result:
                When secrets.SecretSuccess:
                    Set successful_secret_retrievals to successful_secret_retrievals plus 1
                Otherwise:
                    Note: Continue testing
        
        Let secret_retrieval_time be get_current_timestamp minus secret_retrieval_start
        
        Note: Test interpolation performance
        Let interpolation_start be get_current_timestamp
        Let interpolation_successes be 0
        
        For each configuration in all_configurations:
            Let interpolation_result be config.get_configuration_value with:
                configuration as configuration
                key as "app.full_endpoint"
                default_value as None
                data_type as None
            
            Match interpolation_result:
                When config.ConfigurationSuccess:
                    Set interpolation_successes to interpolation_successes plus 1
                Otherwise:
                    Note: Continue testing
        
        Let interpolation_time be get_current_timestamp minus interpolation_start
        
        Note: Validate performance metrics
        test.assert_equal with 
            actual as successful_retrievals
            expected as total_retrievals
            message as "All configuration retrievals should succeed"
        
        test.assert_equal with 
            actual as successful_secret_retrievals
            expected as total_secret_retrievals
            message as "All secret retrievals should succeed"
        
        test.assert_equal with 
            actual as interpolation_successes
            expected as length of all_configurations
            message as "All interpolations should succeed"
        
        Note: Performance thresholds (adjust based on requirements)
        Let expected_config_ops_per_second be 1000.0
        Let actual_config_ops_per_second be total_retrievals as Float divided by retrieval_time
        
        test.assert_true with 
            value as actual_config_ops_per_second is greater than expected_config_ops_per_second
            message as "Configuration retrieval should meet performance threshold (" plus actual_config_ops_per_second as String plus " ops/sec)"
        
        Let expected_secret_ops_per_second be 100.0
        Let actual_secret_ops_per_second be total_secret_retrievals as Float divided by secret_retrieval_time
        
        test.assert_true with 
            value as actual_secret_ops_per_second is greater than expected_secret_ops_per_second
            message as "Secret retrieval should meet performance threshold (" plus actual_secret_ops_per_second as String plus " ops/sec)"
        
        Note: Memory and resource usage should be reasonable
        test.assert_true with 
            value as setup_time is less than 60.0
            message as "Setup time should be reasonable (" plus setup_time as String plus " seconds)"
        
        Return test.TestSuccess with message as "Configuration ecosystem performance test passed - " plus total_retrievals as String plus " config ops in " plus retrieval_time as String plus "s, " plus total_secret_retrievals as String plus " secret ops in " plus secret_retrieval_time as String plus "s"
    
    Catch error:
        Return test.TestFailure with message as "Configuration ecosystem performance failed: " plus error.message

Note: Test Suite Runner
Process called "run_configuration_ecosystem_integration_tests" returns test.TestSuiteResult:
    Let test_results be list containing
    
    Note: Run all integration tests
    Add test_complete_application_configuration_workflow to test_results
    Add test_multi_environment_configuration_management to test_results
    Add test_security_compliance_workflow to test_results
    Add test_configuration_ecosystem_performance to test_results
    
    Return test.create_test_suite_result with:
        suite_name as "Configuration Ecosystem Integration Tests"
        test_results as test_results
        metadata as dictionary containing:
            "total_tests" as length of test_results
            "test_categories" as list containing:
                "End-to-End Workflows"
                "Multi-Environment Management"
                "Security and Compliance"
                "Performance and Load Testing"
            "scope" as "full_ecosystem_integration"
            "coverage" as "production_scenarios"