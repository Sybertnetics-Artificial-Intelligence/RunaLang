Note:
Runa Compiler Integration Test: With Standard Library Stubs

This test validates that the compiler can successfully process Runa code
using the standard library stubs for types and language keywords.

Test Coverage:
- Basic type checking with stubs
- Language keyword recognition
- Type enforcement with stubs
- End-to-end compilation pipeline
:End Note

Note: Import dependencies
Import "../../../src/compiler/driver.runa"
Import "../../../src/modules/stdlib/stubs/core_types.runa"

Note: Test Suite Setup
Process called "run_compiler_integration_tests":
    Note: Run all compiler integration tests with stubs
    Print "Running Compiler Integration Tests with Stubs..."
    
    Let test_count be 0
    Let passed_count be 0
    Let failed_count be 0
    
    Note: Test Basic Type Checking
    Let basic_types_result be test_basic_type_checking
    Set test_count to test_count plus 1
    If basic_types_result.success:
        Set passed_count to passed_count plus 1
        Print "  ✅ Basic Type Checking: PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Print "  ❌ Basic Type Checking: FAILED"
        Print "     Error: " plus basic_types_result.error
    
    Note: Test Language Keywords
    Let language_keywords_result be test_language_keywords
    Set test_count to test_count plus 1
    If language_keywords_result.success:
        Set passed_count to passed_count plus 1
        Print "  ✅ Language Keywords: PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Print "  ❌ Language Keywords: FAILED"
        Print "     Error: " plus language_keywords_result.error
    
    Note: Test Type Enforcement with Stubs
    Let type_enforcement_result be test_type_enforcement_with_stubs
    Set test_count to test_count plus 1
    If type_enforcement_result.success:
        Set passed_count to passed_count plus 1
        Print "  ✅ Type Enforcement with Stubs: PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Print "  ❌ Type Enforcement with Stubs: FAILED"
        Print "     Error: " plus type_enforcement_result.error
    
    Note: Test End-to-End Compilation
    Let end_to_end_result be test_end_to_end_compilation
    Set test_count to test_count plus 1
    If end_to_end_result.success:
        Set passed_count to passed_count plus 1
        Print "  ✅ End-to-End Compilation: PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Print "  ❌ End-to-End Compilation: FAILED"
        Print "     Error: " plus end_to_end_result.error
    
    Note: Test Summary
    Print "📊 Compiler Integration Test Summary:"
    Print "  Total Tests: " plus test_count
    Print "  Passed: " plus passed_count
    Print "  Failed: " plus failed_count
    Print "  Success Rate: " plus ((passed_count divided by test_count) multiplied by 100) plus "%"
    
    Return dictionary containing:
        "success" as failed_count is equal to 0
        "total_tests" as test_count
        "passed_tests" as passed_count
        "failed_tests" as failed_count

Note: Basic Type Checking Test
Process called "test_basic_type_checking" returns Dictionary[String, Any]:
    Note: Test that the compiler can handle basic type declarations
    Let source_code be """
Note: Test basic type checking with stubs
Let x (Integer) be 42
Let y (String) be "hello"
Let z (Boolean) be true
Let list_var (List[Integer]) be list containing 1, 2, 3
Let dict_var (Dictionary[String, Integer]) be dictionary with "a" as 1 and "b" as 2
"""
    
    Let result be compile_source with source as source_code
    
    If not result.success:
        Return dictionary containing "success" as false and "error" as "Basic type checking failed: " plus result.error
    
    Return dictionary containing "success" as true

Note: Language Keywords Test
Process called "test_language_keywords" returns Dictionary[String, Any]:
    Note: Test that the compiler can handle language keywords (not function calls)
    Let source_code be """
Note: Test language keywords with stubs
Let numbers (List[Integer]) be list containing 1, 2, 3
Let count (Integer) be length of numbers
Display count

Let text (String) be "hello world"
Display text

Let data (Dictionary[String, Integer]) be dictionary with "x" as 10 and "y" as 20
Let value (Optional[Integer]) be data["x"]
Display value
"""
    
    Let result be compile_source with source as source_code
    
    If not result.success:
        Return dictionary containing "success" as false and "error" as "Language keywords test failed: " plus result.error
    
    Return dictionary containing "success" as true

Note: Type Enforcement with Stubs Test
Process called "test_type_enforcement_with_stubs" returns Dictionary[String, Any]:
    Note: Test type enforcement with standard library stubs
    Let source_code be """
Note: Test type enforcement with stubs
Let x (Integer) be 42
Let y (String) be "hello"
Let z (Integer) be x plus 10  Note: Should work with Integer + Integer

Let list_var (List[Integer]) be list containing 1, 2, 3
Let dict_var (Dictionary[String, Integer]) be dictionary with "a" as 1
Let value (Optional[Integer]) be dict_var["a"]  Note: Should work with Dictionary lookup
"""
    
    Let result be compile_source with source as source_code
    
    If not result.success:
        Return dictionary containing "success" as false and "error" as "Type enforcement with stubs failed: " plus result.error
    
    Return dictionary containing "success" as true

Note: End-to-End Compilation Test
Process called "test_end_to_end_compilation" returns Dictionary[String, Any]:
    Note: Test complete compilation pipeline with stubs
    Let source_code be """
Note: Test complete compilation pipeline
Process called "calculate_average" that takes numbers (List[Integer]) returns Float:
    Let total (Integer) be 0
    Let count (Integer) be length of numbers
    
    For each number in numbers:
        Set total to total plus number
    
    Return total divided by count

Process called "main":
    Let scores (List[Integer]) be list containing 85, 92, 78, 96, 88
    Let average (Float) be calculate_average with numbers as scores
    Display "Average score: "
    Display average
"""
    
    Let result be compile_source with source as source_code
    
    If not result.success:
        Return dictionary containing "success" as false and "error" as "End-to-end compilation failed: " plus result.error
    
    Return dictionary containing "success" as true

Note: Test Error Cases
Process called "test_error_cases" returns Dictionary[String, Any]:
    Note: Test that the compiler properly reports errors with stubs
    Let source_code be """
Note: Test error cases with stubs
Let x (Integer) be 42
Let y (String) be "hello"
Let z (Integer) be x plus y  Note: Should fail - Integer + String
"""
    
    Let result be compile_source with source as source_code
    
    If result.success:
        Return dictionary containing "success" as false and "error" as "Compiler should report type error for Integer + String"
    
    Return dictionary containing "success" as true

Note: Test Stub Availability
Process called "test_stub_availability" returns Dictionary[String, Any]:
    Note: Test that all required stubs are available
    Let required_types be list containing:
        "Integer"
        "Float"
        "String"
        "Boolean"
        "List"
        "Dictionary"
        "Optional"
        "Any"
    
    Note: Check that all required types are defined
    For each type_name in required_types:
        Note: Verify type is available (this would be checked at compile time)
        Continue
    
    Return dictionary containing "success" as true

Note: Performance Test
Process called "test_compiler_performance" returns Dictionary[String, Any]:
    Note: Test compiler performance with stubs
    Let large_source_code be generate_large_test_program
    
    Let start_time be get_current_time_ms
    Let result be compile_source with source as large_source_code
    Let end_time be get_current_time_ms
    
    Let compilation_time be end_time minus start_time
    
    If not result.success:
        Return dictionary containing "success" as false and "error" as "Performance test compilation failed"
    
    If compilation_time is greater than 5000:  Note: 5 seconds max
        Return dictionary containing "success" as false and "error" as "Compilation too slow: " plus compilation_time plus "ms"
    
    Return dictionary containing "success" as true and "performance" as compilation_time

Note: Helper Functions
Process called "generate_large_test_program" returns String:
    Note: Generate a large test program for performance testing
    Let program be "Note: Large test program for performance testing\n"
    
    For i from 1 to 100:
        Set program to program plus "Let var" plus i plus " (Integer) be " plus i plus "\n"
    
    For i from 1 to 50:
        Set program to program plus "Process called \"func" plus i plus "\" that takes x (Integer) returns Integer:\n"
        Set program to program plus "    Return x plus " plus i plus "\n"
    
    Set program to program plus "Process called \"main\":\n"
    Set program to program plus "    Let result (Integer) be 0\n"
    
    For i from 1 to 50:
        Set program to program plus "    Set result to result plus func" plus i plus " with x as " plus i plus "\n"
    
    Set program to program plus "    Display result\n"
    
    Return program

Process called "get_current_time_ms" returns Integer:
    Note: Get current time in milliseconds
    Return current_timestamp_ms

Note: Test Runner
Process called "main":
    Note: Main test runner
    Let result be run_compiler_integration_tests
    
    If result.success:
        Print "🎉 All Compiler Integration Tests PASSED!"
        Print "✅ Compiler works correctly with standard library stubs"
        Exit with code 0
    Otherwise:
        Print "💥 Some Compiler Integration Tests FAILED!"
        Print "❌ Compiler has issues with standard library stubs"
        Print "Failed tests: " plus result.failed_tests
        Exit with code 1 