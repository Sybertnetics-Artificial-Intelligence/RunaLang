Note:
Runa Semantic Analyzer Test Suite

Comprehensive tests for the semantic analyzer including:
- Type checking and inference
- Symbol resolution and scope management
- Semantic validation rules
- LSP integration features
- Performance and error handling
:End Note

Note: Import dependencies
Import "../../../src/compiler/semantic/semantic_analyzer.runa"
Import "../../../src/compiler/parser/parser.runa"
Import "../../../src/compiler/lexer/lexer.runa"

Note: Test Configuration
Let test_config be dictionary containing:
    "total_tests" as 0
    "passed_tests" as 0
    "failed_tests" as 0
    "performance_tests" as 0
    "edge_case_tests" as 0
    "error_recovery_tests" as 0

Note: Test Results Tracking
Let test_results be dictionary containing:
    "test_name" as ""
    "success" as false
    "error_message" as ""
    "performance_metrics" as dictionary containing
    "execution_time_ms" as 0

Note: Test Helper Functions
Process called "run_test" that takes test_name as String and test_function as Process returns Boolean:
    Note: Run a single test and track results
    Set test_config.total_tests to test_config.total_tests plus 1
    Set test_results.test_name to test_name
    
    Let start_time be get_current_time_ms
    Let success be false
    Let error_message be ""
    
    Try:
        Call test_function
        Set success to true
    Catch error:
        Set error_message to error.message
        Set success to false
    
    Let end_time be get_current_time_ms
    Set test_results.execution_time_ms to end_time minus start_time
    Set test_results.success to success
    Set test_results.error_message to error_message
    
    If success:
        Set test_config.passed_tests to test_config.passed_tests plus 1
        Display "✅ PASS: " plus test_name plus " (" plus test_results.execution_time_ms plus "ms)"
    Otherwise:
        Set test_config.failed_tests to test_config.failed_tests plus 1
        Display "❌ FAIL: " plus test_name plus " - " plus error_message
    
    Return success

Process called "run_performance_test" that takes test_name as String and test_function as Process returns Boolean:
    Note: Run a performance-focused test
    Set test_config.performance_tests to test_config.performance_tests plus 1
    Return run_test with test_name as test_name and test_function as test_function

Process called "run_edge_case_test" that takes test_name as String and test_function as Process returns Boolean:
    Note: Run an edge case test
    Set test_config.edge_case_tests to test_config.edge_case_tests plus 1
    Return run_test with test_name as test_name and test_function as test_function

Process called "run_error_recovery_test" that takes test_name as String and test_function as Process returns Boolean:
    Note: Run an error recovery test
    Set test_config.error_recovery_tests to test_config.error_recovery_tests plus 1
    Return run_test with test_name as test_name and test_function as test_function

Note: Test Data Creation
Process called "create_test_ast" that takes source_code as String returns ASTNode:
    Note: Create AST for testing
    Let tokens be tokenize with source_code as source_code and file_path as "test.runa"
    Let parser be create_parser with tokens as tokens
    Let parsing_result be parse_program with parser as parser
    Return parsing_result.ast

Note: Basic Semantic Analysis Tests
Process called "test_basic_semantic_analysis":
    Note: Test basic semantic analysis functionality
    Let source be "Let x be 42\nLet y be x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Assert length of result.errors is equal to 0
    Assert result.symbol_table is not None
    Assert result.type_environment is not None

Process called "test_variable_declaration_analysis":
    Note: Test variable declaration analysis
    Let source be "Let my_variable be 42\nLet another_variable be \"Hello World\""
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Assert length of result.errors is equal to 0
    
    Let symbols be get_document_symbols with table as result.symbol_table and file_path as "test.runa"
    Assert length of symbols is greater than or equal to 2

Process called "test_function_declaration_analysis":
    Note: Test function declaration analysis
    Let source be "Process called \"calculate\" that takes x as Integer returns Integer:\n    Return x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Assert length of result.errors is equal to 0
    
    Let function_symbols be find_symbols_by_kind with table as result.symbol_table and kind as "function"
    Assert length of function_symbols is greater than or equal to 1

Note: Type Checking Tests
Process called "test_basic_type_checking":
    Note: Test basic type checking
    Let source be "Let x be 42\nLet y be x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Assert result.type_environment is not None
    
    Let type_checker be result.type_environment
    Assert type_checker.types contains "Integer"
    Assert type_checker.types contains "String"

Process called "test_type_inference":
    Note: Test type inference for unannotated variables
    Let source be "Let x be 42\nLet y be x plus 10\nLet message be \"Hello\""
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let symbols be get_document_symbols with table as result.symbol_table and file_path as "test.runa"
    For each symbol in symbols:
        If symbol.name is equal to "x" or symbol.name is equal to "y":
            Assert symbol.type is not None
            Assert symbol.type.name is equal to "Integer"
        Otherwise if symbol.name is equal to "message":
            Assert symbol.type is not None
            Assert symbol.type.name is equal to "String"

Process called "test_type_compatibility":
    Note: Test type compatibility checking
    Let source be "Let x be 42\nLet y be \"Hello\"\nLet z be x plus y"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Note: This should succeed due to string concatenation
    Assert result.success is true

Process called "test_generic_type_support":
    Note: Test generic type support
    Let source be "Let numbers be List[Integer] with 1, 2, 3\nLet first_number be numbers at index 0"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Assert result.type_environment.types contains "List"

Note: Symbol Resolution Tests
Process called "test_symbol_resolution":
    Note: Test symbol resolution in different scopes
    Let source be "Let global_var be 42\nProcess called \"test\" that takes param as Integer:\n    Let local_var be param plus global_var\n    Return local_var"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let global_symbol be resolve_symbol with table as result.symbol_table and name as "global_var"
    Assert global_symbol is not None
    Assert global_symbol.scope.name is equal to "global"
    
    Let function_symbols be find_symbols_by_kind with table as result.symbol_table and kind as "function"
    Assert length of function_symbols is greater than or equal to 1

Process called "test_scope_management":
    Note: Test scope creation and management
    Let source be "Let x be 1\nIf x is greater than 0:\n    Let y be 2\n    Let z be x plus y\nLet w be x"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let scopes be get_all_scopes with table as result.symbol_table
    Assert length of scopes is greater than 1

Process called "test_import_resolution":
    Note: Test import symbol resolution
    Let source be "Import \"math\"\nLet result be math.sqrt with 16"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Note: This should handle import resolution gracefully
    Assert result.success is true or length of result.errors is greater than 0

Note: Semantic Validation Tests
Process called "test_variable_usage_validation":
    Note: Test variable usage before declaration validation
    Let source be "Let y be x plus 10\nLet x be 42"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Note: Should detect undefined variable usage
    Assert result.success is false or length of result.errors is greater than 0

Process called "test_function_call_validation":
    Note: Test function call argument validation
    Let source be "Process called \"test\" that takes x as Integer:\n    Return x\nLet result be test with 42, 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Note: Should detect argument count mismatch
    Assert result.success is false or length of result.errors is greater than 0

Process called "test_circular_dependency_detection":
    Note: Test circular dependency detection
    Let source be "Import \"module_a\"\nImport \"module_b\""
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Note: Should handle dependency analysis gracefully
    Assert result.success is true

Process called "test_unused_variable_detection":
    Note: Test unused variable detection
    Let source be "Let unused_var be 42\nLet used_var be 10\nLet result be used_var plus 5"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    Note: Should generate warnings for unused variables
    Assert length of result.warnings is greater than or equal to 0

Note: LSP Integration Tests
Process called "test_autocompletion":
    Note: Test autocompletion functionality
    Let source be "Let x be 42\nLet y be x"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let position be SourceLocation with file_path as "test.runa" and line as 2 and column as 8
    Let completion_items be get_completion_items with analyzer as result.analyzer and position as position
    
    Assert length of completion_items is greater than 0

Process called "test_hover_information":
    Note: Test hover information functionality
    Let source be "Let my_variable be 42"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let position be SourceLocation with file_path as "test.runa" and line as 1 and column as 5
    Let hover_info be get_hover_info with analyzer as result.analyzer and position as position
    
    Assert hover_info is not None
    Assert length of hover_info.contents is greater than 0

Process called "test_go_to_definition":
    Note: Test go to definition functionality
    Let source be "Let x be 42\nLet y be x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let position be SourceLocation with file_path as "test.runa" and line as 2 and column as 8
    Let definition_location be get_definition_location with analyzer as result.analyzer and position as position
    
    Assert definition_location is not None
    Assert definition_location.line is equal to 1

Process called "test_find_all_references":
    Note: Test find all references functionality
    Let source be "Let x be 42\nLet y be x plus 10\nLet z be x multiplied by 2"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let position be SourceLocation with file_path as "test.runa" and line as 1 and column as 5
    Let references be get_references with analyzer as result.analyzer and position as position
    
    Assert length of references is greater than or equal to 2

Process called "test_document_symbols":
    Note: Test document symbols for outline view
    Let source be "Let x be 42\nProcess called \"test\" that takes param as Integer:\n    Return param plus x"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let symbols be get_symbols with analyzer as result.analyzer and file_path as "test.runa"
    Assert length of symbols is greater than or equal to 2

Note: Performance Tests
Process called "test_large_file_performance":
    Note: Test performance with large files
    Let large_source be ""
    For i from 1 to 1000:
        Set large_source to large_source plus "Let variable_" plus i plus " be " plus i plus "\n"
    
    Let ast be create_test_ast with source_code as large_source
    Let result be analyze_semantics with ast as ast and file_path as "large_test.runa"
    
    Assert result.success is true
    Assert result.performance_metrics.analysis_time_ms is less than 1000  Note: Should complete within 1 second

Process called "test_incremental_analysis":
    Note: Test incremental analysis performance
    Let source be "Let x be 42\nLet y be x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "test.runa"
    
    Assert result.success is true
    
    Let changed_nodes be list containing "node_1", "node_2"
    Let incremental_result be analyze_incrementally with analyzer as result.analyzer and changed_nodes as changed_nodes
    
    Assert incremental_result is not None

Note: Edge Case Tests
Process called "test_empty_file":
    Note: Test semantic analysis of empty file
    Let ast be create_test_ast with source_code as ""
    Let result be analyze_semantics with ast as ast and file_path as "empty.runa"
    
    Assert result.success is true
    Assert length of result.errors is equal to 0

Process called "test_complex_nested_structures":
    Note: Test complex nested structures
    Let source be "Process called \"outer\" that takes x as Integer:\n    Process called \"inner\" that takes y as Integer:\n        Let z be x plus y\n        Return z\n    Return inner with x"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "nested.runa"
    
    Assert result.success is true

Process called "test_deep_scope_nesting":
    Note: Test deep scope nesting
    Let source be "Let level0 be 0\nIf true:\n    Let level1 be 1\n    If true:\n        Let level2 be 2\n        If true:\n            Let level3 be 3\n            If true:\n                Let level4 be 4"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "deep_nested.runa"
    
    Assert result.success is true

Note: Error Recovery Tests
Process called "test_semantic_error_recovery":
    Note: Test semantic error recovery
    Let source be "Let x be undefined_function with 42\nLet y be 10\nLet z be y plus 5"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "error_recovery.runa"
    
    Note: Should detect error but continue analysis
    Assert result.success is false or length of result.errors is greater than 0
    Assert result.symbol_table is not None

Process called "test_multiple_error_handling":
    Note: Test handling of multiple semantic errors
    Let source be "Let x be undefined_var\nLet y be another_undefined_var\nProcess called \"test\" that takes param as Integer:\n    Return param plus undefined_in_scope"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "multiple_errors.runa"
    
    Note: Should collect multiple errors
    Assert result.success is false
    Assert length of result.errors is greater than 1

Process called "test_warning_collection":
    Note: Test warning collection
    Let source be "Let unused1 be 1\nLet unused2 be 2\nLet used be 3\nLet result be used plus 5"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "warnings.runa"
    
    Assert result.success is true
    Note: Should collect warnings for unused variables
    Assert length of result.warnings is greater than or equal to 0

Note: Utility Function Tests
Process called "test_performance_metrics":
    Note: Test performance metrics collection
    Let source be "Let x be 42\nLet y be x plus 10"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "metrics_test.runa"
    
    Assert result.success is true
    Assert result.performance_metrics is not None
    Assert result.performance_metrics.analysis_time_ms is greater than or equal to 0

Process called "test_cache_management":
    Note: Test cache management functionality
    Let source be "Let x be 42"
    Let ast be create_test_ast with source_code as source
    Let result be analyze_semantics with ast as ast and file_path as "cache_test.runa"
    
    Assert result.success is true
    
    Let analyzer be result.analyzer
    Call clear_semantic_analyzer_cache with analyzer as analyzer
    
    Note: Cache should be cleared
    Assert analyzer.analysis_cache is not None

Note: Main Test Runner
Process called "run_all_semantic_analyzer_tests":
    Note: Run all semantic analyzer tests
    Display "🧠 Starting Runa Semantic Analyzer Test Suite..."
    Display ""
    
    Note: Basic functionality tests
    Call run_test with test_name as "Basic Semantic Analysis" and test_function as test_basic_semantic_analysis
    Call run_test with test_name as "Variable Declaration Analysis" and test_function as test_variable_declaration_analysis
    Call run_test with test_name as "Function Declaration Analysis" and test_function as test_function_declaration_analysis
    
    Note: Type checking tests
    Call run_test with test_name as "Basic Type Checking" and test_function as test_basic_type_checking
    Call run_test with test_name as "Type Inference" and test_function as test_type_inference
    Call run_test with test_name as "Type Compatibility" and test_function as test_type_compatibility
    Call run_test with test_name as "Generic Type Support" and test_function as test_generic_type_support
    
    Note: Symbol resolution tests
    Call run_test with test_name as "Symbol Resolution" and test_function as test_symbol_resolution
    Call run_test with test_name as "Scope Management" and test_function as test_scope_management
    Call run_test with test_name as "Import Resolution" and test_function as test_import_resolution
    
    Note: Semantic validation tests
    Call run_test with test_name as "Variable Usage Validation" and test_function as test_variable_usage_validation
    Call run_test with test_name as "Function Call Validation" and test_function as test_function_call_validation
    Call run_test with test_name as "Circular Dependency Detection" and test_function as test_circular_dependency_detection
    Call run_test with test_name as "Unused Variable Detection" and test_function as test_unused_variable_detection
    
    Note: LSP integration tests
    Call run_test with test_name as "Autocompletion" and test_function as test_autocompletion
    Call run_test with test_name as "Hover Information" and test_function as test_hover_information
    Call run_test with test_name as "Go to Definition" and test_function as test_go_to_definition
    Call run_test with test_name as "Find All References" and test_function as test_find_all_references
    Call run_test with test_name as "Document Symbols" and test_function as test_document_symbols
    
    Note: Performance tests
    Call run_performance_test with test_name as "Large File Performance" and test_function as test_large_file_performance
    Call run_performance_test with test_name as "Incremental Analysis" and test_function as test_incremental_analysis
    
    Note: Edge case tests
    Call run_edge_case_test with test_name as "Empty File" and test_function as test_empty_file
    Call run_edge_case_test with test_name as "Complex Nested Structures" and test_function as test_complex_nested_structures
    Call run_edge_case_test with test_name as "Deep Scope Nesting" and test_function as test_deep_scope_nesting
    
    Note: Error recovery tests
    Call run_error_recovery_test with test_name as "Semantic Error Recovery" and test_function as test_semantic_error_recovery
    Call run_error_recovery_test with test_name as "Multiple Error Handling" and test_function as test_multiple_error_handling
    Call run_error_recovery_test with test_name as "Warning Collection" and test_function as test_warning_collection
    
    Note: Utility function tests
    Call run_test with test_name as "Performance Metrics" and test_function as test_performance_metrics
    Call run_test with test_name as "Cache Management" and test_function as test_cache_management
    
    Note: Display test summary
    Display ""
    Display "📊 Semantic Analyzer Test Summary:"
    Display "   Total Tests: " plus test_config.total_tests
    Display "   Passed: " plus test_config.passed_tests
    Display "   Failed: " plus test_config.failed_tests
    Display "   Performance Tests: " plus test_config.performance_tests
    Display "   Edge Case Tests: " plus test_config.edge_case_tests
    Display "   Error Recovery Tests: " plus test_config.error_recovery_tests
    Display ""
    
    Let success_rate be (test_config.passed_tests divided by test_config.total_tests) multiplied by 100
    Display "   Success Rate: " plus success_rate plus "%"
    
    If test_config.failed_tests is equal to 0:
        Display "🎉 All semantic analyzer tests passed!"
        Return true
    Otherwise:
        Display "⚠️  Some semantic analyzer tests failed. Please review the errors above."
        Return false 