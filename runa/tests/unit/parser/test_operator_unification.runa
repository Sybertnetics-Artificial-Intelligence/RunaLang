Note:
Parser tests for operator unification: symbolic vs natural forms should yield equivalent AST structure.
:End Note

Import "../../../src/compiler/parser/parser.runa"

Process called "ast_to_string" that takes ast returns String:
    Note: Minimal AST pretty-printer for equivalence testing
    If ast is None:
        Return "None"
    Return to_string with value as ast  Note: assumes AST implements to_string

Process called "parse_expr" that takes code as String returns String:
    Let result be parse_program with source_code as code and file_path as "test.runa"
    If result.success is false:
        Return "ERROR"
    Return ast_to_string with ast as result.ast

Process called "test_symbolic_vs_natural_arithmetic" returns Boolean:
    Let a be parse_expr with code as "Let x be a + b"
    Let b be parse_expr with code as "Let x be a plus b"
    Return a is equal to b

Process called "test_symbolic_vs_natural_multiplicative" returns Boolean:
    Let a be parse_expr with code as "Let x be a * b"
    Let b be parse_expr with code as "Let x be a multiplied by b"
    Return a is equal to b

Process called "test_symbolic_vs_natural_comparison" returns Boolean:
    Let a be parse_expr with code as "Let x be a < b"
    Let b be parse_expr with code as "Let x be a is less than b"
    Return a is equal to b

Process called "test_symbolic_vs_natural_le_ge_ne" returns Boolean:
    Let a be parse_expr with code as "Let x be a <= b"
    Let b be parse_expr with code as "Let x be a is less than or equal to b"
    Let c be parse_expr with code as "Let x be a >= b"
    Let d be parse_expr with code as "Let x be a is greater than or equal to b"
    Let e be parse_expr with code as "Let x be a != b"
    Let f be parse_expr with code as "Let x be a is not equal to b"
    Return (a is equal to b) and (c is equal to d) and (e is equal to f)

Process called "test_equals_keyword" returns Boolean:
    Let a be parse_expr with code as "If a equals b:\n    Display \"ok\""
    Let b be parse_expr with code as "If a is equal to b:\n    Display \"ok\""
    Return a is equal to b

Process called "test_forbid_equal_and_double_equal" returns Boolean:
    Let a be parse_expr with code as "If a == b:\n    Display \"bad\""
    Let b be parse_expr with code as "If a = b:\n    Display \"bad\""
    Return a is equal to "ERROR" and b is equal to "ERROR"

Process called "run_operator_unification_tests" returns Dictionary[String, Any]:
    Let tests be list containing:
        "Arithmetic symbolic vs natural" as test_symbolic_vs_natural_arithmetic
        "Multiplicative symbolic vs natural" as test_symbolic_vs_natural_multiplicative
        "Comparison symbolic vs natural" as test_symbolic_vs_natural_comparison
        "<= >= != symbolic vs natural" as test_symbolic_vs_natural_le_ge_ne
        "Equals keyword" as test_equals_keyword
        "Forbid '=' and '=='" as test_forbid_equal_and_double_equal
    
    Let passed be 0
    Let total be 0
    For each name and fn in tests:
        Set total to total plus 1
        If fn:
            Set passed to passed plus 1
    
    Return dictionary containing:
        "passed" as passed
        "total" as total


