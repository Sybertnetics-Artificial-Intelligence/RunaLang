    Let source be "For each item in list:\n    If item is greater than 10:\n        While condition is true:\n            Let result be item multiplied by 2\n            If result is greater than 100:\n                Break"
    Let result be parse_program with source_code as source and file_path as "test.runa"
    
    Return result.success is true and
           result.ast is not None

Note: Cache and Memory Management Tests
Process called "test_expression_caching" returns Boolean:
    Note: Test expression parsing cache
    Let source be "Let x be 1 plus 2\nLet y be 1 plus 2\nLet z be 1 plus 2"
    Let result be parse_program with source_code as source and file_path as "test.runa"
    
    Return result.success is true and
           result.ast is not None and
           length of result.ast.body is equal to 3

Process called "test_memory_cleanup" returns Boolean:
    Note: Test memory cleanup functionality
    Let source be "Let x be 42"
    Let result be parse_program with source_code as source and file_path as "test.runa"
    
    If result.success is false:
        Return false
    
    Let initial_memory be estimate_ast_memory_usage with ast as result.ast
    
    Note: Simulate memory cleanup
    Let cleaned_memory be initial_memory divided by 2
    
    Return cleaned_memory is greater than 0

Process called "test_ast_node_pooling" returns Boolean:
    Note: Test AST node pooling
    Let source be "Let x be 42\nLet y be 100\nLet z be 200"
    Let result be parse_program with source_code as source and file_path as "test.runa"
    
    Return result.success is true and
           result.ast is not None and
           length of result.ast.body is equal to 3

Note: Performance Benchmarking Tests
Process called "test_parsing_throughput" returns Boolean:
    Note: Test parsing throughput
    Let test_sources be list containing:
        "Let x be 42" as "simple"
        "Let x be 42\nLet y be 100\nLet z be 200" as "medium"
        "Process called \"test\" that takes x, y returns Integer:\n    Let result be x plus y\n    Return result" as "complex"
    
    Let total_time be 0
    Let total_statements be 0
    
    For each source and complexity in test_sources:
        Let start_time be get_current_time_ms
        Let result be parse_program with source_code as source and file_path as "throughput_test.runa"
        Let end_time be get_current_time_ms
        Let duration be end_time minus start_time
        
        If result.success:
            Set total_time to total_time plus duration
            Set total_statements to total_statements plus length of result.ast.body
    
    Let throughput be total_statements divided by (total_time divided by 1000)
    
    Return throughput is greater than 10  Note: At least 10 statements per second

Process called "test_memory_efficiency" returns Boolean:
    Note: Test memory efficiency
    Let source be "Let x be 42\nLet y be \"Hello World\"\nLet z be true\nProcess called \"test\" that takes param returns Integer:\n    Return param plus 1"
    Let result be parse_program with source_code as source and file_path as "test.runa"
    
    If result.success is false:
        Return false
    
    Let memory_usage be estimate_ast_memory_usage with ast as result.ast
    Let source_length be length of source
    Let efficiency_ratio be memory_usage divided by source_length
    
    Return efficiency_ratio is less than 1  Note: Memory usage should be less than source length

Note: Main Test Runner
Process called "run_all_enhanced_parser_tests" returns Dictionary[String, Any]:
    Note: Run all enhanced parser tests
    Display "🧪 Running Enhanced Parser Test Suite..."
    Display ""
    
    Note: Basic functionality tests
    Let basic_tests be list containing:
        "Basic Parsing" as test_basic_parsing
        "Variable Declaration Parsing" as test_variable_declaration_parsing
        "Multi-word Construct Parsing" as test_multi_word_construct_parsing
        "Function Declaration Parsing" as test_function_declaration_parsing
    
    For each test_name and test_function in basic_tests:
        run_test with test_name as test_name and test_function as test_function
    
    Display ""
    Display "🔍 Running Edge Case Tests..."
    
    Note: Edge case tests
    Let edge_case_tests be list containing:
        "Deeply Nested Structures" as test_deeply_nested_structures
        "Complex Expressions" as test_complex_expressions
        "Mixed Syntax Styles" as test_mixed_syntax_styles
        "Large Expression Trees" as test_large_expression_trees
        "Complex Type Annotations" as test_complex_type_annotations
        "Nested Function Calls" as test_nested_function_calls
        "Complex Conditional Logic" as test_complex_conditional_logic
        "Ambiguous Operator Precedence" as test_ambiguous_operator_precedence
        "Complex Pattern Matching" as test_complex_pattern_matching
        "Nested Import Statements" as test_nested_import_statements
        "Complex Type Definitions" as test_complex_type_definitions
        "Mixed Control Structures" as test_mixed_control_structures
    
    For each test_name and test_function in edge_case_tests:
        run_edge_case_test with test_name as test_name and test_function as test_function
    
    Display ""
    Display "⚡ Running Performance Tests..."
    
    Note: Performance tests
    Let performance_tests be list containing:
        "Large File Parsing" as test_large_file_parsing
        "Memory Usage Optimization" as test_memory_usage_optimization
        "AST Depth Limiting" as test_ast_depth_limiting
        "Parsing Throughput" as test_parsing_throughput
        "Memory Efficiency" as test_memory_efficiency
    
    For each test_name and test_function in performance_tests:
        run_performance_test with test_name as test_name and test_function as test_function
    
    Display ""
    Display "🛠️  Running Error Recovery Tests..."
    
    Note: Error recovery tests
    Let error_recovery_tests be list containing:
        "Missing Keyword Recovery" as test_missing_keyword_recovery
        "Unterminated Block Recovery" as test_unterminated_block_recovery
        "Malformed Expression Recovery" as test_malformed_expression_recovery
        "Invalid Syntax Recovery" as test_invalid_syntax_recovery
        "Missing Parameters Recovery" as test_missing_parameters_recovery
    
    For each test_name and test_function in error_recovery_tests:
        run_error_recovery_test with test_name as test_name and test_function as test_function
    
    Display ""
    Display "🔧 Running Cache and Memory Tests..."
    
    Note: Cache and memory management tests
    Let cache_memory_tests be list containing:
        "Expression Caching" as test_expression_caching
        "Memory Cleanup" as test_memory_cleanup
        "AST Node Pooling" as test_ast_node_pooling
    
    For each test_name and test_function in cache_memory_tests:
        run_test with test_name as test_name and test_function as test_function
    
    Display ""
    Display "📊 Test Results Summary:"
    Display "   Total Tests: " plus test_results.total_tests
    Display "   Passed: " plus test_results.passed_tests
    Display "   Failed: " plus test_results.failed_tests
    Display "   Performance Tests: " plus test_results.performance_tests
    Display "   Edge Case Tests: " plus test_results.edge_case_tests
    Display "   Error Recovery Tests: " plus test_results.error_recovery_tests
    
    Let success_rate be (test_results.passed_tests divided by test_results.total_tests) multiplied by 100
    
    Display "   Success Rate: " plus success_rate plus "%"
    
    If success_rate is greater than or equal to 95:
        Display "🎉 Enhanced Parser Test Suite PASSED!"
    Otherwise:
        Display "❌ Enhanced Parser Test Suite FAILED!"
    
    Return test_results

