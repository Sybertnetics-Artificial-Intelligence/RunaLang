            debug_mode as false
        
        Let server be create_lsp_server with config as config
        Let uri be "file:///test.runa"
        Let content be "Let x be 42\nPrint x"
        
        Note: Perform some operations to generate metrics
        Let analysis_result be analyze_document with server as server and uri as uri and content as content
        
        Let metrics be get_server_performance_metrics with server as server
        
        Note: Verify metrics were updated
        Assert metrics.documents_analyzed is greater than 0
        Assert metrics.analysis_time_ms is greater than or equal to 0
        
