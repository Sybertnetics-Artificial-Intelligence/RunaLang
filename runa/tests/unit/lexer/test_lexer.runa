Process called "test_unexpected_character_handling" returns Boolean:
    Note: Test handling of unexpected characters
    Let source be "Let x @ 42"
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let error_tokens be find_tokens_by_type with tokens as tokens and token_type as ERROR
    
    Return length of error_tokens is greater than 0

Process called "test_unterminated_string_handling" returns Boolean:
    Note: Test handling of unterminated strings
    Let source be "Let message be \"Hello, World!"
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let error_tokens be find_tokens_by_type with tokens as tokens and token_type as ERROR
    
    Return length of error_tokens is greater than 0

Process called "test_indentation_error_handling" returns Boolean:
    Note: Test handling of indentation errors
    Let source be "If x is greater than 0:\n  Display x\n    Set x to x minus 1"
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let error_tokens be find_tokens_by_type with tokens as tokens and token_type as ERROR
    
    Return length of error_tokens is greater than 0

Note: Natural Language Tests
Process called "run_natural_language_tests" returns Dictionary[String, Any]:
    Note: Test natural language syntax support
    Let total_tests be 0
    Let passed_tests be 0
    Let failed_tests be 0
    
    Note: Test natural language function definition
    Let test1_result be test_natural_language_function
    Set total_tests to total_tests plus 1
    If test1_result:
        Set passed_tests to passed_tests plus 1
    Otherwise:
        Set failed_tests to failed_tests plus 1
    
    Note: Test method calls with parameters
    Let test2_result be test_method_calls_with_parameters
    Set total_tests to total_tests plus 1
    If test2_result:
        Set passed_tests to passed_tests plus 1
    Otherwise:
        Set failed_tests to failed_tests plus 1
    
    Note: Test complex natural language expressions
    Let test3_result be test_complex_natural_language
    Set total_tests to total_tests plus 1
    If test3_result:
        Set passed_tests to passed_tests plus 1
    Otherwise:
        Set failed_tests to failed_tests plus 1
    
    Return dictionary containing:
        "total_tests" as total_tests
        "passed_tests" as passed_tests
        "failed_tests" as failed_tests

Process called "test_natural_language_function" returns Boolean:
    Note: Test natural language function definition
    Let source be "Process called add that takes a as integer and b as integer returns integer"
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let keyword_tokens be find_tokens_by_type with tokens as tokens and token_type as KEYWORD
    Let identifier_tokens be find_tokens_by_type with tokens as tokens and token_type as IDENTIFIER
    
    Return length of keyword_tokens is greater than 0 and
           length of identifier_tokens is greater than 0

Process called "test_method_calls_with_parameters" returns Boolean:
    Note: Test method calls with parameters
    Let source be "Display message with text as \"Hello\" and color as \"red\""
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let with_tokens be find_tokens_by_type with tokens as tokens and token_type as WITH_KEYWORD
    Let as_tokens be find_tokens_by_type with tokens as tokens and token_type as AS_KEYWORD
    
    Return length of with_tokens is greater than 0 and
           length of as_tokens is greater than 0

Process called "test_complex_natural_language" returns Boolean:
    Note: Test complex natural language expressions
    Let source be "If user age is greater than 18 and user name is not equal to \"\":\n    Display welcome message with name as user name"
    Let tokens be tokenize with source_code as source and file_path as "test.runa"
    
    Let operator_tokens be find_tokens_by_type with tokens as tokens and token_type as OPERATOR
    Let qualified_tokens be find_tokens_by_type with tokens as tokens and token_type as QUALIFIED_IDENTIFIER
    
    Return length of operator_tokens is greater than 0 and
           length of qualified_tokens is greater than 0

Note: Test Results Display
Process called "display_test_results" that takes results as Dictionary[String, Any]:
    Note: Display test results in a formatted way
    Display "=== Runa Lexer Test Results ==="
    Display "Total Tests: " plus results.total_tests
    Display "Passed: " plus results.passed_tests
    Display "Failed: " plus results.failed_tests
    Display "Success Rate: " plus results.success_rate plus "%"
    
    If results.success_rate is equal to 100:
        Display "🎉 All tests passed! The lexer is working perfectly."
    Otherwise if results.success_rate is greater than or equal to 90:
        Display "✅ Most tests passed. Minor issues to address."
    Otherwise if results.success_rate is greater than or equal to 70:
        Display "⚠️  Some tests failed. Significant issues to fix."
    Otherwise:
        Display "❌ Many tests failed. Major issues to address."

Note: Main test execution
Let test_results be run_lexer_test_suite
Display display_test_results with results as test_results 