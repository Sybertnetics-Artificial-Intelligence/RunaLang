Process called "test_target_specific_optimizations" returns Dictionary[String, Any]:
    Note: Test target-specific optimizations
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let ir_module be create_ir_module
    
    Let passed be true
    Let errors be list containing
    
    Note: Create a target platform
    Let target_platform be TargetPlatform with:
        architecture as "x86_64"
        cpu_model as "generic"
        cache_size as 32768
        cache_line_size as 64
        vector_width as 8
        instruction_set as list containing "sse", "avx2"
        metadata as dictionary containing
    
    Note: Test target-specific optimization
    Let target_result be optimize_for_target with ir_module as ir_module and target_platform as target_platform and context as context
    
    If target_result.success is false:
        Set passed to false
        Add "Target-specific optimization failed" to errors
    
    Note: Check that optimizations were applied
    If target_result.statistics at key "optimizations_applied" is less than 0:
        Set passed to false
        Add "No target-specific optimizations were applied" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "Target-Specific Optimizations"

Note: Test Runner
Process called "run_optimization_tests" returns String:
    Note: Run all optimization tests and return results
    Let results be test_optimization_system
    Let summary be results at key "summary"
    
    Let output be "IR Optimization Test Results:\n"
    Set output to output plus "Total Tests: " plus summary.total_tests plus "\n"
    Set output to output plus "Passed: " plus summary.passed_tests plus "\n"
    Set output to output plus "Failed: " plus summary.failed_tests plus "\n"
    Set output to output plus "Success Rate: " plus summary.success_rate plus "%\n"
    
    If summary.all_passed:
        Set output to output plus "✅ All optimization tests passed!\n"
    Otherwise:
        Set output to output plus "❌ Some optimization tests failed!\n"
        Set output to output plus "\nDetailed Results:\n"
        
        For each test_name in results:
            If test_name is not equal to "summary":
                Let test_result be results at key test_name
                Set output to output plus test_name plus ": "
                If test_result.passed:
                    Set output to output plus "✅ PASSED\n"
                Otherwise:
                    Set output to output plus "❌ FAILED\n"
                    For each error in test_result.errors:
                        Set output to output plus "  - " plus error plus "\n"
    
    Return output 