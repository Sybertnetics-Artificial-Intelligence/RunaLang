Process called "test_optimization_levels" returns Dictionary[String, Any]:
    Note: Test different optimization levels
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    
    Let passed be true
    Let errors be list containing
    
    Note: Test optimization level descriptions
    Let level0_desc be get_optimization_level_description with level as 0
    If level0_desc is not equal to "No optimizations":
        Set passed to false
        Add "Incorrect level 0 description" to errors
    
    Let level1_desc be get_optimization_level_description with level as 1
    If level1_desc is not equal to "Basic optimizations (inlining, constant folding)":
        Set passed to false
        Add "Incorrect level 1 description" to errors
    
    Let level2_desc be get_optimization_level_description with level as 2
    If level2_desc is not equal to "Standard optimizations (includes register allocation)":
        Set passed to false
        Add "Incorrect level 2 description" to errors
    
    Let level3_desc be get_optimization_level_description with level as 3
    If level3_desc is not equal to "Aggressive optimizations (includes advanced passes)":
        Set passed to false
        Add "Incorrect level 3 description" to errors
    
    Note: Test optimization pass descriptions
    Let inlining_desc be get_optimization_pass_description with pass_name as "hir_inlining"
    If inlining_desc is not equal to "Function inlining at HIR level":
        Set passed to false
        Add "Incorrect inlining pass description" to errors
    
    Let folding_desc be get_optimization_pass_description with pass_name as "mir_constant_folding"
    If folding_desc is not equal to "Constant folding at MIR level":
        Set passed to false
        Add "Incorrect constant folding pass description" to errors
    
    Let allocation_desc be get_optimization_pass_description with pass_name as "lir_register_allocation"
    If allocation_desc is not equal to "Register allocation at LIR level":
        Set passed to false
        Add "Incorrect register allocation pass description" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "Optimization Levels"

Process called "test_hir_loop_optimization" returns Dictionary[String, Any]:
    Note: Test HIR loop optimization
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let hir_module be create_hir_module with name as "test"
    
    Let passed be true
    Let errors be list containing
    
    Note: Test loop optimization on a simple loop
    Let loop_result be optimize_hir_with_loop_optimization with hir_module as hir_module and context as context
    
    If loop_result.success is false:
        Set passed to false
        Add "Loop optimization failed" to errors
    
    Note: Check that optimizations were applied
    If loop_result.statistics at key "loops_optimized" is less than 0:
        Set passed to false
        Add "No loops were optimized" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "HIR Loop Optimization"

