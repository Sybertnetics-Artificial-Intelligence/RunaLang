Note: IR Optimization Test Suite
Process called "test_optimization_system" returns Dictionary[String, Any]:
    Note: Run all optimization tests
    Let test_results be dictionary containing
    Let passed_tests be 0
    Let total_tests be 0
    
    Note: Test Optimization Pipeline
    Let pipeline_test be test_optimization_pipeline
    Set test_results at key "optimization_pipeline" to pipeline_test
    Set total_tests to total_tests plus 1
    If pipeline_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test HIR Inlining
    Let inlining_test be test_hir_inlining
    Set test_results at key "hir_inlining" to inlining_test
    Set total_tests to total_tests plus 1
    If inlining_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test HIR Loop Optimization
    Let loop_optimization_test be test_hir_loop_optimization
    Set test_results at key "hir_loop_optimization" to loop_optimization_test
    Set total_tests to total_tests plus 1
    If loop_optimization_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test MIR Constant Folding
    Let constant_folding_test be test_mir_constant_folding
    Set test_results at key "mir_constant_folding" to constant_folding_test
    Set total_tests to total_tests plus 1
    If constant_folding_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test MIR Dead Code Elimination
    Let dead_code_elimination_test be test_mir_dead_code_elimination
    Set test_results at key "mir_dead_code_elimination" to dead_code_elimination_test
    Set total_tests to total_tests plus 1
    If dead_code_elimination_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test MIR SSA Construction
    Let ssa_test be test_mir_ssa_construction
    Set test_results at key "mir_ssa_construction" to ssa_test
    Set total_tests to total_tests plus 1
    If ssa_test.passed:
        Set passed_tests to passed_tests plus 1
    
        Note: Test LIR Register Allocation
    Let register_allocation_test be test_lir_register_allocation
    Set test_results at key "lir_register_allocation" to register_allocation_test
    Set total_tests to total_tests plus 1
    If register_allocation_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test HIR Loop Vectorization
    Let vectorization_test be test_hir_loop_vectorization
    Set test_results at key "hir_loop_vectorization" to vectorization_test
    Set total_tests to total_tests plus 1
    If vectorization_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test HIR Advanced Loop Optimizations
    Let advanced_loop_test be test_hir_advanced_loop_optimizations
    Set test_results at key "hir_advanced_loop_optimizations" to advanced_loop_test
    Set total_tests to total_tests plus 1
    If advanced_loop_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test Profile-Guided Optimization
    Let profile_test be test_profile_guided_optimization
    Set test_results at key "profile_guided_optimization" to profile_test
    Set total_tests to total_tests plus 1
    If profile_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test Interprocedural Analysis
    Let interprocedural_test be test_interprocedural_analysis
    Set test_results at key "interprocedural_analysis" to interprocedural_test
    Set total_tests to total_tests plus 1
    If interprocedural_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test Target-Specific Optimizations
    Let target_test be test_target_specific_optimizations
    Set test_results at key "target_specific_optimizations" to target_test
    Set total_tests to total_tests plus 1
    If target_test.passed:
        Set passed_tests to passed_tests plus 1

    Note: Test Optimization Levels
    Let levels_test be test_optimization_levels
    Set test_results at key "optimization_levels" to levels_test
    Set total_tests to total_tests plus 1
    If levels_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Set test_results at key "summary" to dictionary containing:
        "total_tests" as total_tests
        "passed_tests" as passed_tests
        "failed_tests" as (total_tests minus passed_tests)
        "success_rate" as ((passed_tests divided by total_tests) multiplied by 100.0)
        "all_passed" as (passed_tests is equal to total_tests)
    
    Return test_results

Process called "test_optimization_pipeline" returns Dictionary[String, Any]:
    Note: Test the optimization pipeline
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let ir_module be create_ir_module
    
    Let passed be true
    Let errors be list containing
    
    Note: Test optimization level 0 (no optimizations)
    Let level0_result be optimize_ir_module with ir_module as ir_module and context as context and optimization_level as 0
    If level0_result.success is false:
        Set passed to false
        Add "Level 0 optimization failed" to errors
    
    Note: Test optimization level 1 (basic optimizations)
    Let level1_result be optimize_ir_module with ir_module as ir_module and context as context and optimization_level as 1
    If level1_result.success is false:
        Set passed to false
        Add "Level 1 optimization failed" to errors
    
    Note: Test optimization level 2 (standard optimizations)
    Let level2_result be optimize_ir_module with ir_module as ir_module and context as context and optimization_level as 2
    If level2_result.success is false:
        Set passed to false
        Add "Level 2 optimization failed" to errors
    
    Note: Test enabled passes for different levels
    Let level0_passes be get_enabled_passes_for_level with level as 0
    If length of level0_passes is not equal to 0:
        Set passed to false
        Add "Level 0 should have no enabled passes" to errors
    
    Let level1_passes be get_enabled_passes_for_level with level as 1
    If length of level1_passes is not equal to 2:
        Set passed to false
        Add "Level 1 should have 2 enabled passes" to errors
    
    Let level2_passes be get_enabled_passes_for_level with level as 2
    If length of level2_passes is not equal to 3:
        Set passed to false
        Add "Level 2 should have 3 enabled passes" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "Optimization Pipeline"

Process called "test_hir_inlining" returns Dictionary[String, Any]:
    Note: Test HIR function inlining
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let hir_module be create_hir_module with name as "test_inlining"
    
    Let passed be true
    Let errors be list containing
    
    Note: Create a simple function to inline
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let body be list containing
    Let return_stmt be HIRReturnStatement with value as None
    Add return_stmt to body
    
    Let process_decl be HIRProcessDeclaration with name as "simple_func" and parameters as parameters and return_type as int_type and body as body and is_function as true
    Add process_decl to hir_module.declarations
    
    Note: Test inlining optimization
    Let inlining_result be optimize_hir_with_inlining with hir_module as hir_module and context as context
    If inlining_result.success is false:
        Set passed to false
        Add "HIR inlining optimization failed" to errors
    Otherwise:
        Let statistics be inlining_result.statistics
        If statistics.inlined_calls is less than 0:
            Set passed to false
            Add "Invalid inlined calls count" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "HIR Inlining"

Process called "test_mir_constant_folding" returns Dictionary[String, Any]:
    Note: Test MIR constant folding
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let mir_module be create_mir_module with name as "test_constant_folding"
    
    Let passed be true
    Let errors be list containing
    
    Note: Create a simple function with constant operations
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let basic_block be create_mir_basic_block with name as "entry"
    Let return_terminator be create_mir_return_terminator with value as None
    Set basic_block.terminator to return_terminator
    
    Let mir_function be create_mir_function with name as "test_func" and parameters as parameters and return_type as int_type
    Add basic_block to mir_function.basic_blocks
    Add mir_function to mir_module.functions
    
    Note: Test constant folding optimization
    Let folding_result be optimize_mir_with_constant_folding with mir_module as mir_module and context as context
    If folding_result.success is false:
        Set passed to false
        Add "MIR constant folding optimization failed" to errors
    Otherwise:
        Let statistics be folding_result.statistics
        If statistics.folded_instructions is less than 0:
            Set passed to false
            Add "Invalid folded instructions count" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "MIR Constant Folding"

