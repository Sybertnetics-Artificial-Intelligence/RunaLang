Note: Runa Compiler: IR System Test Suite
Note: Comprehensive tests for HIR, MIR, and LIR levels

Import "../../../src/runa/compiler/ir/ir.runa"
Import "../../../src/runa/compiler/ir/hir/hir.runa"
Import "../../../src/runa/compiler/ir/mir/mir.runa"
Import "../../../src/runa/compiler/ir/lir/lir.runa"
Import "../../../src/runa/compiler/ir/types/types.runa"
Import "../../../src/runa/compiler/ir/ir_context.runa"

Note: IR System Test Suite
Process called "test_ir_system" returns Dictionary[String, Any]:
    Note: Run all IR system tests
    Let test_results be dictionary containing
    Let passed_tests be 0
    Let total_tests be 0
    
    Note: Test IR Module Creation
    Let module_test be test_ir_module_creation
    Set test_results at key "module_creation" to module_test
    Set total_tests to total_tests plus 1
    If module_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test Type System
    Let type_test be test_type_system
    Set test_results at key "type_system" to type_test
    Set total_tests to total_tests plus 1
    If type_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test HIR Creation
    Let hir_test be test_hir_creation
    Set test_results at key "hir_creation" to hir_test
    Set total_tests to total_tests plus 1
    If hir_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test MIR Creation
    Let mir_test be test_mir_creation
    Set test_results at key "mir_creation" to mir_test
    Set total_tests to total_tests plus 1
    If mir_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test LIR Creation
    Let lir_test be test_lir_creation
    Set test_results at key "lir_creation" to lir_test
    Set total_tests to total_tests plus 1
    If lir_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test IR Transformations
    Let transform_test be test_ir_transformations
    Set test_results at key "transformations" to transform_test
    Set total_tests to total_tests plus 1
    If transform_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Note: Test IR Validation
    Let validation_test be test_ir_validation
    Set test_results at key "validation" to validation_test
    Set total_tests to total_tests plus 1
    If validation_test.passed:
        Set passed_tests to passed_tests plus 1
    
    Set test_results at key "summary" to dictionary containing:
        "total_tests" as total_tests
        "passed_tests" as passed_tests
        "failed_tests" as (total_tests minus passed_tests)
        "success_rate" as ((passed_tests divided by total_tests) multiplied by 100.0)
        "all_passed" as (passed_tests is equal to total_tests)
    
    Return test_results

Process called "test_ir_module_creation" returns Dictionary[String, Any]:
    Note: Test IR module creation
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let ir_module be create_ir_module
    
    Let passed be true
    Let errors be list containing
    
    Note: Check that IR module has all required components
    If ir_module.hir is None:
        Set passed to false
        Add "HIR module is None" to errors
    
    If ir_module.mir is None:
        Set passed to false
        Add "MIR module is None" to errors
    
    If ir_module.lir is None:
        Set passed to false
        Add "LIR module is None" to errors
    
    If ir_module.types is None:
        Set passed to false
        Add "Type system is None" to errors
    
    If ir_module.context is None:
        Set passed to false
        Add "IR context is None" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "IR Module Creation"

Process called "test_type_system" returns Dictionary[String, Any]:
    Note: Test type system functionality
    Let type_system be create_type_system
    
    Let passed be true
    Let errors be list containing
    
    Note: Check primitive types
    Let int_type be lookup_type with type_system as type_system and name as "Integer"
    If int_type is None:
        Set passed to false
        Add "Integer type not found" to errors
    
    Let float_type be lookup_type with type_system as type_system and name as "Float"
    If float_type is None:
        Set passed to false
        Add "Float type not found" to errors
    
    Let string_type be lookup_type with type_system as type_system and name as "String"
    If string_type is None:
        Set passed to false
        Add "String type not found" to errors
    
    Let bool_type be lookup_type with type_system as type_system and name as "Boolean"
    If bool_type is None:
        Set passed to false
        Add "Boolean type not found" to errors
    
    Note: Test type compatibility
    If is_primitive_compatible with source as "Integer" and target as "Float" is false:
        Set passed to false
        Add "Integer to Float compatibility failed" to errors
    
    If is_primitive_compatible with source as "Character" and target as "String" is false:
        Set passed to false
        Add "Character to String compatibility failed" to errors
    
    Note: Test type size calculation
    Let int_size be get_type_size with type_system as type_system and ir_type as int_type
    If int_size is not equal to 8:
        Set passed to false
        Add "Integer size should be 8, got " plus int_size to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "Type System"

Process called "test_hir_creation" returns Dictionary[String, Any]:
    Note: Test HIR creation and manipulation
    Let hir_module be create_hir_module with name as "test_hir"
    
    Let passed be true
    Let errors be list containing
    
    Note: Check basic HIR module structure
    If hir_module.name is not equal to "test_hir":
        Set passed to false
        Add "HIR module name incorrect" to errors
    
    If length of hir_module.declarations is not equal to 0:
        Set passed to false
        Add "New HIR module should have no declarations" to errors
    
    If length of hir_module.statements is not equal to 0:
        Set passed to false
        Add "New HIR module should have no statements" to errors
    
    Note: Test HIR literal creation
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let literal be create_hir_literal with value as 42 and literal_type as "integer" and inferred_type as int_type and location as SourceLocation with line as 1 and column as 1 and file as "test.runa" and length as 2
    
    If get_hir_node_type with node as literal is not equal to "literal":
        Set passed to false
        Add "HIR literal node type incorrect" to errors
    
    If is_hir_literal with node as literal is false:
        Set passed to false
        Add "HIR literal detection failed" to errors
    
    Note: Test HIR identifier creation
    Let identifier be create_hir_identifier with name as "x" and resolved_symbol as "x" and inferred_type as int_type and location as SourceLocation with line as 1 and column as 1 and file as "test.runa" and length as 1
    
    If get_hir_node_type with node as identifier is not equal to "identifier":
        Set passed to false
        Add "HIR identifier node type incorrect" to errors
    
    If is_hir_identifier with node as identifier is false:
        Set passed to false
        Add "HIR identifier detection failed" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "HIR Creation"

Process called "test_mir_creation" returns Dictionary[String, Any]:
    Note: Test MIR creation and manipulation
    Let mir_module be create_mir_module with name as "test_mir"
    
    Let passed be true
    Let errors be list containing
    
    Note: Check basic MIR module structure
    If mir_module.name is not equal to "test_mir":
        Set passed to false
        Add "MIR module name incorrect" to errors
    
    If length of mir_module.functions is not equal to 0:
        Set passed to false
        Add "New MIR module should have no functions" to errors
    
    Note: Test MIR function creation
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let mir_function be create_mir_function with name as "test_func" and parameters as parameters and return_type as int_type
    
    If mir_function.name is not equal to "test_func":
        Set passed to false
        Add "MIR function name incorrect" to errors
    
    If length of mir_function.basic_blocks is not equal to 1:
        Set passed to false
        Add "New MIR function should have one basic block" to errors
    
    If mir_function.entry_block is not equal to "entry":
        Set passed to false
        Add "MIR function entry block name incorrect" to errors
    
    Note: Test MIR basic block creation
    Let basic_block be create_mir_basic_block with name as "test_block"
    
    If basic_block.name is not equal to "test_block":
        Set passed to false
        Add "MIR basic block name incorrect" to errors
    
    If length of basic_block.instructions is not equal to 0:
        Set passed to false
        Add "New MIR basic block should have no instructions" to errors
    
    Note: Test MIR instruction creation
    Let load_inst be create_mir_load with destination as "dest" and source as "source" and type as int_type
    
    If get_mir_instruction_type with instruction as load_inst is not equal to "load":
        Set passed to false
        Add "MIR load instruction type incorrect" to errors
    
    If is_mir_terminator with instruction as load_inst is true:
        Set passed to false
        Add "MIR load instruction should not be a terminator" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "MIR Creation"

Process called "test_lir_creation" returns Dictionary[String, Any]:
    Note: Test LIR creation and manipulation
    Let lir_module be create_lir_module with name as "test_lir"
    
    Let passed be true
    Let errors be list containing
    
    Note: Check basic LIR module structure
    If lir_module.name is not equal to "test_lir":
        Set passed to false
        Add "LIR module name incorrect" to errors
    
    If length of lir_module.functions is not equal to 0:
        Set passed to false
        Add "New LIR module should have no functions" to errors
    
    Note: Test LIR function creation
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let lir_function be create_lir_function with name as "test_func" and parameters as parameters and return_type as int_type
    
    If lir_function.name is not equal to "test_func":
        Set passed to false
        Add "LIR function name incorrect" to errors
    
    If length of lir_function.basic_blocks is not equal to 1:
        Set passed to false
        Add "New LIR function should have one basic block" to errors
    
    If lir_function.entry_block is not equal to "entry":
        Set passed to false
        Add "LIR function entry block name incorrect" to errors
    
    Note: Test virtual register creation
    Let virtual_reg be create_virtual_register with name as "%0" and type as int_type
    
    If virtual_reg.name is not equal to "%0":
        Set passed to false
        Add "Virtual register name incorrect" to errors
    
    If virtual_reg.type is not equal to int_type:
        Set passed to false
        Add "Virtual register type incorrect" to errors
    
    If virtual_reg.is_spilled is not equal to false:
        Set passed to false
        Add "New virtual register should not be spilled" to errors
    
    Note: Test immediate creation
    Let int_immediate be create_integer_immediate with value as 42 and type as int_type
    
    If int_immediate.value is not equal to 42:
        Set passed to false
        Add "Integer immediate value incorrect" to errors
    
    If int_immediate.type is not equal to int_type:
        Set passed to false
        Add "Integer immediate type incorrect" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "LIR Creation"

Process called "test_ir_transformations" returns Dictionary[String, Any]:
    Note: Test IR transformations between levels
    Let context be create_ir_context with compilation_unit as "test" and source_file as "test.runa"
    Let type_system be create_type_system
    
    Let passed be true
    Let errors be list containing
    
    Note: Test HIR to MIR transformation (simplified)
    Let hir_module be create_hir_module with name as "test_transform"
    
    Note: Add a simple function declaration to HIR
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let body be list containing
    Let return_stmt be HIRReturnStatement with value as None
    Add return_stmt to body
    
    Let process_decl be HIRProcessDeclaration with name as "test_func" and parameters as parameters and return_type as int_type and body as body and is_function as true
    Add process_decl to hir_module.declarations
    
    Note: Transform HIR to MIR
    Let mir_result be build_mir_from_hir with hir_module as hir_module and context as context
    If mir_result.success is false:
        Set passed to false
        Add "HIR to MIR transformation failed" to errors
    Otherwise:
        Let mir_module be mir_result.mir_module
        If length of mir_module.functions is not equal to 1:
            Set passed to false
            Add "MIR module should have one function" to errors
        
        Let mir_function be mir_module.functions at index 0
        If mir_function.name is not equal to "test_func":
            Set passed to false
            Add "MIR function name should match HIR" to errors
    
    Note: Test MIR to LIR transformation (simplified)
    If passed:
        Let lir_result be build_lir_from_mir with mir_module as mir_module and context as context
        If lir_result.success is false:
            Set passed to false
            Add "MIR to LIR transformation failed" to errors
        Otherwise:
            Let lir_module be lir_result.lir_module
            If length of lir_module.functions is not equal to 1:
                Set passed to false
                Add "LIR module should have one function" to errors
            
            Let lir_function be lir_module.functions at index 0
            If lir_function.name is not equal to "test_func":
                Set passed to false
                Add "LIR function name should match MIR" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "IR Transformations"

Process called "test_ir_validation" returns Dictionary[String, Any]:
    Note: Test IR validation functionality
    Let passed be true
    Let errors be list containing
    
    Note: Test MIR validation
    Let mir_module be create_mir_module with name as "test_validation"
    Let int_type be IRPrimitiveType with name as "Integer" and size as 8 and alignment as 8
    Let parameters be list containing
    Let mir_function be create_mir_function with name as "test_func" and parameters as parameters and return_type as int_type
    
    Note: Add a valid basic block
    Let basic_block be create_mir_basic_block with name as "entry"
    Let return_terminator be create_mir_return_terminator with value as None
    Set basic_block.terminator to return_terminator
    Add basic_block to mir_function.basic_blocks
    
    Add mir_function to mir_module.functions
    
    Let validation_result be validate_mir with mir_module as mir_module
    If validation_result.valid is false:
        Set passed to false
        Add "Valid MIR module failed validation" to errors
    
    Note: Test LIR validation
    Let lir_module be create_lir_module with name as "test_validation"
    Let lir_function be create_lir_function with name as "test_func" and parameters as parameters and return_type as int_type
    
    Note: Add a valid basic block
    Let lir_basic_block be create_lir_basic_block with name as "entry"
    Let lir_return_terminator be create_lir_return_terminator with value as None
    Set lir_basic_block.terminator to lir_return_terminator
    Add lir_basic_block to lir_function.basic_blocks
    
    Add lir_function to lir_module.functions
    
    Let lir_validation_result be validate_lir_function with lir_function as lir_function
    If lir_validation_result.valid is false:
        Set passed to false
        Add "Valid LIR function failed validation" to errors
    
    Return dictionary containing:
        "passed" as passed
        "errors" as errors
        "test_name" as "IR Validation"

Note: Test Runner
Process called "run_ir_tests" returns String:
    Note: Run all IR tests and return results
    Let results be test_ir_system
    Let summary be results at key "summary"
    
    Let output be "IR System Test Results:\n"
    Set output to output plus "Total Tests: " plus summary.total_tests plus "\n"
    Set output to output plus "Passed: " plus summary.passed_tests plus "\n"
    Set output to output plus "Failed: " plus summary.failed_tests plus "\n"
    Set output to output plus "Success Rate: " plus summary.success_rate plus "%\n"
    
    If summary.all_passed:
        Set output to output plus "✅ All tests passed!\n"
    Otherwise:
        Set output to output plus "❌ Some tests failed!\n"
        Set output to output plus "\nDetailed Results:\n"
        
        For each test_name in results:
            If test_name is not equal to "summary":
                Let test_result be results at key test_name
                Set output to output plus test_name plus ": "
                If test_result.passed:
                    Set output to output plus "✅ PASSED\n"
                Otherwise:
                    Set output to output plus "❌ FAILED\n"
                    For each error in test_result.errors:
                        Set output to output plus "  - " plus error plus "\n"
    
    Return output 