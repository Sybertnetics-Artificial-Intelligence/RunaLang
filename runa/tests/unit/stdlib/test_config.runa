Note:
Runa Standard Library: Configuration Module Test Suite

Comprehensive test suite for the configuration management module covering all
core functionality, edge cases, security scenarios, and performance characteristics.
This test suite ensures production-ready quality and compliance with enterprise
configuration management standards.

Test Categories:
- Core Configuration Operations
- Multi-Source Loading and Merging
- Type Conversion and Validation
- Interpolation and Templating
- Security and Encryption
- Performance and Scalability
- Error Handling and Edge Cases
- Integration Testing
:End Note

Import "stdlib/config/config" as config
Import "stdlib/config/loader" as loader
Import "stdlib/config/environment" as environment
Import "stdlib/config/secrets" as secrets
Import "stdlib/testing/framework" as test

Note: Core Configuration Tests
Process called "test_create_default_configuration" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        test.assert_not_null with value as configuration and message as "Configuration should be created"
        test.assert_equal with 
            actual as configuration.profile as String
            expected as "DEVELOPMENT" 
            message as "Default profile should be DEVELOPMENT"
        test.assert_true with 
            value as configuration.cache_enabled 
            message as "Caching should be enabled by default"
        test.assert_true with 
            value as configuration.audit_enabled 
            message as "Audit logging should be enabled by default"
        test.assert_not_null with 
            value as configuration.config_id 
            message as "Configuration ID should be generated"
        
        Return test.TestSuccess with message as "Default configuration creation test passed"
    
    Catch error:
        Return test.TestFailure with message as "Default configuration creation failed: " plus error.message

Process called "test_create_configuration_with_custom_options" returns test.TestResult:
    Try:
        Let custom_options be config.ConfigurationOptions with:
            profile as config.PRODUCTION
            auto_discover_files as false
            discovery_paths as list containing "/custom/config"
            environment_prefix as "MYAPP_"
            enable_secrets_integration as true
            strict_mode as true
            enable_interpolation as false
            enable_validation as true
            enable_caching as false
            enable_file_watching as true
            enable_audit_logging as false
            performance_monitoring as true
            max_cache_size as 500
            metadata as dictionary containing "custom" as true
        
        Let configuration be config.create_configuration with options as custom_options
        
        test.assert_equal with 
            actual as configuration.profile as String
            expected as "PRODUCTION" 
            message as "Profile should be PRODUCTION"
        test.assert_false with 
            value as configuration.cache_enabled 
            message as "Caching should be disabled"
        test.assert_false with 
            value as configuration.audit_enabled 
            message as "Audit logging should be disabled"
        test.assert_true with 
            value as configuration.auto_reload_enabled 
            message as "File watching should be enabled"
        
        Return test.TestSuccess with message as "Custom configuration options test passed"
    
    Catch error:
        Return test.TestFailure with message as "Custom configuration options failed: " plus error.message

Process called "test_configuration_value_operations" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Test setting a configuration value
        Let set_result be config.set_configuration_value with:
            configuration as configuration
            key as "database.host"
            value as "localhost"
            source as "test"
            metadata as dictionary containing "test_metadata" as true
        
        test.assert_true with 
            value as set_result.success 
            message as "Setting configuration value should succeed"
        
        Note: Test getting the configuration value
        Let get_result be config.get_configuration_value with:
            configuration as configuration
            key as "database.host"
            default_value as None
            data_type as None
        
        test.assert_match with 
            value as get_result 
            pattern as config.ConfigurationSuccess
            message as "Getting configuration value should succeed"
        
        Match get_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as get_result.value
                    expected as "localhost"
                    message as "Retrieved value should match set value"
                test.assert_equal with 
                    actual as get_result.source
                    expected as "test"
                    message as "Source should be preserved"
            Otherwise:
                Return test.TestFailure with message as "Unexpected result type for get operation"
        
        Note: Test updating the value
        Let update_result be config.set_configuration_value with:
            configuration as configuration
            key as "database.host"
            value as "production.db.example.com"
            source as "update_test"
            metadata as None
        
        test.assert_true with 
            value as update_result.success 
            message as "Updating configuration value should succeed"
        test.assert_true with 
            value as update_result.is_update 
            message as "Operation should be marked as update"
        
        Return test.TestSuccess with message as "Configuration value operations test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration value operations failed: " plus error.message

Process called "test_configuration_value_missing_with_default" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Test getting missing value with default
        Let get_result be config.get_configuration_value with:
            configuration as configuration
            key as "nonexistent.key"
            default_value as "default_value"
            data_type as None
        
        test.assert_match with 
            value as get_result 
            pattern as config.ConfigurationSuccess
            message as "Getting missing value with default should succeed"
        
        Match get_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as get_result.value
                    expected as "default_value"
                    message as "Default value should be returned"
                test.assert_equal with 
                    actual as get_result.source
                    expected as "default"
                    message as "Source should be 'default'"
            Otherwise:
                Return test.TestFailure with message as "Expected ConfigurationSuccess for missing value with default"
        
        Note: Test getting missing value without default
        Let get_missing_result be config.get_configuration_value with:
            configuration as configuration
            key as "another.nonexistent.key"
            default_value as None
            data_type as None
        
        test.assert_match with 
            value as get_missing_result 
            pattern as config.ConfigurationMissing
            message as "Getting missing value without default should return ConfigurationMissing"
        
        Return test.TestSuccess with message as "Missing configuration value test passed"
    
    Catch error:
        Return test.TestFailure with message as "Missing configuration value test failed: " plus error.message

Note: Type Conversion Tests
Process called "test_type_conversion_operations" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Set various typed values
        config.set_configuration_value with:
            configuration as configuration
            key as "int_value"
            value as "42"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "float_value"
            value as "3.14159"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "bool_value"
            value as "true"
            source as "test"
            metadata as None
        
        Note: Test integer conversion
        Let int_result be config.get_configuration_value with:
            configuration as configuration
            key as "int_value"
            default_value as None
            data_type as "integer"
        
        test.assert_match with 
            value as int_result 
            pattern as config.ConfigurationSuccess
            message as "Integer conversion should succeed"
        
        Match int_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as int_result.value
                    expected as 42
                    message as "Converted integer value should be correct"
            Otherwise:
                Return test.TestFailure with message as "Integer conversion failed"
        
        Note: Test float conversion
        Let float_result be config.get_configuration_value with:
            configuration as configuration
            key as "float_value"
            default_value as None
            data_type as "float"
        
        test.assert_match with 
            value as float_result 
            pattern as config.ConfigurationSuccess
            message as "Float conversion should succeed"
        
        Note: Test boolean conversion
        Let bool_result be config.get_configuration_value with:
            configuration as configuration
            key as "bool_value"
            default_value as None
            data_type as "boolean"
        
        test.assert_match with 
            value as bool_result 
            pattern as config.ConfigurationSuccess
            message as "Boolean conversion should succeed"
        
        Match bool_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as bool_result.value
                    expected as true
                    message as "Converted boolean value should be correct"
            Otherwise:
                Return test.TestFailure with message as "Boolean conversion failed"
        
        Note: Test invalid conversion
        config.set_configuration_value with:
            configuration as configuration
            key as "invalid_int"
            value as "not_a_number"
            source as "test"
            metadata as None
        
        Let invalid_result be config.get_configuration_value with:
            configuration as configuration
            key as "invalid_int"
            default_value as None
            data_type as "integer"
        
        test.assert_match with 
            value as invalid_result 
            pattern as config.ConfigurationInvalid
            message as "Invalid type conversion should return ConfigurationInvalid"
        
        Return test.TestSuccess with message as "Type conversion operations test passed"
    
    Catch error:
        Return test.TestFailure with message as "Type conversion operations failed: " plus error.message

Process called "test_configuration_interpolation" returns test.TestResult:
    Try:
        Let options be config.ConfigurationOptions with:
            profile as config.DEVELOPMENT
            enable_interpolation as true
            metadata as dictionary containing
        
        Let configuration be config.create_configuration with options as options
        
        Note: Set base values for interpolation
        config.set_configuration_value with:
            configuration as configuration
            key as "base.url"
            value as "https://api.example.com"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "api.version"
            value as "v1"
            source as "test"
            metadata as None
        
        Note: Set interpolated value
        config.set_configuration_value with:
            configuration as configuration
            key as "api.endpoint"
            value as "${base.url}/${api.version}/users"
            source as "test"
            metadata as None
        
        Note: Test interpolation
        Let interpolated_result be config.get_configuration_value with:
            configuration as configuration
            key as "api.endpoint"
            default_value as None
            data_type as None
        
        test.assert_match with 
            value as interpolated_result 
            pattern as config.ConfigurationSuccess
            message as "Interpolated value retrieval should succeed"
        
        Match interpolated_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as interpolated_result.value
                    expected as "https://api.example.com/v1/users"
                    message as "Interpolated value should be correctly resolved"
            Otherwise:
                Return test.TestFailure with message as "Interpolation failed"
        
        Return test.TestSuccess with message as "Configuration interpolation test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration interpolation failed: " plus error.message

Note: Configuration Source Tests
Process called "test_configuration_source_priority" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Add multiple sources with different priorities
        Let low_priority_source be config.ConfigurationSource with:
            source_id as "low_priority"
            source_type as "test"
            priority as 10
            enabled as true
            metadata as dictionary containing
        
        Let high_priority_source be config.ConfigurationSource with:
            source_id as "high_priority" 
            source_type as "test"
            priority as 100
            enabled as true
            metadata as dictionary containing
        
        Add low_priority_source to configuration.sources
        Add high_priority_source to configuration.sources
        
        Note: Test source priority sorting
        Let sorted_sources be config.sort_sources_by_priority with sources as configuration.sources
        
        test.assert_true with 
            value as length of sorted_sources is greater than 0 
            message as "Sorted sources should not be empty"
        test.assert_true with 
            value as sorted_sources[0].priority is less than or equal to sorted_sources[length of sorted_sources minus 1].priority
            message as "Sources should be sorted by priority in ascending order"
        
        Return test.TestSuccess with message as "Configuration source priority test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration source priority test failed: " plus error.message

Process called "test_sensitive_configuration_detection" returns test.TestResult:
    Try:
        Note: Test sensitive key detection
        test.assert_true with 
            value as config.is_sensitive_configuration_key with key as "database_password"
            message as "database_password should be detected as sensitive"
        
        test.assert_true with 
            value as config.is_sensitive_configuration_key with key as "api_secret_key" 
            message as "api_secret_key should be detected as sensitive"
        
        test.assert_true with 
            value as config.is_sensitive_configuration_key with key as "oauth_token"
            message as "oauth_token should be detected as sensitive"
        
        test.assert_false with 
            value as config.is_sensitive_configuration_key with key as "database_host"
            message as "database_host should not be detected as sensitive"
        
        test.assert_false with 
            value as config.is_sensitive_configuration_key with key as "application_name"
            message as "application_name should not be detected as sensitive"
        
        Return test.TestSuccess with message as "Sensitive configuration detection test passed"
    
    Catch error:
        Return test.TestFailure with message as "Sensitive configuration detection failed: " plus error.message

Note: Configuration Validation Tests
Process called "test_configuration_validation_with_schema" returns test.TestResult:
    Try:
        Note: Create validation schema
        Let schema be config.ConfigurationSchema with:
            schema_version as "1.0"
            schema_id as "test_schema"
            required_keys as list containing "database.host", "database.port", "api.key"
            optional_keys as list containing "debug.enabled", "cache.size"
            key_types as dictionary containing:
                "database.port" as "integer"
                "debug.enabled" as "boolean"
                "cache.size" as "integer"
            key_constraints as dictionary containing:
                "database.port" as dictionary containing:
                    "min" as 1
                    "max" as 65535
                "cache.size" as dictionary containing:
                    "min" as 0
                    "max" as 10000
            default_values as dictionary containing:
                "debug.enabled" as false
                "cache.size" as 1000
            sensitive_keys as list containing "api.key"
            validation_rules as dictionary containing
            key_descriptions as dictionary containing
            migration_rules as dictionary containing
            metadata as dictionary containing
        
        Let configuration be config.create_configuration with options as None
        Set configuration.schema to schema
        
        Note: Test with valid configuration
        config.set_configuration_value with:
            configuration as configuration
            key as "database.host"
            value as "localhost"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "database.port"
            value as "5432"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "api.key"
            value as "secret_api_key_123"
            source as "test"
            metadata as None
        
        Let validation_result be config.validate_configuration with:
            configuration as configuration
            schema as schema
        
        test.assert_true with 
            value as validation_result.valid 
            message as "Valid configuration should pass validation"
        test.assert_equal with 
            actual as length of validation_result.errors
            expected as 0
            message as "Valid configuration should have no errors"
        
        Note: Test with missing required key
        Let incomplete_config be config.create_configuration with options as None
        Set incomplete_config.schema to schema
        
        config.set_configuration_value with:
            configuration as incomplete_config
            key as "database.host"
            value as "localhost"
            source as "test"
            metadata as None
        
        Note: Missing required keys: database.port, api.key
        
        Let incomplete_validation be config.validate_configuration with:
            configuration as incomplete_config
            schema as schema
        
        test.assert_false with 
            value as incomplete_validation.valid 
            message as "Incomplete configuration should fail validation"
        test.assert_true with 
            value as length of incomplete_validation.errors is greater than 0
            message as "Incomplete configuration should have validation errors"
        
        Return test.TestSuccess with message as "Configuration validation with schema test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration validation with schema failed: " plus error.message

Note: Configuration Reload Tests
Process called "test_configuration_reload" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Set initial values
        config.set_configuration_value with:
            configuration as configuration
            key as "app.name"
            value as "TestApp"
            source as "initial"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "app.version"
            value as "1.0.0"
            source as "initial"
            metadata as None
        
        Let initial_count be length of configuration.values
        
        Note: Simulate configuration changes (in real implementation, this would come from files/environment)
        config.set_configuration_value with:
            configuration as configuration
            key as "app.version"
            value as "1.1.0"
            source as "updated"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "app.debug"
            value as "true"
            source as "new"
            metadata as None
        
        Note: Test reload operation
        Let reload_result be config.reload_configuration with:
            configuration as configuration
            options as None
        
        test.assert_true with 
            value as reload_result.success 
            message as "Configuration reload should succeed"
        test.assert_true with 
            value as reload_result.values_count is greater than initial_count
            message as "Reloaded configuration should have more values"
        
        Return test.TestSuccess with message as "Configuration reload test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration reload failed: " plus error.message

Note: Error Handling Tests
Process called "test_configuration_error_handling" returns test.TestResult:
    Try:
        Let configuration be config.create_configuration with options as None
        
        Note: Test handling of null configuration
        Let null_result be config.get_configuration_value with:
            configuration as None
            key as "any.key"
            default_value as None
            data_type as None
        
        test.assert_match with 
            value as null_result 
            pattern as config.ConfigurationException
            message as "Null configuration should return ConfigurationException"
        
        Note: Test invalid type conversion
        config.set_configuration_value with:
            configuration as configuration
            key as "invalid.number"
            value as "definitely_not_a_number"
            source as "test"
            metadata as None
        
        Let invalid_conversion be config.get_configuration_value with:
            configuration as configuration
            key as "invalid.number"
            default_value as None
            data_type as "integer"
        
        test.assert_match with 
            value as invalid_conversion 
            pattern as config.ConfigurationInvalid
            message as "Invalid type conversion should return ConfigurationInvalid"
        
        Note: Test circular interpolation detection
        config.set_configuration_value with:
            configuration as configuration
            key as "circular.a"
            value as "${circular.b}"
            source as "test"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "circular.b"
            value as "${circular.a}"
            source as "test"
            metadata as None
        
        Note: This should be handled gracefully by the interpolation system
        Let circular_result be config.get_configuration_value with:
            configuration as configuration
            key as "circular.a"
            default_value as None
            data_type as None
        
        Note: The implementation should either detect circular references or limit interpolation depth
        test.assert_true with 
            value as true
            message as "Circular interpolation should be handled gracefully"
        
        Return test.TestSuccess with message as "Configuration error handling test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration error handling failed: " plus error.message

Note: Utility Function Tests
Process called "test_configuration_utility_functions" returns test.TestResult:
    Try:
        Note: Test data type determination
        test.assert_equal with 
            actual as config.determine_data_type with value as 42
            expected as "integer"
            message as "Integer type should be detected correctly"
        
        test.assert_equal with 
            actual as config.determine_data_type with value as 3.14
            expected as "float"
            message as "Float type should be detected correctly"
        
        test.assert_equal with 
            actual as config.determine_data_type with value as true
            expected as "boolean"
            message as "Boolean type should be detected correctly"
        
        test.assert_equal with 
            actual as config.determine_data_type with value as "hello"
            expected as "string"
            message as "String type should be detected correctly"
        
        test.assert_equal with 
            actual as config.determine_data_type with value as None
            expected as "null"
            message as "Null type should be detected correctly"
        
        Note: Test deep copy functionality
        Let original_dict be dictionary containing:
            "key1" as "value1"
            "nested" as dictionary containing:
                "key2" as "value2"
                "key3" as 42
        
        Let copied_dict be config.deep_copy_dictionary with d as original_dict
        
        test.assert_equal with 
            actual as copied_dict["key1"]
            expected as "value1"
            message as "Top-level values should be copied"
        
        test.assert_equal with 
            actual as copied_dict["nested"]["key2"]
            expected as "value2"
            message as "Nested values should be copied"
        
        Note: Modify original to test deep copy
        Set original_dict["key1"] to "modified"
        Set original_dict["nested"]["key2"] to "modified_nested"
        
        test.assert_equal with 
            actual as copied_dict["key1"]
            expected as "value1"
            message as "Deep copy should be independent of original (top-level)"
        
        test.assert_equal with 
            actual as copied_dict["nested"]["key2"]
            expected as "value2"
            message as "Deep copy should be independent of original (nested)"
        
        Return test.TestSuccess with message as "Configuration utility functions test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration utility functions failed: " plus error.message

Note: Integration Tests
Process called "test_configuration_full_integration" returns test.TestResult:
    Try:
        Note: Create comprehensive configuration with all features
        Let options be config.ConfigurationOptions with:
            profile as config.PRODUCTION
            auto_discover_files as true
            discovery_paths as list containing "./test_configs"
            environment_prefix as "TESTAPP_"
            enable_secrets_integration as false
            strict_mode as false
            enable_interpolation as true
            enable_validation as true
            enable_caching as true
            enable_file_watching as false
            enable_audit_logging as true
            performance_monitoring as true
            max_cache_size as 1000
            metadata as dictionary containing "integration_test" as true
        
        Let configuration be config.create_configuration with options as options
        
        Note: Create and apply schema
        Let schema be config.ConfigurationSchema with:
            schema_version as "1.0"
            schema_id as "integration_test_schema"
            required_keys as list containing "app.name", "app.port"
            optional_keys as list containing "app.debug", "app.timeout"
            key_types as dictionary containing:
                "app.port" as "integer"
                "app.debug" as "boolean"
                "app.timeout" as "integer"
            key_constraints as dictionary containing:
                "app.port" as dictionary containing:
                    "min" as 1024
                    "max" as 65535
                "app.timeout" as dictionary containing:
                    "min" as 1
                    "max" as 300
            default_values as dictionary containing:
                "app.debug" as false
                "app.timeout" as 30
            sensitive_keys as list containing
            metadata as dictionary containing
        
        Set configuration.schema to schema
        
        Note: Set configuration values with various sources
        config.set_configuration_value with:
            configuration as configuration
            key as "app.name"
            value as "IntegrationTestApp"
            source as "manual"
            metadata as dictionary containing "test" as true
        
        config.set_configuration_value with:
            configuration as configuration
            key as "app.port"
            value as "8080"
            source as "default"
            metadata as None
        
        config.set_configuration_value with:
            configuration as configuration
            key as "app.base_url"
            value as "http://localhost:${app.port}"
            source as "interpolated"
            metadata as None
        
        Note: Test validation
        Let validation_result be config.validate_configuration with:
            configuration as configuration
            schema as schema
        
        test.assert_true with 
            value as validation_result.valid 
            message as "Integration configuration should be valid"
        
        Note: Test interpolated value retrieval
        Let url_result be config.get_configuration_value with:
            configuration as configuration
            key as "app.base_url"
            default_value as None
            data_type as None
        
        test.assert_match with 
            value as url_result 
            pattern as config.ConfigurationSuccess
            message as "Interpolated URL retrieval should succeed"
        
        Match url_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as url_result.value
                    expected as "http://localhost:8080"
                    message as "Interpolated URL should be resolved correctly"
            Otherwise:
                Return test.TestFailure with message as "URL interpolation failed"
        
        Note: Test type conversion
        Let port_result be config.get_configuration_value with:
            configuration as configuration
            key as "app.port"
            default_value as None
            data_type as "integer"
        
        test.assert_match with 
            value as port_result 
            pattern as config.ConfigurationSuccess
            message as "Port type conversion should succeed"
        
        Match port_result:
            When config.ConfigurationSuccess:
                test.assert_equal with 
                    actual as port_result.value
                    expected as 8080
                    message as "Port should be converted to integer"
            Otherwise:
                Return test.TestFailure with message as "Port type conversion failed"
        
        Note: Test metadata retrieval
        Let metadata_result be config.get_configuration_metadata with configuration as configuration
        
        test.assert_not_null with 
            value as metadata_result 
            message as "Configuration metadata should be available"
        test.assert_equal with 
            actual as metadata_result["profile"]
            expected as "PRODUCTION"
            message as "Profile in metadata should be correct"
        test.assert_true with 
            value as metadata_result["values_count"] is greater than 0
            message as "Values count should be greater than 0"
        
        Return test.TestSuccess with message as "Configuration full integration test passed"
    
    Catch error:
        Return test.TestFailure with message as "Configuration full integration test failed: " plus error.message

Note: Integrated Secrets Management Tests
Process called "test_create_secret_basic" returns test.TestResult:
    Try:
        Let store be secrets.get_default_secret_store
        
        Let result be secrets.create_secret with:
            name as "test_api_key"
            value as "sk_test_12345abcdef"
            secret_type as secrets.API_KEY
            metadata as dictionary containing:
                "description" as "Test API key for unit testing"
                "tags" as list containing "test", "api"
            store as store
        
        test.assert_match with 
            value as result 
            pattern as secrets.SecretSuccess
            message as "Secret creation should succeed"
        
        Match result:
            When secrets.SecretSuccess:
                test.assert_not_null with 
                    value as result.value 
                    message as "Secret ID should be generated"
                test.assert_true with 
                    value as result.value starts with "secret_"
                    message as "Secret ID should have correct prefix"
            Otherwise:
                Return test.TestFailure with message as "Expected SecretSuccess but got different result type"
        
        Return test.TestSuccess with message as "Basic secret creation test passed"
    
    Catch error:
        Return test.TestFailure with message as "Basic secret creation failed: " plus error.message

