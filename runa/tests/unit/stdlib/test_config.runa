Process called "test_secrets_configuration_integration" returns test.TestResult:
    Try:
        Let store be secrets.get_default_secret_store
        
        Let create_result be secrets.create_secret with:
            name as "database_password"
            value as "super_secure_db_password_789"
            secret_type as secrets.DATABASE_CREDENTIAL
            metadata as dictionary containing:
                "description" as "Database password for configuration integration test"
            store as store
        
        test.assert_match with 
            value as create_result 
            pattern as secrets.SecretSuccess
            message as "Secret creation for integration should succeed"
        
        Match create_result:
            When secrets.SecretSuccess:
                Let secret_id be create_result.value
                
                Let config_options be config.ConfigurationOptions with:
                    profile as config.DEVELOPMENT
                    enable_secrets_integration as true
                    secrets_store as store
                    metadata as dictionary containing
                
                Let configuration be config.create_configuration with options as config_options
                
                config.set_configuration_value with:
                    configuration as configuration
                    key as "database.password_secret_id"
                    value as secret_id
                    source as "test"
                    metadata as dictionary containing "secret_reference" as true
                
                Let config_result be config.get_configuration_value with:
                    configuration as configuration
                    key as "database.password_secret_id"
                    default_value as None
                    data_type as None
                
                test.assert_match with 
                    value as config_result 
                    pattern as config.ConfigurationSuccess
                    message as "Configuration should store secret reference"
                
                Match config_result:
                    When config.ConfigurationSuccess:
                        test.assert_equal with 
                            actual as config_result.value
                            expected as secret_id
                            message as "Configuration should contain the secret ID"
                        
                        Let secret_value_result be secrets.get_secret with:
                            secret_id as config_result.value
                            store as store
                        
                        test.assert_match with 
                            value as secret_value_result 
                            pattern as secrets.SecretSuccess
                            message as "Secret retrieval via configuration should succeed"
                        
                        Match secret_value_result:
                            When secrets.SecretSuccess:
                                test.assert_equal with 
                                    actual as secret_value_result.value
                                    expected as "super_secure_db_password_789"
                                    message as "Secret value should be retrievable via configuration integration"
                            Otherwise:
                                Return test.TestFailure with message as "Secret retrieval via configuration failed"
                    Otherwise:
                        Return test.TestFailure with message as "Configuration failed to store secret reference"
            Otherwise:
                Return test.TestFailure with message as "Secret creation for integration failed"
        
        Return test.TestSuccess with message as "Secrets-configuration integration test passed"
    
    Catch error:
        Return test.TestFailure with message as "Secrets-configuration integration failed: " plus error.message

Process called "test_secret_access_control" returns test.TestResult:
    Try:
        Let store be secrets.get_default_secret_store
        
        Let create_result be secrets.create_secret with:
            name as "access_control_secret"
            value as "protected_secret_value"
            secret_type as secrets.PRIVATE_KEY
            metadata as dictionary containing
            store as store
        
        test.assert_match with 
            value as create_result 
            pattern as secrets.SecretSuccess
            message as "Secret creation should succeed"
        
        Match create_result:
            When secrets.SecretSuccess:
                Let secret_id be create_result.value
                
                Let grant_result be secrets.grant_secret_access with:
                    secret_id as secret_id
                    principal as "test_user_123"
                    permissions as list containing "read", "metadata"
                    conditions as dictionary containing:
                        "ip_range" as "192.168.1.0/24"
                    expires_at as None
                    store as store
                
                test.assert_match with 
                    value as grant_result 
                    pattern as secrets.SecretSuccess
                    message as "Access grant should succeed"
                
                Match grant_result:
                    When secrets.SecretSuccess:
                        Let access_id be grant_result.value
                        test.assert_not_null with 
                            value as access_id
                            message as "Access ID should be generated"
                        
                        Let revoke_result be secrets.revoke_secret_access with:
                            access_id as access_id
                            store as store
                        
                        test.assert_match with 
                            value as revoke_result 
                            pattern as secrets.SecretSuccess
                            message as "Access revocation should succeed"
                    Otherwise:
                        Return test.TestFailure with message as "Access grant failed"
            Otherwise:
                Return test.TestFailure with message as "Secret creation failed"
        
        Return test.TestSuccess with message as "Secret access control test passed"
    
    Catch error:
        Return test.TestFailure with message as "Secret access control failed: " plus error.message

