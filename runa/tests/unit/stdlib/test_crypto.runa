Process called "test_rsa_key_generation" returns CryptoTestResult:
    Note: Test RSA key pair generation and validation
    Try:
        Let start_time be time.now
        
        Note: Generate 2048-bit RSA key pair
        Let keypair_result be asymmetric.generate_rsa_keypair with key_size as 2048
        
        Match keypair_result:
            When asymmetric.AsymmetricFailure:
                Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as keypair_result.message
            When asymmetric.AsymmetricSuccess with value as keypair:
                Note: Validate key pair structure
                If keypair.public_key is None or keypair.private_key is None:
                    Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as "Generated keypair missing keys"
                
                Note: Validate key sizes
                If keypair.key_size is not equal to 2048:
                    Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as "Incorrect key size"
                
                Note: Test key validation
                Let validation_result be asymmetric.validate_rsa_keypair with keypair as keypair
                Match validation_result:
                    When asymmetric.AsymmetricFailure:
                        Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as "Key validation failed"
                    When asymmetric.AsymmetricSuccess:
                        Note: Test key generation for different sizes
                        Let small_key_result be asymmetric.generate_rsa_keypair with key_size as 1024
                        Match small_key_result:
                            When asymmetric.AsymmetricSuccess:
                                Note: All tests passed
                            When asymmetric.AsymmetricFailure:
                                Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as "Failed to generate 1024-bit key"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_rsa_key_generation" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_rsa_key_generation" and passed as false and error as error as String

