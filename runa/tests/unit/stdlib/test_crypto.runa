Process called "test_sha256_basic" returns CryptoTestResult:
    Note: Test basic SHA-256 functionality with known test vectors
    Try:
        Let start_time be time.now
        
        Note: Test empty string
        Let empty_data be empty list
        Let empty_result be hash.compute_hash with data as empty_data and algorithm as "SHA256"
        
        Match empty_result:
            When hash.HashSuccess with value as empty_hash:
                Note: SHA-256 of empty string should be e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855
                Let expected_empty be list containing 227, 176, 196, 66, 152, 252, 28, 20, 154, 251, 244, 200, 153, 111, 185, 36, 39, 174, 65, 228, 100, 155, 147, 76, 164, 149, 153, 27, 120, 82, 184, 85
                
                If not bytes_equal with a as empty_hash and b as expected_empty:
                    Return create_test_result with name as "test_sha256_basic" and passed as false and error as "Empty string hash mismatch"
            When hash.HashFailure:
                Return create_test_result with name as "test_sha256_basic" and passed as false and error as "Failed to hash empty string"
        
        Note: Test "abc" string
        Let abc_data be string_to_bytes with text as "abc"
        Let abc_result be hash.compute_hash with data as abc_data and algorithm as "SHA256"
        
        Match abc_result:
            When hash.HashSuccess with value as abc_hash:
                Note: SHA-256 of "abc" should be ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
                Let expected_abc be list containing 186, 120, 22, 191, 143, 1, 207, 234, 65, 65, 64, 222, 93, 174, 34, 35, 176, 3, 97, 163, 150, 23, 122, 156, 180, 16, 255, 97, 242, 0, 21, 173
                
                If not bytes_equal with a as abc_hash and b as expected_abc:
                    Return create_test_result with name as "test_sha256_basic" and passed as false and error as "ABC string hash mismatch"
            When hash.HashFailure:
                Return create_test_result with name as "test_sha256_basic" and passed as false and error as "Failed to hash ABC string"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_sha256_basic" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_sha256_basic" and passed as false and error as error as String

Process called "test_hmac_sha256" returns CryptoTestResult:
    Note: Test HMAC-SHA256 with known test vectors
    Try:
        Let start_time be time.now
        
        Note: Test vector from RFC 4231
        Let key be string_to_bytes with text as "key"
        Let message be string_to_bytes with text as "The quick brown fox jumps over the lazy dog"
        
        Let hmac_result be hash.hmac with key as key and message as message and algorithm as "SHA256"
        
        Match hmac_result:
            When hash.HashSuccess with value as hmac_hash:
                Note: Expected HMAC should be f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8
                Let expected_hmac be list containing 247, 188, 131, 244, 48, 83, 132, 36, 177, 50, 152, 230, 170, 111, 177, 67, 239, 77, 89, 161, 73, 70, 23, 89, 151, 71, 157, 188, 45, 26, 60, 216
                
                If not bytes_equal with a as hmac_hash and b as expected_hmac:
                    Return create_test_result with name as "test_hmac_sha256" and passed as false and error as "HMAC hash mismatch"
            When hash.HashFailure:
                Return create_test_result with name as "test_hmac_sha256" and passed as false and error as hmac_result.message
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_hmac_sha256" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_hmac_sha256" and passed as false and error as error as String

