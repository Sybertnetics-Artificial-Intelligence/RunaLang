Process called "test_random_generation" returns CryptoTestResult:
    Note: Test CSPRNG functionality
    Try:
        Let start_time be time.now
        
        Note: Test secure byte generation
        Let random_result be random.generate_secure_bytes with count as 32
        Match random_result:
            When random.RandomFailure:
                Return create_test_result with name as "test_random_generation" and passed as false and error as random_result.message
            When random.RandomSuccess with value as random_bytes:
                If (length of random_bytes) is not equal to 32:
                    Return create_test_result with name as "test_random_generation" and passed as false and error as "Incorrect random bytes length"
                
                Note: Test that multiple calls produce different results
                Let random_result2 be random.generate_secure_bytes with count as 32
                Match random_result2:
                    When random.RandomSuccess with value as random_bytes2:
                        If bytes_equal with a as random_bytes and b as random_bytes2:
                            Return create_test_result with name as "test_random_generation" and passed as false and error as "Random bytes are identical"
                    When random.RandomFailure:
                        Return create_test_result with name as "test_random_generation" and passed as false and error as "Second random generation failed"
        
        Note: Test random integer generation
        Let int_result be random.generate_random_integer with min as 1 and max as 1000
        Match int_result:
            When random.RandomSuccess with value as random_int:
                If random_int is less than 1 or random_int is greater than 1000:
                    Return create_test_result with name as "test_random_generation" and passed as false and error as "Random integer out of range"
            When random.RandomFailure:
                Return create_test_result with name as "test_random_generation" and passed as false and error as "Random integer generation failed"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_random_generation" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_random_generation" and passed as false and error as error as String

Process called "test_bignum_basic_arithmetic" returns CryptoTestResult:
    Note: Test big integer arithmetic operations
    Try:
        Let start_time be time.now
        
        Note: Create test big integers
        Let a_result be bignum.from_integer with value as 12345678901234567890
        Let b_result be bignum.from_integer with value as 98765432109876543210
        
        Match a_result:
            When bignum.BignumSuccess with value as a:
                Match b_result:
                    When bignum.BignumSuccess with value as b:
                        Note: Test addition
                        Let add_result be bignum.add with a as a and b as b
                        Match add_result:
                            When bignum.BignumSuccess with value as sum:
                                Note: Test subtraction
                                Let sub_result be bignum.subtract with a as b and b as a
                                Match sub_result:
                                    When bignum.BignumSuccess:
                                        Note: Test multiplication
                                        Let mul_result be bignum.multiply with a as a and b as b
                                        Match mul_result:
                                            When bignum.BignumSuccess:
                                                Note: Basic arithmetic tests passed
                                            When bignum.BignumFailure:
                                                Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as "Multiplication failed"
                                    When bignum.BignumFailure:
                                        Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as "Subtraction failed"
                            When bignum.BignumFailure:
                                Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as "Addition failed"
                    When bignum.BignumFailure:
                        Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as "Failed to create bignum b"
            When bignum.BignumFailure:
                Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as "Failed to create bignum a"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_bignum_basic_arithmetic" and passed as false and error as error as String

Process called "test_curve_point_arithmetic" returns CryptoTestResult:
    Note: Test elliptic curve point operations
    Try:
        Let start_time be time.now
        
        Note: Test with P-256 curve
        Let curve_result be curve.get_standard_curve with name as "P-256"
        Match curve_result:
            When curve.CurveSuccess with value as p256_curve:
                Note: Get generator point
                Let generator_result be curve.get_generator_point with curve as p256_curve
                Match generator_result:
                    When curve.CurveSuccess with value as generator:
                        Note: Test point doubling
                        Let double_result be curve.point_double with point as generator and curve as p256_curve
                        Match double_result:
                            When curve.CurveSuccess with value as doubled_point:
                                Note: Test point addition
                                Let add_result be curve.point_add with point1 as generator and point2 as doubled_point and curve as p256_curve
                                Match add_result:
                                    When curve.CurveSuccess:
                                        Note: Point arithmetic tests passed
                                    When curve.CurveFailure:
                                        Return create_test_result with name as "test_curve_point_arithmetic" and passed as false and error as "Point addition failed"
                            When curve.CurveFailure:
                                Return create_test_result with name as "test_curve_point_arithmetic" and passed as false and error as "Point doubling failed"
                    When curve.CurveFailure:
                        Return create_test_result with name as "test_curve_point_arithmetic" and passed as false and error as "Failed to get generator point"
            When curve.CurveFailure:
                Return create_test_result with name as "test_curve_point_arithmetic" and passed as false and error as "Failed to get P-256 curve"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_curve_point_arithmetic" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_curve_point_arithmetic" and passed as false and error as error as String

Process called "test_field_arithmetic" returns CryptoTestResult:
    Note: Test finite field arithmetic operations
    Try:
        Let start_time be time.now
        
        Note: Test with P-256 prime field
        Let field_result be field.create_prime_field with prime as "115792089210356248762697446949407573530086143415290314195533631308867097853951"
        Match field_result:
            When field.FieldSuccess with value as p256_field:
                Note: Create field elements
                Let a_result be field.create_element with field as p256_field and value as "12345678901234567890"
                Let b_result be field.create_element with field as p256_field and value as "98765432109876543210"
                
                Match a_result:
                    When field.FieldSuccess with value as a:
                        Match b_result:
                            When field.FieldSuccess with value as b:
                                Note: Test field addition
                                Let add_result be field.add with a as a and b as b and field as p256_field
                                Match add_result:
                                    When field.FieldSuccess:
                                        Note: Test field multiplication
                                        Let mul_result be field.multiply with a as a and b as b and field as p256_field
                                        Match mul_result:
                                            When field.FieldSuccess:
                                                Note: Field arithmetic tests passed
                                            When field.FieldFailure:
                                                Return create_test_result with name as "test_field_arithmetic" and passed as false and error as "Field multiplication failed"
                                    When field.FieldFailure:
                                        Return create_test_result with name as "test_field_arithmetic" and passed as false and error as "Field addition failed"
                            When field.FieldFailure:
                                Return create_test_result with name as "test_field_arithmetic" and passed as false and error as "Failed to create field element b"
                    When field.FieldFailure:
                        Return create_test_result with name as "test_field_arithmetic" and passed as false and error as "Failed to create field element a"
            When field.FieldFailure:
                Return create_test_result with name as "test_field_arithmetic" and passed as false and error as "Failed to create prime field"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_field_arithmetic" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_field_arithmetic" and passed as false and error as error as String

