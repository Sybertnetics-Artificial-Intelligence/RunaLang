Process called "test_jwt_creation_hs256" returns CryptoTestResult:
    Note: Test JWT creation with HMAC-SHA256
    Try:
        Let start_time be time.now
        
        Note: Create signing key
        Let secret_key be "super_secret_key_for_testing_2024"
        Let signing_key be dictionary containing: "secret" as secret_key
        
        Note: Create payload
        Let payload be jwt.JwtPayload with:
            iss as Some with value as "test_issuer"
            sub as Some with value as "user123"
            aud as Some with value as list containing "test_audience"
            exp as None  Note: Will be set automatically
            nbf as None
            iat as None  Note: Will be set automatically
            jti as Some with value as "unique_token_id"
            custom_claims as dictionary containing: "role" as "admin", "permissions" as list containing "read", "write"
        
        Let jwt_result be jwt.create_jwt with payload as payload and signing_key as signing_key and algorithm as "HS256" and header_claims as None
        
        Match jwt_result:
            When jwt.JwtFailure:
                Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as jwt_result.message
            When jwt.JwtSuccess with value as token_string:
                Note: Verify token structure (should have 3 parts)
                Let parts be split_string with text as token_string and delimiter as "."
                If (length of parts) is not equal to 3:
                    Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as "Invalid JWT structure"
                
                Note: Test token parsing
                Let parse_result be jwt.parse_jwt with token as token_string
                Match parse_result:
                    When jwt.JwtFailure:
                        Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as parse_result.message
                    When jwt.JwtSuccess with value as parsed_jwt:
                        Note: Verify header
                        If parsed_jwt.header.alg is not equal to "HS256":
                            Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as "Algorithm mismatch"
                        
                        If parsed_jwt.header.typ is not equal to "JWT":
                            Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as "Type mismatch"
                        
                        Note: Verify payload claims
                        If parsed_jwt.payload.iss is not equal to "test_issuer":
                            Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as "Issuer mismatch"
                        
                        If parsed_jwt.payload.sub is not equal to "user123":
                            Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as "Subject mismatch"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_jwt_creation_hs256" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_jwt_creation_hs256" and passed as false and error as error as String

