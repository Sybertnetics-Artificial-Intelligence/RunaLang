Process called "test_aes_gcm_basic_encryption" returns CryptoTestResult:
    Note: Test basic AES-GCM encryption and decryption
    Try:
        Let start_time be time.now
        
        Note: Generate 256-bit key
        Let key_result be random.generate_secure_bytes with count as 32
        Match key_result:
            When random.RandomFailure:
                Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as false and error as "Failed to generate key"
            When random.RandomSuccess with value as key:
                Note: Test encryption
                Let plaintext be string_to_bytes with text as "Hello, Runa Crypto!"
                Let encryption_result be aead.encrypt_aes_gcm with plaintext as plaintext and key as key
                
                Match encryption_result:
                    When aead.AeadFailure:
                        Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as false and error as encryption_result.message
                    When aead.AeadSuccess with value as encrypted:
                        Note: Test decryption
                        Let decryption_result be aead.decrypt_aes_gcm with ciphertext as encrypted.ciphertext and key as key and nonce as encrypted.nonce and tag as encrypted.tag
                        
                        Match decryption_result:
                            When aead.AeadFailure:
                                Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as false and error as decryption_result.message
                            When aead.AeadSuccess with value as decrypted:
                                If not bytes_equal with a as plaintext and b as decrypted:
                                    Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as false and error as "Plaintext mismatch after decryption"
        
        Let end_time be time.now
        Let execution_time be time.difference_milliseconds with start_time as start_time and end_time as end_time
        
        Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as true and execution_time as execution_time
    
    Catch error:
        Return create_test_result with name as "test_aes_gcm_basic_encryption" and passed as false and error as error as String

