Process called "test_optimizer_creation" returns Boolean:
    Display "  Testing optimizer creation..."
    
    Let optimizer be optimizer_module.create_optimization_engine
    
    Assert length of optimizer["optimization_passes"] is equal to 10
    Assert optimizer["optimization_level"] is equal to 2
    Assert optimizer["target_architecture"] is equal to "generic"
    Assert optimizer["optimization_statistics"]["total_passes_run"] is equal to 0
    
    Return true

Process called "test_control_flow_analysis" returns Boolean:
    Display "  Testing control flow analysis..."
    
    Let test_program be list containing
        dictionary with: "type" as "variable_declaration", "name" as "x", "variable_type" as "Integer",
        dictionary with: "type" as "assignment", "target" as "x", "value" as dictionary with: "type" as "constant", "value" as 42,
        dictionary with: "type" as "if_statement", "condition" as "x > 0", "body" as list containing
            dictionary with: "type" as "assignment", "target" as "y", "value" as dictionary with: "type" as "constant", "value" as 1
    
    Let cfg_result be optimizer_module.build_control_flow_graph with program as test_program
    
    Assert cfg_result["success"] is equal to true
    Assert length of cfg_result["cfg"]["basic_blocks"] is greater than 1
    Assert cfg_result["cfg"]["entry_block"]["block_id"] is equal to "entry"
    
    Return true

Process called "test_data_flow_analysis" returns Boolean:
    Display "  Testing data flow analysis..."
    
    Let test_cfg be dictionary with:
        "basic_blocks" as list containing
            dictionary with:
                "block_id" as "entry"
                "statements" as list containing
                    dictionary with: "type" as "assignment", "target" as "x", "value" as dictionary with: "type" as "constant", "value" as 42
                "predecessors" as list containing
                "successors" as list containing
    
    Let symbols be dictionary with:
        "x" as dictionary with: "name" as "x", "type" as "Integer", "scope" as "local"
    
    Let dfa_result be optimizer_module.perform_data_flow_analysis with cfg as test_cfg and symbols as symbols
    
    Assert dfa_result["success"] is equal to true
    Assert "reaching_definitions" is in dfa_result["analysis"]
    Assert "live_variables" is in dfa_result["analysis"]
    Assert "available_expressions" is in dfa_result["analysis"]
    
    Return true

Process called "test_dead_code_elimination" returns Boolean:
    Display "  Testing dead code elimination..."
    
    Let test_program be list containing
        dictionary with: "type" as "variable_declaration", "name" as "unused_var", "variable_type" as "Integer",
        dictionary with: "type" as "variable_declaration", "name" as "used_var", "variable_type" as "Integer",
        dictionary with: "type" as "assignment", "target" as "used_var", "value" as dictionary with: "type" as "constant", "value" as 42
    
    Let context be dictionary with:
        "source_ast" as test_program
        "data_flow_analysis" as dictionary with:
            "live_variables" as dictionary with:
                "block1" as list containing "used_var"
        "symbol_table" as dictionary with:
            "unused_var" as dictionary with: "name" as "unused_var"
            "used_var" as dictionary with: "name" as "used_var"
    
    Let dce_result be optimizer_module.apply_dead_code_elimination with program as test_program and context as context
    
    Assert dce_result["success"] is equal to true
    Assert dce_result["transformations_applied"] is greater than 0
    Assert length of dce_result["optimized_program"] is less than length of test_program
    
    Return true

