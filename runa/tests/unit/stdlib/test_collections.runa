Process called "test_frozen_set_algebra" that returns Boolean:
    Display "Testing frozen set algebra operations..."
    
    Let fs1 be frozen_set_module.create_frozen_set_from_list with items as list containing "a", "b", "c"
    Let fs2 be frozen_set_module.create_frozen_set_from_list with items as list containing "b", "c", "d"
    
    Let union be frozen_set_module.frozen_set_union with fs1 as fs1 and fs2 as fs2
    Assert frozen_set_module.frozen_set_size with fs as union is equal to 4
    
    Let intersection be frozen_set_module.frozen_set_intersection with fs1 as fs1 and fs2 as fs2
    Assert frozen_set_module.frozen_set_size with fs as intersection is equal to 2
    Assert frozen_set_module.frozen_set_contains with fs as intersection and element as "b" is equal to true
    
    Let difference be frozen_set_module.frozen_set_difference with fs1 as fs1 and fs2 as fs2
    Assert frozen_set_module.frozen_set_size with fs as difference is equal to 1
    Assert frozen_set_module.frozen_set_contains with fs as difference and element as "a" is equal to true
    
    Display "Frozen set algebra operations: PASSED"
    Return true

