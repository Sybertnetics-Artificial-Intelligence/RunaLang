Note:
Comprehensive Test Suite for Runa Collections Module

Tests all major collection data structures including dictionaries, deques, counters,
default dictionaries, chain maps, bloom filters, disjoint sets, LRU caches, frozen sets,
multisets, graphs, heaps, enhanced lists, skip lists, sparse arrays, suffix arrays,
tree structures (BST/AVL), and tries. Validates functionality, edge cases, 
error handling, performance characteristics, and integration patterns.

This test suite ensures 100% specification compliance and production readiness
for all collections in the Runa standard library. Includes 46 comprehensive test
functions covering basic operations, advanced algorithms, statistical analysis,
string processing, tree operations, and cross-collection integration scenarios.
:End Note

Import "collections/dict" as dict_module
Import "collections/deque" as deque_module
Import "collections/counter" as counter_module
Import "collections/default_dict" as default_dict_module
Import "collections/chain_map" as chain_map_module
Import "collections/bloom_filter" as bloom_filter_module
Import "collections/disjoint_set" as disjoint_set_module
Import "collections/lru_cache" as lru_cache_module
Import "collections/frozen_set" as frozen_set_module
Import "collections/multiset" as multiset_module
Import "collections/graph" as graph_module
Import "collections/heap" as heap_module
Import "collections/list" as list_module
Import "collections/priority_queue" as priority_queue_module
Import "collections/segment_tree" as segment_tree_module
Import "collections/set" as set_module
Import "collections/ordered_dict" as ordered_dict_module
Import "collections/skip_list" as skip_list_module
Import "collections/sparse_array" as sparse_array_module
Import "collections/suffix_array" as suffix_array_module
Import "collections/tree" as tree_module
Import "collections/trie" as trie_module

Note: Dictionary Utilities Tests
Process called "test_dict_basic_operations" that returns Boolean:
    Display "Testing dictionary basic operations..."
    
    Let d be dict_module.create_empty_dict()
    Assert dict_module.is_empty with d as d is equal to true
    Assert dict_module.size with d as d is equal to 0
    
    Let d be dict_module.set with d as d and key as "name" and value as "Alice"
    Let d be dict_module.set with d as d and key as "age" and value as 25
    
    Assert dict_module.size with d as d is equal to 2
    Assert dict_module.get with d as d and key as "name" is equal to "Alice"
    Assert dict_module.get with d as d and key as "age" is equal to 25
    Assert dict_module.contains with d as d and key as "name" is equal to true
    Assert dict_module.contains with d as d and key as "city" is equal to false
    
    Let safe_value be dict_module.get_safe with d as d and key as "city" and default as "Unknown"
    Assert safe_value is equal to "Unknown"
    
    Display "Dictionary basic operations: PASSED"
    Return true

Process called "test_dict_advanced_operations" that returns Boolean:
    Display "Testing dictionary advanced operations..."
    
    Let d1 be dict_module.from_pairs with pairs as list containing ("a", 1), ("b", 2)
    Let d2 be dict_module.from_pairs with pairs as list containing ("c", 3), ("d", 4)
    
    Let merged be dict_module.merge with d1 as d1 and d2 as d2
    Assert dict_module.size with d as merged is equal to 4
    Assert dict_module.get with d as merged and key as "a" is equal to 1
    Assert dict_module.get with d as merged and key as "c" is equal to 3
    
    Let keys be dict_module.keys with d as merged
    Assert length of keys is equal to 4
    
    Let values be dict_module.values with d as merged
    Assert length of values is equal to 4
    
    Let items be dict_module.items with d as merged
    Assert length of items is equal to 4
    
    Display "Dictionary advanced operations: PASSED"
    Return true

Note: Deque Tests
Process called "test_deque_basic_operations" that returns Boolean:
    Display "Testing deque basic operations..."
    
    Let deque be deque_module.create_deque()
    Assert deque_module.deque_is_empty with deque as deque is equal to true
    Assert deque_module.deque_length with deque as deque is equal to 0
    
    Let deque be deque_module.add_to_back with deque as deque and value as "first"
    Let deque be deque_module.add_to_back with deque as deque and value as "second"
    Let deque be deque_module.add_to_front with deque as deque and value as "zero"
    
    Assert deque_module.deque_length with deque as deque is equal to 3
    Assert deque_module.peek_front with deque as deque is equal to "zero"
    Assert deque_module.peek_back with deque as deque is equal to "second"
    
    Let (deque, front_value) be deque_module.remove_from_front with deque as deque
    Assert front_value is equal to "zero"
    Assert deque_module.deque_length with deque as deque is equal to 2
    
    Let (deque, back_value) be deque_module.remove_from_back with deque as deque
    Assert back_value is equal to "second"
    Assert deque_module.deque_length with deque as deque is equal to 1
    
    Display "Deque basic operations: PASSED"
    Return true

Process called "test_deque_with_maxlen" that returns Boolean:
    Display "Testing deque with maxlen..."
    
    Let deque be deque_module.create_deque_with_maxlen with maxlen as 3
    Let deque be deque_module.add_to_back with deque as deque and value as 1
    Let deque be deque_module.add_to_back with deque as deque and value as 2
    Let deque be deque_module.add_to_back with deque as deque and value as 3
    
    Assert deque_module.deque_length with deque as deque is equal to 3
    Assert deque_module.deque_is_full with deque as deque is equal to true
    
    Let deque be deque_module.add_to_back with deque as deque and value as 4
    Assert deque_module.deque_length with deque as deque is equal to 3
    Assert deque_module.peek_front with deque as deque is equal to 2
    Assert deque_module.peek_back with deque as deque is equal to 4
    
    Display "Deque with maxlen: PASSED"
    Return true

Note: Counter Tests
Process called "test_counter_basic_operations" that returns Boolean:
    Display "Testing counter basic operations..."
    
    Let counter be counter_module.create_counter()
    Assert counter_module.is_counter_empty with counter as counter is equal to true
    
    Let counter be counter_module.increment_counter with counter as counter and element as "apple"
    Let counter be counter_module.increment_counter with counter as counter and element as "banana"
    Let counter be counter_module.increment_counter with counter as counter and element as "apple"
    
    Assert counter_module.get_count with counter as counter and element as "apple" is equal to 2
    Assert counter_module.get_count with counter as counter and element as "banana" is equal to 1
    Assert counter_module.get_count with counter as counter and element as "orange" is equal to 0
    
    Assert counter_module.get_total_count with counter as counter is equal to 3
    Assert counter_module.get_unique_elements_count with counter as counter is equal to 2
    
    Display "Counter basic operations: PASSED"
    Return true

Process called "test_counter_from_list" that returns Boolean:
    Display "Testing counter from list..."
    
    Let elements be list containing "a", "b", "a", "c", "b", "a"
    Let counter be counter_module.create_counter_from_list with elements as elements
    
    Assert counter_module.get_count with counter as counter and element as "a" is equal to 3
    Assert counter_module.get_count with counter as counter and element as "b" is equal to 2
    Assert counter_module.get_count with counter as counter and element as "c" is equal to 1
    
    Let most_common be counter_module.get_most_common with counter as counter and limit as 2
    Assert length of most_common is equal to 2
    Assert most_common[0] is equal to "a"
    Assert most_common[1] is equal to "b"
    
    Display "Counter from list: PASSED"
    Return true

