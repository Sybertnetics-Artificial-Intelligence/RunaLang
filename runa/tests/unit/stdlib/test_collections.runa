Note: Heap Tests  
Process called "test_heap_basic_operations" that returns Boolean:
    Display "Testing heap basic operations..."
    
    Let heap be heap_module.create_heap()
    Assert heap_module.heap_is_empty with heap as heap is equal to true
    Assert heap_module.heap_size with heap as heap is equal to 0
    
    Set heap to heap_module.heap_push with heap as heap and value as "high" and priority as 1.0
    Set heap to heap_module.heap_push with heap as heap and value as "medium" and priority as 5.0
    Set heap to heap_module.heap_push with heap as heap and value as "low" and priority as 10.0
    
    Assert heap_module.heap_size with heap as heap is equal to 3
    
    Let peek_result be heap_module.heap_peek with heap as heap
    Assert peek_result["value"] is equal to "high"
    Assert peek_result["priority"] is equal to 1.0
    
    Let pop_result be heap_module.heap_pop with heap as heap
    Assert pop_result["success"] is equal to true
    Assert pop_result["value"] is equal to "high"
    Assert heap_module.heap_size with heap as pop_result["heap"] is equal to 2
    
    Display "Heap basic operations: PASSED"
    Return true

Process called "test_heap_priority_ordering" that returns Boolean:
    Display "Testing heap priority ordering..."
    
    Let heap be heap_module.create_heap()
