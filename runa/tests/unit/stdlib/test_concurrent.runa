Process called "run_all_concurrent_tests" returns TestSuite:
    Display "=" times 50
    Display "RUNA CONCURRENT FRAMEWORK TEST SUITE"
    Display "=" times 50
    
    Set test_suite.setup_complete to true
    
    Let test_functions be list containing:
        "test_atomic_integer_basic_operations",
        "test_atomic_compare_and_swap",
        "test_atomic_memory_ordering",
        "test_channel_basic_send_receive",
        "test_channel_buffering_and_blocking",
        "test_spsc_channel_performance",
        "test_broadcast_channel_fanout",
        "test_future_basic_completion",
        "test_future_combinators",
        "test_future_combination",
        "test_mutex_basic_locking",
        "test_read_write_lock_semantics",
        "test_condition_variable_signaling",
        "test_barrier_coordination",
        "test_cyclic_barrier_reuse",
        "test_countdown_latch_mechanism",
        "test_counting_semaphore_permits",
        "test_binary_semaphore_mutual_exclusion",
        "test_fair_semaphore_ordering",
        "test_timed_semaphore_rate_limiting",
        "test_thread_lifecycle",
        "test_thread_pool_execution",
        "test_work_stealing_pool",
        "test_thread_local_storage",
        "test_actor_creation_and_messaging",
        "test_actor_supervision",
        "test_work_pool_task_execution",
        "test_async_pipeline_processing",
        "test_concurrent_system_integration",
        "test_cross_module_interaction",
        "test_performance_characteristics"
    
    For each test_function in test_functions:
        Let test_result be run_test with:
            test_name as test_function
            test_function as test_function
        
        Add test_result to test_suite.test_results
        
        Match test_result:
            When TestPassed:
                Display "✓ " plus test_result.test_name plus " (" plus test_result.execution_time as String plus "s)"
            
            When TestFailed:
                Display "✗ " plus test_result.test_name plus " - " plus test_result.error_message
            
            When TestSkipped:
                Display "- " plus test_result.test_name plus " (skipped: " plus test_result.reason plus ")"
    
    Set test_suite.teardown_complete to true
    
    Display ""
    Display "Test Results Summary:"
    Display "-" times 30
    Display "Total Tests Run: " plus test_suite.tests_run as String
    Display "Tests Passed: " plus test_suite.tests_passed as String
    Display "Tests Failed: " plus test_suite.tests_failed as String
    Display "Tests Skipped: " plus test_suite.tests_skipped as String
    Display "Total Execution Time: " plus test_suite.total_execution_time as String plus "s"
    
    Let success_rate be (test_suite.tests_passed times 100.0) divided by test_suite.tests_run
    Display "Success Rate: " plus success_rate as String plus "%"
    
    If test_suite.tests_failed is equal to 0:
        Display ""
        Display "🎉 ALL TESTS PASSED! Concurrent framework is production-ready!"
    Otherwise:
        Display ""
        Display "⚠️  " plus test_suite.tests_failed as String plus " test(s) failed. Review failures above."
    
    Display "=" times 50
    
    Return test_suite

