Process called "test_async_pipeline_processing" returns Dictionary[String, Any]:
    Display "Testing async pipeline processing..."
    
    Let pipeline be concurrent.create_async_pipeline
    
    assert_not_null with:
        value as pipeline
        message as "Async pipeline should be created"
    
    Let add_stage1_result be concurrent.add_pipeline_stage with:
        pipeline as pipeline
        stage_function as "validate_data"
        stage_config as dictionary containing "strict" as true
    
    Let add_stage2_result be concurrent.add_pipeline_stage with:
        pipeline as pipeline
        stage_function as "transform_data"
        stage_config as dictionary containing "format" as "json"
    
    Let add_stage3_result be concurrent.add_pipeline_stage with:
        pipeline as pipeline
        stage_function as "save_data"
        stage_config as dictionary containing "destination" as "database"
    
    assert_equals with:
        actual as length of pipeline.stages
        expected as 3
        message as "Pipeline should have 3 stages"
    
    Let input_data be list containing "item1", "item2", "item3"
    
    Let pipeline_result be concurrent.run_async_pipeline with:
        pipeline as pipeline
        input_data as input_data
    
    Match pipeline_result:
        When concurrent.ConcurrentSuccess:
            Let output_data be pipeline_result.value
            assert_equals with:
                actual as length of output_data
                expected as 3
                message as "Pipeline should process all input items"
        
        When concurrent.ConcurrentTimeout:
            Display "Pipeline execution timed out"
        
        Otherwise:
            Display "Pipeline execution failed: " plus pipeline_result.error_message
    
    Let pipeline_stats be concurrent.get_pipeline_statistics with pipeline as pipeline
    assert_true with:
        condition as pipeline_stats["stage_count"] is equal to 3
        message as "Pipeline stats should show 3 stages"
    
    Return dictionary containing "success" as true, "error_message" as ""
:End Note

