Note: Actor Model Tests
Process called "test_actor_creation_and_messaging" returns Dictionary[String, Any]:
    Display "Testing actor creation and messaging..."
    
    Let actor be concurrent.create_actor with:
        behavior as "test_behavior"
        initial_state as dictionary containing "counter" as 0
    
    assert_not_null with:
        value as actor
        message as "Actor should be created"
    
    assert_not_null with:
        value as actor.actor_id
        message as "Actor should have an ID"
    
    Let send_result be concurrent.send_message with:
        recipient as actor
        message as "test_message"
        sender_id as "test_sender"
    
    Match send_result:
        When concurrent.ConcurrentSuccess:
            assert_equals with:
                actual as send_result.value
                expected as "message_sent"
                message as "Message should be sent successfully"
        
        Otherwise:
            Throw "Actor message send should have succeeded"
    
    Let receive_result be concurrent.receive_message with:
        actor as actor
        timeout as 2.0
    
    Match receive_result:
        When concurrent.ConcurrentSuccess:
            Let envelope be receive_result.value
            assert_equals with:
                actual as envelope.message
                expected as "test_message"
                message as "Received message should match sent message"
            
            assert_equals with:
                actual as envelope.sender_id
                expected as "test_sender"
                message as "Sender ID should match"
        
        Otherwise:
            Throw "Actor message receive should have succeeded"
    
    Let stats be concurrent.get_actor_statistics with actor as actor
    assert_equals with:
        actual as stats["message_count"]
        expected as 1
        message as "Message count should be 1"
    
    Return dictionary containing "success" as true, "error_message" as ""

