                        name as "Histogram Creation" 
                        and module as "visualization" 
                        and passed as false 
                        and error as Some with value as "Histogram properties incorrect"
                        and time_ms as time_diff(test_start)
                        and metrics as Dictionary with empty entries
                        to results
            
            When viz_core.PlotError with error as hist_error:
                Add create_test_result with 
                    name as "Histogram Creation" 
                    and module as "visualization" 
                    and passed as false 
                    and error as Some with value as "Histogram creation failed"
                    and time_ms as time_diff(test_start)
                    and metrics as Dictionary with empty entries
