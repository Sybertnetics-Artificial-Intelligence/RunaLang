                        and module as "visualization" 
                        and passed as false 
                        and error as Some with value as "Line plot properties incorrect"
                        and time_ms as time_diff(test_start)
                        and metrics as Dictionary with empty entries
                        to results
            
            When viz_core.PlotError with error as plot_error and context as error_context:
                Add create_test_result with 
                    name as "Line Plot Creation" 
                    and module as "visualization" 
                    and passed as false 
                    and error as Some with value as "Plot creation failed"
                    and time_ms as time_diff(test_start)
                    and metrics as Dictionary with empty entries
