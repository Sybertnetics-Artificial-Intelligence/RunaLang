Note:
Comprehensive Test Suite: Audio Module

This test suite covers all major audio functionality including core audio processing,
synthesis, effects, analysis, recording, streaming, and MIDI integration.
Tests cover successful operations, error conditions, and edge cases across all components.
:End Note

Import "audio/core" as audio_core
Import "audio/synthesis" as synthesis
Import "audio/effects" as effects
Import "audio/analysis" as analysis
Import "audio/recording" as recording
Import "audio/streaming" as streaming
Import "audio/midi" as midi

Test Suite called "Audio Module Comprehensive Tests":

Test Suite called "Audio Core System Tests":
    
    Test called "test_create_audio_system":
        Let config be audio_core.AudioConfiguration with:
            sample_rate as 44100
            buffer_size as 512
            channels as 2
            bit_depth as 24
            device_name as "default"
            latency_mode as audio_core.LOW_LATENCY
        
        Let audio_system be audio_core.create_audio_system with config as config
        
        Assert audio_system is not None
        Assert audio_system["sample_rate"] is equal to 44100
        Assert audio_system["buffer_size"] is equal to 512
        Assert audio_system["channels"] is equal to 2
        Assert audio_system["bit_depth"] is equal to 24
        Assert audio_system["status"] is equal to audio_core.INITIALIZED
    
    Test called "test_initialize_audio_device":
        Let system be create_test_audio_system
        Let device_config be audio_core.DeviceConfiguration with:
            input_device as "Built-in Microphone"
            output_device as "Built-in Speakers"
            enable_monitoring as true
            monitoring_level as 0.8
        
        Let device_result be audio_core.initialize_audio_device with system as system and device_config as device_config
        
        Assert device_result["success"] is true
        Assert device_result["input_device_connected"] is true
        Assert device_result["output_device_connected"] is true
        Assert device_result["monitoring_enabled"] is true
        Assert device_result["latency_ms"] is greater than 0.0
    
    Test called "test_create_audio_buffer":
        Let buffer be audio_core.create_audio_buffer with channels as 2 and samples as 1024 and sample_rate as 44100
        
        Assert buffer is not None
        Assert buffer["channels"] is equal to 2
        Assert buffer["samples"] is equal to 1024
        Assert buffer["sample_rate"] is equal to 44100
        Assert buffer["duration"] is approximately equal to 0.023
        Assert length of buffer["data"] is equal to 2048  Note: 2 channels * 1024 samples
    
    Test called "test_audio_buffer_processing":
        Let buffer be create_test_audio_buffer
        Let processor be audio_core.AudioProcessor with:
            processor_type as audio_core.GAIN_PROCESSOR
            parameters as dictionary with "gain" as 0.5
        
        Let result be audio_core.process_audio_buffer with buffer as buffer and processor as processor
        
        Assert result["success"] is true
        Assert result["processed_buffer"] is not None
        Assert result["processed_buffer"]["samples"] is equal to buffer["samples"]
        Assert result["processing_time_ms"] is greater than 0.0
    
    Test called "test_mix_audio_buffers":
        Let buffer1 be create_test_audio_buffer_with_tone with frequency as 440.0
        Let buffer2 be create_test_audio_buffer_with_tone with frequency as 880.0
        Let mix_config be audio_core.MixConfiguration with:
            mix_levels as list containing 0.5, 0.5
            mix_mode as audio_core.ADD_MIX
            normalize_output as true
        
        Let mixed_buffer be audio_core.mix_audio_buffers with buffers as list containing buffer1, buffer2 and mix_config as mix_config
        
        Assert mixed_buffer is not None
        Assert mixed_buffer["channels"] is equal to 2
        Assert mixed_buffer["samples"] is equal to buffer1["samples"]
        Assert mixed_buffer["peak_level"] is less than or equal to 1.0
    
    Test called "test_sample_rate_conversion":
        Let original_buffer be create_test_audio_buffer_with_sample_rate with sample_rate as 44100
        Let target_rate be 48000
        
        Let converted_buffer be audio_core.convert_sample_rate with buffer as original_buffer and target_rate as target_rate
        
        Assert converted_buffer is not None
        Assert converted_buffer["sample_rate"] is equal to 48000
        Assert converted_buffer["channels"] is equal to original_buffer["channels"]
        Assert converted_buffer["samples"] is approximately equal to (original_buffer["samples"] * 48000) divided by 44100

Test Suite called "Audio Synthesis Tests":
    
    Test called "test_create_synthesizer":
        Let synth_config be synthesis.SynthesizerConfiguration with:
            synthesis_type as synthesis.SUBTRACTIVE
            polyphony as 16
            voice_allocation as synthesis.ROUND_ROBIN
            master_volume as 0.8
            pitch_bend_range as 2
        
        Let synthesizer be synthesis.create_synthesizer with synth_config as synth_config
        
        Assert synthesizer is not None
        Assert synthesizer["synthesis_type"] is equal to synthesis.SUBTRACTIVE
        Assert synthesizer["polyphony"] is equal to 16
        Assert synthesizer["voice_allocation"] is equal to synthesis.ROUND_ROBIN
        Assert synthesizer["master_volume"] is equal to 0.8
        Assert synthesizer["active_voices"] is equal to 0
    
    Test called "test_generate_waveform":
        Let sine_buffer be synthesis.generate_waveform with waveform_type as synthesis.SINE and frequency as 440.0 and duration as 1.0
        
        Assert sine_buffer is not None
        Assert sine_buffer["duration"] is approximately equal to 1.0
        Assert sine_buffer["fundamental_frequency"] is approximately equal to 440.0
        Assert sine_buffer["waveform_type"] is equal to synthesis.SINE
        Assert sine_buffer["peak_amplitude"] is greater than 0.0
        
        Let sawtooth_buffer be synthesis.generate_waveform with waveform_type as synthesis.SAWTOOTH and frequency as 220.0 and duration as 0.5
        
        Assert sawtooth_buffer["duration"] is approximately equal to 0.5
        Assert sawtooth_buffer["fundamental_frequency"] is approximately equal to 220.0
        Assert sawtooth_buffer["waveform_type"] is equal to synthesis.SAWTOOTH
    
    Test called "test_create_oscillator":
        Let osc_config be synthesis.OscillatorConfiguration with:
            waveform_type as synthesis.SQUARE
            frequency as 880.0
            amplitude as 0.7
            phase as 0.25
            sync_enabled as false
        
        Let oscillator be synthesis.create_oscillator with osc_config as osc_config
        
        Assert oscillator is not None
        Assert oscillator["waveform_type"] is equal to synthesis.SQUARE
        Assert oscillator["frequency"] is equal to 880.0
        Assert oscillator["amplitude"] is equal to 0.7
        Assert oscillator["phase"] is equal to 0.25
        Assert oscillator["sync_enabled"] is false
    
    Test called "test_apply_envelope":
        Let test_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        Let envelope_config be synthesis.EnvelopeConfiguration with:
            attack_time as 0.1
            decay_time as 0.3
            sustain_level as 0.6
            release_time as 1.0
            curve_type as synthesis.EXPONENTIAL
        
        Let enveloped_buffer be synthesis.apply_envelope with buffer as test_buffer and envelope as envelope_config
        
        Assert enveloped_buffer is not None
        Assert enveloped_buffer["samples"] is equal to test_buffer["samples"]
        Assert enveloped_buffer["envelope_applied"] is true
        Assert enveloped_buffer["attack_samples"] is greater than 0
        Assert enveloped_buffer["release_samples"] is greater than 0
    
    Test called "test_create_filter":
        Let filter_config be synthesis.FilterConfiguration with:
            filter_type as synthesis.LOW_PASS
            cutoff_frequency as 1000.0
            resonance as 0.7
            filter_slope as synthesis.SLOPE_24DB
            envelope_amount as 0.5
        
        Let audio_filter be synthesis.create_filter with filter_config as filter_config
        
        Assert audio_filter is not None
        Assert audio_filter["filter_type"] is equal to synthesis.LOW_PASS
        Assert audio_filter["cutoff_frequency"] is equal to 1000.0
        Assert audio_filter["resonance"] is equal to 0.7
        Assert audio_filter["filter_slope"] is equal to synthesis.SLOPE_24DB
    
    Test called "test_modulation_system":
        Let modulator_config be synthesis.ModulationSource with:
            source_type as synthesis.LFO
            frequency as 2.0
            amplitude as 1.0
            waveform as synthesis.TRIANGLE
            phase_offset as 0.0
        
        Let modulation_result be synthesis.modulate_parameter with parameter as "filter_cutoff" and modulator as modulator_config and amount as 0.8
        
        Assert modulation_result["success"] is true
        Assert modulation_result["parameter_name"] is equal to "filter_cutoff"
        Assert modulation_result["modulation_amount"] is equal to 0.8
        Assert modulation_result["modulator_frequency"] is equal to 2.0

Test Suite called "Audio Effects Tests":
    
    Test called "test_create_effect_chain":
        Let reverb_config be effects.ReverbConfiguration with:
            room_size as 0.8
            damping as 0.5
            wet_level as 0.3
            dry_level as 0.7
            pre_delay as 0.02
            reverb_type as effects.HALL_REVERB
        
        Let compressor_config be effects.CompressorConfiguration with:
            threshold as -12.0
            ratio as 4.0
            attack_time as 0.003
            release_time as 0.1
            knee_width as 2.0
            makeup_gain as 2.0
        
        Let effect_chain be effects.create_effect_chain with effects as list containing compressor_config, reverb_config
        
        Assert effect_chain is not None
        Assert length of effect_chain["effects"] is equal to 2
        Assert effect_chain["effects"][0]["effect_type"] is equal to effects.COMPRESSOR
        Assert effect_chain["effects"][1]["effect_type"] is equal to effects.REVERB
        Assert effect_chain["bypass_state"] is false
    
    Test called "test_apply_reverb":
        Let test_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        Let reverb_config be effects.ReverbConfiguration with:
            room_size as 0.6
            damping as 0.4
            wet_level as 0.4
            dry_level as 0.6
            pre_delay as 0.015
            reverb_type as effects.ROOM_REVERB
        
        Let reverb_buffer be effects.apply_reverb with buffer as test_buffer and reverb_config as reverb_config
        
        Assert reverb_buffer is not None
        Assert reverb_buffer["samples"] is equal to test_buffer["samples"]
        Assert reverb_buffer["reverb_applied"] is true
        Assert reverb_buffer["wet_level"] is equal to 0.4
        Assert reverb_buffer["dry_level"] is equal to 0.6
    
    Test called "test_apply_compression":
        Let dynamic_buffer be create_test_audio_buffer_with_dynamics
        Let compressor_config be effects.CompressorConfiguration with:
            threshold as -18.0
            ratio as 3.0
            attack_time as 0.005
            release_time as 0.05
            knee_width as 4.0
            makeup_gain as 3.0
        
        Let compressed_buffer be effects.apply_compression with buffer as dynamic_buffer and compressor_config as compressor_config
        
        Assert compressed_buffer is not None
        Assert compressed_buffer["samples"] is equal to dynamic_buffer["samples"]
        Assert compressed_buffer["compression_applied"] is true
        Assert compressed_buffer["gain_reduction_max"] is greater than 0.0
        Assert compressed_buffer["output_gain"] is approximately equal to 3.0
    
    Test called "test_apply_eq":
        Let test_buffer be create_test_audio_buffer_with_full_spectrum
        Let eq_config be effects.EqualizerConfiguration with:
            bands as list containing create_eq_band with frequency as 100.0 and gain as 3.0 and q as 1.0,
                                    create_eq_band with frequency as 1000.0 and gain as -2.0 and q as 0.7,
                                    create_eq_band with frequency as 8000.0 and gain as 4.0 and q as 1.5
        
        Let eq_buffer be effects.apply_eq with buffer as test_buffer and eq_config as eq_config
        
        Assert eq_buffer is not None
        Assert eq_buffer["samples"] is equal to test_buffer["samples"]
        Assert eq_buffer["eq_applied"] is true
        Assert length of eq_buffer["frequency_response"] is equal to 3
        Assert eq_buffer["frequency_response"][0]["frequency"] is equal to 100.0
        Assert eq_buffer["frequency_response"][0]["gain"] is equal to 3.0
    
    Test called "test_apply_distortion":
        Let clean_buffer be create_test_audio_buffer_with_tone with frequency as 220.0
        Let distortion_config be effects.DistortionConfiguration with:
            drive_amount as 0.8
            distortion_type as effects.TUBE_SATURATION
            tone_control as 0.6
            output_level as 0.7
            oversampling as true
        
        Let distorted_buffer be effects.apply_distortion with buffer as clean_buffer and distortion_config as distortion_config
        
        Assert distorted_buffer is not None
        Assert distorted_buffer["samples"] is equal to clean_buffer["samples"]
        Assert distorted_buffer["distortion_applied"] is true
        Assert distorted_buffer["harmonic_content"] is greater than clean_buffer["harmonic_content"]
        Assert distorted_buffer["peak_level"] is less than or equal to 1.0
    
    Test called "test_convolution_reverb":
        Let impulse_response be load_test_impulse_response
        Let convolution_reverb be effects.create_convolution_reverb with impulse_response as impulse_response
        
        Assert convolution_reverb is not None
        Assert convolution_reverb["impulse_length"] is greater than 0
        Assert convolution_reverb["sample_rate"] is equal to impulse_response["sample_rate"]
        Assert convolution_reverb["ready"] is true
        
        Let test_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        Let convolved_buffer be effects.apply_convolution_reverb with reverb as convolution_reverb and buffer as test_buffer
        
        Assert convolved_buffer is not None
        Assert convolved_buffer["convolution_applied"] is true
    
    Test called "test_stereo_effects":
        Let stereo_buffer be create_test_stereo_audio_buffer
        Let stereo_config be effects.StereoConfiguration with:
            stereo_width as 1.2
            stereo_imaging as effects.MID_SIDE_PROCESSING
            left_delay as 0.001
            right_delay as 0.0
            crossfeed_amount as 0.1
        
        Let processed_stereo be effects.apply_stereo_effects with buffer as stereo_buffer and stereo_config as stereo_config
        
        Assert processed_stereo is not None
        Assert processed_stereo["channels"] is equal to 2
        Assert processed_stereo["stereo_width"] is equal to 1.2
        Assert processed_stereo["stereo_processing_applied"] is true

Test Suite called "Audio Analysis Tests":
    
    Test called "test_analyze_spectrum":
        Let test_buffer be create_test_audio_buffer_with_harmonics
        Let spectrum_config be analysis.SpectrumConfiguration with:
            fft_size as 2048
            window_type as analysis.HANNING_WINDOW
            overlap_factor as 0.5
            frequency_range as list containing 20.0, 20000.0
        
        Let spectrum_analysis be analysis.analyze_spectrum with buffer as test_buffer and analysis_config as spectrum_config
        
        Assert spectrum_analysis is not None
        Assert spectrum_analysis["fft_size"] is equal to 2048
        Assert spectrum_analysis["frequency_bins"] is equal to 1024
        Assert spectrum_analysis["peak_frequency"] is greater than 0.0
        Assert spectrum_analysis["spectral_centroid"] is greater than 0.0
        Assert spectrum_analysis["spectral_bandwidth"] is greater than 0.0
        Assert length of spectrum_analysis["magnitude_spectrum"] is equal to 1024
    
    Test called "test_detect_pitch":
        Let pitched_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        Let pitch_config be analysis.PitchConfiguration with:
            algorithm as analysis.YIN_ALGORITHM
            frequency_range as list containing 80.0, 800.0
            confidence_threshold as 0.8
        
        Let pitch_result be analysis.detect_pitch with buffer as pitched_buffer and pitch_config as pitch_config
        
        Assert pitch_result is not None
        Assert pitch_result["frequency"] is approximately equal to 440.0
        Assert pitch_result["confidence"] is greater than 0.8
        Assert pitch_result["algorithm_used"] is equal to analysis.YIN_ALGORITHM
        Assert pitch_result["detection_time_ms"] is greater than 0.0
    
    Test called "test_detect_onset":
        Let onset_buffer be create_test_audio_buffer_with_onsets
        Let onset_config be analysis.OnsetConfiguration with:
            detection_function as analysis.SPECTRAL_FLUX
            threshold as 0.3
            min_interval as 0.05
            pre_max as 0.03
            post_max as 0.03
        
        Let onset_result be analysis.detect_onset with buffer as onset_buffer and onset_config as onset_config
        
        Assert onset_result is not None
        Assert length of onset_result["onset_times"] is greater than 0
        Assert onset_result["onset_count"] is greater than 0
        Assert onset_result["detection_function"] is equal to analysis.SPECTRAL_FLUX
        Assert onset_result["threshold_used"] is equal to 0.3
    
    Test called "test_analyze_tempo":
        Let rhythmic_buffer be create_test_audio_buffer_with_rhythm
        Let tempo_config be analysis.TempoConfiguration with:
            tempo_range as list containing 60.0, 180.0
            analysis_method as analysis.BEAT_TRACKING
            window_size as 4.0
            hop_size as 0.25
        
        Let tempo_result be analysis.analyze_tempo with buffer as rhythmic_buffer and tempo_config as tempo_config
        
        Assert tempo_result is not None
        Assert tempo_result["tempo_bpm"] is greater than 60.0
        Assert tempo_result["tempo_bpm"] is less than 180.0
        Assert tempo_result["confidence"] is greater than 0.0
        Assert length of tempo_result["beat_times"] is greater than 0
        Assert tempo_result["time_signature_numerator"] is greater than 0
    
    Test called "test_extract_features":
        Let feature_buffer be create_test_audio_buffer_with_complex_content
        Let feature_config be analysis.FeatureConfiguration with:
            features as list containing analysis.MFCC, analysis.SPECTRAL_CENTROID, analysis.ZERO_CROSSING_RATE, analysis.SPECTRAL_ROLLOFF
            frame_size as 1024
            hop_size as 512
            mel_filters as 13
        
        Let audio_features be analysis.extract_features with buffer as feature_buffer and feature_config as feature_config
        
        Assert audio_features is not None
        Assert audio_features["mfcc"] is not None
        Assert length of audio_features["mfcc"] is equal to 13
        Assert audio_features["spectral_centroid"] is greater than 0.0
        Assert audio_features["zero_crossing_rate"] is greater than or equal to 0.0
        Assert audio_features["spectral_rolloff"] is greater than 0.0
        Assert audio_features["extraction_time_ms"] is greater than 0.0
    
    Test called "test_create_spectrogram":
        Let spectrogram_buffer be create_test_audio_buffer_with_varying_content
        Let window_config be analysis.WindowConfiguration with:
            window_size as 1024
            hop_size as 256
            window_function as analysis.BLACKMAN_WINDOW
            zero_padding as 512
        
        Let spectrogram be analysis.create_spectrogram with buffer as spectrogram_buffer and window_config as window_config
        
        Assert spectrogram is not None
        Assert spectrogram["time_frames"] is greater than 0
        Assert spectrogram["frequency_bins"] is equal to 768  Note: (1024 + 512) / 2
        Assert length of spectrogram["time_axis"] is equal to spectrogram["time_frames"]
        Assert length of spectrogram["frequency_axis"] is equal to spectrogram["frequency_bins"]
        Assert spectrogram["magnitude_data"] is not None
    
    Test called "test_detect_chords":
        Let chord_buffer be create_test_audio_buffer_with_chord
        Let chord_config be analysis.ChordConfiguration with:
            chord_templates as analysis.MAJOR_MINOR_TEMPLATES
            harmonic_change_variance as 0.1
            chord_change_threshold as 0.5
            minimum_chord_duration as 0.2
        
        Let chord_result be analysis.detect_chords with buffer as chord_buffer and chord_config as chord_config
        
        Assert chord_result is not None
        Assert length of chord_result["detected_chords"] is greater than 0
        Assert chord_result["detected_chords"][0]["chord_name"] is not equal to ""
        Assert chord_result["detected_chords"][0]["confidence"] is greater than 0.0
        Assert chord_result["detected_chords"][0]["start_time"] is greater than or equal to 0.0

Test Suite called "Audio Recording Tests":
    
    Test called "test_create_recorder":
        Let recorder_config be recording.RecorderConfiguration with:
            input_channels as 2
            sample_rate as 48000
            bit_depth as 24
            buffer_duration as 0.1
            monitoring_enabled as true
            auto_gain_control as false
        
        Let recorder be recording.create_recorder with recorder_config as recorder_config
        
        Assert recorder is not None
        Assert recorder["input_channels"] is equal to 2
        Assert recorder["sample_rate"] is equal to 48000
        Assert recorder["bit_depth"] is equal to 24
        Assert recorder["buffer_duration"] is equal to 0.1
        Assert recorder["monitoring_enabled"] is true
        Assert recorder["status"] is equal to recording.READY
    
    Test called "test_recording_lifecycle":
        Let recorder be create_test_recorder
        Let output_config be recording.OutputConfiguration with:
            output_path as "/tmp/test_recording.wav"
            file_format as recording.WAV_FORMAT
            quality_preset as recording.HIGH_QUALITY
            automatic_naming as false
            max_file_size as 100000000
        
        Let start_result be recording.start_recording with recorder as recorder and output_config as output_config
        
        Assert start_result["success"] is true
        Assert start_result["recording_started"] is true
        Assert start_result["output_file"] is equal to "/tmp/test_recording.wav"
        Assert recorder["status"] is equal to recording.RECORDING
        
        Note: Simulate recording time
        Wait 0.1 seconds
        
        Let stop_result be recording.stop_recording with recorder as recorder
        
        Assert stop_result["success"] is true
        Assert stop_result["recording_stopped"] is true
        Assert stop_result["duration"] is greater than 0.0
        Assert stop_result["file_size"] is greater than 0
        Assert recorder["status"] is equal to recording.STOPPED
    
    Test called "test_load_audio_file":
        Let test_file_path be create_test_audio_file
        
        Let loaded_buffer be recording.load_audio_file with file_path as test_file_path
        
        Assert loaded_buffer is not None
        Assert loaded_buffer["channels"] is greater than 0
        Assert loaded_buffer["samples"] is greater than 0
        Assert loaded_buffer["sample_rate"] is greater than 0
        Assert loaded_buffer["duration"] is greater than 0.0
        Assert loaded_buffer["file_format"] is not equal to ""
    
    Test called "test_save_audio_file":
        Let test_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        Let save_path be "/tmp/test_save.wav"
        Let format_config be recording.FormatConfiguration with:
            file_format as recording.WAV_FORMAT
            bit_depth as 16
            compression_level as 0
            metadata_embed as true
        
        Let save_result be recording.save_audio_file with buffer as test_buffer and file_path as save_path and format_config as format_config
        
        Assert save_result["success"] is true
        Assert save_result["file_saved"] is true
        Assert save_result["output_path"] is equal to save_path
        Assert save_result["file_size"] is greater than 0
        Assert save_result["duration_saved"] is approximately equal to test_buffer["duration"]
    
    Test called "test_stream_audio_file":
        Let streaming_file_path be create_test_audio_file
        Let stream_config be recording.StreamConfiguration with:
            buffer_size as 1024
            preload_buffers as 4
            loop_enabled as false
            start_position as 0.0
        
        Let audio_stream be recording.stream_audio_file with file_path as streaming_file_path and stream_config as stream_config
        
        Assert audio_stream is not None
        Assert audio_stream["stream_ready"] is true
        Assert audio_stream["total_duration"] is greater than 0.0
        Assert audio_stream["buffer_size"] is equal to 1024
        Assert audio_stream["preload_buffers"] is equal to 4
        Assert audio_stream["current_position"] is equal to 0.0
    
    Test called "test_apply_metadata":
        Let metadata_file_path be create_test_audio_file
        Let metadata be recording.AudioMetadata with:
            title as "Test Recording"
            artist as "Test Artist"
            album as "Test Album"
            genre as "Test"
            year as 2024
            track_number as 1
            comments as "Generated by Runa test suite"
        
        Let metadata_result be recording.apply_metadata with file_path as metadata_file_path and metadata as metadata
        
        Assert metadata_result["success"] is true
        Assert metadata_result["metadata_applied"] is true
        Assert metadata_result["metadata_fields_written"] is equal to 7
        Assert metadata_result["file_modified"] is true

Test Suite called "Audio Streaming Tests":
    
    Test called "test_create_stream_server":
        Let server_config be streaming.StreamServerConfiguration with:
            port as 8080
            protocol as streaming.WEBRTC_PROTOCOL
            max_clients as 10
            audio_codec as streaming.OPUS_CODEC
            bitrate as 128000
            latency_target as 50
        
        Let stream_server be streaming.create_stream_server with server_config as server_config
        
        Assert stream_server is not None
        Assert stream_server["port"] is equal to 8080
        Assert stream_server["protocol"] is equal to streaming.WEBRTC_PROTOCOL
        Assert stream_server["max_clients"] is equal to 10
        Assert stream_server["audio_codec"] is equal to streaming.OPUS_CODEC
        Assert stream_server["status"] is equal to streaming.SERVER_READY
    
    Test called "test_create_stream_client":
        Let client_config be streaming.StreamClientConfiguration with:
            server_address as "localhost"
            server_port as 8080
            protocol as streaming.WEBRTC_PROTOCOL
            audio_codec as streaming.OPUS_CODEC
            buffer_size as 1024
            jitter_buffer_size as 4
        
        Let stream_client be streaming.create_stream_client with client_config as client_config
        
        Assert stream_client is not None
        Assert stream_client["server_address"] is equal to "localhost"
        Assert stream_client["server_port"] is equal to 8080
        Assert stream_client["protocol"] is equal to streaming.WEBRTC_PROTOCOL
        Assert stream_client["buffer_size"] is equal to 1024
        Assert stream_client["status"] is equal to streaming.CLIENT_READY
    
    Test called "test_start_broadcast":
        Let server be create_test_stream_server
        Let broadcast_config be streaming.BroadcastConfiguration with:
            stream_name as "Test Broadcast"
            description as "Test audio broadcast"
            quality_adaptive as true
            auto_start as true
        
        Let broadcast_result be streaming.start_broadcast with server as server and broadcast_config as broadcast_config
        
        Assert broadcast_result["success"] is true
        Assert broadcast_result["broadcast_started"] is true
        Assert broadcast_result["stream_url"] is not equal to ""
        Assert broadcast_result["stream_name"] is equal to "Test Broadcast"
        Assert server["status"] is equal to streaming.SERVER_BROADCASTING
    
    Test called "test_connect_to_stream":
        Let client be create_test_stream_client
        Let server be create_test_stream_server_with_broadcast
        Let connection_config be streaming.ConnectionConfiguration with:
            stream_url as server["stream_url"]
            auto_reconnect as true
            connection_timeout as 5000
            quality_preference as streaming.LOW_LATENCY
        
        Let connection_result be streaming.connect_to_stream with client as client and connection_config as connection_config
        
        Assert connection_result["success"] is true
        Assert connection_result["connected"] is true
        Assert connection_result["stream_info"] is not None
        Assert connection_result["latency_ms"] is greater than 0
        Assert client["status"] is equal to streaming.CLIENT_CONNECTED
    
    Test called "test_configure_codec":
        Let codec_config be streaming.CodecConfiguration with:
            bitrate as 256000
            sample_rate as 48000
            channels as 2
            complexity as streaming.HIGH_COMPLEXITY
            vbr_enabled as true
            dtx_enabled as false
        
        Let codec_result be streaming.configure_codec with codec_type as streaming.OPUS_CODEC and codec_config as codec_config
        
        Assert codec_result["success"] is true
        Assert codec_result["codec_configured"] is true
        Assert codec_result["codec_type"] is equal to streaming.OPUS_CODEC
        Assert codec_result["bitrate"] is equal to 256000
        Assert codec_result["sample_rate"] is equal to 48000
    
    Test called "test_manage_stream_quality":
        Let stream be create_test_audio_stream
        Let quality_config be streaming.QualityConfiguration with:
            adaptive_bitrate_enabled as true
            target_latency_ms as 100
            quality_levels as list containing 64000, 128000, 256000
            bandwidth_threshold as 0.8
        
        Let quality_result be streaming.manage_stream_quality with stream as stream and quality_config as quality_config
        
        Assert quality_result["success"] is true
        Assert quality_result["quality_adjusted"] is true
        Assert quality_result["current_bitrate"] is greater than 0
        Assert quality_result["current_latency_ms"] is greater than 0
        Assert quality_result["adaptation_active"] is true

Test Suite called "MIDI Integration Tests":
    
    Test called "test_create_midi_system":
        Let midi_config be midi.MIDIConfiguration with:
            input_devices as list containing "MIDI Keyboard"
            output_devices as list containing "Software Synthesizer"
            clock_source as midi.INTERNAL_CLOCK
            tempo as 120.0
        
        Let midi_system be midi.create_midi_system with midi_config as midi_config
        
        Assert midi_system is not None
        Assert length of midi_system["input_devices"] is equal to 1
        Assert length of midi_system["output_devices"] is equal to 1
        Assert midi_system["clock_source"] is equal to midi.INTERNAL_CLOCK
        Assert midi_system["tempo"] is equal to 120.0
        Assert midi_system["status"] is equal to midi.SYSTEM_READY
    
    Test called "test_connect_midi_device":
        Let system be create_test_midi_system
        Let device_config be midi.MIDIDeviceConfiguration with:
            device_name as "Test MIDI Keyboard"
            device_type as midi.INPUT_DEVICE
            channel_filter as list containing 1, 2, 3, 4
            message_filter as list containing midi.NOTE_ON, midi.NOTE_OFF, midi.CONTROL_CHANGE
        
        Let midi_device be midi.connect_midi_device with system as system and device_config as device_config
        
        Assert midi_device is not None
        Assert midi_device["device_name"] is equal to "Test MIDI Keyboard"
        Assert midi_device["device_type"] is equal to midi.INPUT_DEVICE
        Assert midi_device["connected"] is true
        Assert length of midi_device["channel_filter"] is equal to 4
        Assert length of midi_device["message_filter"] is equal to 3
    
    Test called "test_send_midi_message":
        Let device be create_test_midi_output_device
        Let note_on_message be midi.MIDIMessage with:
            message_type as midi.NOTE_ON
            channel as 1
            note as 60
            velocity as 127
            timestamp as current_timestamp
        
        Let midi_result be midi.send_midi_message with device as device and message as note_on_message
        
        Assert midi_result["success"] is true
        Assert midi_result["message_sent"] is true
        Assert midi_result["message_type"] is equal to midi.NOTE_ON
        Assert midi_result["timestamp_sent"] is greater than 0
        
        Let note_off_message be midi.MIDIMessage with:
            message_type as midi.NOTE_OFF
            channel as 1
            note as 60
            velocity as 0
            timestamp as current_timestamp plus 1000
        
        Let note_off_result be midi.send_midi_message with device as device and message as note_off_message
        
        Assert note_off_result["success"] is true
        Assert note_off_result["message_type"] is equal to midi.NOTE_OFF
    
    Test called "test_load_midi_file":
        Let midi_file_path be create_test_midi_file
        
        Let midi_sequence be midi.load_midi_file with file_path as midi_file_path
        
        Assert midi_sequence is not None
        Assert midi_sequence["track_count"] is greater than 0
        Assert midi_sequence["tempo_bpm"] is greater than 0
        Assert midi_sequence["time_division"] is greater than 0
        Assert midi_sequence["duration_ticks"] is greater than 0
        Assert length of midi_sequence["tracks"] is equal to midi_sequence["track_count"]
    
    Test called "test_create_midi_mapping":
        Let mapping_config be midi.MIDIMappingConfiguration with:
            controller_id as 1
            parameter_name as "filter_cutoff"
            min_value as 20.0
            max_value as 20000.0
            curve_type as midi.LOGARITHMIC_CURVE
            invert_range as false
        
        Let midi_mapping be midi.create_midi_mapping with mapping_config as mapping_config
        
        Assert midi_mapping is not None
        Assert midi_mapping["controller_id"] is equal to 1
        Assert midi_mapping["parameter_name"] is equal to "filter_cutoff"
        Assert midi_mapping["min_value"] is equal to 20.0
        Assert midi_mapping["max_value"] is equal to 20000.0
        Assert midi_mapping["curve_type"] is equal to midi.LOGARITHMIC_CURVE
    
    Test called "test_sync_midi_clock":
        Let system be create_test_midi_system  
        Let clock_config be midi.ClockConfiguration with:
            clock_source as midi.EXTERNAL_CLOCK
            sync_device as "MIDI Clock Device"
            tempo_follow as true
            clock_division as midi.QUARTER_NOTE
        
        Let clock_result be midi.sync_midi_clock with system as system and clock_config as clock_config
        
        Assert clock_result["success"] is true
        Assert clock_result["clock_synced"] is true
        Assert clock_result["clock_source"] is equal to midi.EXTERNAL_CLOCK
        Assert clock_result["sync_device"] is equal to "MIDI Clock Device"
        Assert system["clock_synchronized"] is true

Test Suite called "Integration and Cross-Module Tests":
    
    Test called "test_audio_core_synthesis_integration":
        Let audio_system be create_test_audio_system
        Let synthesizer be create_test_synthesizer
        
        Note: Generate audio with synthesizer and process through audio system
        Let synth_buffer be synthesis.generate_waveform with waveform_type as synthesis.SAWTOOTH and frequency as 220.0 and duration as 1.0
        
        Let processor be audio_core.AudioProcessor with:
            processor_type as audio_core.GAIN_PROCESSOR
            parameters as dictionary with "gain" as 0.8
        
        Let processed_synth = audio_core.process_audio_buffer with buffer as synth_buffer and processor as processor
        
        Assert processed_synth["success"] is true
        Assert processed_synth["processed_buffer"]["samples"] is equal to synth_buffer["samples"]
        Assert processed_synth["processed_buffer"]["peak_level"] is less than synth_buffer["peak_level"]
    
    Test called "test_effects_analysis_integration":
        Let clean_buffer be create_test_audio_buffer_with_tone with frequency as 440.0
        
        Note: Apply distortion effect
        Let distortion_config be effects.DistortionConfiguration with:
            drive_amount as 0.6
            distortion_type as effects.OVERDRIVE
            tone_control as 0.5
            output_level as 0.8
            oversampling as true
        
        Let distorted_buffer be effects.apply_distortion with buffer as clean_buffer and distortion_config as distortion_config
        
        Note: Analyze harmonic content
        Let spectrum_config be analysis.SpectrumConfiguration with:
            fft_size as 2048
            window_type as analysis.HANNING_WINDOW
            overlap_factor as 0.5
            frequency_range as list containing 20.0, 20000.0
        
        Let clean_analysis be analysis.analyze_spectrum with buffer as clean_buffer and analysis_config as spectrum_config
        Let distorted_analysis be analysis.analyze_spectrum with buffer as distorted_buffer and analysis_config as spectrum_config
        
        Assert distorted_analysis["harmonic_content"] is greater than clean_analysis["harmonic_content"]
        Assert distorted_analysis["spectral_centroid"] is greater than clean_analysis["spectral_centroid"]
    
    Test called "test_recording_streaming_integration":
        Let recorder be create_test_recorder
        Let stream_server be create_test_stream_server
        
        Note: Record audio and stream it
        Let recording_config be recording.OutputConfiguration with:
            output_path as "/tmp/stream_source.wav"
            file_format as recording.WAV_FORMAT
            quality_preset as recording.STREAMING_QUALITY
            automatic_naming as false
            max_file_size as 50000000
        
        Let recording_result be recording.start_recording with recorder as recorder and output_config as recording_config
        Assert recording_result["success"] is true
        
        Note: Simulate recording
        Wait 0.5 seconds
        
        Let stop_result be recording.stop_recording with recorder as recorder
        Assert stop_result["success"] is true
        
        Note: Stream the recorded file
        Let stream_config be recording.StreamConfiguration with:
            buffer_size as 1024
            preload_buffers as 8
            loop_enabled as true
            start_position as 0.0
        
        Let audio_stream be recording.stream_audio_file with file_path as recording_config["output_path"] and stream_config as stream_config
        
        Assert audio_stream["stream_ready"] is true
        Assert audio_stream["total_duration"] is approximately equal to stop_result["duration"]
    
    Test called "test_midi_synthesis_integration":
        Let midi_system be create_test_midi_system
        Let synthesizer be create_test_synthesizer
        
        Note: Send MIDI note to trigger synthesis
        Let midi_device be create_test_midi_output_device
        
        Let note_on_message be midi.MIDIMessage with:
            message_type as midi.NOTE_ON
            channel as 1
            note as 60
            velocity as 100
            timestamp as current_timestamp
        
        Let midi_result be midi.send_midi_message with device as midi_device and message as note_on_message
        Assert midi_result["success"] is true
        
        Note: Generate corresponding audio
        Let note_frequency be 261.63  Note: C4 = MIDI note 60
        Let synth_buffer be synthesis.generate_waveform with waveform_type as synthesis.SINE and frequency as note_frequency and duration as 1.0
        
        Assert synth_buffer["fundamental_frequency"] is approximately equal to note_frequency
        Assert synth_buffer["duration"] is approximately equal to 1.0
    
    Test called "test_full_audio_pipeline":
        Note: Test complete audio processing pipeline
        Let audio_system be create_test_audio_system
        Let synthesizer be create_test_synthesizer  
        Let recorder be create_test_recorder
        
        Note: 1. Generate audio with synthesis
        Let synth_buffer be synthesis.generate_waveform with waveform_type as synthesis.SAWTOOTH and frequency as 440.0 and duration as 2.0
        
        Note: 2. Apply effects
        Let filter_config be synthesis.FilterConfiguration with:
            filter_type as synthesis.LOW_PASS
            cutoff_frequency as 2000.0
            resonance as 0.3
            filter_slope as synthesis.SLOPE_12DB
            envelope_amount as 0.0
        
        Let filtered_buffer be synthesis.apply_filter with buffer as synth_buffer and filter_config as filter_config
        
        Let reverb_config be effects.ReverbConfiguration with:
            room_size as 0.4
            damping as 0.6
            wet_level as 0.2
            dry_level as 0.8
            pre_delay as 0.01
            reverb_type as effects.ROOM_REVERB
        
        Let final_buffer be effects.apply_reverb with buffer as filtered_buffer and reverb_config as reverb_config
        
        Note: 3. Analyze the result
        Let analysis_config be analysis.SpectrumConfiguration with:
            fft_size as 2048
            window_type as analysis.HANNING_WINDOW
            overlap_factor as 0.5
            frequency_range as list containing 20.0, 20000.0
        
        Let final_analysis be analysis.analyze_spectrum with buffer as final_buffer and analysis_config as analysis_config
        
        Note: 4. Save the processed audio
        Let save_config be recording.FormatConfiguration with:
            file_format as recording.WAV_FORMAT
            bit_depth as 24
            compression_level as 0
            metadata_embed as true
        
        Let save_result be recording.save_audio_file with buffer as final_buffer and file_path as "/tmp/pipeline_output.wav" and format_config as save_config
        
        Assert save_result["success"] is true
        Assert final_analysis["peak_frequency"] is approximately equal to 440.0
        Assert final_buffer["duration"] is approximately equal to 2.0
        Assert final_buffer["reverb_applied"] is true

Test Suite called "Error Handling and Edge Cases":
    
    Test called "test_invalid_audio_configuration":
        Let invalid_config be audio_core.AudioConfiguration with:
            sample_rate as 0
            buffer_size as -1
            channels as 0
            bit_depth as 99
            device_name as ""
            latency_mode as audio_core.LOW_LATENCY
        
        Try:
            Let audio_system be audio_core.create_audio_system with config as invalid_config
            Assert false  Note: Should not reach here
        Catch error:
            Assert true   Note: Expected to fail with invalid configuration
    
    Test called "test_synthesis_frequency_limits":
        Note: Test synthesis with extreme frequencies
        Let very_low_freq be synthesis.generate_waveform with waveform_type as synthesis.SINE and frequency as 0.1 and duration as 1.0
        Let very_high_freq be synthesis.generate_waveform with waveform_type as synthesis.SINE and frequency as 50000.0 and duration as 1.0
        
        Assert very_low_freq is not None
        Assert very_high_freq is not None
        Assert very_low_freq["fundamental_frequency"] is approximately equal to 0.1
        Assert very_high_freq["fundamental_frequency"] is approximately equal to 50000.0
    
    Test called "test_effects_extreme_parameters":
        Let test_buffer be create_test_audio_buffer_with_tone with frequency as 1000.0
        
        Note: Test extreme compression settings
        Let extreme_compressor_config be effects.CompressorConfiguration with:
            threshold as -60.0
            ratio as 100.0
            attack_time as 0.0001
            release_time as 10.0
            knee_width as 0.0
            makeup_gain as 60.0
        
        Let compressed_buffer be effects.apply_compression with buffer as test_buffer and compressor_config as extreme_compressor_config
        
        Assert compressed_buffer is not None
        Assert compressed_buffer["compression_applied"] is true
        Assert compressed_buffer["peak_level"] is less than or equal to 1.0
    
    Test called "test_analysis_empty_buffer":
        Let empty_buffer be audio_core.create_audio_buffer with channels as 2 and samples as 0 and sample_rate as 44100
        
        Let spectrum_config be analysis.SpectrumConfiguration with:
            fft_size as 1024
            window_type as analysis.HANNING_WINDOW
            overlap_factor as 0.5
            frequency_range as list containing 20.0, 20000.0
        
        Let empty_analysis be analysis.analyze_spectrum with buffer as empty_buffer and analysis_config as spectrum_config
        
        Assert empty_analysis["analysis_valid"] is false
        Assert empty_analysis["error_message"] contains "empty" or empty_analysis["error_message"] contains "insufficient"
    
    Test called "test_recording_invalid_path":
        Let recorder be create_test_recorder
        Let invalid_output_config be recording.OutputConfiguration with:
            output_path as "/invalid/path/that/does/not/exist/recording.wav"
            file_format as recording.WAV_FORMAT
            quality_preset as recording.HIGH_QUALITY
            automatic_naming as false
            max_file_size as 100000000
        
        Let recording_result be recording.start_recording with recorder as recorder and output_config as invalid_output_config
        
        Assert recording_result["success"] is false
        Assert recording_result["error_message"] contains "path" or recording_result["error_message"] contains "directory"
    
    Test called "test_streaming_connection_failure":
        Let client_config be streaming.StreamClientConfiguration with:
            server_address as "nonexistent.server.com"
            server_port as 9999
            protocol as streaming.WEBRTC_PROTOCOL
            audio_codec as streaming.OPUS_CODEC
            buffer_size as 1024
            jitter_buffer_size as 4
        
        Let stream_client be streaming.create_stream_client with client_config as client_config
        
        Let connection_config be streaming.ConnectionConfiguration with:
            stream_url as "rtc://nonexistent.server.com:9999/stream"
            auto_reconnect as false
            connection_timeout as 1000
            quality_preference as streaming.LOW_LATENCY
        
        Let connection_result be streaming.connect_to_stream with client as stream_client and connection_config as connection_config
        
        Assert connection_result["success"] is false
        Assert connection_result["error_message"] contains "connection" or connection_result["error_message"] contains "timeout"
    
    Test called "test_midi_device_not_found":
        Let system be create_test_midi_system
        Let invalid_device_config be midi.MIDIDeviceConfiguration with:
            device_name as "Nonexistent MIDI Device"
            device_type as midi.INPUT_DEVICE
            channel_filter as list containing 1
            message_filter as list containing midi.NOTE_ON
        
        Let midi_device be midi.connect_midi_device with system as system and device_config as invalid_device_config
        
        Assert midi_device["connected"] is false
        Assert midi_device["error_message"] contains "not found" or midi_device["error_message"] contains "unavailable"

