Note: Comprehensive Test Suite for Cloud Infrastructure Integration
Tests all cloud modules: docker, kubernetes, aws, azure, gcp, serverless, terraform
Validates production-ready functionality with complete error handling and edge cases

Built-in functions and testing framework are automatically available in Runa programs:End Note

Note: Test Docker container management and operations
Process called "test_docker_operations":
    Display "Testing Docker container and image operations..."
    
    Note: Test Docker image operations
    Let images_result be list_docker_images
    Assert that "success" is in images_result
    Assert that "images" is in images_result
    
    Note: Test image building with comprehensive configuration
    Let build_config be empty Dictionary[String, Any]
    Set build_config at "dockerfile_path" to "./Dockerfile.test"
    Set build_config at "tag" to "runa-test:latest"
    Set build_config at "context" to "."
    Set build_config at "build_args" to empty Dictionary[String, String]
    Set build_config at "build_args" at "VERSION" to "test"
    Set build_config at "build_args" at "ENVIRONMENT" to "testing"
    
    Let build_result be build_docker_image with build_config
    Assert that "success" is in build_result
    
    Note: Test container creation with full configuration
    Let container_config be empty Dictionary[String, Any]
    Set container_config at "image" to "nginx:alpine"
    Set container_config at "name" to "test-nginx-container"
    Set container_config at "ports" to list containing "8080:80", "8443:443"
    Set container_config at "environment" to list containing "ENV=test", "DEBUG=true"
    Set container_config at "volumes" to list containing "/tmp/test:/app/data"
    Set container_config at "network" to "bridge"
    Set container_config at "restart_policy" to "unless-stopped"
    
    Let create_result be create_docker_container with container_config
    Assert that "success" is in create_result
    Assert that "container_id" is in create_result
    
    Let container_id be create_result at "container_id" as String
    
    Note: Test container lifecycle management
    Let start_result be start_docker_container with container_id
    Assert that start_result at "success" is true
    
    Let containers_result be list_docker_containers with true
    Assert that "success" is in containers_result
    Assert that "containers" is in containers_result
    
    Note: Test container monitoring
    Let stats_config be empty Dictionary[String, Any]
    Set stats_config at "container" to container_id
    Set stats_config at "stream" to false
    
    Let stats_result be get_docker_container_stats with stats_config
    Assert that "success" is in stats_result
    Assert that "stats" is in stats_result
    
    Note: Test container logs
    Let log_config be empty Dictionary[String, Any]
    Set log_config at "container" to container_id
    Set log_config at "tail" to 50
    Set log_config at "timestamps" to true
    
    Let logs_result be get_docker_container_logs with log_config
    Assert that "success" is in logs_result
    Assert that "logs" is in logs_result
    
    Note: Test Docker Compose operations
    Let compose_config be empty Dictionary[String, Any]
    Set compose_config at "compose_file" to "docker-compose.test.yml"
    Set compose_config at "project_name" to "runa-test-project"
    Set compose_config at "detached" to true
    
    Let compose_up_result be docker_compose_up with compose_config
    Assert that "success" is in compose_up_result
    
    Let compose_status_result be docker_compose_status with "runa-test-project"
    Assert that "success" is in compose_status_result
    Assert that "services" is in compose_status_result
    
    Note: Test network operations
    Let network_config be empty Dictionary[String, Any]
    Set network_config at "name" to "test-network"
    Set network_config at "driver" to "bridge"
    Set network_config at "subnet" to "172.20.0.0/16"
    
    Let network_result be create_docker_network with network_config
    Assert that "success" is in network_result
    
    Let networks_result be list_docker_networks
    Assert that "success" is in networks_result
    Assert that "networks" is in networks_result
    
    Note: Test volume operations
    Let volume_config be empty Dictionary[String, Any]
    Set volume_config at "name" to "test-volume"
    Set volume_config at "driver" to "local"
    
    Let volume_result be create_docker_volume with volume_config
    Assert that "success" is in volume_result
    
    Note: Test container cleanup
    Let stop_result be stop_docker_container with container_id
    Assert that stop_result at "success" is true
    
    Let remove_result be remove_docker_container with container_id
    Assert that remove_result at "success" is true
    
    Display "✓ Docker operations tests passed"

Note: Test Kubernetes cluster management and orchestration
Process called "test_kubernetes_operations":
    Display "Testing Kubernetes cluster management..."
    
    Note: Test cluster connectivity
    Let cluster_info be get_kubernetes_cluster_info
    Assert that "success" is in cluster_info
    Assert that "version" is in cluster_info
    Assert that "node_count" is in cluster_info
    
    Note: Test deployment creation
    Let deployment_config be empty Dictionary[String, Any]
    Set deployment_config at "name" to "test-web-deployment"
    Set deployment_config at "namespace" to "default"
    Set deployment_config at "image" to "nginx:1.20"
    Set deployment_config at "replicas" to 2
    Set deployment_config at "ports" to list containing 80
    Set deployment_config at "environment" to empty Dictionary[String, String]
    Set deployment_config at "environment" at "ENV" to "test"
    Set deployment_config at "environment" at "LOG_LEVEL" to "info"
    Set deployment_config at "labels" to empty Dictionary[String, String]
    Set deployment_config at "labels" at "app" to "test-web"
    Set deployment_config at "labels" at "version" to "1.0"
    
    Let deployment_result be create_kubernetes_deployment with deployment_config
    Assert that "success" is in deployment_result
    Assert that "deployment_name" is in deployment_result
    
    Note: Test service creation
    Let service_config be empty Dictionary[String, Any]
    Set service_config at "name" to "test-web-service"
    Set service_config at "namespace" to "default"
    Set service_config at "selector" to empty Dictionary[String, String]
    Set service_config at "selector" at "app" to "test-web"
    Set service_config at "ports" to list containing empty Dictionary[String, Integer]
    Set service_config at "ports" at 0 at "port" to 80
    Set service_config at "ports" at 0 at "targetPort" to 80
    Set service_config at "type" to "ClusterIP"
    
    Let service_result be create_kubernetes_service with service_config
    Assert that "success" is in service_result
    
    Note: Test ConfigMap creation
    Let configmap_config be empty Dictionary[String, Any]
    Set configmap_config at "name" to "test-config"
    Set configmap_config at "namespace" to "default"
    Set configmap_config at "data" to empty Dictionary[String, String]
    Set configmap_config at "data" at "database.url" to "postgresql://localhost:5432/testdb"
    Set configmap_config at "data" at "cache.redis.url" to "redis://localhost:6379"
    Set configmap_config at "data" at "app.debug" to "true"
    
    Let configmap_result be create_kubernetes_configmap with configmap_config
    Assert that "success" is in configmap_result
    
    Note: Test Secret creation
    Let secret_config be empty Dictionary[String, Any]
    Set secret_config at "name" to "test-secrets"
    Set secret_config at "namespace" to "default"
    Set secret_config at "data" to empty Dictionary[String, String]
    Set secret_config at "data" at "database.password" to "test-password"
    Set secret_config at "data" at "api.key" to "test-api-key-12345"
    
    Let secret_result be create_kubernetes_secret with secret_config
    Assert that "success" is in secret_result
    
    Note: Test Horizontal Pod Autoscaler
    Let hpa_config be empty Dictionary[String, Any]
    Set hpa_config at "name" to "test-web-hpa"
    Set hpa_config at "namespace" to "default"
    Set hpa_config at "target_deployment" to "test-web-deployment"
    Set hpa_config at "min_replicas" to 2
    Set hpa_config at "max_replicas" to 10
    Set hpa_config at "cpu_threshold" to 70
    
    Let hpa_result be create_kubernetes_hpa with hpa_config
    Assert that "success" is in hpa_result
    
    Note: Test Persistent Volume creation
    Let pv_config be empty Dictionary[String, Any]
    Set pv_config at "name" to "test-storage"
    Set pv_config at "size" to "5Gi"
    Set pv_config at "access_modes" to list containing "ReadWriteOnce"
    Set pv_config at "storage_class" to "standard"
    
    Let pv_result be create_kubernetes_persistent_volume with pv_config
    Assert that "success" is in pv_result
    
    Note: Test resource listing
    Let deployments_list be list_kubernetes_deployments with "default"
    Assert that "success" is in deployments_list
    Assert that "deployments" is in deployments_list
    
    Let services_list be list_kubernetes_services with "default"
    Assert that "success" is in services_list
    Assert that "services" is in services_list
    
    Note: Test resource scaling
    Let scale_result be scale_kubernetes_deployment with "test-web-deployment" and "default" and 3
    Assert that "success" is in scale_result
    
    Display "✓ Kubernetes operations tests passed"

Note: Test AWS cloud services integration
Process called "test_aws_operations":
    Display "Testing AWS cloud services integration..."
    
    Note: Test EC2 instance operations
    Let instance_config be empty Dictionary[String, Any]
    Set instance_config at "image_id" to "ami-0abcdef1234567890"
    Set instance_config at "instance_type" to "t3.micro"
    Set instance_config at "key_name" to "test-keypair"
    Set instance_config at "security_groups" to list containing "default"
    Set instance_config at "user_data" to "#!/bin/bash\necho 'Test instance' > /tmp/test.txt"
    Set instance_config at "tags" to empty Dictionary[String, String]
    Set instance_config at "tags" at "Name" to "RunaTestInstance"
    Set instance_config at "tags" at "Environment" to "test"
    
    Let instance_result be create_ec2_instance with instance_config
    Assert that "success" is in instance_result
    
    Let instances_list be list_ec2_instances
    Assert that "success" is in instances_list
    Assert that "instances" is in instances_list
    
    Note: Test S3 bucket operations
    Let bucket_name be "runa-test-bucket-" concatenated with current_timestamp as String
    Let create_bucket_result be create_s3_bucket with bucket_name and "us-west-2"
    Assert that "success" is in create_bucket_result
    
    Let buckets_list be list_s3_buckets
    Assert that "success" is in buckets_list
    Assert that "buckets" is in buckets_list
    
    Note: Test S3 object operations
    Let upload_config be empty Dictionary[String, Any]
    Set upload_config at "bucket" to bucket_name
    Set upload_config at "key" to "test/sample.txt"
    Set upload_config at "content" to "This is a test file for Runa AWS integration"
    Set upload_config at "content_type" to "text/plain"
    Set upload_config at "metadata" to empty Dictionary[String, String]
    Set upload_config at "metadata" at "creator" to "runa-test-suite"
    Set upload_config at "metadata" at "purpose" to "integration-testing"
    
    Let upload_result be upload_s3_object with upload_config
    Assert that "success" is in upload_result
    
    Let download_result be download_s3_object with bucket_name and "test/sample.txt"
    Assert that "success" is in download_result
    Assert that "content" is in download_result
    
    Let objects_list be list_s3_objects with bucket_name and "test/"
    Assert that "success" is in objects_list
    Assert that "objects" is in objects_list
    
    Note: Test Lambda function operations
    Let function_config be empty Dictionary[String, Any]
    Set function_config at "function_name" to "runa-test-function"
    Set function_config at "runtime" to "python3.9"
    Set function_config at "handler" to "lambda_function.lambda_handler"
    Set function_config at "role" to "arn:aws:iam::123456789012:role/lambda-test-role"
    Set function_config at "zip_file" to "UEsDBAoAAAAIAA=="  Note: Base64 encoded test zip
    Set function_config at "environment_variables" to empty Dictionary[String, String]
    Set function_config at "environment_variables" at "TEST_VAR" to "runa-integration"
    Set function_config at "environment_variables" at "S3_BUCKET" to bucket_name
    
    Let function_result be create_lambda_function with function_config
    Assert that "success" is in function_result
    
    Let functions_list be list_lambda_functions
    Assert that "success" is in functions_list
    Assert that "functions" is in functions_list
    
    Note: Test RDS operations
    Let db_config be empty Dictionary[String, Any]
    Set db_config at "db_instance_identifier" to "runa-test-db"
    Set db_config at "db_instance_class" to "db.t3.micro"
    Set db_config at "engine" to "postgres"
    Set db_config at "master_username" to "testuser"
    Set db_config at "master_password" to "testpassword123"
    Set db_config at "allocated_storage" to 20
    Set db_config at "vpc_security_group_ids" to list containing "sg-12345678"
    
    Let db_result be create_rds_instance with db_config
    Assert that "success" is in db_result
    
    Note: Test VPC operations
    Let vpc_config be empty Dictionary[String, Any]
    Set vpc_config at "cidr_block" to "10.0.0.0/16"
    Set vpc_config at "enable_dns_hostnames" to true
    Set vpc_config at "enable_dns_support" to true
    Set vpc_config at "tags" to empty Dictionary[String, String]
    Set vpc_config at "tags" at "Name" to "RunaTestVPC"
    
    Let vpc_result be create_vpc with vpc_config
    Assert that "success" is in vpc_result
    
    Note: Test CloudFormation operations
    Let stack_config be empty Dictionary[String, Any]
    Set stack_config at "stack_name" to "runa-test-stack"
    Set stack_config at "template_body" to "{\"AWSTemplateFormatVersion\": \"2010-09-09\", \"Resources\": {}}"
    Set stack_config at "parameters" to empty List[Dictionary[String, String]]
    Set stack_config at "tags" to empty Dictionary[String, String]
    Set stack_config at "tags" at "Project" to "Runa"
    Set stack_config at "tags" at "Environment" to "Test"
    
    Let stack_result be create_cloudformation_stack with stack_config
    Assert that "success" is in stack_result
    
    Let stacks_list be list_cloudformation_stacks
    Assert that "success" is in stacks_list
    Assert that "stacks" is in stacks_list
    
    Display "✓ AWS operations tests passed"

