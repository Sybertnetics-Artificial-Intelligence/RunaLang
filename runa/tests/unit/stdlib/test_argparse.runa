Note:
Comprehensive Test Suite for ArgParse Module

Tests all functionality including:
- Positional and optional arguments
- Type conversion and validation
- Subcommands and command groups
- Mutually exclusive groups and dependencies
- Argument file expansion
- Config/env var overrides
- Help/usage generation
- Error handling and edge cases
:End Note

Note: Test Framework Setup
Process called "run_test" that takes test_name as String and test_function as Process returns Boolean:
    Try:
        Let result be test_function
        If result:
            Display "✓ " plus test_name plus " - PASSED"
            Return true
        Otherwise:
            Display "✗ " plus test_name plus " - FAILED"
            Return false
    Catch error:
        Display "✗ " plus test_name plus " - ERROR: " plus error.message
        Return false

Process called "run_test_suite" that takes suite_name as String and tests as List[Tuple[String, Process]] returns Integer:
    Display "Running " plus suite_name plus " tests..."
    Let passed be 0
    Let total be length of tests
    For each test in tests:
        Let test_name be test[0]
        Let test_function be test[1]
        If run_test with test_name as test_name and test_function as test_function:
            Set passed to passed plus 1
    Display "Results: " plus passed plus "/" plus total plus " tests passed"
    Return passed

Note: Basic Argument Tests
Process called "test_positional_argument" returns Boolean:
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let arg be Argument with:
        name as "input"
        type as STRING
        required as true
        help as "Input file"
        positional as true
    Let parser be add_argument with parser as parser and argument as arg
    Let argv be list containing "file.txt"
    Let result be parse_args with parser as parser and argv as argv
    Match result:
        When ParseSuccess with values as args:
            Return args["input"] is equal to "file.txt"
        Otherwise:
            Return false

Process called "test_optional_argument" returns Boolean:
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let arg be Argument with:
        name as "--verbose"
        type as BOOLEAN
        default as false
        help as "Enable verbose"
    Let parser be add_argument with parser as parser and argument as arg
    Let argv be list containing "--verbose"
    Let result be parse_args with parser as parser and argv as argv
    Match result:
        When ParseSuccess with values as args:
            Return args["--verbose"] is true
        Otherwise:
            Return false

Process called "test_type_conversion" returns Boolean:
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let arg be Argument with:
        name as "--count"
        type as INTEGER
        default as 1
        help as "Count"
    Let parser be add_argument with parser as parser and argument as arg
    Let argv be list containing "--count", "5"
    Let result be parse_args with parser as parser and argv as argv
    Match result:
