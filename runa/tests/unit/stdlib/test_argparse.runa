Note: Subcommand Tests
Process called "test_subcommand" returns Boolean:
    Process called "handle_run" that takes args as Dictionary[String, Any] returns None:
        Return None
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let subcmd be Subcommand with:
        name as "run"
        help as "Run command"
        arguments as list containing Argument with:
            name as "input"
            type as STRING
            required as true
            help as "Input file"
            positional as true
        handler as handle_run
        subcommands as list containing
        parent as None
        hidden as false
    Let parser be add_subcommand with parser as parser and subcommand as subcmd
    Let argv be list containing "run", "file.txt"
    Let result be parse_args with parser as parser and argv as argv
    Match result:
        When ParseSuccess with values as args and command as cmd:
            Return cmd is equal to "run" and args["input"] is equal to "file.txt"
        Otherwise:
            Return false

