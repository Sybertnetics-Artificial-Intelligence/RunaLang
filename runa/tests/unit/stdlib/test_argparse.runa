            Return args["--count"] is equal to 5
        Otherwise:
            Return false

Process called "test_default_value" returns Boolean:
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let arg be Argument with:
        name as "--mode"
        type as STRING
