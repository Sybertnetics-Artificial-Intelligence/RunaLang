    Let parser be add_argument with parser as parser and argument as arg2
    Let parser be add_argument with parser as parser and argument as arg3
    Let argv be list containing "--input", "/tmp/test.txt", "-v"
    Let result be parse_args with parser as parser and argv as argv
    Match result:
        When ParseSuccess with values as args:
            Return args["--input"] is equal to "/tmp/test.txt" and args["--verbose"] is true
        Otherwise:
            Return false

