Process called "test_large_argument_parsing" returns Boolean:
    Note: Test parsing performance with multiple arguments
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    
    Note: Add multiple arguments
    For i from 1 to 10:
        Let arg_name be "--arg" with message string_from_integer with num as i
        Let arg be Argument with:
            name as arg_name
            type as STRING
            help as "Argument " with message string_from_integer with num as i
        Set parser to add_argument with parser as parser and argument as arg
    
    Note: Create argv with all arguments
    Let argv be list containing
    For i from 1 to 10:
        Let arg_name be "--arg" with message string_from_integer with num as i
        Let arg_value be "value" with message string_from_integer with num as i
        Add arg_name to argv
        Add arg_value to argv
    
    Let result be parse_args with parser as parser and argv as argv
    Match result:
        When ParseSuccess with values as args:
            Return args["--arg1"] is equal to "value1"
        Otherwise:
            Return false

Process called "test_validation_performance" returns Boolean:
    Note: Test performance of validation
    Process called "simple_validator" that takes value as String returns ValidationResult:
        If length of value is less than 3:
            Return ValidationError with message as "Too short"
        Return ValidationSuccess with value as value
    
    Let parser be create_parser with program_name as "testapp" and description as "Test CLI"
    Let arg be Argument with:
        name as "--text"
        type as STRING
        validator as simple_validator
        help as "Text input"
