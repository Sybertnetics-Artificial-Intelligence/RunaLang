Note:
Comprehensive Test Suite for Runa Built-ins Module

Tests all built-in functionality including exceptions, functions, globals, and operators.
Validates specification compliance and production-ready behavior with edge cases.
:End Note

Import "builtins/exceptions" as exceptions
Import "builtins/functions" as functions
Import "builtins/globals" as globals
Import "builtins/operators" as operators

Note: Exception System Tests
Process called "test_exception_creation" returns Boolean:
    Note: Test basic exception creation
    Let basic_exception be exceptions.create_exception with exception_type as "TestException" and message as "Test message"
    
    If basic_exception["message"] is not equal to "Test message":
        Return false
    If basic_exception["error_code"] is not equal to "TestException":
        Return false
    If basic_exception["cause"] is not None:
        Return false
    If length of basic_exception["stack_trace"] is equal to 0:
        Return false
    
    Return true

Process called "test_type_error_creation" returns Boolean:
    Note: Test TypeError creation with proper fields
    Let type_error be exceptions.create_type_error with expected as "String" and actual as "Integer" and variable as "user_name"
    
    If type_error["expected_type"] is not equal to "String":
        Return false
    If type_error["actual_type"] is not equal to "Integer":
        Return false
    If type_error["variable_name"] is not equal to "user_name":
        Return false
    If not (type_error["message"] contains "Expected type String"):
        Return false
    If not (type_error["message"] contains "user_name"):
        Return false
    
    Return true

Process called "test_value_error_creation" returns Boolean:
    Note: Test ValueError creation with constraint validation
    Let value_error be exceptions.create_value_error with value as -5 and constraint as "Value must be positive"
    
    If value_error["invalid_value"] is not equal to -5:
        Return false
    If value_error["constraint_violated"] is not equal to "Value must be positive":
        Return false
    If not (value_error["message"] contains "-5"):
        Return false
    If not (value_error["message"] contains "constraint"):
        Return false
    
    Return true

Process called "test_exception_chaining" returns Boolean:
    Note: Test exception chaining mechanism
    Let original_error be exceptions.create_value_error with value as 0 and constraint as "Division by zero"
    Let chained_error be exceptions.create_runtime_error with operation as "calculate" and context as dictionary with "step" as "division"
    
    Let final_exception be exceptions.chain_exception with new_exception as chained_error and cause as original_error
    
    If final_exception["cause"] is not equal to original_error:
        Return false
    
    Let chain be exceptions.get_exception_chain with exception as final_exception
    If length of chain is not equal to 2:
        Return false
    If chain[0] is not equal to final_exception:
        Return false
    If chain[1] is not equal to original_error:
        Return false
    
    Return true

Process called "test_exception_formatting" returns Boolean:
    Note: Test exception message formatting
    Let test_error be exceptions.create_type_error with expected as "List" and actual as "String" and variable as "items"
    Let formatted be exceptions.format_exception with exception as test_error
    
    If not (formatted contains "TypeError"):
        Return false
    If not (formatted contains "List"):
        Return false
    If not (formatted contains "String"):
        Return false
    If not (formatted contains "items"):
        Return false
    
    Return true

Process called "test_error_recovery_suggestions" returns Boolean:
    Note: Test error recovery suggestion system
    Let type_error be exceptions.create_type_error with expected as "Integer" and actual as "String" and variable as "count"
    Let suggestions be exceptions.suggest_error_resolution with exception as type_error
    
    If length of suggestions is equal to 0:
        Return false
    
    Let found_type_suggestion be false
    For each suggestion in suggestions:
        If suggestion contains "type":
            Set found_type_suggestion to true
    
    Return found_type_suggestion

Note: Built-in Functions Tests
Process called "test_mathematical_functions" returns Boolean:
    Note: Test mathematical utility functions
    If functions.abs with value as -42 is not equal to 42:
        Return false
    If functions.abs with value as 42 is not equal to 42:
        Return false
    If functions.abs with value as 0 is not equal to 0:
        Return false
    
    Let numbers be list containing 10, 5, 8, 3, 15
    If functions.min with values as numbers is not equal to 3:
        Return false
    If functions.max with values as numbers is not equal to 15:
        Return false
    If functions.sum with values as numbers is not equal to 41:
        Return false
    
    If functions.pow with base as 2 and exponent as 3 is not equal to 8:
        Return false
    If functions.sqrt with value as 25 is not equal to 5:
        Return false
    
    Return true

Process called "test_type_conversion_functions" returns Boolean:
    Note: Test type conversion utilities
    If functions.to_string with value as 42 is not equal to "42":
        Return false
    If functions.to_string with value as true is not equal to "true":
        Return false
    
    If functions.to_integer with value as "123" is not equal to 123:
        Return false
    If functions.to_integer with value as 45.7 is not equal to 45:
        Return false
    If functions.to_integer with value as true is not equal to 1:
        Return false
    If functions.to_integer with value as false is not equal to 0:
        Return false
    
    If functions.to_float with value as "3.14" is not equal to 3.14:
        Return false
    If functions.to_float with value as 42 is not equal to 42.0:
        Return false
    
    If functions.to_boolean with value as "true" is not true:
        Return false
    If functions.to_boolean with value as "false" is not false:
        Return false
    If functions.to_boolean with value as 1 is not true:
        Return false
    If functions.to_boolean with value as 0 is not false:
        Return false
    
    Return true

Process called "test_string_manipulation" returns Boolean:
    Note: Test string processing functions
    Let test_string be "Hello, World!"
    
    If functions.length with collection as test_string is not equal to 13:
        Return false
    
    Let words be functions.split with text as "apple,banana,cherry" and delimiter as ","
    If length of words is not equal to 3:
        Return false
    If words[0] is not equal to "apple":
        Return false
    If words[2] is not equal to "cherry":
        Return false
    
    Let joined be functions.join with strings as words and separator as "|"
    If joined is not equal to "apple|banana|cherry":
        Return false
    
    Let trimmed be functions.trim with text as "  hello  "
    If trimmed is not equal to "hello":
        Return false
    
    Let capitalized be functions.capitalize with text as "hello world"
    If not (capitalized contains "Hello"):
        Return false
    
    Return true

Process called "test_collection_functions" returns Boolean:
    Note: Test collection manipulation utilities
    Let test_list be list containing 1, 2, 3
    Let appended be functions.append with collection as test_list and item as 4
    If length of appended is not equal to 4:
        Return false
    If appended[3] is not equal to 4:
        Return false
    
    Let prepended be functions.prepend with collection as test_list and item as 0
    If prepended[0] is not equal to 0:
        Return false
    
    If not (functions.contains with collection as test_list and item as 2):
        Return false
    If functions.contains with collection as test_list and item as 10:
        Return false
    
    Let index be functions.index_of with collection as test_list and item as 2
    If index is not equal to 1:
        Return false
    
    Let reversed be functions.reverse with collection as test_list
    If reversed[0] is not equal to 3:
        Return false
    If reversed[2] is not equal to 1:
        Return false
    
    Let unsorted be list containing 3, 1, 4, 1, 5
    Let sorted be functions.sort with collection as unsorted
    If sorted[0] is not equal to 1:
        Return false
    If sorted[4] is not equal to 5:
        Return false
    
    Let unique_list be functions.unique with collection as unsorted
    If length of unique_list is not equal to 4:  Note: 3, 1, 4, 5
        Return false
    
    Return true

Process called "test_utility_functions" returns Boolean:
    Note: Test utility and helper functions
    Let range_result be functions.range with start as 1 and end as 5 and step as 1
    If length of range_result is not equal to 4:  Note: 1, 2, 3, 4
        Return false
    If range_result[0] is not equal to 1:
        Return false
    If range_result[3] is not equal to 4:
        Return false
    
    Let test_list be list containing "a", "b", "c"
    Let enumerated be functions.enumerate with collection as test_list
    If length of enumerated is not equal to 3:
        Return false
    If enumerated[0]["index"] is not equal to 0:
        Return false
    If enumerated[1]["value"] is not equal to "b":
        Return false
    
    Let list1 be list containing 1, 2, 3
    Let list2 be list containing "a", "b", "c"
    Let collections be list containing list1, list2
    Let zipped be functions.zip with collections as collections
    If length of zipped is not equal to 3:
        Return false
    If zipped[0][0] is not equal to 1:
        Return false
    If zipped[1][1] is not equal to "b":
        Return false
    
    Return true

Process called "test_validation_functions" returns Boolean:
    Note: Test validation and checking functions
    If not (functions.is_empty with collection as ""):
        Return false
    If not (functions.is_empty with collection as list containing):
        Return false
    If functions.is_empty with collection as "hello":
        Return false
    
    If not (functions.is_numeric with value as "123"):
        Return false
    If not (functions.is_alphabetic with value as "hello"):
        Return false
    If not (functions.is_alphanumeric with value as "hello123"):
        Return false
    
    Return true

Note: Global Variables Tests
Process called "test_mathematical_constants" returns Boolean:
    Note: Test mathematical constant definitions
    If globals.PI is not equal to 3.141592653589793:
        Return false
    If globals.E is not equal to 2.718281828459045:
        Return false
    If globals.TAU is not equal to 6.283185307179586:
        Return false
    If globals.GOLDEN_RATIO is not equal to 1.618033988749895:
        Return false
    
    Return true

Process called "test_numeric_limits" returns Boolean:
    Note: Test numeric limit constants
    If globals.MAX_INTEGER is not equal to 9223372036854775807:
        Return false
    If globals.MIN_INTEGER is not equal to -9223372036854775808:
        Return false
    If globals.MAX_FLOAT is not equal to 1.7976931348623157e+308:
        Return false
    If globals.MIN_FLOAT is not equal to -1.7976931348623157e+308:
        Return false
    
    Return true

Process called "test_system_information" returns Boolean:
    Note: Test system information access
    If globals.RUNA_VERSION is not equal to "2.1.0":
        Return false
    If globals.RUNA_MAJOR_VERSION is not equal to 2:
        Return false
    If globals.RUNA_MINOR_VERSION is not equal to 1:
        Return false
    If globals.RUNA_PATCH_VERSION is not equal to 0:
        Return false
    
    Let platform be globals.get_platform_name
    If length of platform is equal to 0:
        Return false
    
    Let cpu_count be globals.get_cpu_count
    If cpu_count is less than 1:
        Return false
    
    Return true

Process called "test_global_variable_access" returns Boolean:
    Note: Test global variable retrieval system
    Let pi_value be globals.get_global_variable with name as "PI"
    If pi_value is not equal to globals.PI:
        Return false
    
    Let invalid_global be globals.get_global_variable with name as "NONEXISTENT"
    If invalid_global is not None:
        Return false
    
    Let global_list be globals.list_global_variables
    If length of global_list is equal to 0:
        Return false
    
    Let found_pi be false
    For each global_name in global_list:
        If global_name is equal to "PI":
            Set found_pi to true
    
    If not found_pi:
        Return false
    
    Return true

Process called "test_runtime_statistics" returns Boolean:
    Note: Test runtime statistics collection
    Let stats be globals.get_runtime_statistics
    
    If not (stats contains key "runa_version"):
        Return false
    If stats["runa_version"] is not equal to "2.1.0":
        Return false
    
    If not (stats contains key "platform"):
        Return false
    If not (stats contains key "cpu_count"):
        Return false
    If not (stats contains key "memory_size_bytes"):
        Return false
    
    Return true

Note: Operator System Tests
Process called "test_arithmetic_operators" returns Boolean:
    Note: Test arithmetic operator implementations
    If operators.add with left as 5 and right as 3 is not equal to 8:
        Return false
    If operators.subtract with left as 10 and right as 4 is not equal to 6:
        Return false
    If operators.multiply with left as 6 and right as 7 is not equal to 42:
        Return false
    If operators.divide with left as 15 and right as 3 is not equal to 5:
        Return false
    If operators.modulo with left as 17 and right as 5 is not equal to 2:
        Return false
    If operators.power with base as 2 and exponent as 4 is not equal to 16:
        Return false
    
    If operators.negate with value as 5 is not equal to -5:
        Return false
    If operators.absolute with value as -8 is not equal to 8:
        Return false
    
    Return true

Process called "test_comparison_operators" returns Boolean:
    Note: Test comparison operator implementations
    If not (operators.equals with left as 5 and right as 5):
        Return false
    If operators.equals with left as 5 and right as 3:
        Return false
    
    If operators.not_equals with left as 5 and right as 5:
        Return false
    If not (operators.not_equals with left as 5 and right as 3):
        Return false
    
    If not (operators.less_than with left as 3 and right as 7):
        Return false
    If operators.less_than with left as 7 and right as 3:
        Return false
    
    If not (operators.greater_than with left as 9 and right as 4):
        Return false
    If operators.greater_than with left as 4 and right as 9:
        Return false
    
    If operators.compare with left as 5 and right as 3 is not equal to 1:
        Return false
    If operators.compare with left as 3 and right as 5 is not equal to -1:
        Return false
    If operators.compare with left as 5 and right as 5 is not equal to 0:
        Return false
    
    Return true

Process called "test_logical_operators" returns Boolean:
    Note: Test logical operator implementations
    If not (operators.logical_and with left as true and right as true):
        Return false
    If operators.logical_and with left as true and right as false:
        Return false
    
    If not (operators.logical_or with left as true and right as false):
        Return false
    If operators.logical_or with left as false and right as false:
        Return false
    
    If operators.logical_not with value as true:
        Return false
    If not (operators.logical_not with value as false):
        Return false
    
    If operators.logical_xor with left as true and right as true:
        Return false
    If not (operators.logical_xor with left as true and right as false):
        Return false
    
    Return true

Process called "test_string_operators" returns Boolean:
    Note: Test string operation implementations
    Let concatenated be operators.string_concatenate with left as "Hello" and right as "World"
    If concatenated is not equal to "HelloWorld":
        Return false
    
    Let repeated be operators.string_repeat with text as "Hi" and count as 3
    If repeated is not equal to "HiHiHi":
        Return false
    
    If not (operators.string_contains with text as "Hello World" and substring as "World"):
        Return false
    If operators.string_contains with text as "Hello" and substring as "World":
        Return false
    
    If not (operators.string_starts_with with text as "Hello World" and prefix as "Hello"):
        Return false
    If operators.string_starts_with with text as "Hello" and prefix as "World":
        Return false
    
    If not (operators.string_ends_with with text as "Hello World" and suffix as "World"):
        Return false
    If operators.string_ends_with with text as "Hello" and suffix as "World":
        Return false
    
    Return true

Process called "test_collection_operators" returns Boolean:
    Note: Test collection operation implementations
    Let list1 be list containing 1, 2, 3
    Let list2 be list containing 4, 5, 6
    Let concatenated be operators.list_concatenate with left as list1 and right as list2
    If length of concatenated is not equal to 6:
        Return false
    If concatenated[3] is not equal to 4:
        Return false
    
    If not (operators.list_contains with collection as list1 and item as 2):
        Return false
    If operators.list_contains with collection as list1 and item as 10:
        Return false
    
    Let index be operators.list_index with collection as list1 and item as 2
    If index is not equal to 1:
        Return false
    
    Let count be operators.list_count with collection as list containing 1, 2, 2, 3 and item as 2
    If count is not equal to 2:
        Return false
    
    Let dict be dictionary with "a" as 1, "b" as 2
    If not (operators.dictionary_contains_key with dict as dict and key as "a"):
        Return false
    If operators.dictionary_contains_key with dict as dict and key as "c":
        Return false
    
    If not (operators.dictionary_contains_value with dict as dict and value as 1):
        Return false
    If operators.dictionary_contains_value with dict as dict and value as 10:
        Return false
    
    Return true

Process called "test_operator_precedence" returns Boolean:
    Note: Test operator precedence calculations
    Let power_precedence be operators.get_operator_precedence with operator as "**"
    Let multiply_precedence be operators.get_operator_precedence with operator as "*"
    Let add_precedence be operators.get_operator_precedence with operator as "+"
    
    If power_precedence is not greater than multiply_precedence:
        Return false
    If multiply_precedence is not greater than add_precedence:
        Return false
    
    Let associativity be operators.get_operator_associativity with operator as "**"
    If associativity is not equal to "right":
        Return false
    
    Let left_assoc be operators.get_operator_associativity with operator as "+"
    If left_assoc is not equal to "left":
        Return false
    
    Return true

Process called "test_operator_overloading" returns Boolean:
    Note: Test operator overloading support
    If not (operators.can_overload_operator with operator as "+"):
        Return false
    If not (operators.can_overload_operator with operator as "=="):
        Return false
    If operators.can_overload_operator with operator as "=":
        Return false
    
    Let registered be operators.register_operator_overload with type_name as "CustomType" and operator as "+" and implementation as "custom_add"
    If not registered:
        Return false
    
    Return true

Process called "test_natural_language_mapping" returns Boolean:
    Note: Test natural language operator mapping
    If operators.map_natural_language_operator with operator_phrase as "plus" is not equal to "+":
        Return false
    If operators.map_natural_language_operator with operator_phrase as "is greater than" is not equal to ">":
        Return false
    If operators.map_natural_language_operator with operator_phrase as "contains" is not equal to "in":
        Return false
    
    Return true

Note: Integration Tests
Process called "test_error_handling_integration" returns Boolean:
    Note: Test integration between exceptions and other modules
    Try:
        Let result be functions.to_integer with value as "invalid"
        Return false  Note: Should have thrown exception
    Catch error:
        If not (error["error_code"] is equal to "TypeError"):
            Return false
    
    Try:
        Let result be operators.divide with left as 10 and right as 0
        Return false  Note: Should have thrown exception
    Catch error:
        If not (error["error_code"] is equal to "ValueError"):
            Return false
    
    Return true

Process called "test_type_system_integration" returns Boolean:
    Note: Test type checking across modules
    If not (operators.validate_operator_arguments with operator as "+" and left as 5 and right as 3):
        Return false
    If operators.validate_operator_arguments with operator as "+" and left as "hello" and right as 3:
        Return false
    
    If functions.get_type_name with value as 42 is not equal to "Integer":
        Return false
    If functions.get_type_name with value as "hello" is not equal to "String":
        Return false
    
    Return true

Note: Edge Case Tests
Process called "test_edge_cases" returns Boolean:
    Note: Test edge cases and boundary conditions
    
    Note: Empty collections
    Try:
        Let result be functions.min with values as list containing
        Return false  Note: Should throw error
    Catch error:
        If not (error["error_code"] is equal to "ValueError"):
            Return false
    
    Note: Division by zero
    Try:
        Let result be operators.divide with left as 5 and right as 0
        Return false  Note: Should throw error
    Catch error:
        If not (error["message"] contains "Division by zero"):
            Return false
    
    Note: Negative square root
    Try:
        Let result be functions.sqrt with value as -4
        Return false  Note: Should throw error
    Catch error:
        If not (error["message"] contains "negative"):
            Return false
    
    Note: String boundary conditions
    Let empty_trimmed be functions.trim with text as ""
    If empty_trimmed is not equal to "":
        Return false
    
    Let single_char be functions.capitalize with text as "a"
    If single_char is not equal to "A":
        Return false
    
    Return true

Note: Performance Tests
Process called "test_performance_characteristics" returns Boolean:
    Note: Test performance with reasonable data sizes
    Let large_list be list containing
    For i from 1 to 1000:
        Add i to large_list
    
    Let sum_result be functions.sum with values as large_list
    If sum_result is not equal to 500500:  Note: Sum of 1 to 1000
        Return false
    
    Let unique_result be functions.unique with collection as large_list
    If length of unique_result is not equal to 1000:
        Return False
    
    Return true

Note: Test Runner and Results
Process called "run_all_builtins_tests" returns Dictionary[String, Boolean]:
    Let results be dictionary with:
        "test_exception_creation" as test_exception_creation,
        "test_type_error_creation" as test_type_error_creation,
        "test_value_error_creation" as test_value_error_creation,
        "test_exception_chaining" as test_exception_chaining,
        "test_exception_formatting" as test_exception_formatting,
        "test_error_recovery_suggestions" as test_error_recovery_suggestions,
        "test_mathematical_functions" as test_mathematical_functions,
        "test_type_conversion_functions" as test_type_conversion_functions,
        "test_string_manipulation" as test_string_manipulation,
        "test_collection_functions" as test_collection_functions,
        "test_utility_functions" as test_utility_functions,
        "test_validation_functions" as test_validation_functions,
        "test_mathematical_constants" as test_mathematical_constants,
        "test_numeric_limits" as test_numeric_limits,
        "test_system_information" as test_system_information,
        "test_global_variable_access" as test_global_variable_access,
        "test_runtime_statistics" as test_runtime_statistics,
        "test_arithmetic_operators" as test_arithmetic_operators,
        "test_comparison_operators" as test_comparison_operators,
        "test_logical_operators" as test_logical_operators,
        "test_string_operators" as test_string_operators,
        "test_collection_operators" as test_collection_operators,
        "test_operator_precedence" as test_operator_precedence,
        "test_operator_overloading" as test_operator_overloading,
        "test_natural_language_mapping" as test_natural_language_mapping,
        "test_error_handling_integration" as test_error_handling_integration,
        "test_type_system_integration" as test_type_system_integration,
        "test_edge_cases" as test_edge_cases,
        "test_performance_characteristics" as test_performance_characteristics
    
    Return results

Process called "display_test_results" that takes results as Dictionary[String, Boolean] returns None:
    Let passed be 0
    Let total be 0
    
    Display "Runa Built-ins Module Test Results:"
    Display "======================================="
    
    For each test_name and passed_status in results:
        Set total to total plus 1
        If passed_status:
            Set passed to passed plus 1
            Display test_name with message ": PASSED"
        Otherwise:
            Display test_name with message ": FAILED"
    
    Display ""
    Display "Summary: " with message passed with message "/" with message total with message " tests passed"
    
    If passed is equal to total:
        Display "All tests passed! Built-ins module is working correctly."
    Otherwise:
        Display "Some tests failed. Please check the implementation."
    
    Return None

Note: Main test execution
Let test_results be run_all_builtins_tests
display_test_results with results as test_results