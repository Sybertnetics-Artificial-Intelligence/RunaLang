Note:
Runa Standard Library Test Suite: Complete Compression Ecosystem

Comprehensive tests for all compression modules including the unified interface,
individual algorithm implementations (BZ2, GZIP, LZMA), and archive formats 
(TAR, ZIP). Covers all aspects of production-ready compression functionality.

Test Coverage:
- Unified compression interface with all algorithms
- Individual module testing (BZ2, GZIP, LZMA, TAR, ZIP)
- Configuration validation and error handling
- Batch processing and performance optimization
- Integration between compression and archive formats
- Unicode and binary data handling
- Error recovery and diagnostics
- Memory management and large file support
- Cross-platform compatibility and web standards
- Archive operations and metadata preservation
:End Note

Import "stdlib/compress/compress" as compress
Import "stdlib/compress/bz2" as bz2
Import "stdlib/compress/gzip" as gzip
Import "stdlib/compress/lzma" as lzma
Import "stdlib/compress/tar" as tar
Import "stdlib/compress/zip" as zip
Import "stdlib/testing/framework" as test

Note: Test Data and Fixtures
Let test_string_small be "Hello, World! This is a small test string for compression testing."

Let test_string_medium be "Lorem ipsum dolor sit amet, consectetur adipiscing elit. " plus
    "Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. " plus
    "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris " plus
    "nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in " plus
    "reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla " plus
    "pariatur. Excepteur sint occaecat cupidatat non proident, sunt in " plus
    "culpa qui officia deserunt mollit anim id est laborum. " times 10

Let test_string_large be test_string_medium times 100

Let test_binary_data be list containing 0, 1, 2, 3, 4, 5, 255, 254, 253, 0, 128, 127, 65, 66, 67

Let test_unicode_data be "Testing Unicode: αβγδε 中文 한글 🌟🚀💫 Ñoël café naïve résumé"

Let test_empty_data be ""

Let test_repetitive_data be "AAAAAAAAAA" times 1000
:End Note

Note: Core Compression Interface Tests
Process called "test_compression_algorithms_basic" returns test.TestResult:
    Let algorithms be list containing "gzip", "bzip2", "lzma"
    Let test_results be list containing
    
    For each algorithm in algorithms:
        Let compression_result be compress.compress_data with:
            data as test_string_medium
            algorithm as algorithm
            config as None
        
        Match compression_result:
            When "success":
                Let decompression_result be compress.decompress_data with:
                    compressed_data as compression_result.compressed_data
                    algorithm as algorithm
                    config as None
                
                Match decompression_result:
                    When "success":
                        Let is_data_equal be decompression_result.decompressed_data is equal to test_string_medium
                        Add test.create_assertion with:
                            description as algorithm plus " basic compression/decompression roundtrip"
                            condition as is_data_equal
                            expected as test_string_medium
                            actual as decompression_result.decompressed_data
                        to test_results
                    When "error":
                        Add test.create_assertion with:
                            description as algorithm plus " decompression should succeed"
                            condition as false
                            expected as "success"
                            actual as decompression_result.error_code
                        to test_results
            When "error":
                Add test.create_assertion with:
                    description as algorithm plus " compression should succeed"
                    condition as false
                    expected as "success"
                    actual as compression_result.error_code
                to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_algorithms_with_levels" returns test.TestResult:
    Let compression_levels be list containing 1, 6, 9
    Let test_results be list containing
    
    For each level in compression_levels:
        Let config be compress.create_compression_config with:
            compression_level as level
            enable_verification as true
        
        Let compression_result be compress.compress_data with:
            data as test_string_medium
            algorithm as "gzip"
            config as config
        
        Match compression_result:
            When "success":
                Add test.create_assertion with:
                    description as "GZIP compression level " plus level as String plus " should succeed"
                    condition as compression_result.compression_ratio is greater than 0.0
                    expected as "positive ratio"
                    actual as compression_result.compression_ratio as String
                to test_results
                
                Let is_compressed be length of compression_result.compressed_data is less than length of test_string_medium
                Add test.create_assertion with:
                    description as "GZIP level " plus level as String plus " should reduce data size"
                    condition as is_compressed
                    expected as "compressed size less than original"
                    actual as "original: " plus length of test_string_medium as String plus ", compressed: " plus length of compression_result.compressed_data as String
                to test_results
            When "error":
                Add test.create_assertion with:
                    description as "GZIP level " plus level as String plus " compression should succeed"
                    condition as false
                    expected as "success"
                    actual as compression_result.error_code
                to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_unicode_handling" returns test.TestResult:
    Let test_results be list containing
    
    Let compression_result be compress.compress_data with:
        data as test_unicode_data
        algorithm as "gzip"
        config as None
    
    Match compression_result:
        When "success":
            Let decompression_result be compress.decompress_data with:
                compressed_data as compression_result.compressed_data
                algorithm as "gzip"
                config as None
            
            Match decompression_result:
                When "success":
                    Let is_unicode_preserved be decompression_result.decompressed_data is equal to test_unicode_data
                    Add test.create_assertion with:
                        description as "Unicode data should be preserved through compression"
                        condition as is_unicode_preserved
                        expected as test_unicode_data
                        actual as decompression_result.decompressed_data
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "Unicode decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as decompression_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "Unicode compression should succeed"
                condition as false
                expected as "success"
                actual as compression_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_empty_data" returns test.TestResult:
    Let test_results be list containing
    
    Let compression_result be compress.compress_data with:
        data as test_empty_data
        algorithm as "gzip"
        config as None
    
    Match compression_result:
        When "error":
            Let is_empty_error be compression_result.error_code is equal to "COMPRESS_EMPTY_INPUT"
            Add test.create_assertion with:
                description as "Empty data should return appropriate error"
                condition as is_empty_error
                expected as "COMPRESS_EMPTY_INPUT"
                actual as compression_result.error_code
            to test_results
        When "success":
            Add test.create_assertion with:
                description as "Empty data compression should fail"
                condition as false
                expected as "error"
                actual as "success"
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_repetitive_data" returns test.TestResult:
    Let test_results be list containing
    
    Let compression_result be compress.compress_data with:
        data as test_repetitive_data
        algorithm as "gzip"
        config as None
    
    Match compression_result:
        When "success":
            Let good_compression_ratio be compression_result.compression_ratio is less than 0.1
            Add test.create_assertion with:
                description as "Repetitive data should compress very well"
                condition as good_compression_ratio
                expected as "compression ratio < 0.1"
                actual as compression_result.compression_ratio as String
            to test_results
            
            Let decompression_result be compress.decompress_data with:
                compressed_data as compression_result.compressed_data
                algorithm as "gzip"
                config as None
            
            Match decompression_result:
                When "success":
                    Let is_data_preserved be decompression_result.decompressed_data is equal to test_repetitive_data
                    Add test.create_assertion with:
                        description as "Repetitive data should be preserved through compression"
                        condition as is_data_preserved
                        expected as "data preserved"
                        actual as length of decompression_result.decompressed_data as String plus " chars"
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "Repetitive data decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as decompression_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "Repetitive data compression should succeed"
                condition as false
                expected as "success"
                actual as compression_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Configuration and Error Handling Tests
Process called "test_invalid_algorithm" returns test.TestResult:
    Let test_results be list containing
    
    Let compression_result be compress.compress_data with:
        data as test_string_small
        algorithm as "invalid_algorithm"
        config as None
    
    Match compression_result:
        When "error":
            Let is_unsupported_error be compression_result.error_code is equal to "COMPRESS_UNSUPPORTED_ALGORITHM"
            Add test.create_assertion with:
                description as "Invalid algorithm should return unsupported error"
                condition as is_unsupported_error
                expected as "COMPRESS_UNSUPPORTED_ALGORITHM"
                actual as compression_result.error_code
            to test_results
        When "success":
            Add test.create_assertion with:
                description as "Invalid algorithm should fail"
                condition as false
                expected as "error"
                actual as "success"
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_invalid_compression_level" returns test.TestResult:
    Let test_results be list containing
    
    Let invalid_config be compress.create_compression_config with:
        compression_level as 15
        enable_verification as true
    
    Let compression_result be compress.compress_data with:
        data as test_string_small
        algorithm as "gzip"
        config as invalid_config
    
    Match compression_result:
        When "error":
            Let is_invalid_config_error be compression_result.error_code is equal to "COMPRESS_INVALID_CONFIG"
            Add test.create_assertion with:
                description as "Invalid compression level should return config error"
                condition as is_invalid_config_error
                expected as "COMPRESS_INVALID_CONFIG"
                actual as compression_result.error_code
            to test_results
        When "success":
            Add test.create_assertion with:
                description as "Invalid compression level should fail"
                condition as false
                expected as "error"
                actual as "success"
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_config_validation" returns test.TestResult:
    Let test_results be list containing
    
    Let valid_config be compress.create_compression_config with:
        compression_level as 6
        enable_verification as true
        buffer_size as 65536
        memory_limit as 1048576
    
    Let validation_result be compress.validate_compression_config with config as valid_config
    
    Add test.create_assertion with:
        description as "Valid configuration should pass validation"
        condition as validation_result.is_valid
        expected as true
        actual as validation_result.is_valid
    to test_results
    
    Let invalid_config be compress.create_compression_config with:
        compression_level as -1
        enable_verification as true
        buffer_size as 100
        memory_limit as 1000
    
    Let invalid_validation_result be compress.validate_compression_config with config as invalid_config
    
    Add test.create_assertion with:
        description as "Invalid configuration should fail validation"
        condition as not invalid_validation_result.is_valid
        expected as false
        actual as invalid_validation_result.is_valid
    to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Archive Format Integration Tests
Process called "test_compression_with_tar_integration" returns test.TestResult:
    Let test_results be list containing
    
    Let tar_config be compress.create_tar_config with:
        compression_algorithm as "gzip"
        compression_level as 6
        enable_verification as true
    
    Let files_to_archive be list containing "test_file1.txt", "test_file2.txt"
    
    Let archive_result be compress.create_compressed_archive with:
        files as files_to_archive
        archive_path as "test_archive.tar.gz"
        format as "tar"
        config as tar_config
    
    Match archive_result:
        When "success":
            Add test.create_assertion with:
                description as "TAR with GZIP compression should succeed"
                condition as archive_result.compression_ratio is greater than 0.0
                expected as "positive compression ratio"
                actual as archive_result.compression_ratio as String
            to test_results
            
            Let extraction_result be compress.extract_compressed_archive with:
                archive_path as "test_archive.tar.gz"
                output_directory as "test_output"
                config as tar_config
            
            Match extraction_result:
                When "success":
                    Add test.create_assertion with:
                        description as "TAR archive extraction should succeed"
                        condition as extraction_result.files_extracted is equal to length of files_to_archive
                        expected as length of files_to_archive as String
                        actual as extraction_result.files_extracted as String
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "TAR archive extraction should succeed"
                        condition as false
                        expected as "success"
                        actual as extraction_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "TAR with GZIP compression should succeed"
                condition as false
                expected as "success"
                actual as archive_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_with_zip_integration" returns test.TestResult:
    Let test_results be list containing
    
    Let zip_config be compress.create_zip_config with:
        compression_algorithm as "lzma"
        compression_level as 9
        enable_encryption as false
    
    Let files_to_zip be list containing "document1.txt", "document2.txt", "image.png"
    
    Let zip_result be compress.create_compressed_archive with:
        files as files_to_zip
        archive_path as "test_archive.zip"
        format as "zip"
        config as zip_config
    
    Match zip_result:
        When "success":
            Add test.create_assertion with:
                description as "ZIP with LZMA compression should succeed"
                condition as zip_result.files_processed is equal to length of files_to_zip
                expected as length of files_to_zip as String
                actual as zip_result.files_processed as String
            to test_results
            
            Let list_result be compress.list_archive_contents with:
                archive_path as "test_archive.zip"
                config as zip_config
            
            If list_result.success:
                Add test.create_assertion with:
                    description as "ZIP archive should list correct number of files"
                    condition as list_result.total_files is equal to length of files_to_zip
                    expected as length of files_to_zip as String
                    actual as list_result.total_files as String
                to test_results
            Otherwise:
                Add test.create_assertion with:
                    description as "ZIP archive listing should succeed"
                    condition as false
                    expected as "success"
                    actual as list_result.error_code
                to test_results
        When "error":
            Add test.create_assertion with:
                description as "ZIP with LZMA compression should succeed"
                condition as false
                expected as "success"
                actual as zip_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Performance and Memory Management Tests
Process called "test_compression_large_data_memory_efficiency" returns test.TestResult:
    Let test_results be list containing
    
    Let memory_limited_config be compress.create_compression_config with:
        compression_level as 6
        enable_verification as true
        buffer_size as 8192
        memory_limit as 2097152
        enable_streaming as true
    
    Let compression_result be compress.compress_data with:
        data as test_string_large
        algorithm as "gzip"
        config as memory_limited_config
    
    Match compression_result:
        When "success":
            Add test.create_assertion with:
                description as "Large data compression with memory limits should succeed"
                condition as compression_result.memory_used is less than or equal to 2097152
                expected as "memory usage <= 2MB"
                actual as compression_result.memory_used as String plus " bytes"
            to test_results
            
            Let is_efficient_compression be compression_result.compression_ratio is less than 0.8
            Add test.create_assertion with:
                description as "Large data should compress efficiently"
                condition as is_efficient_compression
                expected as "compression ratio < 0.8"
                actual as compression_result.compression_ratio as String
            to test_results
        When "error":
            Add test.create_assertion with:
                description as "Large data compression should succeed"
                condition as false
                expected as "success"
                actual as compression_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_batch_processing" returns test.TestResult:
    Let test_results be list containing
    
    Let data_batch be list containing test_string_small, test_string_medium, test_unicode_data
    
    Let batch_result be compress.compress_data_batch with:
        data_list as data_batch
        algorithm as "bzip2"
        config as None
    
    Match batch_result:
        When "success":
            Add test.create_assertion with:
                description as "Batch compression should process all items"
                condition as batch_result.items_processed is equal to length of data_batch
                expected as length of data_batch as String
                actual as batch_result.items_processed as String
            to test_results
            
            Add test.create_assertion with:
                description as "Batch compression should have no failures"
                condition as length of batch_result.failed_items is equal to 0
                expected as "0"
                actual as length of batch_result.failed_items as String
            to test_results
        When "error":
            Add test.create_assertion with:
                description as "Batch compression should succeed"
                condition as false
                expected as "success"
                actual as batch_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Cross-Platform and Edge Case Tests
Process called "test_compression_cross_platform_compatibility" returns test.TestResult:
    Let test_results be list containing
    
    Let cross_platform_config be compress.create_compression_config with:
        compression_level as 6
        enable_verification as true
        normalize_line_endings as true
        preserve_file_attributes as false
    
    Let test_data_with_line_endings be "Line 1\nLine 2\r\nLine 3\rLine 4"
    
    Let compression_result be compress.compress_data with:
        data as test_data_with_line_endings
        algorithm as "gzip"
        config as cross_platform_config
    
    Match compression_result:
        When "success":
            Let decompression_result be compress.decompress_data with:
                compressed_data as compression_result.compressed_data
                algorithm as "gzip"
                config as cross_platform_config
            
            Match decompression_result:
                When "success":
                    Add test.create_assertion with:
                        description as "Cross-platform compression should preserve data semantics"
                        condition as length of decompression_result.decompressed_data is greater than 0
                        expected as "non-empty result"
                        actual as length of decompression_result.decompressed_data as String plus " chars"
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "Cross-platform decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as decompression_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "Cross-platform compression should succeed"
                condition as false
                expected as "success"
                actual as compression_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_binary_data_handling" returns test.TestResult:
    Let test_results be list containing
    
    Let compression_result be compress.compress_binary_data with:
        binary_data as test_binary_data
        algorithm as "lzma"
