                    Let is_binary_preserved be decompression_result.decompressed_data is equal to test_binary_data
                    Add test.create_assertion with:
                        description as "Binary data should be preserved exactly"
                        condition as is_binary_preserved
                        expected as test_binary_data as String
                        actual as decompression_result.decompressed_data as String
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "Binary decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as decompression_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "Binary compression should succeed"
                condition as false
                expected as "success"
                actual as compression_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Individual Module Tests
Process called "test_bz2_module_comprehensive" returns test.TestResult:
    Let test_results be list containing
    
    Note: Test basic BZ2 compression
    Let bz2_result be bz2.bz2_compress with:
        data as test_string_medium
        config as None
    
    Match bz2_result:
        When "success":
            Add test.create_assertion with:
                description as "BZ2 module compression should succeed"
                condition as bz2_result.compression_ratio is greater than 0.0
                expected as "positive compression ratio"
                actual as bz2_result.compression_ratio as String
            to test_results
            
            Let bz2_decompress_result be bz2.bz2_decompress with:
                compressed_data as bz2_result.compressed_data
                config as None
            
            Match bz2_decompress_result:
                When "success":
                    Add test.create_assertion with:
                        description as "BZ2 roundtrip should preserve data exactly"
                        condition as bz2_decompress_result.decompressed_data is equal to test_string_medium
                        expected as test_string_medium
                        actual as bz2_decompress_result.decompressed_data
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "BZ2 decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as bz2_decompress_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "BZ2 compression should succeed"
                condition as false
                expected as "success"
                actual as bz2_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_gzip_module_comprehensive" returns test.TestResult:
    Let test_results be list containing
    
    Note: Test GZIP compression with headers
    Let gzip_config be gzip.create_gzip_config with:
        compression_level as 6
        use_gzip_headers as true
        enable_crc_check as true
    
    Let gzip_result be gzip.gzip_compress with:
        data as test_string_medium
        config as gzip_config
    
    Match gzip_result:
        When "success":
            Add test.create_assertion with:
                description as "GZIP module compression should succeed"
                condition as gzip_result.compression_ratio is greater than 0.0
                expected as "positive compression ratio"
                actual as gzip_result.compression_ratio as String
            to test_results
            
            Add test.create_assertion with:
                description as "GZIP should include valid headers"
                condition as gzip_result.has_valid_header
                expected as true
                actual as gzip_result.has_valid_header
            to test_results
            
            Let gzip_decompress_result be gzip.gzip_decompress with:
                compressed_data as gzip_result.compressed_data
                config as gzip_config
            
            Match gzip_decompress_result:
                When "success":
                    Add test.create_assertion with:
                        description as "GZIP roundtrip should preserve data exactly"
                        condition as gzip_decompress_result.decompressed_data is equal to test_string_medium
                        expected as test_string_medium
                        actual as gzip_decompress_result.decompressed_data
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "GZIP decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as gzip_decompress_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "GZIP compression should succeed"
                condition as false
                expected as "success"
                actual as gzip_result.error_code
            to test_results
    
    Note: Test DEFLATE-only compression
    Let deflate_result be gzip.deflate_compress with:
        data as test_string_small
        config as None
    
    Match deflate_result:
        When "success":
            Add test.create_assertion with:
                description as "DEFLATE compression should succeed"
                condition as deflate_result.compression_ratio is greater than 0.0
                expected as "positive compression ratio"
                actual as deflate_result.compression_ratio as String
            to test_results
        When "error":
            Add test.create_assertion with:
                description as "DEFLATE compression should succeed"
                condition as false
                expected as "success"
                actual as deflate_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_lzma_module_comprehensive" returns test.TestResult:
    Let test_results be list containing
    
    Note: Test LZMA compression
    Let lzma_config be lzma.create_lzma_config with:
        compression_level as 6
        enable_integrity_check as true
        enable_extreme_mode as false
    
    Let lzma_result be lzma.lzma_compress with:
        data as test_string_medium
        config as lzma_config
    
    Match lzma_result:
        When "success":
            Add test.create_assertion with:
                description as "LZMA module compression should succeed"
                condition as lzma_result.compression_ratio is greater than 0.0
                expected as "positive compression ratio"
                actual as lzma_result.compression_ratio as String
            to test_results
            
            Let lzma_decompress_result be lzma.lzma_decompress with:
                compressed_data as lzma_result.compressed_data
                config as lzma_config
            
            Match lzma_decompress_result:
                When "success":
                    Add test.create_assertion with:
                        description as "LZMA roundtrip should preserve data exactly"
                        condition as lzma_decompress_result.decompressed_data is equal to test_string_medium
                        expected as test_string_medium
                        actual as lzma_decompress_result.decompressed_data
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as "LZMA decompression should succeed"
                        condition as false
                        expected as "success"
                        actual as lzma_decompress_result.error_code
                    to test_results
        When "error":
            Add test.create_assertion with:
                description as "LZMA compression should succeed"
                condition as false
                expected as "success"
                actual as lzma_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_tar_module_comprehensive" returns test.TestResult:
    Let test_results be list containing
    
    Note: Test TAR archive creation
    Let tar_config be tar.create_tar_config with:
        compression_algorithm as "gzip"
        compression_level as 6
        enable_verification as true
        preserve_permissions as true
    
    Let files_to_archive be list containing "test1.txt", "test2.txt", "dir/test3.txt"
    
    Let tar_result be tar.create_tar_archive with:
        files as files_to_archive
        archive_path as "test.tar.gz"
        config as tar_config
    
    Match tar_result:
        When "success":
            Add test.create_assertion with:
                description as "TAR archive creation should succeed"
                condition as tar_result.files_processed is equal to length of files_to_archive
                expected as length of files_to_archive as String
                actual as tar_result.files_processed as String
            to test_results
            
            Let tar_list_result be tar.list_tar_contents with:
                archive_path as "test.tar.gz"
                config as tar_config
            
            If tar_list_result.success:
                Add test.create_assertion with:
                    description as "TAR should list correct number of files"
                    condition as tar_list_result.total_files is equal to length of files_to_archive
                    expected as length of files_to_archive as String
                    actual as tar_list_result.total_files as String
                to test_results
            Otherwise:
                Add test.create_assertion with:
                    description as "TAR listing should succeed"
                    condition as false
                    expected as "success"
                    actual as tar_list_result.error_code
                to test_results
        When "error":
            Add test.create_assertion with:
                description as "TAR archive creation should succeed"
                condition as false
                expected as "success"
                actual as tar_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_zip_module_comprehensive" returns test.TestResult:
    Let test_results be list containing
    
    Note: Test ZIP archive creation
    Let zip_config be zip.create_zip_config with:
        compression_method as "deflate"
        compression_level as 6
        enable_zip64 as true
        enable_encryption as false
    
    Let files_to_zip be list containing "doc1.txt", "doc2.txt", "images/pic.png"
    
    Let zip_result be zip.create_zip_archive with:
        files as files_to_zip
        archive_path as "test.zip"
        config as zip_config
    
    Match zip_result:
        When "success":
            Add test.create_assertion with:
                description as "ZIP archive creation should succeed"
                condition as zip_result.files_processed is equal to length of files_to_zip
                expected as length of files_to_zip as String
                actual as zip_result.files_processed as String
            to test_results
            
            Let zip_list_result be zip.list_zip_contents with:
                archive_path as "test.zip"
                config as zip_config
            
            If zip_list_result.success:
                Add test.create_assertion with:
                    description as "ZIP should list correct number of files"
                    condition as zip_list_result.total_files is equal to length of files_to_zip
                    expected as length of files_to_zip as String
                    actual as zip_list_result.total_files as String
                to test_results
            Otherwise:
                Add test.create_assertion with:
                    description as "ZIP listing should succeed"
                    condition as false
                    expected as "success"
                    actual as zip_list_result.error_code
                to test_results
        When "error":
            Add test.create_assertion with:
                description as "ZIP archive creation should succeed"
                condition as false
                expected as "success"
                actual as zip_result.error_code
            to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Comprehensive Compression Algorithm Tests
Process called "test_all_algorithms_efficiency" returns test.TestResult:
    Let test_results be list containing
    Let algorithms be list containing "gzip", "bzip2", "lzma"
    
    For each algorithm in algorithms:
        Let compression_result be compress.compress_data with:
            data as test_repetitive_data
            algorithm as algorithm
            config as None
        
        Match compression_result:
            When "success":
                Add test.create_assertion with:
                    description as algorithm plus " should compress repetitive data efficiently"
                    condition as compression_result.compression_ratio is less than 0.2
                    expected as "compression ratio < 0.2"
                    actual as compression_result.compression_ratio as String
                to test_results
            When "error":
                Add test.create_assertion with:
                    description as algorithm plus " compression should succeed"
                    condition as false
                    expected as "success"
                    actual as compression_result.error_code
                to test_results
    
    Return test.combine_test_results with results as test_results

Process called "test_compression_levels_across_algorithms" returns test.TestResult:
    Let test_results be list containing
    Let algorithms be list containing "gzip", "bzip2", "lzma"
    Let levels be list containing 1, 6, 9
    
    For each algorithm in algorithms:
        For each level in levels:
            Let config be compress.create_compression_config with:
                compression_level as level
                enable_verification as true
            
            Let compression_result be compress.compress_data with:
                data as test_string_medium
                algorithm as algorithm
                config as config
            
            Match compression_result:
                When "success":
                    Add test.create_assertion with:
                        description as algorithm plus " level " plus level as String plus " should succeed"
                        condition as compression_result.compression_ratio is greater than 0.0
                        expected as "positive ratio"
                        actual as compression_result.compression_ratio as String
                    to test_results
                When "error":
                    Add test.create_assertion with:
                        description as algorithm plus " level " plus level as String plus " should succeed"
                        condition as false
                        expected as "success"
                        actual as compression_result.error_code
                    to test_results
    
    Return test.combine_test_results with results as test_results
:End Note

Note: Test Suite Execution
Process called "run_all_compression_tests" returns test.TestSuiteResult:
    Let test_suite be test.create_test_suite with name as "Complete Compression Ecosystem Tests"
    
    Note: Unified interface tests
    Add test_compression_algorithms_basic to test_suite
    Add test_compression_algorithms_with_levels to test_suite
    Add test_compression_unicode_handling to test_suite
    Add test_compression_empty_data to test_suite
    Add test_compression_repetitive_data to test_suite
    Add test_invalid_algorithm to test_suite
    Add test_invalid_compression_level to test_suite
    Add test_compression_config_validation to test_suite
    Add test_compression_with_tar_integration to test_suite
    Add test_compression_with_zip_integration to test_suite
    Add test_compression_large_data_memory_efficiency to test_suite
    Add test_compression_batch_processing to test_suite
    Add test_compression_cross_platform_compatibility to test_suite
    Add test_compression_binary_data_handling to test_suite
    
    Note: Individual module tests
    Add test_bz2_module_comprehensive to test_suite
    Add test_gzip_module_comprehensive to test_suite
    Add test_lzma_module_comprehensive to test_suite
    Add test_tar_module_comprehensive to test_suite
    Add test_zip_module_comprehensive to test_suite
    
    Note: Cross-algorithm tests
    Add test_all_algorithms_efficiency to test_suite
    Add test_compression_levels_across_algorithms to test_suite
    
    Return test.execute_test_suite with suite as test_suite
:End Note