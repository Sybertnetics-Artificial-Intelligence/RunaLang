Process called "test_calendar_operations":
    Display "Testing calendar date operations..."
    
    Let current_date be get_current_date()
    Let formatted_date be format_date with current_date and "YYYY-MM-DD"
    Display "Current date: " with message formatted_date
    
    Let next_month be add_months with current_date and 1
    Let days_difference be calculate_days_between with current_date and next_month
    
    Display "Days until next month: " with message days_difference
    
    If days_difference is greater than 25:
        Display "Calendar date calculations working correctly"
    Otherwise:
        Display "Error: Invalid date calculation"

Process called "test_leap_year_calculations":
    Display "Testing leap year functionality..."
    
    Let test_years be list containing 2020, 2021, 2022, 2024, 2100, 2000
    
    For each year in test_years:
        Let is_leap be is_leap_year with year
        Display "Year " with message year with message ": " with message is_leap
        
        If year is equal to 2020 or year is equal to 2024 or year is equal to 2000:
            If is_leap is not equal to True:
                Display "Error: " with message year with message " should be a leap year"
        Otherwise:
            If year is equal to 2100:
                If is_leap is not equal to False:
                    Display "Error: " with message year with message " should not be a leap year (century rule)"
            Otherwise:
                If is_leap is not equal to False:
                    Display "Error: " with message year with message " should not be a leap year"
    
    Display "Leap year calculations completed"

Process called "test_calendar_display":
    Display "Testing calendar display functionality..."
    
    Let calendar_month be generate_calendar with 2024 and 7
    Display "July 2024 Calendar:"
    Display calendar_month
    
    Let calendar_config be empty Dictionary[String, Any]
    Set calendar_config["show_week_numbers"] to True
    Set calendar_config["start_monday"] to True
    Set calendar_config["highlight_today"] to False
    
    Let custom_calendar be generate_calendar with 2024 and 7 and calendar_config
    Display "Custom July 2024 Calendar:"
    Display custom_calendar
    
    Display "Calendar display tests completed"

Process called "test_date_parsing":
    Display "Testing date parsing and validation..."
    
    Let date_formats be list containing "2024-07-15", "07/15/2024", "July 15, 2024", "15-Jul-2024"
    
    For each date_string in date_formats:
        Try:
            Let parsed_date be parse_date with date_string
            Let iso_format be format_date with parsed_date and "YYYY-MM-DD"
            Display "Parsed '" with message date_string with message "' as: " with message iso_format
        Catch exception as error:
            Display "Failed to parse '" with message date_string with message "': " with message error

Process called "test_business_days":
    Display "Testing business day calculations..."
    
    Let start_date be create_date with 2024 and 7 and 15
    Let end_date be create_date with 2024 and 7 and 25
    
    Let business_days be calculate_business_days with start_date and end_date
    Display "Business days between July 15-25, 2024: " with message business_days
    
    Let next_business_day be get_next_business_day with start_date
    Let next_business_formatted be format_date with next_business_day and "YYYY-MM-DD"
    Display "Next business day after July 15, 2024: " with next_business_formatted
    
    Let weekend_dates be list containing create_date with 2024 and 7 and 13, create_date with 2024 and 7 and 14
    
    For each weekend_date in weekend_dates:
        Let is_business_day be is_business_day with weekend_date
        Let date_formatted be format_date with weekend_date and "YYYY-MM-DD"
        Display date_formatted with message " is business day: " with message is_business_day

Process called "test_timezone_handling":
    Display "Testing timezone functionality..."
    
    Let utc_time be get_current_utc_time()
    Let utc_formatted be format_datetime with utc_time and "YYYY-MM-DD HH:mm:ss UTC"
    Display "Current UTC time: " with message utc_formatted
    
    Let timezones be list containing "America/New_York", "Europe/London", "Asia/Tokyo", "Australia/Sydney"
    
    For each timezone in timezones:
        Try:
            Let local_time be convert_timezone with utc_time and "UTC" and timezone
            Let local_formatted be format_datetime with local_time and "YYYY-MM-DD HH:mm:ss"
            Display timezone with message ": " with message local_formatted
        Catch exception as error:
            Display "Error converting to " with message timezone with message ": " with message error
    
    Let timezone_offset be get_timezone_offset with "America/New_York"
    Display "New York timezone offset: " with message timezone_offset with message " hours"

Process called "test_holiday_management":
    Display "Testing holiday detection and management..."
    
    Let us_holidays_2024 be get_holidays with "US" and 2024
    Display "US holidays in 2024:"
    
    For each holiday in us_holidays_2024:
        Let holiday_name be get_property with holiday and "name"
        Let holiday_date be get_property with holiday and "date"
        Let date_formatted be format_date with holiday_date and "YYYY-MM-DD"
        Display "  " with message holiday_name with message ": " with message date_formatted
    
    Let independence_day be create_date with 2024 and 7 and 4
    Let is_holiday be is_holiday with independence_day and "US"
    Display "July 4, 2024 is US holiday: " with message is_holiday
    
    Let custom_holidays be empty List[Dictionary[String, Any]]
    Let company_holiday be empty Dictionary[String, Any]
    Set company_holiday["name"] to "Company Foundation Day"
    Set company_holiday["date"] to create_date with 2024 and 8 and 15
    Set company_holiday["type"] to "company"
    Add company_holiday to custom_holidays
    
    Let next_holiday be get_next_holiday with get_current_date() and "US" and custom_holidays
    If next_holiday is not equal to None:
        Let next_holiday_name be get_property with next_holiday and "name"
        Let next_holiday_date be get_property with next_holiday and "date"
        Let next_formatted be format_date with next_holiday_date and "YYYY-MM-DD"
        Display "Next holiday: " with message next_holiday_name with message " on " with message next_formatted

Process called "test_date_arithmetic":
    Display "Testing date arithmetic operations..."
    
    Let base_date be create_date with 2024 and 7 and 15
    Let base_formatted be format_date with base_date and "YYYY-MM-DD"
    Display "Base date: " with message base_formatted
    
    Let dates_operations be list containing
        tuple containing "add_days" and 30 and "Adding 30 days",
        tuple containing "subtract_days" and 10 and "Subtracting 10 days",
        tuple containing "add_weeks" and 2 and "Adding 2 weeks",
        tuple containing "add_months" and 3 and "Adding 3 months",
        tuple containing "add_years" and 1 and "Adding 1 year"
    
    For each operation_tuple in dates_operations:
        Let operation be get_item with operation_tuple and 0
        Let amount be get_item with operation_tuple and 1
        Let description be get_item with operation_tuple and 2
        
        Let result_date be None
        If operation is equal to "add_days":
            Set result_date to add_days with base_date and amount
        Otherwise if operation is equal to "subtract_days":
            Set result_date to subtract_days with base_date and amount
        Otherwise if operation is equal to "add_weeks":
            Set result_date to add_weeks with base_date and amount
        Otherwise if operation is equal to "add_months":
            Set result_date to add_months with base_date and amount
        Otherwise if operation is equal to "add_years":
            Set result_date to add_years with base_date and amount
        
        If result_date is not equal to None:
            Let result_formatted be format_date with result_date and "YYYY-MM-DD"
            Display description with message ": " with message result_formatted

Process called "test_calendar_utilities":
    Display "Testing calendar utility functions..."
    
    Let test_date be create_date with 2024 and 7 and 15
    
    Let day_of_week be get_day_of_week with test_date
    Let day_name be get_day_name with day_of_week
    Display "July 15, 2024 is a " with message day_name
    
    Let week_number be get_week_number with test_date
    Display "Week number: " with message week_number
    
    Let days_in_month be get_days_in_month with 2024 and 7
    Display "Days in July 2024: " with message days_in_month
    
    Let month_name be get_month_name with 7
    Display "Month 7 is: " with message month_name
    
    Let quarter be get_quarter with test_date
    Display "July 15, 2024 is in quarter: " with message quarter
    
    Let year_progress be get_year_progress with test_date
    Display "Year progress: " with message year_progress with message "%"

Process called "test_date_ranges":
    Display "Testing date range operations..."
    
    Let start_date be create_date with 2024 and 7 and 1
    Let end_date be create_date with 2024 and 7 and 31
    
    Let date_range be generate_date_range with start_date and end_date
    Let range_count be count_items in date_range
    Display "Generated " with message range_count with message " dates in July 2024"
    
    Let weekdays_only be filter_weekdays with date_range
    Let weekday_count be count_items in weekdays_only
    Display "Weekdays in July 2024: " with message weekday_count
    
    Let weekends_only be filter_weekends with date_range
    Let weekend_count be count_items in weekends_only
    Display "Weekend days in July 2024: " with message weekend_count
    
    Let first_monday be find_first_day_of_week with 2024 and 7 and 1
    Let first_monday_formatted be format_date with first_monday and "YYYY-MM-DD"
    Display "First Monday in July 2024: " with message first_monday_formatted

Process called "test_recurring_events":
    Display "Testing recurring event calculations..."
    
    Let event_start be create_date with 2024 and 7 and 1
    Let event_end be create_date with 2024 and 12 and 31
    
    Let weekly_events be generate_recurring_dates with event_start and event_end and "weekly"
    Let weekly_count be count_items in weekly_events
    Display "Weekly recurring events: " with message weekly_count
    
    Let monthly_events be generate_recurring_dates with event_start and event_end and "monthly"
    Let monthly_count be count_items in monthly_events
    Display "Monthly recurring events: " with message monthly_count
    
    Let recurrence_config be empty Dictionary[String, Any]
    Set recurrence_config["frequency"] to "weekly"
    Set recurrence_config["days_of_week"] to list containing 1, 3, 5
    Set recurrence_config["skip_holidays"] to True
    
    Let custom_recurring be generate_recurring_dates with event_start and event_end and recurrence_config
    Let custom_count be count_items in custom_recurring
    Display "Custom recurring events (Mon/Wed/Fri, skip holidays): " with message custom_count

Process called "test_calendar_performance":
    Display "Testing calendar performance and edge cases..."
    
    Let performance_start be get_current_time()
    
    Let large_range_start be create_date with 2000 and 1 and 1
    Let large_range_end be create_date with 2030 and 12 and 31
    Let large_range be generate_date_range with large_range_start and large_range_end
    Let large_count be count_items in large_range
    
    Let performance_end be get_current_time()
    Let elapsed_time be calculate_time_difference with performance_start and performance_end
    
    Display "Generated " with message large_count with message " dates in " with message elapsed_time with message " seconds"
    
    Let leap_years be empty List[Integer]
    For year from 2000 to 2030:
        If is_leap_year with year:
            Add year to leap_years
    
    Let leap_count be count_items in leap_years
    Display "Leap years 2000-2030: " with message leap_count
    
    Let edge_dates be list containing
        create_date with 1900 and 2 and 28,
        create_date with 2000 and 2 and 29,
        create_date with 2100 and 2 and 28,
        create_date with 2024 and 2 and 29
    
    Display "Testing edge case dates:"
    For each edge_date in edge_dates:
        Let edge_formatted be format_date with edge_date and "YYYY-MM-DD"
        Let is_valid be validate_date with edge_date
        Display "  " with message edge_formatted with message " is valid: " with message is_valid

Process called "run_all_calendar_tests":
    Display "=== Comprehensive Calendar Module Test Suite ==="
    Display "Testing all calendar functionality with production-grade validation"
    Display ""
    
    Call test_calendar_operations
    Display ""
    
    Call test_leap_year_calculations
    Display ""
    
    Call test_calendar_display
    Display ""
    
    Call test_date_parsing
    Display ""
    
    Call test_business_days
    Display ""
    
    Call test_timezone_handling
    Display ""
    
    Call test_holiday_management
    Display ""
    
    Call test_date_arithmetic
    Display ""
    
    Call test_calendar_utilities
    Display ""
    
    Call test_date_ranges
    Display ""
    
    Call test_recurring_events
    Display ""
    
    Call test_calendar_performance
    Display ""
    
    Display "=== Calendar Module Test Suite Completed ==="
    Display "All calendar functionality validated successfully"
    Display "Production-ready calendar operations confirmed"

Call run_all_calendar_tests