Note:
Test Suite: AI Agent Lifecycle Module
Comprehensive testing for agent lifecycle state management and transitions
:End Note

Import "../../../src/stdlib/ai/agent/lifecycle" as Lifecycle
Import "../../../src/stdlib/ai/agent/core" as AgentCore

Type called "TestResult":
    test_name as String
    passed as Boolean
    message as String

Process called "assert_true" that takes condition as Boolean and message as String returns TestResult:
    If condition:
        Return TestResult with:
            test_name as message
            passed as true
            message as "PASSED"
    Else:
        Return TestResult with:
            test_name as message
            passed as false
            message as "ASSERTION FAILED"

Process called "test_lifecycle_creation" returns TestResult:
    Let agent_id be "test_agent"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Let has_agent_id be lifecycle.agent_id is equal to agent_id
    Let initial_state be lifecycle.current_state is equal to "initializing"
    Let has_history be length of lifecycle.state_history >= 1
    
    Let creation_valid be has_agent_id and initial_state and has_history
    
    Return assert_true with condition as creation_valid and message as "Lifecycle creation works correctly"

Process called "test_state_transition_valid" returns TestResult:
    Let agent_id be "transition_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Let transition_result be Lifecycle.transition_state with lifecycle as lifecycle and new_state as "active"
    
    Let transition_successful be transition_result.current_state is equal to "active"
    Let history_updated be length of transition_result.state_history >= 2
    
    Return assert_true with condition as (transition_successful and history_updated) and message as "Valid state transition works"

Process called "test_state_transition_invalid" returns TestResult:
    Let agent_id be "invalid_transition_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Note: Try invalid transition from initializing to terminated
    Let invalid_transition be Lifecycle.transition_state with lifecycle as lifecycle and new_state as "terminated"
    
    Let state_unchanged be invalid_transition.current_state is equal to "initializing"
    
    Return assert_true with condition as state_unchanged and message as "Invalid state transition is rejected"

Process called "test_lifecycle_validation" returns TestResult:
    Let agent_id be "validation_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Let is_valid be Lifecycle.validate_lifecycle_state with lifecycle as lifecycle
    
    Return assert_true with condition as is_valid and message as "Lifecycle validation works"

Process called "test_agent_startup_sequence" returns TestResult:
    Let agent_id be "startup_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Note: Simulate startup sequence
    Let step1 be Lifecycle.transition_state with lifecycle as lifecycle and new_state as "active"
    Let step2 be Lifecycle.transition_state with lifecycle as step1 and new_state as "ready"
    
    Let startup_complete be step2.current_state is equal to "ready"
    Let proper_history be length of step2.state_history is equal to 3
    
    Return assert_true with condition as (startup_complete and proper_history) and message as "Agent startup sequence works"

Process called "test_agent_shutdown_sequence" returns TestResult:
    Let agent_id be "shutdown_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Note: Get to active state first
    Let active_lifecycle be Lifecycle.transition_state with lifecycle as lifecycle and new_state as "active"
    Let ready_lifecycle be Lifecycle.transition_state with lifecycle as active_lifecycle and new_state as "ready"
    
    Note: Now test shutdown
    Let shutting_down be Lifecycle.transition_state with lifecycle as ready_lifecycle and new_state as "shutting_down"
    Let terminated be Lifecycle.transition_state with lifecycle as shutting_down and new_state as "terminated"
    
    Let shutdown_complete be terminated.current_state is equal to "terminated"
    
    Return assert_true with condition as shutdown_complete and message as "Agent shutdown sequence works"

Process called "test_lifecycle_state_history" returns TestResult:
    Let agent_id be "history_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Note: Make several transitions
    Let state1 be Lifecycle.transition_state with lifecycle as lifecycle and new_state as "active"
    Let state2 be Lifecycle.transition_state with lifecycle as state1 and new_state as "ready"
    Let state3 be Lifecycle.transition_state with lifecycle as state2 and new_state as "paused"
    
    Let history_length be length of state3.state_history
    Let history_complete be history_length is equal to 4
    
    Return assert_true with condition as history_complete and message as "State history tracking works"

Process called "test_lifecycle_metrics_integration" returns TestResult:
    Let agent_id be "metrics_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Let with_metrics be Lifecycle.create_lifecycle_with_metrics with agent_id as agent_id
    
    Let metrics_integrated be with_metrics.agent_id is equal to agent_id
    
    Return assert_true with condition as metrics_integrated and message as "Lifecycle metrics integration works"

Process called "test_health_monitoring" returns TestResult:
    Let agent_id be "health_test"
    Let lifecycle be Lifecycle.create_agent_lifecycle with agent_id as agent_id
    
    Let health_data be Dictionary with:
        "overall_health" as 85.0
        "memory_health" as 90.0
        "cpu_health" as 80.0
        "network_health" as 95.0
    
    Let health_updated be Lifecycle.update_agent_health with lifecycle as lifecycle and health_data as health_data
    
    Let health_tracked be health_updated is not equal to ""
    
    Return assert_true with condition as health_tracked and message as "Health monitoring works"

Process called "run_all_tests" returns List[TestResult]:
    Let results be list containing
    
    Add test_lifecycle_creation() to results
    Add test_state_transition_valid() to results
    Add test_state_transition_invalid() to results
    Add test_lifecycle_validation() to results
    Add test_agent_startup_sequence() to results
    Add test_agent_shutdown_sequence() to results
    Add test_lifecycle_state_history() to results
    Add test_lifecycle_metrics_integration() to results
    Add test_health_monitoring() to results
    
    Return results

Process called "print_results" that takes results as List[TestResult] returns Nothing:
    Let passed be 0
    Let failed be 0
    
    For each result in results:
        If result.passed:
            Set passed to passed plus 1
            Print "✅ PASS: " + result.test_name
        Else:
            Set failed to failed plus 1
            Print "❌ FAIL: " + result.test_name + " - " + result.message
    
    Print ""
    Print "Summary: " + passed + " passed, " + failed + " failed"
    Let success_rate be (passed * 100) / (passed + failed)
    Print "Success Rate: " + success_rate + "%"