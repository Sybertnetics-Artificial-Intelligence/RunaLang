Note:
Test Suite: AI Agent Configuration Module
Comprehensive testing for production-grade configuration management
:End Note

Import "../../../src/stdlib/ai/agent/config" as AgentConfig

Type called "TestResult":
    test_name as String
    passed as Boolean
    message as String

Process called "assert_true" that takes condition as Boolean and message as String returns TestResult:
    If condition:
        Return TestResult with:
            test_name as message
            passed as true
            message as "PASSED"
    Else:
        Return TestResult with:
            test_name as message
            passed as false
            message as "ASSERTION FAILED"

Process called "test_default_config_structure" returns TestResult:
    Let config be AgentConfig.get_config()
    
    Let has_agent_section be config contains "agent"
    Let has_resources_section be config contains "resources"
    Let has_swarm_section be config contains "swarm"
    Let has_hierarchical_section be config contains "hierarchical"
    
    Let structure_valid be has_agent_section and has_resources_section and has_swarm_section and has_hierarchical_section
    
    Return assert_true with condition as structure_valid and message as "Default config has all required sections"

Process called "test_health_calculation_config" returns TestResult:
    Let config be AgentConfig.get_config()
    Let health_config be config.agent["health_calculation"]
    
    Let has_max_health be health_config contains "max_health"
    Let has_resource_divisor be health_config contains "resource_divisor"
    Let has_failure_penalty be health_config contains "failure_penalty"
    Let has_uptime_divisor be health_config contains "uptime_divisor"
    
    Let health_config_complete be has_max_health and has_resource_divisor and has_failure_penalty and has_uptime_divisor
    
    Return assert_true with condition as health_config_complete and message as "Health calculation config is complete"

Process called "test_swarm_weights_config" returns TestResult:
    Let config be AgentConfig.get_config()
    Let swarm_config be config.swarm
    
    Let has_leader_weights be swarm_config contains "leader_weights"
    Let has_task_weights be swarm_config contains "task_assignment_weights"
    
    Let leader_weights be swarm_config["leader_weights"]
    Let has_performance_weight be leader_weights contains "performance"
    Let has_trust_weight be leader_weights contains "trust"
    Let has_load_weight be leader_weights contains "load"
    Let has_capability_weight be leader_weights contains "capability"
    
    Let weights_complete be has_leader_weights and has_task_weights and has_performance_weight and has_trust_weight and has_load_weight and has_capability_weight
    
    Return assert_true with condition as weights_complete and message as "Swarm weights configuration is complete"

Process called "test_hierarchical_config" returns TestResult:
    Let config be AgentConfig.get_config()
    Let hierarchical_config be config.hierarchical
    
    Let has_selection_strategy be hierarchical_config contains "default_child_selection_strategy"
    Let has_selection_weights be hierarchical_config contains "selection_weights"
    Let has_task_complexity be hierarchical_config contains "task_complexity"
    Let has_adaptive_scoring be hierarchical_config contains "adaptive_scoring"
    
    Let hierarchical_complete be has_selection_strategy and has_selection_weights and has_task_complexity and has_adaptive_scoring
    
    Return assert_true with condition as hierarchical_complete and message as "Hierarchical configuration is complete"

Process called "test_config_validation" returns TestResult:
    Let config be AgentConfig.get_config()
    
    Note: Test that all numeric values are positive
    Let health_config be config.agent["health_calculation"]
    Let max_health_positive be health_config["max_health"] > 0.0
    Let resource_divisor_positive be health_config["resource_divisor"] > 0.0
    
    Let values_valid be max_health_positive and resource_divisor_positive
    
    Return assert_true with condition as values_valid and message as "Configuration values are valid"

Process called "test_config_merge" returns TestResult:
    Let base_config be Dictionary with "test_key" as "base_value"
    Let override_config be Dictionary with "test_key" as "override_value"
    
    Let merged_config be AgentConfig.merge_configs with base as base_config and overrides as override_config
    
    Let merge_worked be merged_config["test_key"] is equal to "override_value"
    
    Return assert_true with condition as merge_worked and message as "Configuration merge works correctly"

Process called "run_all_tests" returns List[TestResult]:
    Let results be list containing
    
    Add test_default_config_structure() to results
    Add test_health_calculation_config() to results
    Add test_swarm_weights_config() to results
    Add test_hierarchical_config() to results
    Add test_config_validation() to results
    Add test_config_merge() to results
    
    Return results

Process called "print_results" that takes results as List[TestResult] returns Nothing:
    Let passed be 0
    Let failed be 0
    
    For each result in results:
        If result.passed:
            Set passed to passed plus 1
            Print "✅ PASS: " + result.test_name
        Else:
            Set failed to failed plus 1
            Print "❌ FAIL: " + result.test_name + " - " + result.message
    
    Print ""
    Print "Summary: " + passed + " passed, " + failed + " failed"
    Let success_rate be (passed * 100) / (passed + failed)
    Print "Success Rate: " + success_rate + "%"