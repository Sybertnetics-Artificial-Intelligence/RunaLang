Note:
Test Suite: AI Agent Registry Module
Comprehensive testing for agent discovery, registration, and service management
:End Note

Import "../../../src/stdlib/ai/agent/registry" as AgentRegistry
Import "../../../src/stdlib/ai/agent/core" as AgentCore
Import "../../../src/stdlib/ai/agent/metrics" as AgentMetrics

Type called "TestResult":
    test_name as String
    passed as Boolean
    message as String

Process called "assert_true" that takes condition as Boolean and message as String returns TestResult:
    If condition:
        Return TestResult with:
            test_name as message
            passed as true
            message as "PASSED"
    Else:
        Return TestResult with:
            test_name as message
            passed as false
            message as "ASSERTION FAILED"

Process called "test_registry_creation" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    
    Let has_agents be registry.registered_agents is not equal to ""
    Let has_services be registry.service_endpoints is not equal to ""
    Let has_trust_scores be registry.trust_scores is not equal to ""
    Let has_health_status be registry.health_status is not equal to ""
    
    Let creation_valid be has_agents and has_services and has_trust_scores and has_health_status
    
    Return assert_true with condition as creation_valid and message as "Registry creation works correctly"

Process called "test_agent_registration" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_identity be AgentCore.create_agent_identity with name as "TestAgent" and description as "Test registration"
    
    Let registration_result be AgentRegistry.register_agent with registry as registry and agent_id as agent_identity.id and agent_info as agent_identity
    
    Let agent_registered be registration_result.registered_agents contains agent_identity.id
    Let trust_score_set be registration_result.trust_scores contains agent_identity.id
    
    Return assert_true with condition as (agent_registered and trust_score_set) and message as "Agent registration works"

Process called "test_agent_discovery" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_identity be AgentCore.create_agent_identity with name as "DiscoveryTest" and description as "Discovery test"
    
    Note: Register agent first
    Let registered_registry be AgentRegistry.register_agent with registry as registry and agent_id as agent_identity.id and agent_info as agent_identity
    
    Note: Now discover it
    Let discovered_agents be AgentRegistry.discover_agents with registry as registered_registry and criteria as Dictionary with "name" as "DiscoveryTest"
    
    Let agent_found be length of discovered_agents > 0
    Let correct_agent be discovered_agents[0].id is equal to agent_identity.id
    
    Return assert_true with condition as (agent_found and correct_agent) and message as "Agent discovery works"

Process called "test_service_endpoint_management" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_id be "service_test_agent"
    Let endpoint be "http://localhost:8080/agent"
    
    Let endpoint_registered be AgentRegistry.register_service_endpoint with registry as registry and agent_id as agent_id and endpoint as endpoint
    
    Let service_registered be endpoint_registered.service_endpoints contains agent_id
    Let correct_endpoint be endpoint_registered.service_endpoints[agent_id] is equal to endpoint
    
    Return assert_true with condition as (service_registered and correct_endpoint) and message as "Service endpoint management works"

Process called "test_health_status_tracking" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_id be "health_test_agent"
    
    Let health_data be Dictionary with:
        "overall_health" as 85.0
        "response_time" as 120.0
        "error_rate" as 0.02
        "availability" as 99.5
    
    Let health_updated be AgentRegistry.update_agent_health with registry as registry and agent_id as agent_id and health_metrics as health_data
    
    Let health_tracked be health_updated.health_status contains agent_id
    
    Return assert_true with condition as health_tracked and message as "Health status tracking works"

Process called "test_trust_score_management" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_id be "trust_test_agent"
    
    Note: Set initial trust score
    Set registry.trust_scores[agent_id] to 0.8
    
    Note: Update trust based on performance
    Let performance_metrics be Dictionary with:
        "success_rate" as 0.95
        "response_time_avg" as 100.0
        "error_rate" as 0.01
    
    Let trust_updated be AgentRegistry.update_trust_score with registry as registry and agent_id as agent_id and metrics as performance_metrics
    
    Let trust_score_exists be trust_updated.trust_scores contains agent_id
    Let trust_score_valid be trust_updated.trust_scores[agent_id] >= 0.0 and trust_updated.trust_scores[agent_id] <= 1.0
    
    Return assert_true with condition as (trust_score_exists and trust_score_valid) and message as "Trust score management works"

Process called "test_agent_deregistration" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_identity be AgentCore.create_agent_identity with name as "DeregisterTest" and description as "Deregistration test"
    
    Note: Register agent first
    Let registered_registry be AgentRegistry.register_agent with registry as registry and agent_id as agent_identity.id and agent_info as agent_identity
    
    Note: Verify it's registered
    Let agent_exists be registered_registry.registered_agents contains agent_identity.id
    
    Note: Now deregister it
    Let deregistered_registry be AgentRegistry.deregister_agent with registry as registered_registry and agent_id as agent_identity.id
    
    Let agent_removed be not deregistered_registry.registered_agents contains agent_identity.id
    
    Return assert_true with condition as (agent_exists and agent_removed) and message as "Agent deregistration works"

Process called "test_registry_metrics_integration" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let metrics_manager be AgentMetrics.get_metrics_manager()
    
    Let registry_with_metrics be AgentRegistry.create_registry_with_metrics with manager as metrics_manager
    
    Let metrics_integrated be registry_with_metrics is not equal to ""
    
    Return assert_true with condition as metrics_integrated and message as "Registry metrics integration works"

Process called "test_circuit_breaker_integration" returns TestResult:
    Let registry be AgentRegistry.create_registry()
    Let agent_id be "circuit_test_agent"
    
    Note: Simulate multiple failures to trigger circuit breaker
    Let failure_count be 0
    While failure_count < 6:
        Let failure_result be AgentRegistry.record_agent_failure with registry as registry and agent_id as agent_id
        Set failure_count to failure_count plus 1
    
    Let final_registry be failure_result
    Let circuit_triggered be final_registry.circuit_breakers contains agent_id
    
    Return assert_true with condition as circuit_triggered and message as "Circuit breaker integration works"

Process called "run_all_tests" returns List[TestResult]:
    Let results be list containing
    
    Add test_registry_creation() to results
    Add test_agent_registration() to results
    Add test_agent_discovery() to results
    Add test_service_endpoint_management() to results
    Add test_health_status_tracking() to results
    Add test_trust_score_management() to results
    Add test_agent_deregistration() to results
    Add test_registry_metrics_integration() to results
    Add test_circuit_breaker_integration() to results
    
    Return results

Process called "print_results" that takes results as List[TestResult] returns Nothing:
    Let passed be 0
    Let failed be 0
    
    For each result in results:
        If result.passed:
            Set passed to passed plus 1
            Print "✅ PASS: " + result.test_name
        Else:
            Set failed to failed plus 1
            Print "❌ FAIL: " + result.test_name + " - " + result.message
    
    Print ""
    Print "Summary: " + passed + " passed, " + failed + " failed"
    Let success_rate be (passed * 100) / (passed + failed)
    Print "Success Rate: " + success_rate + "%"