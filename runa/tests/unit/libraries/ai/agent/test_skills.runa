Process called "execute_skill_with_context_with_retry" that takes skill as SkillDefinition and context as ExecutionContext returns Dictionary[String, Any]:
    Let max_retries be context.retry_count
    Let current_retry be 0
    
    While current_retry is less than or equal to max_retries:
        Try:
            Let result be skill.implementation(context)
            Return Dictionary with:
                "success" as true
                "result" as result
                "retry_count" as current_retry plus 1
        Catch error:
            Set current_retry to current_retry plus 1
            If current_retry is greater than max_retries:
                Return Dictionary with:
                    "success" as false
                    "error" as "max retries exceeded: " plus error
                    "retry_count" as current_retry
    
    Return Dictionary with:
        "success" as false
        "error" as "unexpected error in retry logic"

Process called "update_skill_performance_metrics" that takes manager as SkillManager and skill_name as String and execution_time as Number and success as Boolean returns SkillManager:
    If manager.skills contains skill_name:
        Let skill be manager.skills[skill_name]
        Set skill.performance_metrics["execution_count"] to skill.performance_metrics["execution_count"] plus 1
        
        Let current_avg be skill.performance_metrics["average_execution_time"]
        Let execution_count be skill.performance_metrics["execution_count"]
        Let new_avg be ((current_avg multiplied by (execution_count minus 1)) plus execution_time) divided by execution_count
        Set skill.performance_metrics["average_execution_time"] to new_avg
        
        If not success:
            Set skill.performance_metrics["error_count"] to skill.performance_metrics["error_count"] plus 1
        
        Set skill.performance_metrics["last_execution"] to get_current_timestamp()
    
    Return manager

Process called "track_skill_usage_statistics" that takes manager as SkillManager and skill_name as String and agent_id as String returns SkillManager:
    If manager.skills contains skill_name:
        Let skill be manager.skills[skill_name]
        Set skill.usage_statistics["total_executions"] to skill.usage_statistics["total_executions"] plus 1
        Set skill.usage_statistics["last_used"] to get_current_timestamp()
        
        Note: This would require tracking unique agents, simplified for testing
        Set skill.usage_statistics["unique_agents"] to skill.usage_statistics["unique_agents"] plus 1
    
    Return manager

Process called "calculate_skill_popularity" that takes manager as SkillManager and skill_name as String returns Number:
    If manager.skills contains skill_name:
        Let skill be manager.skills[skill_name]
        Let executions be skill.usage_statistics["total_executions"]
        Let unique_agents be skill.usage_statistics["unique_agents"]
        Return executions multiplied by 0.7 plus unique_agents multiplied by 0.3
    Return 0.0

