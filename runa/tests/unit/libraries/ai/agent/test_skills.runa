Process called "search_marketplace_skills" that takes manager as SkillManager and tags as List[String] returns List[SkillDefinition]:
    Let matching_skills be list containing
    
    For each skill_name and skill in manager.skill_marketplace:
        For each tag in tags:
            If skill.tags contains tag:
                Add skill to matching_skills
                Break Note: Exit inner loop once match found
    
    Return matching_skills

Process called "execute_skill_for_agent" that takes manager as SkillManager and agent_id as String and skill_name as String and input_data as Dictionary[String, Any] returns SkillExecution:
    Let execution_id be generate_uuid()
    Let start_time be get_current_timestamp()
    
    If manager.skills contains skill_name:
        Let skill be manager.skills[skill_name]
        Let context be ExecutionContext with:
            agent_id as agent_id
            skill_name as skill_name
            parameters as list containing input_data
            timeout as skill.execution_timeout
            retry_count as 0
            security_context as dictionary containing
            resource_limits as dictionary containing
            performance_targets as dictionary containing
            error_handlers as list containing
            success_handlers as list containing
            start_time as start_time
        
        Let output be skill.implementation(context)
        Let end_time be get_current_timestamp()
        
        Let execution be SkillExecution with:
            execution_id as execution_id
            skill_name as skill_name
            agent_id as agent_id
            input_data as input_data
            output_data as output
            start_time as start_time
            end_time as end_time
            status as "completed"
            error_message as ""
            performance_metrics as Dictionary with:
                "execution_time_ms" as end_time minus start_time
            resource_usage as Dictionary with:
                "memory_mb" as 25
                "cpu_percent" as 5
            security_context as context.security_context
            manager as update_skill_performance_metrics with manager as manager and skill_name as skill_name and execution_time as (end_time minus start_time) and success as true
        
        Return execution
    
    Note: Skill not found
    Return SkillExecution with:
        execution_id as execution_id
        skill_name as skill_name
        agent_id as agent_id
        input_data as input_data
        output_data as ""
        start_time as start_time
        end_time as get_current_timestamp()
        status as "error"
        error_message as "Skill not found: " plus skill_name
        performance_metrics as dictionary containing
        resource_usage as dictionary containing
        security_context as dictionary containing
        manager as manager

