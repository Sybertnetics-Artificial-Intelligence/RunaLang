Note:
Test Suite: AI Agent Hierarchical Module
Comprehensive testing for hierarchical agent management and child selection strategies
:End Note

Import "../../../src/stdlib/ai/agent/hierarchical" as Hierarchical
Import "../../../src/stdlib/ai/agent/config" as AgentConfig

Type called "TestResult":
    test_name as String
    passed as Boolean
    message as String

Process called "assert_true" that takes condition as Boolean and message as String returns TestResult:
    If condition:
        Return TestResult with:
            test_name as message
            passed as true
            message as "PASSED"
    Else:
        Return TestResult with:
            test_name as message
            passed as false
            message as "ASSERTION FAILED"

Process called "test_hierarchy_creation" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent_agent" and max_children as 5
    
    Let has_parent be hierarchy.parent_agent_id is equal to "parent_agent"
    Let has_max_children be hierarchy.max_children is equal to 5
    Let has_children_list be length of hierarchy.children_ids is equal to 0
    
    Let creation_valid be has_parent and has_max_children and has_children_list
    
    Return assert_true with condition as creation_valid and message as "Hierarchy creation works correctly"

Process called "test_child_selection_round_robin" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent" and max_children as 3
    Set hierarchy.children_ids to list containing "child1" and "child2" and "child3"
    
    Let manager be Hierarchical.create_hierarchy_manager()
    
    Let selected1 be Hierarchical.select_child_round_robin with hierarchy as hierarchy and manager as manager and parent_agent_id as "parent"
    Let selected2 be Hierarchical.select_child_round_robin with hierarchy as hierarchy and manager as manager and parent_agent_id as "parent"
    
    Let different_selections be selected1 is not equal to selected2
    Let valid_selections be (selected1 in hierarchy.children_ids) and (selected2 in hierarchy.children_ids)
    
    Return assert_true with condition as (different_selections and valid_selections) and message as "Round robin selection works correctly"

Process called "test_child_selection_least_loaded" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent" and max_children as 2
    Set hierarchy.children_ids to list containing "light_child" and "heavy_child"
    
    Let selected_child be Hierarchical.select_child_least_loaded with hierarchy as hierarchy
    
    Let selection_made be selected_child is not equal to ""
    Let valid_child be selected_child in hierarchy.children_ids
    
    Return assert_true with condition as (selection_made and valid_child) and message as "Least loaded selection works"

Process called "test_child_selection_best_capability" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent" and max_children as 2
    Set hierarchy.children_ids to list containing "compute_child" and "storage_child"
    
    Let selected_child be Hierarchical.select_child_best_capability with hierarchy as hierarchy and task_description as "compute_task"
    
    Let selection_made be selected_child is not equal to ""
    Let valid_child be selected_child in hierarchy.children_ids
    
    Return assert_true with condition as (selection_made and valid_child) and message as "Best capability selection works"

Process called "test_child_selection_adaptive" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent" and max_children as 2
    Set hierarchy.children_ids to list containing "child1" and "child2"
    
    Let manager be Hierarchical.create_hierarchy_manager()
    Let task_description be "adaptive_test_task"
    Let input_data be Dictionary with "complexity" as "medium"
    
    Let selected_child be Hierarchical.select_child_adaptive with hierarchy as hierarchy and manager as manager and parent_agent_id as "parent" and task_description as task_description and input_data as input_data
    
    Let selection_made be selected_child is not equal to ""
    Let valid_child be selected_child in hierarchy.children_ids
    
    Return assert_true with condition as (selection_made and valid_child) and message as "Adaptive selection works"

Process called "test_optimal_child_selection" returns TestResult:
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "parent" and max_children as 3
    Set hierarchy.children_ids to list containing "child1" and "child2" and "child3"
    
    Let task_description be "optimization_task"
    Let input_data be Dictionary with "priority" as "high"
    
    Let selected_child be Hierarchical.select_optimal_child_agent with hierarchy as hierarchy and task_description as task_description and input_data as input_data
    
    Let selection_made be selected_child is not equal to ""
    Let valid_child be selected_child in hierarchy.children_ids
    
    Return assert_true with condition as (selection_made and valid_child) and message as "Optimal child selection works"

Process called "test_hierarchy_management" returns TestResult:
    Let manager be Hierarchical.create_hierarchy_manager()
    Let hierarchy be Hierarchical.create_hierarchy with parent_id as "test_parent" and max_children as 10
    
    Let add_result be Hierarchical.add_hierarchy with manager as manager and hierarchy_id as "test_hierarchy" and hierarchy as hierarchy
    
    Let hierarchy_added be add_result.hierarchies contains "test_hierarchy"
    
    Return assert_true with condition as hierarchy_added and message as "Hierarchy management works"

Process called "test_child_suitability_scoring" returns TestResult:
    Let child_id be "test_child"
    Let task_description be "scoring_test"
    Let input_data be Dictionary with "test" as true
    
    Let score be Hierarchical.calculate_child_suitability_score with child_id as child_id and task_description as task_description and input_data as input_data
    
    Let score_valid be score >= 0.0 and score <= 1.0
    
    Return assert_true with condition as score_valid and message as "Child suitability scoring returns valid range"

Process called "run_all_tests" returns List[TestResult]:
    Let results be list containing
    
    Add test_hierarchy_creation() to results
    Add test_child_selection_round_robin() to results
    Add test_child_selection_least_loaded() to results
    Add test_child_selection_best_capability() to results
    Add test_child_selection_adaptive() to results
    Add test_optimal_child_selection() to results
    Add test_hierarchy_management() to results
    Add test_child_suitability_scoring() to results
    
    Return results

Process called "print_results" that takes results as List[TestResult] returns Nothing:
    Let passed be 0
    Let failed be 0
    
    For each result in results:
        If result.passed:
            Set passed to passed plus 1
            Print "✅ PASS: " + result.test_name
        Else:
            Set failed to failed plus 1
            Print "❌ FAIL: " + result.test_name + " - " + result.message
    
    Print ""
    Print "Summary: " + passed + " passed, " + failed + " failed"
    Let success_rate be (passed * 100) / (passed + failed)
    Print "Success Rate: " + success_rate + "%"