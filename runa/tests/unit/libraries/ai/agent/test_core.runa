Import "../../../../../../src/stdlib/ai/agent/core.runa"
Import "../../../../../runtime/test_framework.runa"

Note:
Unit Tests for AI Agent Core Module

Comprehensive test coverage for agent identity, lifecycle, state management, capabilities,
runtime execution, performance monitoring, and validation functions. Tests include normal
cases, boundary conditions, error conditions, and edge cases.

Test Categories:
- Agent Identity Management
- Agent State Management  
- Agent Lifecycle Management
- Agent Capability Management
- Agent Runtime Execution
- Performance Monitoring
- Validation Functions
- Error Handling
- Edge Cases
:End Note

Note: Test Fixtures and Setup
Process called "setup_test_agent" returns AgentIdentity:
    Return create_agent_identity with name as "TestAgent" and description as "Test agent for unit tests"

Process called "setup_test_state" returns AgentState:
    Return create_agent_state()

Process called "setup_test_lifecycle" returns AgentLifecycle:
    Return create_agent_lifecycle()

Process called "setup_test_capability" returns AgentCapability:
    Return create_agent_capability with name as "test_skill" and description as "Test capability for unit tests"

Process called "teardown_test_environment" returns Boolean:
    Note: Clean up any test artifacts
    Return true

Note: Agent Identity Tests
Test "test_create_agent_identity_basic":
    Let identity be create_agent_identity with name as "TestAgent" and description as "Test Description"
    
    Assert identity.name is equal to "TestAgent"
    Assert identity.description is equal to "Test Description"
    Assert identity.version is equal to "1.0.0"
    Assert length of identity.id is greater than 0
    Assert length of identity.signature is greater than 0
    Assert length of identity.public_key is greater than 0
    Assert identity.created_at is greater than 0
    Assert identity.last_updated is greater than 0
    Assert identity.permissions contains "basic"
    Assert length of identity.capabilities is equal to 0
    Assert identity.resource_limits contains "memory_mb"
    Assert identity.resource_limits contains "cpu_percent"

Test "test_create_agent_identity_with_metadata":
    Let metadata be Dictionary with:
        "environment" as "test"
        "version" as "2.0.0"
        "custom_field" as "test_value"
    
    Let identity be create_agent_identity_with_metadata with name as "MetaTestAgent" and description as "Agent with metadata" and metadata as metadata
    
    Assert identity.name is equal to "MetaTestAgent"
    Assert identity.metadata["environment"] is equal to "test"
    Assert identity.metadata["version"] is equal to "2.0.0"
    Assert identity.metadata["custom_field"] is equal to "test_value"

Test "test_update_agent_identity":
    Let identity be setup_test_agent()
    Let original_updated_time be identity.last_updated
    
    Let updates be Dictionary with:
        "name" as "UpdatedAgent"
        "description" as "Updated description"
        "custom_field" as "new_value"
    
    Let updated_identity be update_agent_identity with identity as identity and updates as updates
    
    Assert updated_identity.name is equal to "UpdatedAgent"
    Assert updated_identity.description is equal to "Updated description"
    Assert updated_identity.metadata["custom_field"] is equal to "new_value"
    Assert updated_identity.last_updated is greater than original_updated_time

Test "test_verify_agent_identity":
    Let identity be setup_test_agent()
    Let is_valid be verify_agent_identity with identity as identity
    
    Assert is_valid is true

Test "test_add_remove_agent_capability":
    Let identity be setup_test_agent()
    
    Note: Add capability
    Let updated_identity be add_agent_capability with identity as identity and capability as "new_skill"
    Assert updated_identity.capabilities contains "new_skill"
    
    Note: Remove capability
    Let final_identity be remove_agent_capability with identity as updated_identity and capability as "new_skill"
    Assert not final_identity.capabilities contains "new_skill"

Test "test_has_agent_capability":
    Let identity be setup_test_agent()
    Let updated_identity be add_agent_capability with identity as identity and capability as "test_skill"
    
    Assert has_agent_capability with identity as updated_identity and capability as "test_skill"
    Assert not has_agent_capability with identity as updated_identity and capability as "nonexistent_skill"

Test "test_agent_metadata_operations":
    Let identity be setup_test_agent()
    
    Note: Set metadata
    Let updated_identity be set_agent_metadata with identity as identity and key as "test_key" and value as "test_value"
    
    Note: Get metadata
    Let retrieved_value be get_agent_metadata with identity as updated_identity and key as "test_key"
    Assert retrieved_value is equal to "test_value"
    
    Note: Get nonexistent metadata
    Let empty_value be get_agent_metadata with identity as updated_identity and key as "nonexistent_key"
    Assert empty_value is equal to ""

Test "test_check_agent_permissions":
    Let identity be setup_test_agent()
    Let updated_identity be add_agent_capability with identity as identity and capability as "admin"
    Set updated_identity.permissions to list containing "basic", "admin"
    
    Assert check_agent_permissions with identity as updated_identity and required_permissions as list containing "basic"
    Assert check_agent_permissions with identity as updated_identity and required_permissions as list containing "basic", "admin"
    Assert not check_agent_permissions with identity as updated_identity and required_permissions as list containing "superuser"

Note: Agent State Tests
Test "test_create_agent_state":
    Let state be create_agent_state()
    
    Assert state.status is equal to "initialized"
    Assert state.current_task is equal to ""
    Assert length of state.active_skills is equal to 0
    Assert state.error_count is equal to 0
    Assert state.success_count is equal to 0
    Assert state.uptime is equal to 0
    Assert state.circuit_breaker_state is equal to "closed"
    Assert state.circuit_breaker_failures is equal to 0
    Assert state.health_score is greater than 0
    Assert state.load_factor is equal to 0.0

Test "test_update_agent_status":
    Let state be setup_test_state()
    Let original_heartbeat be state.last_heartbeat
    
    Let updated_state be update_agent_status with state as state and status as "active"
    
    Assert updated_state.status is equal to "active"
    Assert updated_state.last_heartbeat is greater than original_heartbeat
    Assert length of updated_state.performance_history is greater than 0

Test "test_update_agent_status_invalid":
    Let state be setup_test_state()
    Let original_status be state.status
    
    Let updated_state be update_agent_status with state as state and status as "invalid_status"
    
    Note: Status should remain unchanged for invalid values
    Assert updated_state.status is equal to original_status

Test "test_set_current_task":
    Let state be setup_test_state()
    
    Note: Set task
    Let updated_state be set_current_task with state as state and task_id as "task_123"
    Assert updated_state.current_task is equal to "task_123"
    Assert updated_state.status is equal to "busy"
    
    Note: Clear task
    Let cleared_state be set_current_task with state as updated_state and task_id as ""
    Assert cleared_state.current_task is equal to ""
    Assert cleared_state.status is equal to "idle"

Test "test_add_remove_active_skill":
    Let state be setup_test_state()
    
    Note: Add skill
    Let updated_state be add_active_skill with state as state and skill_name as "test_skill"
    Assert updated_state.active_skills contains "test_skill"
    
    Note: Remove skill
    Let final_state be remove_active_skill with state as updated_state and skill_name as "test_skill"
    Assert not final_state.active_skills contains "test_skill"

Test "test_update_performance_metric":
    Let state be setup_test_state()
    
    Let updated_state be update_performance_metric with state as state and metric as "response_time" and value as 150.5
    
    Assert updated_state.performance_metrics["response_time"] is equal to 150.5
    Assert length of updated_state.performance_history is greater than 0

Test "test_increment_success_count":
    Let state be setup_test_state()
    Let original_count be state.success_count
    
    Let updated_state be increment_success_count with state as state
    
    Assert updated_state.success_count is equal to original_count plus 1
    Assert length of updated_state.performance_history is greater than 0

Test "test_increment_error_count":
    Let state be setup_test_state()
    Let original_count be state.error_count
    
    Let updated_state be increment_error_count with state as state
    
    Assert updated_state.error_count is equal to original_count plus 1
    Assert length of updated_state.error_history is greater than 0

Test "test_update_uptime":
    Let state be setup_test_state()
    
    Let updated_state be update_uptime with state as state and uptime_seconds as 3600
    
    Assert updated_state.uptime is equal to 3600

Test "test_get_success_rate":
    Let state be setup_test_state()
    Set state.success_count to 8
    Set state.error_count to 2
    
    Let success_rate be get_success_rate with state as state
    Assert success_rate is equal to 0.8

Test "test_get_success_rate_no_operations":
    Let state be setup_test_state()
    Set state.success_count to 0
    Set state.error_count to 0
    
    Let success_rate be get_success_rate with state as state
    Assert success_rate is equal to 0.0

Test "test_is_agent_healthy":
    Let state be setup_test_state()
    Set state.last_heartbeat to get_current_timestamp() minus 30  Note: 30 seconds ago
    
    Assert is_agent_healthy with state as state and max_heartbeat_age as 60
    Assert not is_agent_healthy with state as state and max_heartbeat_age as 15

Test "test_update_circuit_breaker":
    Let state be setup_test_state()
    Set state.circuit_breaker_threshold to 3
    
    Note: Test successful operation
    Let success_state be update_circuit_breaker with state as state and success as true
    Assert success_state.circuit_breaker_failures is equal to 0
    Assert success_state.circuit_breaker_state is equal to "closed"
    
    Note: Test failures leading to circuit breaker opening
    Set state.circuit_breaker_failures to 2
    Let fail_state be update_circuit_breaker with state as state and success as false
    Assert fail_state.circuit_breaker_failures is equal to 3
    Assert fail_state.circuit_breaker_state is equal to "open"

Test "test_update_resource_usage":
    Let state be setup_test_state()
    
    Let updated_state be update_resource_usage with state as state and memory_mb as 512 and cpu_percent as 75 and network_mbps as 10
    
    Assert updated_state.memory_usage is equal to 512
    Assert updated_state.cpu_usage is equal to 75
    Assert updated_state.resource_usage["memory_mb"] is equal to 512
    Assert updated_state.resource_usage["cpu_percent"] is equal to 75
    Assert updated_state.resource_usage["network_mbps"] is equal to 10

Test "test_calculate_health_score":
    Let state be setup_test_state()
    Set state.success_count to 9
    Set state.error_count to 1
    Set state.cpu_usage to 50
    Set state.memory_usage to 60
    Set state.uptime to 3600
    Set state.circuit_breaker_failures to 0
    
    Let health_score be calculate_health_score with state as state
    Assert health_score is greater than 0
    Assert health_score is less than or equal to 100

Note: Agent Lifecycle Tests
Test "test_create_agent_lifecycle":
    Let lifecycle be create_agent_lifecycle()
    
    Assert lifecycle.phase is equal to "created"
    Assert length of lifecycle.transitions is equal to 0
    Assert length of lifecycle.rollback_points is equal to 0
    Assert lifecycle.timeout is greater than 0
    Assert lifecycle.retry_policy contains "max_retries"
    Assert lifecycle.retry_policy["max_retries"] is equal to 3

Test "test_transition_agent_phase":
    Let lifecycle be setup_test_lifecycle()
    
    Let updated_lifecycle be transition_agent_phase with lifecycle as lifecycle and new_phase as "initializing"
    
    Assert updated_lifecycle.phase is equal to "initializing"
    Assert length of updated_lifecycle.transitions is greater than 0
    Assert length of updated_lifecycle.rollback_points is greater than 0

Test "test_transition_agent_phase_invalid":
    Let lifecycle be setup_test_lifecycle()
    Let original_phase be lifecycle.phase
    
    Let updated_lifecycle be transition_agent_phase with lifecycle as lifecycle and new_phase as "invalid_phase"
    
    Note: Phase should remain unchanged for invalid transitions
    Assert updated_lifecycle.phase is equal to original_phase

Test "test_rollback_lifecycle":
    Let lifecycle be setup_test_lifecycle()
    
    Note: Make a transition to create a rollback point
    Let transitioned be transition_agent_phase with lifecycle as lifecycle and new_phase as "initializing"
    
    Note: Rollback
    Let rolled_back be rollback_lifecycle with lifecycle as transitioned
    
    Assert rolled_back.phase is equal to "created"
    Assert length of rolled_back.rollback_points is equal to 0

Test "test_add_lifecycle_constraint":
    Let lifecycle be setup_test_lifecycle()
    
    Let updated_lifecycle be add_lifecycle_constraint with lifecycle as lifecycle and constraint as "memory_limit"
    
    Assert updated_lifecycle.constraints contains "memory_limit"

Test "test_add_lifecycle_dependency":
    Let lifecycle be setup_test_lifecycle()
    
    Let updated_lifecycle be add_lifecycle_dependency with lifecycle as lifecycle and dependency as "database_connection"
    
    Assert updated_lifecycle.dependencies contains "database_connection"

Test "test_set_lifecycle_timeout":
    Let lifecycle be setup_test_lifecycle()
    
    Let updated_lifecycle be set_lifecycle_timeout with lifecycle as lifecycle and timeout_seconds as 120
    
    Assert updated_lifecycle.timeout is equal to 120

Test "test_update_retry_policy":
    Let lifecycle be setup_test_lifecycle()
    
    Let new_policy be Dictionary with:
        "max_retries" as 5
        "retry_delay" as 10
        "backoff_factor" as 1.5
    
    Let updated_lifecycle be update_retry_policy with lifecycle as lifecycle and policy as new_policy
    
    Assert updated_lifecycle.retry_policy["max_retries"] is equal to 5
    Assert updated_lifecycle.retry_policy["retry_delay"] is equal to 10
    Assert updated_lifecycle.retry_policy["backoff_factor"] is equal to 1.5

Test "test_can_transition_to":
    Let lifecycle be setup_test_lifecycle()
    
    Assert can_transition_to with lifecycle as lifecycle and target_phase as "initializing"
    Assert not can_transition_to with lifecycle as lifecycle and target_phase as "terminated"

Test "test_get_lifecycle_history":
    Let lifecycle be setup_test_lifecycle()
    Let transitioned be transition_agent_phase with lifecycle as lifecycle and new_phase as "initializing"
    
    Let history be get_lifecycle_history with lifecycle as transitioned
    
    Assert length of history is greater than 0
    Assert history[0] contains "from_phase"
    Assert history[0] contains "to_phase"

Note: Agent Capability Tests
Test "test_create_agent_capability_basic":
    Let capability be create_agent_capability with name as "test_capability" and description as "Test capability"
    
    Assert capability.name is equal to "test_capability"
    Assert capability.description is equal to "Test capability"
    Assert capability.version is equal to "1.0.0"
    Assert capability.is_async is false
    Assert capability.retry_count is equal to 0
    Assert length of capability.dependencies is equal to 0
    Assert length of capability.permissions is equal to 0

Test "test_create_agent_capability_with_options":
    Let parameters be list containing "param1", "param2"
    Let dependencies be list containing "dep1"
    Let permissions be list containing "execute"
    
    Let capability be create_agent_capability_with_options with name as "advanced_capability" and description as "Advanced test capability" and parameters as parameters and return_type as "String" and is_async as true and timeout as 60 and retry_count as 3 and dependencies as dependencies and permissions as permissions
    
    Assert capability.name is equal to "advanced_capability"
    Assert capability.is_async is true
    Assert capability.timeout is equal to 60
    Assert capability.retry_count is equal to 3
    Assert capability.parameters contains "param1"
    Assert capability.parameters contains "param2"
    Assert capability.dependencies contains "dep1"
    Assert capability.permissions contains "execute"

