Note: Integration and Serialization Tests
Test "test_get_agent_summary":
    Let identity be setup_test_agent()
    Let state be setup_test_state()
    Set state.success_count to 10
    Set state.error_count to 2
    Set state.uptime to 3600
    
    Let summary be get_agent_summary with identity as identity and state as state
    
    Assert summary["id"] is equal to identity.id
    Assert summary["name"] is equal to identity.name
    Assert summary["status"] is equal to state.status
    Assert summary["success_rate"] is greater than 0
    Assert summary["uptime"] is equal to 3600

Test "test_serialize_deserialize_agent":
    Let identity be setup_test_agent()
    Let state be setup_test_state()
    Let lifecycle be setup_test_lifecycle()
    
    Let serialized be serialize_agent with identity as identity and state as state and lifecycle as lifecycle
    
    Assert serialized contains "identity"
    Assert serialized contains "state"
    Assert serialized contains "lifecycle"
    Assert serialized contains "serialized_at"
    Assert serialized contains "checksum"
    
    Let (deserialized_identity, deserialized_state, deserialized_lifecycle) be deserialize_agent with data as serialized
    
    Assert deserialized_identity.id is equal to identity.id
    Assert deserialized_state.status is equal to state.status
    Assert deserialized_lifecycle.phase is equal to lifecycle.phase

Note: Performance and Metrics Tests
Test "test_calculate_agent_efficiency":
    Let state be setup_test_state()
    Set state.success_count to 8
    Set state.error_count to 2
    Set state.uptime to 3600
    Set state.cpu_usage to 50
    Set state.memory_usage to 60
    Set state.circuit_breaker_failures to 1
    
    Let efficiency be calculate_agent_efficiency with state as state
    
    Assert efficiency is greater than 0
    Assert efficiency is less than or equal to 100

Test "test_get_agent_metrics":
    Let state be setup_test_state()
    Set state.success_count to 15
    Set state.error_count to 5
    Set state.uptime to 7200
    Set state.memory_usage to 256
    Set state.cpu_usage to 40
    
    Let metrics be get_agent_metrics with state as state
    
    Assert metrics["success_count"] is equal to 15
    Assert metrics["error_count"] is equal to 5
    Assert metrics["success_rate"] is equal to 0.75
    Assert metrics["uptime_hours"] is equal to 2.0
    Assert metrics["memory_usage_mb"] is equal to 256
    Assert metrics["cpu_usage_percent"] is equal to 40

Test "test_reset_agent_metrics":
    Let state be setup_test_state()
    Set state.success_count to 10
    Set state.error_count to 3
    Set state.circuit_breaker_failures to 2
    
    Let reset_state be reset_agent_metrics with state as state
    
    Assert reset_state.success_count is equal to 0
    Assert reset_state.error_count is equal to 0
    Assert reset_state.circuit_breaker_failures is equal to 0
    Assert reset_state.circuit_breaker_state is equal to "closed"

Test "test_optimize_agent_performance":
    Let state be setup_test_state()
    Set state.memory_usage to 85
    Set state.cpu_usage to 90
    Set state.circuit_breaker_failures to 3
    
    Let recommendations be optimize_agent_performance with state as state
    
    Assert recommendations["memory_optimization"] is true
    Assert recommendations["cpu_optimization"] is true
    Assert recommendations["circuit_breaker_adjustment"] is true

Note: Edge Case Tests
Test "test_duplicate_capability_handling":
    Let identity be setup_test_agent()
    
    Note: Add same capability twice
    Let first_add be add_agent_capability with identity as identity and capability as "duplicate_skill"
    Let second_add be add_agent_capability with identity as first_add and capability as "duplicate_skill"
    
    Note: Should only contain one instance
    Let count be 0
    For each capability in second_add.capabilities:
        If capability is equal to "duplicate_skill":
            Set count to count plus 1
    
    Assert count is equal to 1

Test "test_large_metadata_handling":
    Let identity be setup_test_agent()
    Let large_value be ""
    
    Note: Create a large string (1000 characters)
    For i from 0 to 999:
        Set large_value to large_value plus "x"
    
    Let updated_identity be set_agent_metadata with identity as identity and key as "large_field" and value as large_value
    Let retrieved_value be get_agent_metadata with identity as updated_identity and key as "large_field"
    
    Assert length of retrieved_value is equal to 1000

Test "test_concurrent_state_updates":
    Let state be setup_test_state()
    
    Note: Simulate concurrent updates
    Let state1 be update_agent_status with state as state and status as "active"
    Let state2 be increment_success_count with state as state
    Let state3 be update_performance_metric with state as state and metric as "test_metric" and value as 42
    
    Note: Verify all updates created valid states
    Assert validate_agent_state with state as state1
    Assert validate_agent_state with state as state2  
    Assert validate_agent_state with state as state3

Test "test_boundary_resource_limits":
    Let state be setup_test_state()
    
    Note: Test maximum values
    Let updated_state be update_resource_usage with state as state and memory_mb as 999999 and cpu_percent as 100 and network_mbps as 1000
    
    Assert updated_state.memory_usage is equal to 999999
    Assert updated_state.cpu_usage is equal to 100
    Assert updated_state.resource_usage["network_mbps"] is equal to 1000

