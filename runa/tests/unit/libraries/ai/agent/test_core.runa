    Let updated_capability be add_capability_dependency with capability as capability and dependency as "dep1"
    Let final_capability be add_capability_dependency with capability as updated_capability and dependency as "dep2"
    
    Let dependencies be get_capability_dependencies with capability as final_capability
    
    Assert dependencies contains "dep1"
    Assert dependencies contains "dep2"

