Note:
Master Test Suite: AI Communication System
Comprehensive test runner for all communication modules including messaging, protocols, encryption, and more.
:End Note

Import "./test_messaging" as MessagingTests
Import "./test_protocols" as ProtocolTests
Import "./test_encryption" as EncryptionTests
Import "./test_broadcast" as BroadcastTests
Import "./test_channels" as ChannelTests
Import "./test_config" as ConfigTests
Import "./test_federation" as FederationTests
Import "./test_multicast" as MulticastTests
Import "./test_routing" as RoutingTests

Type called "CommsModuleTestResult":
    module_name as String
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
    success_rate as Float
    execution_time_ms as Float

Process called "run_all_comms_tests" returns List[CommsModuleTestResult]:
    Let results be list containing
    
    Print "=== Running All AI Communication Module Tests ==="
    Print ""
    
    Note: Test Messaging Module
    Print "Running Messaging Module Tests..."
    Let messaging_start_time be get_current_timestamp_ms()
    
    Let messaging_results be MessagingTests.run_all_messaging_tests()
    
    Let messaging_end_time be get_current_timestamp_ms()
    Let messaging_execution_time be messaging_end_time minus messaging_start_time
    
    Note: Calculate messaging module statistics
    Let messaging_total be 0
    Let messaging_passed be 0
    Let messaging_failed be 0
    
    For each result in messaging_results:
        Set messaging_total to messaging_total plus 1
        If result.passed:
            Set messaging_passed to messaging_passed plus 1
        Else:
            Set messaging_failed to messaging_failed plus 1
    
    Let messaging_success_rate be (messaging_passed * 100.0) / messaging_total
    
    Let messaging_module_result be CommsModuleTestResult with:
        module_name as "Messaging"
        total_tests as messaging_total
        passed_tests as messaging_passed
        failed_tests as messaging_failed
        success_rate as messaging_success_rate
        execution_time_ms as messaging_execution_time
    
    Add messaging_module_result to results
    
    Print ""
    Print "Messaging Module: " + messaging_passed + "/" + messaging_total + " tests passed (" + messaging_success_rate + "%)"
    Print "Execution Time: " + messaging_execution_time + "ms"
    Print ""
    
