Note:
Unit Tests: AI Communication - Protocol System
Comprehensive test suite for protocol negotiation, QoS management, and connection handling.
:End Note

Import "../../../../src/stdlib/ai/comms/protocols" as Protocols
Import "../../../../src/stdlib/testing/unittest" as UnitTest

Type called "ProtocolTestResult":
    test_name as String
    passed as Boolean
    error_message as Optional[String]
    execution_time_ms as Float

Process called "test_protocol_definition_creation" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let version be Dictionary with:
            "major" as 1
            "minor" as 0
            "patch" as 0
            "label" as ""
        
        Let protocol be Protocols.create_protocol_definition with
            name as "test_protocol" and
            version as version
        
        Note: Validate protocol structure
        If protocol["name"] is not equal to "test_protocol":
            Return ProtocolTestResult with:
                test_name as "test_protocol_definition_creation"
                passed as false
                error_message as "Protocol name mismatch"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If protocol["version"]["major"] is not equal to 1:
            Return ProtocolTestResult with:
                test_name as "test_protocol_definition_creation"
                passed as false
                error_message as "Protocol version mismatch"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Validate configuration integration
        If not protocol["timeout_settings"] contains "connection_timeout":
            Return ProtocolTestResult with:
                test_name as "test_protocol_definition_creation"
                passed as false
                error_message as "Configuration not properly integrated"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_protocol_definition_creation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_protocol_definition_creation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_protocol_negotiation" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let client_capabilities be list containing "reliable_delivery" and "compression"
        Let server_capabilities be list containing "reliable_delivery" and "encryption" and "flow_control"
        
        Let negotiation_result be Protocols.negotiate_protocol_capabilities with
            client_capabilities as client_capabilities and
            server_capabilities as server_capabilities
        
        If not negotiation_result["success"]:
            Return ProtocolTestResult with:
                test_name as "test_protocol_negotiation"
                passed as false
                error_message as "Protocol negotiation failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let common_capabilities be negotiation_result["agreed_capabilities"]
        
        Note: Should have reliable_delivery as common capability
        If not common_capabilities contains "reliable_delivery":
            Return ProtocolTestResult with:
                test_name as "test_protocol_negotiation"
                passed as false
                error_message as "Common capability not identified"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Should not have compression (client-only) or encryption (server-only)
        If common_capabilities contains "compression":
            Return ProtocolTestResult with:
                test_name as "test_protocol_negotiation"
                passed as false
                error_message as "Client-only capability incorrectly included"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_protocol_negotiation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_protocol_negotiation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_flow_control" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test sliding window flow control
        Let flow_state be Protocols.create_flow_control_state with
            mode as "sliding_window" and
            parameters as Dictionary with "window_size" as 32
        
        If flow_state["mode"] is not equal to "sliding_window":
            Return ProtocolTestResult with:
                test_name as "test_flow_control"
                passed as false
                error_message as "Flow control mode not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test window size configuration
        If flow_state["window_size"] is not equal to 32:
            Return ProtocolTestResult with:
                test_name as "test_flow_control"
                passed as false
                error_message as "Window size not configured correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test flow control update
        Let updated_state be Protocols.update_flow_control_state with
            state as flow_state and
            acknowledged_sequence as 5
        
        If updated_state["acknowledged_sequence"] is not equal to 5:
            Return ProtocolTestResult with:
                test_name as "test_flow_control"
                passed as false
                error_message as "Flow control update failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_flow_control"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_flow_control"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_qos_calculation" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let metrics be Dictionary with:
            "latency" as 50.0
            "throughput" as 1000000.0
            "error_rate" as 0.01
            "availability" as 0.99
        
        Let qos_score be Protocols.calculate_qos_score with metrics as metrics
        
        Note: QoS score should be between 0 and 100
        If qos_score < 0.0 or qos_score > 100.0:
            Return ProtocolTestResult with:
                test_name as "test_qos_calculation"
                passed as false
                error_message as "QoS score out of valid range: " + qos_score
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test with poor metrics
        Let poor_metrics be Dictionary with:
            "latency" as 1000.0
            "throughput" as 1000.0
            "error_rate" as 0.5
            "availability" as 0.5
        
        Let poor_qos_score be Protocols.calculate_qos_score with metrics as poor_metrics
        
        Note: Poor metrics should result in lower QoS score
        If poor_qos_score >= qos_score:
            Return ProtocolTestResult with:
                test_name as "test_qos_calculation"
                passed as false
                error_message as "QoS scoring not working correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_qos_calculation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_qos_calculation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_connection_lifecycle" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let connection_id be "test_conn_123"
        
        Note: Test connection initialization
        Let connection be Protocols.initialize_connection with
            connection_id as connection_id and
            local_agent as "agent_1" and
            remote_agent as "agent_2"
        
        If connection["connection_id"] is not equal to connection_id:
            Return ProtocolTestResult with:
                test_name as "test_connection_lifecycle"
                passed as false
                error_message as "Connection ID not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If connection["state"] is not equal to "initializing":
            Return ProtocolTestResult with:
                test_name as "test_connection_lifecycle"
                passed as false
                error_message as "Initial connection state incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test connection state transition
        Let active_connection be Protocols.update_connection_state with
            connection as connection and
            new_state as "established"
        
        If active_connection["state"] is not equal to "established":
            Return ProtocolTestResult with:
                test_name as "test_connection_lifecycle"
                passed as false
                error_message as "Connection state transition failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_connection_lifecycle"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_connection_lifecycle"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_protocol_compatibility" returns ProtocolTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let version_1_0 be Dictionary with:
            "major" as 1
            "minor" as 0
            "patch" as 0
        
        Let version_1_1 be Dictionary with:
            "major" as 1
            "minor" as 1
            "patch" as 0
        
        Let version_2_0 be Dictionary with:
            "major" as 2
            "minor" as 0
            "patch" as 0
        
        Note: Test compatible versions (same major, different minor)
        Let compatibility_result be Protocols.check_protocol_compatibility with
            local_version as version_1_0 and
            remote_version as version_1_1
        
        If not compatibility_result["compatible"]:
            Return ProtocolTestResult with:
                test_name as "test_protocol_compatibility"
                passed as false
                error_message as "Compatible versions marked as incompatible"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test incompatible versions (different major)
        Let incompatibility_result be Protocols.check_protocol_compatibility with
            local_version as version_1_0 and
            remote_version as version_2_0
        
        If incompatibility_result["compatible"]:
            Return ProtocolTestResult with:
                test_name as "test_protocol_compatibility"
                passed as false
                error_message as "Incompatible versions marked as compatible"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ProtocolTestResult with:
            test_name as "test_protocol_compatibility"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ProtocolTestResult with:
            test_name as "test_protocol_compatibility"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "run_all_protocol_tests" returns List[ProtocolTestResult]:
    Let results be list containing
    
    Print "=== Running Protocol Module Tests ==="
    
    Print "Testing protocol definition creation..."
    Let result1 be test_protocol_definition_creation()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing protocol negotiation..."
    Let result2 be test_protocol_negotiation()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing flow control..."
    Let result3 be test_flow_control()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing QoS calculation..."
    Let result4 be test_qos_calculation()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing connection lifecycle..."
    Let result5 be test_connection_lifecycle()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "Testing protocol compatibility..."
    Let result6 be test_protocol_compatibility()
    Add result6 to results
    Print result6.test_name + ": " + (If result6.passed then "PASS" else "FAIL")
    
    Print "=== Protocol Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()