Note:
Unit Tests: AI Communication - Messaging System
Comprehensive test suite for message creation, queue operations, delivery mechanisms, and error handling.
:End Note

Import "../../../../src/stdlib/ai/comms/messaging" as Messaging
Import "../../../../src/stdlib/testing/unittest" as UnitTest
Import "../../../../src/stdlib/testing/mock" as Mock

Type called "MessageTestResult":
    test_name as String
    passed as Boolean
    error_message as Optional[String]
    execution_time_ms as Float

Process called "test_create_message" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test basic message creation
        Let message be Messaging.create_message with
            sender_id as "test_agent_1" and
            receiver_id as "test_agent_2" and
            message_type as "request" and
            payload as "Hello World"
        
        Note: Validate message structure
        If message["message_id"] is equal to "":
            Return MessageTestResult with:
                test_name as "test_create_message"
                passed as false
                error_message as "Message ID not generated"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If message["sender_id"] is not equal to "test_agent_1":
            Return MessageTestResult with:
                test_name as "test_create_message"
                passed as false
                error_message as "Sender ID mismatch"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If message["receiver_id"] is not equal to "test_agent_2":
            Return MessageTestResult with:
                test_name as "test_create_message"
                passed as false
                error_message as "Receiver ID mismatch"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If message["payload"] is not equal to "Hello World":
            Return MessageTestResult with:
                test_name as "test_create_message"
                passed as false
                error_message as "Payload mismatch"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_create_message"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_create_message"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_message_priority_handling" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test priority message creation and handling
        Let high_priority_message be Messaging.create_request_message with
            sender_id as "agent_1" and
            receiver_id as "agent_2" and
            request_data as "urgent_task"
        
        Let normal_message be Messaging.create_message with
            sender_id as "agent_3" and
            receiver_id as "agent_4" and
            message_type as "notification" and
            payload as "regular_update"
        
        Note: Validate priority settings
        If high_priority_message["priority"] is not equal to "high":
            Return MessageTestResult with:
                test_name as "test_message_priority_handling"
                passed as false
                error_message as "High priority not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If normal_message["priority"] is not equal to "normal":
            Return MessageTestResult with:
                test_name as "test_message_priority_handling"
                passed as false
                error_message as "Normal priority not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test priority change
        Let updated_message be Messaging.set_message_priority with
            message as normal_message and
            priority as "critical"
        
        If updated_message["priority"] is not equal to "critical":
            Return MessageTestResult with:
                test_name as "test_message_priority_handling"
                passed as false
                error_message as "Priority update failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_message_priority_handling"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_message_priority_handling"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_message_queue_operations" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test message queue creation and operations
        Let queue be Messaging.create_message_queue with
            agent_id as "test_agent" and
            max_size as 100
        
        Note: Test enqueue operation
        Let message1 be Messaging.create_message with
            sender_id as "sender1" and
            receiver_id as "test_agent" and
            message_type as "request" and
            payload as "test1"
        
        Let enqueue_result be Messaging.enqueue_message with
            queue as queue and
            message as message1
        
        If not enqueue_result["success"]:
            Return MessageTestResult with:
                test_name as "test_message_queue_operations"
                passed as false
                error_message as "Enqueue failed: " + enqueue_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test queue size
        If queue["current_size"] is not equal to 1:
            Return MessageTestResult with:
                test_name as "test_message_queue_operations"
                passed as false
                error_message as "Queue size incorrect after enqueue"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test dequeue operation
        Let dequeue_result be Messaging.dequeue_message with queue as queue
        
        If not dequeue_result["success"]:
            Return MessageTestResult with:
                test_name as "test_message_queue_operations"
                passed as false
                error_message as "Dequeue failed: " + dequeue_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If queue["current_size"] is not equal to 0:
            Return MessageTestResult with:
                test_name as "test_message_queue_operations"
                passed as false
                error_message as "Queue size incorrect after dequeue"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_message_queue_operations"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_message_queue_operations"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_message_delivery" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test message delivery mechanisms
        Let message be Messaging.create_message with
            sender_id as "sender" and
            receiver_id as "receiver" and
            message_type as "notification" and
            payload as "delivery_test"
        
        Note: Test TCP delivery
        Let tcp_result be Messaging.deliver_via_tcp with
            message as message and
            endpoint as "tcp://localhost:8080"
        
        If not tcp_result["success"]:
            Return MessageTestResult with:
                test_name as "test_message_delivery"
                passed as false
                error_message as "TCP delivery failed: " + tcp_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test UDP delivery
        Let udp_result be Messaging.deliver_via_udp with
            message as message and
            endpoint as "udp://localhost:8081"
        
        If not udp_result["success"]:
            Return MessageTestResult with:
                test_name as "test_message_delivery"
                passed as false
                error_message as "UDP delivery failed: " + udp_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_message_delivery"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_message_delivery"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_message_compression" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test message compression and decompression
        Let large_payload be "This is a large message payload that should benefit from compression. " +
                           "It contains repetitive data that compression algorithms can reduce effectively. " +
                           "Testing compression ensures efficient network utilization."
        
        Let compressed_data be Messaging.compress_data with data as large_payload
        
        If compressed_data is equal to large_payload:
            Return MessageTestResult with:
                test_name as "test_message_compression"
                passed as false
                error_message as "Data was not compressed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let decompressed_data be Messaging.decompress_data with
            data as compressed_data and
            compression_type as "gzip"
        
        If decompressed_data is not equal to large_payload:
            Return MessageTestResult with:
                test_name as "test_message_compression"
                passed as false
                error_message as "Decompression failed or data corrupted"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_message_compression"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_message_compression"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_retry_logic" returns MessageTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test retry delay calculation
        Let delay1 be Messaging.calculate_retry_delay with retry_count as 0
        Let delay2 be Messaging.calculate_retry_delay with retry_count as 1
        Let delay3 be Messaging.calculate_retry_delay with retry_count as 2
        
        Note: Validate exponential backoff
        If delay2 <= delay1:
            Return MessageTestResult with:
                test_name as "test_retry_logic"
                passed as false
                error_message as "Retry delay not increasing exponentially"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If delay3 <= delay2:
            Return MessageTestResult with:
                test_name as "test_retry_logic"
                passed as false
                error_message as "Retry delay progression incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test maximum delay cap
        Let max_delay be Messaging.calculate_retry_delay with retry_count as 20
        If max_delay > 300.0:
            Return MessageTestResult with:
                test_name as "test_retry_logic"
                passed as false
                error_message as "Maximum delay cap not enforced"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return MessageTestResult with:
            test_name as "test_retry_logic"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return MessageTestResult with:
            test_name as "test_retry_logic"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "run_all_messaging_tests" returns List[MessageTestResult]:
    Let results be list containing
    
    Print "=== Running Messaging Module Tests ==="
    
    Print "Testing message creation..."
    Let result1 be test_create_message()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing message priority handling..."
    Let result2 be test_message_priority_handling()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing message queue operations..."
    Let result3 be test_message_queue_operations()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing message delivery..."
    Let result4 be test_message_delivery()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing message compression..."
    Let result5 be test_message_compression()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "Testing retry logic..."
    Let result6 be test_retry_logic()
    Add result6 to results
    Print result6.test_name + ": " + (If result6.passed then "PASS" else "FAIL")
    
    Print "=== Messaging Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()