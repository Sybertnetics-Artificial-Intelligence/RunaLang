Note:
Unit Tests: AI Communication - Routing System
Comprehensive test suite for intelligent routing, path discovery, and load balancing.
:End Note

Import "../../../../src/stdlib/ai/comms/routing" as Routing
Import "../../../../src/stdlib/testing/unittest" as UnitTest

Type called "RoutingTestResult":
    test_name as String
    passed as Boolean
    error_message as Optional[String]
    execution_time_ms as Float

Process called "test_routing_table_creation" returns RoutingTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let routing_table be Routing.create_routing_table with
            table_id as "test_routing_table" and
            max_entries as 1000 and
            refresh_interval_seconds as 300
        
        If routing_table["table_id"] is not equal to "test_routing_table":
            Return RoutingTestResult with:
                test_name as "test_routing_table_creation"
                passed as false
                error_message as "Routing table ID not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If routing_table["max_entries"] is not equal to 1000:
            Return RoutingTestResult with:
                test_name as "test_routing_table_creation"
                passed as false
                error_message as "Max entries not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If routing_table["current_entries"] is not equal to 0:
            Return RoutingTestResult with:
                test_name as "test_routing_table_creation"
                passed as false
                error_message as "Initial entry count should be 0"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return RoutingTestResult with:
            test_name as "test_routing_table_creation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return RoutingTestResult with:
            test_name as "test_routing_table_creation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_route_discovery" returns RoutingTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let routing_table be create_test_routing_table()
        
        Note: Add network topology entries
        Let node1_result be Routing.add_route_entry with
            table as routing_table and
            destination as "ai_agent_node_1" and
            next_hop as "gateway_1" and
            cost as 5 and
            latency_ms as 20.0
        
        Let node2_result be Routing.add_route_entry with
            table as routing_table and
            destination as "ai_agent_node_2" and
            next_hop as "gateway_2" and
            cost as 10 and
            latency_ms as 35.0
        
        If not (node1_result["success"] and node2_result["success"]):
            Return RoutingTestResult with:
                test_name as "test_route_discovery"
                passed as false
                error_message as "Failed to add route entries"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test route discovery
        Let discovery_result be Routing.discover_route with
            table as routing_table and
            source as "local_agent" and
            destination as "ai_agent_node_1"
        
        If not discovery_result["success"]:
            Return RoutingTestResult with:
                test_name as "test_route_discovery"
                passed as false
                error_message as "Route discovery failed: " + discovery_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let discovered_route be discovery_result["route"]
        
        If discovered_route["destination"] is not equal to "ai_agent_node_1":
            Return RoutingTestResult with:
                test_name as "test_route_discovery"
                passed as false
                error_message as "Discovered route destination incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If discovered_route["next_hop"] is not equal to "gateway_1":
            Return RoutingTestResult with:
                test_name as "test_route_discovery"
                passed as false
                error_message as "Discovered route next hop incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return RoutingTestResult with:
            test_name as "test_route_discovery"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return RoutingTestResult with:
            test_name as "test_route_discovery"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_load_balancing" returns RoutingTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let routing_table be create_test_routing_table()
        
        Note: Add multiple paths to same destination
        Let path1_result be Routing.add_route_entry with
            table as routing_table and
            destination as "load_balanced_destination" and
            next_hop as "path_1" and
            cost as 8 and
            latency_ms as 25.0
        
        Let path2_result be Routing.add_route_entry with
            table as routing_table and
            destination as "load_balanced_destination" and
            next_hop as "path_2" and
            cost as 8 and
            latency_ms as 30.0
        
        Let path3_result be Routing.add_route_entry with
            table as routing_table and
            destination as "load_balanced_destination" and
            next_hop as "path_3" and
            cost as 8 and
            latency_ms as 28.0
        
        If not (path1_result["success"] and path2_result["success"] and path3_result["success"]):
            Return RoutingTestResult with:
                test_name as "test_load_balancing"
                passed as false
                error_message as "Failed to add multiple paths"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test load balancing algorithm
        Let balancing_result be Routing.configure_load_balancing with
            table as routing_table and
            algorithm as "weighted_round_robin" and
            balance_factor as 0.7
        
        If not balancing_result["success"]:
            Return RoutingTestResult with:
                test_name as "test_load_balancing"
                passed as false
                error_message as "Load balancing configuration failed: " + balancing_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test path selection with load balancing
        Let selected_paths be list containing
        
        For i from 1 to 10:
            Let route_result be Routing.select_optimal_route with
                table as routing_table and
                destination as "load_balanced_destination" and
                selection_criteria as "load_balanced"
            
            Add route_result["route"]["next_hop"] to selected_paths
        
        Note: Verify different paths were selected
        Let unique_paths be get_unique_elements from selected_paths
        
        If length of unique_paths < 2:
            Return RoutingTestResult with:
                test_name as "test_load_balancing"
                passed as false
                error_message as "Load balancing not distributing across multiple paths"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return RoutingTestResult with:
            test_name as "test_load_balancing"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return RoutingTestResult with:
            test_name as "test_load_balancing"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_quality_aware_routing" returns RoutingTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let routing_table be create_test_routing_table()
        
        Note: Add routes with different quality metrics
        Let high_quality_route be Routing.add_route_entry with
            table as routing_table and
            destination as "quality_test_destination" and
            next_hop as "high_quality_path" and
            cost as 15 and
            latency_ms as 10.0 and
            reliability_score as 0.99 and
            bandwidth_mbps as 1000.0
        
        Let low_quality_route be Routing.add_route_entry with
            table as routing_table and
            destination as "quality_test_destination" and
            next_hop as "low_quality_path" and
            cost as 5 and
            latency_ms as 100.0 and
            reliability_score as 0.85 and
            bandwidth_mbps as 100.0
        
        If not (high_quality_route["success"] and low_quality_route["success"]):
            Return RoutingTestResult with:
                test_name as "test_quality_aware_routing"
                passed as false
                error_message as "Failed to add quality-differentiated routes"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test quality-aware route selection
        Let quality_routing_result be Routing.select_optimal_route with
            table as routing_table and
            destination as "quality_test_destination" and
            selection_criteria as "quality_aware" and
            quality_weights as Dictionary with:
                "latency_weight" as 0.4
                "reliability_weight" as 0.4
                "bandwidth_weight" as 0.2
        
        If not quality_routing_result["success"]:
            Return RoutingTestResult with:
                test_name as "test_quality_aware_routing"
                passed as false
                error_message as "Quality-aware routing failed: " + quality_routing_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: High-quality path should be selected despite higher cost
        Let selected_route be quality_routing_result["route"]
        
        If selected_route["next_hop"] is not equal to "high_quality_path":
            Return RoutingTestResult with:
                test_name as "test_quality_aware_routing"
                passed as false
                error_message as "Quality-aware routing did not select high-quality path"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return RoutingTestResult with:
            test_name as "test_quality_aware_routing"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return RoutingTestResult with:
            test_name as "test_quality_aware_routing"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_message_fragmentation" returns RoutingTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let routing_table be create_test_routing_table()
        
        Note: Create large message that needs fragmentation
        Let large_message be Dictionary with:
            "sender_id" as "sender_agent"
            "receiver_id" as "receiver_agent"
            "content" as create_large_content()
            "size_bytes" as 10485760  Note: 10MB message
        
        Note: Configure fragmentation settings
        Let fragmentation_config be Routing.configure_message_fragmentation with
            table as routing_table and
            max_fragment_size_bytes as 1048576 and  Note: 1MB fragments
            fragmentation_enabled as true
        
        If not fragmentation_config["success"]:
            Return RoutingTestResult with:
                test_name as "test_message_fragmentation"
                passed as false
                error_message as "Fragmentation configuration failed: " + fragmentation_config["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test message fragmentation
        Let fragmentation_result be Routing.fragment_message_for_routing with
            message as large_message and
            max_fragment_size as 1048576
        
        If not fragmentation_result["success"]:
            Return RoutingTestResult with:
                test_name as "test_message_fragmentation"
                passed as false
                error_message as "Message fragmentation failed: " + fragmentation_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let fragments be fragmentation_result["fragments"]
        
        Note: Verify fragmentation created expected number of fragments
        Let expected_fragments be (large_message["size_bytes"] / 1048576) + 1
        
        If length of fragments is not equal to expected_fragments:
            Return RoutingTestResult with:
                test_name as "test_message_fragmentation"
                passed as false
                error_message as "Incorrect number of fragments created"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test fragment reassembly
        Let reassembly_result be Routing.reassemble_message_fragments with fragments as fragments
        
        If not reassembly_result["success"]:
            Return RoutingTestResult with:
                test_name as "test_message_fragmentation"
                passed as false
                error_message as "Fragment reassembly failed: " + reassembly_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let reassembled_message be reassembly_result["message"]
        
        If reassembled_message["size_bytes"] is not equal to large_message["size_bytes"]:
            Return RoutingTestResult with:
                test_name as "test_message_fragmentation"
                passed as false
                error_message as "Reassembled message size incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return RoutingTestResult with:
            test_name as "test_message_fragmentation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return RoutingTestResult with:
            test_name as "test_message_fragmentation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "create_test_routing_table" returns RoutingTable:
    Return Routing.create_routing_table with
        table_id as "test_table" and
        max_entries as 100 and
        refresh_interval_seconds as 60

Process called "create_large_content" returns String:
    Let content be ""
    For i from 1 to 10000:
        Set content to content + "Large message content block " + i + " with additional padding data. "
    Return content

Process called "get_unique_elements" that takes list as List[String] returns List[String]:
    Let unique_list be list containing
    
    For each element in list:
        If not unique_list contains element:
            Add element to unique_list
    
    Return unique_list

Process called "run_all_routing_tests" returns List[RoutingTestResult]:
    Let results be list containing
    
    Print "=== Running Routing Module Tests ==="
    
    Print "Testing routing table creation..."
    Let result1 be test_routing_table_creation()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing route discovery..."
    Let result2 be test_route_discovery()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing load balancing..."
    Let result3 be test_load_balancing()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing quality-aware routing..."
    Let result4 be test_quality_aware_routing()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing message fragmentation..."
    Let result5 be test_message_fragmentation()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "=== Routing Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()