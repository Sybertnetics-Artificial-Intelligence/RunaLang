Note:
Unit Tests: AI Communication - Encryption System
Comprehensive test suite for cryptographic operations, key management, and security protocols.
:End Note

Import "../../../../src/stdlib/ai/comms/encryption" as Encryption
Import "../../../../src/stdlib/testing/unittest" as UnitTest

Type called "EncryptionTestResult":
    test_name as String
    passed as Boolean
    error_message as Optional[String]
    execution_time_ms as Float

Process called "test_key_generation" returns EncryptionTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test symmetric key generation
        Let symmetric_key be Encryption.generate_symmetric_key with
            algorithm as "aes_256_gcm" and
            key_length as 32
        
        If symmetric_key["status"] is not equal to "active":
            Return EncryptionTestResult with:
                test_name as "test_key_generation"
                passed as false
                error_message as "Symmetric key not generated with active status"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If symmetric_key["key_type"] is not equal to "symmetric":
            Return EncryptionTestResult with:
                test_name as "test_key_generation"
                passed as false
                error_message as "Key type not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test asymmetric key pair generation
        Let keypair_result be Encryption.generate_asymmetric_keypair with
            algorithm as "ecdh_p256" and
            key_size as 256
        
        If not keypair_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_key_generation"
                passed as false
                error_message as "Keypair generation failed: " + keypair_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let keypair be keypair_result["keypair"]
        If keypair["algorithm"] is not equal to "ecdh_p256":
            Return EncryptionTestResult with:
                test_name as "test_key_generation"
                passed as false
                error_message as "Keypair algorithm not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return EncryptionTestResult with:
            test_name as "test_key_generation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return EncryptionTestResult with:
            test_name as "test_key_generation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_aes_encryption_decryption" returns EncryptionTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test AES-GCM encryption and decryption
        Let test_data be "This is sensitive test data that needs encryption"
        
        Let key be Encryption.generate_symmetric_key with
            algorithm as "aes_256_gcm" and
            key_length as 32
        
        Note: Encrypt the data
        Let encryption_result be Encryption.encrypt_data with
            data as test_data and
            key as key and
            algorithm as "aes_256_gcm"
        
        If not encryption_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_aes_encryption_decryption"
                passed as false
                error_message as "Encryption failed: " + encryption_result["error_message"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify encrypted data is different from original
        If encryption_result["encrypted_data"] is equal to test_data:
            Return EncryptionTestResult with:
                test_name as "test_aes_encryption_decryption"
                passed as false
                error_message as "Data was not actually encrypted"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Decrypt the data
        Let decryption_result be Encryption.decrypt_data with
            encrypted_data as encryption_result["encrypted_data"] and
            authentication_tag as encryption_result["authentication_tag"] and
            nonce as encryption_result["nonce"] and
            key as key and
            algorithm as "aes_256_gcm"
        
        If not decryption_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_aes_encryption_decryption"
                passed as false
                error_message as "Decryption failed: " + decryption_result["error_message"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify decrypted data matches original
        If decryption_result["decrypted_data"] is not equal to test_data:
            Return EncryptionTestResult with:
                test_name as "test_aes_encryption_decryption"
                passed as false
                error_message as "Decrypted data does not match original"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return EncryptionTestResult with:
            test_name as "test_aes_encryption_decryption"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return EncryptionTestResult with:
            test_name as "test_aes_encryption_decryption"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_key_rotation" returns EncryptionTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test key rotation functionality
        Let original_key be Encryption.generate_symmetric_key with
            algorithm as "aes_256_gcm" and
            key_length as 32
        
        Note: Rotate to new key
        Let rotation_result be Encryption.rotate_key with
            old_key as original_key and
            new_algorithm as "aes_256_gcm"
        
        If not rotation_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_key_rotation"
                passed as false
                error_message as "Key rotation failed: " + rotation_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let new_key be rotation_result["new_key"]
        
        Note: Verify old key is marked as expired
        If original_key["status"] is not equal to "expired":
            Return EncryptionTestResult with:
                test_name as "test_key_rotation"
                passed as false
                error_message as "Old key not marked as expired"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify new key is active
        If new_key["status"] is not equal to "active":
            Return EncryptionTestResult with:
                test_name as "test_key_rotation"
                passed as false
                error_message as "New key not marked as active"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify keys are different
        If new_key["key_material"] is equal to original_key["key_material"]:
            Return EncryptionTestResult with:
                test_name as "test_key_rotation"
                passed as false
                error_message as "New key is same as old key"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return EncryptionTestResult with:
            test_name as "test_key_rotation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return EncryptionTestResult with:
            test_name as "test_key_rotation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_digital_signatures" returns EncryptionTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test digital signature creation and verification
        Let keypair_result be Encryption.generate_asymmetric_keypair with
            algorithm as "ecdsa_p256" and
            key_size as 256
        
        If not keypair_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_digital_signatures"
                passed as false
                error_message as "Failed to generate keypair for signing"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Let keypair be keypair_result["keypair"]
        Let message_data be "This message needs to be signed for authenticity"
        
        Note: Create digital signature
        Let signature_result be Encryption.create_signature with
            data as message_data and
            private_key as keypair["private_key"] and
            algorithm as "ecdsa_p256"
        
        If not signature_result["success"]:
            Return EncryptionTestResult with:
                test_name as "test_digital_signatures"
                passed as false
                error_message as "Signature creation failed: " + signature_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify digital signature
        Let verification_result be Encryption.verify_signature with
            data as message_data and
            signature as signature_result["signature"] and
            public_key as keypair["public_key"] and
            algorithm as "ecdsa_p256"
        
        If not verification_result["valid"]:
            Return EncryptionTestResult with:
                test_name as "test_digital_signatures"
                passed as false
                error_message as "Signature verification failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test signature verification with tampered data
        Let tampered_data be message_data + " TAMPERED"
        Let tampered_verification be Encryption.verify_signature with
            data as tampered_data and
            signature as signature_result["signature"] and
            public_key as keypair["public_key"] and
            algorithm as "ecdsa_p256"
        
        If tampered_verification["valid"]:
            Return EncryptionTestResult with:
                test_name as "test_digital_signatures"
                passed as false
                error_message as "Tampered data signature verified incorrectly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return EncryptionTestResult with:
            test_name as "test_digital_signatures"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return EncryptionTestResult with:
            test_name as "test_digital_signatures"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_security_context" returns EncryptionTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test security context creation and management
        Let security_config be Dictionary with:
            "encryption_enabled" as true
            "signature_required" as true
            "key_rotation_interval_hours" as 24
        
        Let context be Encryption.create_security_context with
            agent_id as "test_agent" and
            configuration as security_config
        
        If context["agent_id"] is not equal to "test_agent":
            Return EncryptionTestResult with:
                test_name as "test_security_context"
                passed as false
                error_message as "Security context agent ID not set correctly"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If not context["encryption_enabled"]:
            Return EncryptionTestResult with:
                test_name as "test_security_context"
                passed as false
                error_message as "Encryption not enabled in security context"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test security context validation
        Let validation_result be Encryption.validate_security_context with context as context
        
        If not validation_result["valid"]:
            Return EncryptionTestResult with:
                test_name as "test_security_context"
                passed as false
                error_message as "Security context validation failed: " + validation_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return EncryptionTestResult with:
            test_name as "test_security_context"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return EncryptionTestResult with:
            test_name as "test_security_context"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "run_all_encryption_tests" returns List[EncryptionTestResult]:
    Let results be list containing
    
    Print "=== Running Encryption Module Tests ==="
    
    Print "Testing key generation..."
    Let result1 be test_key_generation()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing AES encryption/decryption..."
    Let result2 be test_aes_encryption_decryption()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing key rotation..."
    Let result3 be test_key_rotation()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing digital signatures..."
    Let result4 be test_digital_signatures()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing security context..."
    Let result5 be test_security_context()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "=== Encryption Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()