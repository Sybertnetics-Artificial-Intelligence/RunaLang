                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return BroadcastTestResult with:
            test_name as "test_broadcast_message_delivery"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return BroadcastTestResult with:
            test_name as "test_broadcast_message_delivery"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_topic_filtering" returns BroadcastTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let channel be Broadcast.create_broadcast_channel with
            channel_id as "filter_test" and
            topic as "filtered_messages" and
            max_subscribers as 100
        
        Note: Subscribe with specific filters
        Let filtered_sub_result be Broadcast.subscribe_to_channel with
            channel as channel and
            subscriber_id as "filtered_agent" and
            subscription_filters as list containing "type:alert" and "priority:high"
        
        Let unfiltered_sub_result be Broadcast.subscribe_to_channel with
            channel as channel and
            subscriber_id as "unfiltered_agent" and
            subscription_filters as list containing
        
        Note: Send filtered message
        Let filtered_message be Dictionary with:
            "content" as "High priority alert"
            "type" as "alert"
            "priority" as "high"
        
        Let filtered_broadcast_result be Broadcast.broadcast_message with
            channel as channel and
            message as filtered_message and
            delivery_guarantee as "best_effort"
        
        Note: Verify filtering worked (both should receive it)
        If filtered_broadcast_result["delivered_count"] is not equal to 2:
            Return BroadcastTestResult with:
                test_name as "test_topic_filtering"
                passed as false
                error_message as "Filtered message delivery count incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Send non-matching message
        Let non_matching_message be Dictionary with:
            "content" as "Low priority info"
            "type" as "info"
            "priority" as "low"
        
        Let non_matching_broadcast_result be Broadcast.broadcast_message with
            channel as channel and
            message as non_matching_message and
            delivery_guarantee as "best_effort"
        
        Note: Only unfiltered agent should receive it
        If non_matching_broadcast_result["delivered_count"] is not equal to 1:
            Return BroadcastTestResult with:
                test_name as "test_topic_filtering"
                passed as false
                error_message as "Non-matching message filtering incorrect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return BroadcastTestResult with:
            test_name as "test_topic_filtering"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return BroadcastTestResult with:
            test_name as "test_topic_filtering"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_broadcast_storm_prevention" returns BroadcastTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test flood control mechanisms
        Let channel be Broadcast.create_broadcast_channel with
            channel_id as "storm_test" and
            topic as "storm_prevention" and
            max_subscribers as 10
        
        Note: Configure flood control
        Let flood_control_result be Broadcast.configure_flood_control with
            channel as channel and
            max_messages_per_second as 5 and
            burst_size as 10
        
        If not flood_control_result["success"]:
            Return BroadcastTestResult with:
                test_name as "test_broadcast_storm_prevention"
                passed as false
                error_message as "Flood control configuration failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Attempt to send messages rapidly
        Let messages_sent be 0
        Let messages_blocked be 0
        
        For i from 1 to 20:
            Let rapid_message be Dictionary with:
                "content" as "Rapid message " + i
                "timestamp" as get_current_timestamp()
            
            Let rapid_broadcast_result be Broadcast.broadcast_message with
                channel as channel and
                message as rapid_message and
                delivery_guarantee as "best_effort"
            
            If rapid_broadcast_result["success"]:
                Set messages_sent to messages_sent plus 1
            Else:
                If rapid_broadcast_result["error"] contains "rate_limit":
                    Set messages_blocked to messages_blocked plus 1
        
        Note: Verify some messages were blocked due to rate limiting
        If messages_blocked < 5:
            Return BroadcastTestResult with:
                test_name as "test_broadcast_storm_prevention"
                passed as false
                error_message as "Flood control not working - expected some blocked messages"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return BroadcastTestResult with:
            test_name as "test_broadcast_storm_prevention"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return BroadcastTestResult with:
            test_name as "test_broadcast_storm_prevention"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "run_all_broadcast_tests" returns List[BroadcastTestResult]:
    Let results be list containing
    
    Print "=== Running Broadcast Module Tests ==="
    
    Print "Testing broadcast channel creation..."
    Let result1 be test_broadcast_channel_creation()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing subscriber management..."
    Let result2 be test_subscriber_management()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing broadcast message delivery..."
    Let result3 be test_broadcast_message_delivery()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing topic filtering..."
    Let result4 be test_topic_filtering()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing broadcast storm prevention..."
    Let result5 be test_broadcast_storm_prevention()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "=== Broadcast Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()

Process called "get_current_timestamp" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_seconds()