            max_subscribers as 50
        
        Note: Add subscribers
        Let sub1_result be Broadcast.subscribe_to_channel with
            channel as channel and
            subscriber_id as "agent_1" and
            subscription_filters as list containing
        
        Let sub2_result be Broadcast.subscribe_to_channel with
            channel as channel and
            subscriber_id as "agent_2" and
            subscription_filters as list containing
        
        Note: Create and broadcast message
        Let broadcast_message be Dictionary with:
            "content" as "Test broadcast message"
            "priority" as "normal"
            "timestamp" as get_current_timestamp()
        
        Let broadcast_result be Broadcast.broadcast_message with
            channel as channel and
            message as broadcast_message and
            delivery_guarantee as "at_least_once"
        
        If not broadcast_result["success"]:
            Return BroadcastTestResult with:
                test_name as "test_broadcast_message_delivery"
                passed as false
                error_message as "Broadcast delivery failed: " + broadcast_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
