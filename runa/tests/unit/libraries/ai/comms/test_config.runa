Note:
Unit Tests: AI Communication - Configuration System
Comprehensive test suite for configuration management, validation, and updates.
:End Note

Import "../../../../src/stdlib/ai/comms/config" as CommsConfig
Import "../../../../src/stdlib/testing/unittest" as UnitTest

Type called "ConfigTestResult":
    test_name as String
    passed as Boolean
    error_message as Optional[String]
    execution_time_ms as Float

Process called "test_config_loading" returns ConfigTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let config be CommsConfig.get_comms_config()
        
        If config["messaging"] is empty:
            Return ConfigTestResult with:
                test_name as "test_config_loading"
                passed as false
                error_message as "Messaging config section not loaded"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If config["protocols"] is empty:
            Return ConfigTestResult with:
                test_name as "test_config_loading"
                passed as false
                error_message as "Protocols config section not loaded"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If config["encryption"] is empty:
            Return ConfigTestResult with:
                test_name as "test_config_loading"
                passed as false
                error_message as "Encryption config section not loaded"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If config["routing"] is empty:
            Return ConfigTestResult with:
                test_name as "test_config_loading"
                passed as false
                error_message as "Routing config section not loaded"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ConfigTestResult with:
            test_name as "test_config_loading"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ConfigTestResult with:
            test_name as "test_config_loading"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_config_validation" returns ConfigTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let config be CommsConfig.get_comms_config()
        
        Note: Validate messaging configuration
        Let messaging_config be config["messaging"]
        Let messaging_validation be CommsConfig.validate_messaging_config with config as messaging_config
        
        If not messaging_validation["valid"]:
            Return ConfigTestResult with:
                test_name as "test_config_validation"
                passed as false
                error_message as "Messaging config validation failed: " + messaging_validation["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Validate protocols configuration
        Let protocols_config be config["protocols"]
        Let protocols_validation be CommsConfig.validate_protocols_config with config as protocols_config
        
        If not protocols_validation["valid"]:
            Return ConfigTestResult with:
                test_name as "test_config_validation"
                passed as false
                error_message as "Protocols config validation failed: " + protocols_validation["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Validate encryption configuration
        Let encryption_config be config["encryption"]
        Let encryption_validation be CommsConfig.validate_encryption_config with config as encryption_config
        
        If not encryption_validation["valid"]:
            Return ConfigTestResult with:
                test_name as "test_config_validation"
                passed as false
                error_message as "Encryption config validation failed: " + encryption_validation["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ConfigTestResult with:
            test_name as "test_config_validation"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ConfigTestResult with:
            test_name as "test_config_validation"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_config_updates" returns ConfigTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Let config be CommsConfig.get_comms_config()
        Let original_timeout be config["messaging"]["timeout_seconds"]
        
        Note: Update configuration value
        Let new_timeout be original_timeout plus 10.0
        Let update_result be CommsConfig.update_config_value with
            section as "messaging" and
            key as "timeout_seconds" and
            value as new_timeout
        
        If not update_result["success"]:
            Return ConfigTestResult with:
                test_name as "test_config_updates"
                passed as false
                error_message as "Config update failed: " + update_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify update took effect
        Let updated_config be CommsConfig.get_comms_config()
        
        If updated_config["messaging"]["timeout_seconds"] is not equal to new_timeout:
            Return ConfigTestResult with:
                test_name as "test_config_updates"
                passed as false
                error_message as "Config update did not take effect"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Restore original value
        Let restore_result be CommsConfig.update_config_value with
            section as "messaging" and
            key as "timeout_seconds" and
            value as original_timeout
        
        Return ConfigTestResult with:
            test_name as "test_config_updates"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ConfigTestResult with:
            test_name as "test_config_updates"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_config_defaults" returns ConfigTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test default configuration creation
        Let default_config be CommsConfig.create_default_config()
        
        Note: Verify all required sections exist
        Let required_sections be list containing "messaging" and "protocols" and "encryption" and "routing" and "broadcast" and "multicast" and "federation" and "channels"
        
        For each section in required_sections:
            If not default_config contains section:
                Return ConfigTestResult with:
                    test_name as "test_config_defaults"
                    passed as false
                    error_message as "Required section missing: " + section
                    execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify messaging defaults
        Let messaging_defaults be default_config["messaging"]
        If messaging_defaults["timeout_seconds"] <= 0.0:
            Return ConfigTestResult with:
                test_name as "test_config_defaults"
                passed as false
                error_message as "Invalid default timeout value"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        If messaging_defaults["max_retries"] <= 0:
            Return ConfigTestResult with:
                test_name as "test_config_defaults"
                passed as false
                error_message as "Invalid default retry value"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Verify encryption defaults
        Let encryption_defaults be default_config["encryption"]
        If encryption_defaults["default_algorithm"] is empty:
            Return ConfigTestResult with:
                test_name as "test_config_defaults"
                passed as false
                error_message as "Default encryption algorithm not set"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ConfigTestResult with:
            test_name as "test_config_defaults"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ConfigTestResult with:
            test_name as "test_config_defaults"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "test_config_environment_overrides" returns ConfigTestResult:
    Let start_time be get_current_timestamp_ms()
    
    Try:
        Note: Test environment variable override functionality
        Let env_override_result be CommsConfig.apply_environment_overrides()
        
        If not env_override_result["success"]:
            Return ConfigTestResult with:
                test_name as "test_config_environment_overrides"
                passed as false
                error_message as "Environment override application failed: " + env_override_result["error"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test specific override pattern
        Let override_test_result be CommsConfig.test_override_pattern with
            pattern as "RUNA_COMMS_MESSAGING_TIMEOUT" and
            expected_path as list containing "messaging" and "timeout_seconds"
        
        If not override_test_result["valid"]:
            Return ConfigTestResult with:
                test_name as "test_config_environment_overrides"
                passed as false
                error_message as "Override pattern validation failed"
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Note: Test override precedence
        Let precedence_test_result be CommsConfig.test_override_precedence()
        
        If not precedence_test_result["correct"]:
            Return ConfigTestResult with:
                test_name as "test_config_environment_overrides"
                passed as false
                error_message as "Override precedence incorrect: " + precedence_test_result["issue"]
                execution_time_ms as get_current_timestamp_ms() minus start_time
        
        Return ConfigTestResult with:
            test_name as "test_config_environment_overrides"
            passed as true
            error_message as ""
            execution_time_ms as get_current_timestamp_ms() minus start_time
    
    Catch error:
        Return ConfigTestResult with:
            test_name as "test_config_environment_overrides"
            passed as false
            error_message as "Exception: " + error["message"]
            execution_time_ms as get_current_timestamp_ms() minus start_time

Process called "run_all_config_tests" returns List[ConfigTestResult]:
    Let results be list containing
    
    Print "=== Running Config Module Tests ==="
    
    Print "Testing config loading..."
    Let result1 be test_config_loading()
    Add result1 to results
    Print result1.test_name + ": " + (If result1.passed then "PASS" else "FAIL")
    
    Print "Testing config validation..."
    Let result2 be test_config_validation()
    Add result2 to results
    Print result2.test_name + ": " + (If result2.passed then "PASS" else "FAIL")
    
    Print "Testing config updates..."
    Let result3 be test_config_updates()
    Add result3 to results
    Print result3.test_name + ": " + (If result3.passed then "PASS" else "FAIL")
    
    Print "Testing config defaults..."
    Let result4 be test_config_defaults()
    Add result4 to results
    Print result4.test_name + ": " + (If result4.passed then "PASS" else "FAIL")
    
    Print "Testing environment overrides..."
    Let result5 be test_config_environment_overrides()
    Add result5 to results
    Print result5.test_name + ": " + (If result5.passed then "PASS" else "FAIL")
    
    Print "=== Config Tests Complete ==="
    Return results

Process called "get_current_timestamp_ms" returns Float:
    Import "../../../../src/stdlib/time/time" as Time
    Return Time.get_timestamp_milliseconds()