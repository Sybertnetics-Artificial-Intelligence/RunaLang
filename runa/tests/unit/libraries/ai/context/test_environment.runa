Import "../../../../../../src/stdlib/ai/context/environment.runa" as Environment
Import "../../../../../testing/framework.runa" as Test

Note:
Comprehensive test suite for AI Context Environment System
Tests environmental sensing, data collection, and sensor fusion
:End Note

Process called "test_create_comprehensive_environment_system":
    Let system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_001"
        and monitoring_scope as "full_system"
    
    Test.assert_not_null with value as system and description as "Environment system should be created"
    Test.assert_equals with 
        actual as system["system_id"] 
        and expected as "test_env_001" 
        and description as "System ID should match"
    Test.assert_equals with 
        actual as system["monitoring_scope"] 
        and expected as "full_system" 
        and description as "Monitoring scope should match"
    Test.assert_true with 
        condition as (system contains "sensor_managers")
        and description as "System should contain sensor managers"

Process called "test_collect_comprehensive_environment_data":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_002"
        and monitoring_scope as "performance_monitoring"
    
    Let result be Environment.collect_comprehensive_environment_data with
        environment_system as environment_system
    
    Test.assert_not_null with value as result and description as "Environment data should not be null"
    Test.assert_equals with 
        actual as result["collection_method"] 
        and expected as "comprehensive_data_collection"
        and description as "Collection method should be correct"
    Test.assert_true with 
        condition as (result contains "sensor_data")
        and description as "Result should contain sensor data"
    Test.assert_true with 
        condition as (result contains "fusion_data")
        and description as "Result should contain fusion data"

Process called "test_monitor_environment_changes":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_003"
        and monitoring_scope as "change_detection"
    
    Let baseline_data be Dictionary with:
        "system_metrics" as Dictionary with: "cpu_usage" as 0.5 and "memory_usage" as 0.4
        "timestamp" as 1000.0
    
    Let result be Environment.monitor_environment_changes with
        environment_system as environment_system
        and baseline_data as baseline_data
    
    Test.assert_not_null with value as result and description as "Change monitoring result should not be null"
    Test.assert_equals with 
        actual as result["monitoring_method"] 
        and expected as "comprehensive_change_monitoring"
        and description as "Monitoring method should be correct"
    Test.assert_true with 
        condition as (result contains "detected_changes")
        and description as "Result should contain detected changes"

Process called "test_collect_sensor_data":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_004"
        and monitoring_scope as "sensor_testing"
    
    Let sensor_config be Dictionary with:
        "sensor_types" as list containing "temporal" and "performance" and "behavioral"
        "collection_strategy" as "comprehensive"
        "quality_assurance" as true
    
    Let result be Environment.collect_sensor_data with
        environment_system as environment_system
        and sensor_config as sensor_config
    
    Test.assert_not_null with value as result and description as "Sensor data should not be null"
    Test.assert_true with 
        condition as (result contains "temporal_data")
        and description as "Result should contain temporal data"
    Test.assert_true with 
        condition as (result contains "performance_data")
        and description as "Result should contain performance data"
    Test.assert_true with 
        condition as (result contains "behavioral_data")
        and description as "Result should contain behavioral data"

Process called "test_process_and_fuse_sensor_data":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_005"
        and monitoring_scope as "data_fusion"
    
    Let sensor_data be Dictionary with:
        "temporal_data" as Dictionary with: "timestamp" as 2000.0
        "performance_data" as Dictionary with: "cpu_usage" as 0.7
        "behavioral_data" as Dictionary with: "user_activity" as 0.6
        "spatial_data" as Dictionary with: "location" as "server_room_1"
    
    Let fusion_strategy be Dictionary with:
        "fusion_method" as "weighted_fusion"
        "confidence_weighting" as true
        "outlier_detection" as true
    
    Let result be Environment.process_and_fuse_sensor_data with
        environment_system as environment_system
        and sensor_data as sensor_data
        and fusion_strategy as fusion_strategy
    
    Test.assert_not_null with value as result and description as "Fusion result should not be null"
    Test.assert_equals with 
        actual as result["fusion_method"] 
        and expected as "comprehensive_sensor_fusion"
        and description as "Fusion method should be correct"
    Test.assert_true with 
        condition as (result contains "fused_data")
        and description as "Result should contain fused data"

Process called "test_validate_environment_data":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_006"
        and monitoring_scope as "data_validation"
    
    Let environment_data be Dictionary with:
        "sensor_data" as Dictionary with: "temperature" as 22.5 and "humidity" as 45.0
        "quality_metrics" as Dictionary with: "data_completeness" as 0.95
        "timestamp" as 3000.0
    
    Let validation_config be Dictionary with:
        "validation_rules" as list containing "range_check" and "consistency_check"
        "quality_thresholds" as Dictionary with: "minimum_completeness" as 0.9
    
    Let result be Environment.validate_environment_data with
        environment_system as environment_system
        and environment_data as environment_data
        and validation_config as validation_config
    
    Test.assert_not_null with value as result and description as "Validation result should not be null"
    Test.assert_equals with 
        actual as result["validation_method"] 
        and expected as "comprehensive_data_validation"
        and description as "Validation method should be correct"
    Test.assert_true with 
        condition as (result contains "validation_status")
        and description as "Result should contain validation status"

Process called "test_analyze_environment_patterns":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_007"
        and monitoring_scope as "pattern_analysis"
    
    Let environment_data be Dictionary with:
        "historical_data" as list containing 
            Dictionary with: "timestamp" as 1000.0 and "cpu_usage" as 0.5
            Dictionary with: "timestamp" as 2000.0 and "cpu_usage" as 0.6
            Dictionary with: "timestamp" as 3000.0 and "cpu_usage" as 0.7
        "current_data" as Dictionary with: "timestamp" as 4000.0 and "cpu_usage" as 0.8
    
    Let analysis_config be Dictionary with:
        "pattern_types" as list containing "trend_analysis" and "anomaly_detection"
        "time_window" as 5000.0
    
    Let result be Environment.analyze_environment_patterns with
        environment_system as environment_system
        and environment_data as environment_data
        and analysis_config as analysis_config
    
    Test.assert_not_null with value as result and description as "Pattern analysis result should not be null"
    Test.assert_equals with 
        actual as result["analysis_method"] 
        and expected as "comprehensive_pattern_analysis"
        and description as "Analysis method should be correct"
    Test.assert_true with 
        condition as (result contains "detected_patterns")
        and description as "Result should contain detected patterns"

Process called "test_random_number_generation":
    Let random1 be Environment.runtime_random_float()
    Let random2 be Environment.runtime_random_float()
    Let random3 be Environment.runtime_random_float()
    
    Test.assert_number_in_range with 
        value as random1 
        and min as 0.0 
        and max as 1.0
        and description as "Random float 1 should be in valid range"
    Test.assert_number_in_range with 
        value as random2 
        and min as 0.0 
        and max as 1.0
        and description as "Random float 2 should be in valid range"
    Test.assert_number_in_range with 
        value as random3 
        and min as 0.0 
        and max as 1.0
        and description as "Random float 3 should be in valid range"
    
    Test.assert_not_equals with 
        actual as random1 
        and expected as random2
        and description as "Random numbers should be different"
    
    Let random_int be Environment.runtime_random_integer_range with min as 10 and max as 20
    Test.assert_number_in_range with 
        value as random_int 
        and min as 10 
        and max as 20
        and description as "Random integer should be in specified range"

Process called "test_sensor_data_collection_fallback":
    Let environment_system be Environment.create_comprehensive_environment_system with
        system_id as "test_env_008"
        and monitoring_scope as "fallback_testing"
    
    Note: Test fallback behavior for different sensor types
    Let temporal_data be Environment.collect_temporal_sensor_data with environment_system
    Test.assert_not_null with value as temporal_data and description as "Temporal data should not be null"
    
    Let performance_data be Environment.collect_performance_sensor_data with environment_system
    Test.assert_not_null with value as performance_data and description as "Performance data should not be null"
    
    Let behavioral_data be Environment.collect_behavioral_sensor_data with environment_system
    Test.assert_not_null with value as behavioral_data and description as "Behavioral data should not be null"
    
    Let spatial_data be Environment.collect_spatial_sensor_data with environment_system
    Test.assert_not_null with value as spatial_data and description as "Spatial data should not be null"

Process called "run_all_environment_tests":
    Test.start_test_suite with suite_name as "AI Context Environment Tests"
    
    test_create_comprehensive_environment_system()
    test_collect_comprehensive_environment_data()
    test_monitor_environment_changes()
    test_collect_sensor_data()
    test_process_and_fuse_sensor_data()
    test_validate_environment_data()
    test_analyze_environment_patterns()
    test_random_number_generation()
    test_sensor_data_collection_fallback()
    
    Test.end_test_suite()
    
    Let results be Test.get_test_results()
    Return results