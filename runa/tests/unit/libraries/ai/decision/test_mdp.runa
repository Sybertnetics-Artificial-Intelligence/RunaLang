Import "../../../../../../src/stdlib/ai/decision/mdp.runa"
Import "../../../../../runtime/test_framework.runa"

Note:
Comprehensive Unit Tests for AI Decision MDP System

Tests cover Markov Decision Processes, value iteration, policy iteration,
Q-learning, SARSA, and POMDP algorithms.
:End Note

Process called "setup_simple_mdp" returns Dictionary:
    Return Dictionary with:
        "states" as list containing "s1", "s2", "s3"
        "actions" as list containing "a1", "a2"
        "transitions" as Dictionary with:
            "s1,a1" as list containing
                Dictionary with "state" as "s1" and "probability" as 0.7
                Dictionary with "state" as "s2" and "probability" as 0.3
            "s1,a2" as list containing
                Dictionary with "state" as "s2" and "probability" as 1.0
        "rewards" as Dictionary with:
            "s1,a1,s1" as 1.0
            "s1,a1,s2" as 5.0
            "s1,a2,s2" as 3.0
        "discount_factor" as 0.9

Test "test_create_mdp":
    Let config be setup_simple_mdp[]
    Let mdp be create_mdp with config as config
    
    Assert mdp.mdp_id is not equal to ""
    Assert length of mdp.states is equal to 3
    Assert length of mdp.actions is equal to 2
    Assert mdp.discount_factor is equal to 0.9

Test "test_value_iteration":
    Let config be setup_simple_mdp[]
    Let mdp be create_mdp with config as config
    
    Let result be solve_value_iteration with mdp as mdp and tolerance as 0.001 and max_iterations as 100
    
    Assert result contains "values"
    Assert result contains "policy"
    Assert result contains "converged"
    Assert length of result["values"] is equal to 3

Test "test_q_learning":
    Let config be setup_simple_mdp[]
    Let mdp be create_mdp with config as config
    
    Let q_table be learn_q_values with mdp as mdp and episodes as 100 and learning_rate as 0.1 and exploration_rate as 0.1
    
    Assert q_table is not equal to null
    Assert q_table contains "s1,a1"
    Assert q_table contains "s1,a2"

Process called "run_all_mdp_tests" returns Boolean:
    Let test_results be list containing
    
    Add run_test with test_name as "test_create_mdp" to test_results
    Add run_test with test_name as "test_value_iteration" to test_results
    Add run_test with test_name as "test_q_learning" to test_results
    
    Let passed_count be 0
    For each result in test_results:
        If result:
            Set passed_count to passed_count plus 1
    
    Let total_tests be length of test_results
    Print "Decision MDP Tests: " plus passed_count plus "/" plus total_tests plus " passed"
    
    Return passed_count is equal to total_tests