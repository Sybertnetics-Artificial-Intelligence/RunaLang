    Note: Cleanup
    Let cleanup_success be teardown_test_environment[]
    
    Note: Count passed tests
    Let passed_count be 0
    For each result in test_results:
        If result:
            Set passed_count to passed_count plus 1
    
    Let total_tests be length of test_results
    Print "Decision Risk Tests: " plus passed_count plus "/" plus total_tests plus " passed"
    
    Return passed_count is equal to total_tests