Import "../../../../../../src/stdlib/ai/decision/game_theory.runa"
Import "../../../../../runtime/test_framework.runa"

Note:
Comprehensive Unit Tests for AI Decision Game Theory System

Tests cover Nash equilibria calculation, auction mechanisms, coalition formation,
strategic reasoning, mechanism design, cooperative games, and evolutionary dynamics.

Test Categories:
- Normal Form Games and Nash Equilibria
- Pure Strategy Nash Equilibria
- Mixed Strategy Nash Equilibria  
- Auction Mechanisms and Bidding
- Cooperative Game Theory
- Coalition Formation and Shapley Values
- Mechanism Design and Truthfulness
- Evolutionary Game Theory
- Strategic Reasoning and Best Response
- Performance and Mathematical Accuracy
- Edge Cases and Error Conditions
:End Note

Note: Test Fixtures and Setup
Process called "setup_basic_two_player_game" returns Game:
    Let player_configs be list containing
        Dictionary with:
            "type" as "rational"
            "strategy_space" as Dictionary with:
                "type" as "pure"
                "strategies" as list containing "cooperate", "defect"
            "utility_function" as Dictionary with:
                "type" as "cardinal"
            "beliefs" as Dictionary containing
        Dictionary with:
            "type" as "rational"  
            "strategy_space" as Dictionary with:
                "type" as "pure"
                "strategies" as list containing "cooperate", "defect"
            "utility_function" as Dictionary with:
                "type" as "cardinal"
            "beliefs" as Dictionary containing
    
    Let payoff_matrix be Dictionary with:
        "player_0,player_1" as Dictionary with:
            "cooperate,cooperate" as list containing 3, 3
            "cooperate,defect" as list containing 0, 5
            "defect,cooperate" as list containing 5, 0
            "defect,defect" as list containing 1, 1
    
    Let config be Dictionary with:
        "player_count" as 2
        "player_configs" as player_configs
        "payoff_matrix" as payoff_matrix
    
    Return create_normal_form_game with config as config

Process called "setup_auction_mechanism" returns AuctionMechanism:
    Let bidder_configs be list containing
        Dictionary with:
            "bidder_id" as "bidder_1"
            "budget" as 1000.0
            "valuation_function" as Dictionary with:
                "type" as "private_value"
                "base_value" as 100.0
            "bidding_strategy" as Dictionary with:
                "type" as "truthful"
            "private_info" as Dictionary containing
            "risk_profile" as Dictionary containing
        Dictionary with:
            "bidder_id" as "bidder_2"
            "budget" as 1500.0
            "valuation_function" as Dictionary with:
                "type" as "private_value"
                "base_value" as 150.0
            "bidding_strategy" as Dictionary with:
                "type" as "truthful"
            "private_info" as Dictionary containing
            "risk_profile" as Dictionary containing
    
    Let items be list containing
        Dictionary with:
            "item_id" as "item_1"
            "description" as "Test auction item"
            "reserve_price" as 50.0
    
    Let config be Dictionary with:
        "type" as "second_price"
        "bidders" as bidder_configs
        "items" as items
        "bidding_rules" as Dictionary containing
        "allocation_rule" as "highest_bidder"
        "payment_rule" as "second_price"
        "properties" as Dictionary containing
    
    Return create_auction_mechanism with config as config

Process called "setup_cooperative_game" returns CooperativeGame:
    Let players be list containing "player_1", "player_2", "player_3"
    
    Let characteristic_function be Dictionary with:
        "coalition_values" as Dictionary with:
            "player_1" as 10.0
            "player_2" as 15.0
            "player_3" as 20.0
            "player_1,player_2" as 30.0
            "player_1,player_3" as 35.0
            "player_2,player_3" as 40.0
            "player_1,player_2,player_3" as 60.0
    
    Let config be Dictionary with:
        "players" as players
        "characteristic_function" as characteristic_function
        "solution_concepts" as list containing "core", "shapley", "nucleolus"
    
    Return create_cooperative_game with config as config

Process called "setup_evolutionary_game" returns Dictionary:
    Let config be Dictionary with:
        "population_size" as 1000
        "strategies" as list containing "hawk", "dove"
        "fitness" as Dictionary with:
            "payoff_matrix" as Dictionary with:
                "hawk,hawk" as list containing -2, -2
                "hawk,dove" as list containing 3, 0
                "dove,hawk" as list containing 0, 3
                "dove,dove" as list containing 1, 1
        "mutation_rate" as 0.01
        "selection_pressure" as 1.0
        "initial_distribution" as Dictionary with:
            "hawk" as 0.5
            "dove" as 0.5
    
    Return create_evolutionary_game with config as config

Process called "teardown_test_environment" returns Boolean:
    Note: Clean up any test artifacts
    Return true

Note: Normal Form Game Tests
Test "test_create_normal_form_game":
    Let game be setup_basic_two_player_game[]
    
    Assert game.game_type is equal to "normal_form"
    Assert game.player_count is equal to 2
    Assert length of game.players is equal to 2
    Assert length of game.strategy_spaces is equal to 2
    Assert length of game.payoff_functions is equal to 2
    Assert game.players[0].player_id is equal to "player_0"
    Assert game.players[1].player_id is equal to "player_1"
    Assert game.players[0].strategy_space.pure_strategies contains "cooperate"
    Assert game.players[0].strategy_space.pure_strategies contains "defect"
    Assert game.players[1].strategy_space.pure_strategies contains "cooperate"
    Assert game.players[1].strategy_space.pure_strategies contains "defect"

Test "test_create_player":
    Let config be Dictionary with:
        "type" as "rational"
        "rationality" as 0.9
        "risk_preference" as "risk_averse"
        "strategy_space" as Dictionary with:
            "type" as "pure"
            "strategies" as list containing "action1", "action2", "action3"
        "utility_function" as Dictionary with:
            "type" as "exponential"
        "beliefs" as Dictionary with:
            "prior" as "uniform"
    
    Let player be create_player with config as config and player_index as 0
    
    Assert player.player_id is equal to "player_0"
    Assert player.player_type is equal to "rational"
    Assert player.rationality_level is equal to 0.9
    Assert player.risk_preference is equal to "risk_averse"
    Assert player.strategy_space.space_type is equal to "pure"
    Assert player.strategy_space.pure_strategies contains "action1"
    Assert player.strategy_space.pure_strategies contains "action2"
    Assert player.strategy_space.pure_strategies contains "action3"

Test "test_create_strategy_space":
    Let config be Dictionary with:
        "type" as "mixed"
        "strategies" as list containing "rock", "paper", "scissors"
        "constraints" as list containing
    
    Let space be create_strategy_space with config as config
    
    Assert space.space_type is equal to "mixed"
    Assert space.pure_strategies contains "rock"
    Assert space.pure_strategies contains "paper"
    Assert space.pure_strategies contains "scissors"
    Assert space.mixed_strategy_probabilities["rock"] is approximately 0.333 with tolerance 0.01
    Assert space.mixed_strategy_probabilities["paper"] is approximately 0.333 with tolerance 0.01
    Assert space.mixed_strategy_probabilities["scissors"] is approximately 0.333 with tolerance 0.01

Note: Nash Equilibria Tests
Test "test_find_pure_nash_equilibria_prisoners_dilemma":
    Let game be setup_basic_two_player_game[]
    Let equilibria be find_pure_nash_equilibria with game as game
    
    Note: Prisoner's dilemma should have one pure Nash equilibrium: (defect, defect)
    Assert length of equilibria is equal to 1
    Assert equilibria[0].equilibrium_type is equal to "pure"
    Assert equilibria[0].strategy_profile["player_0"]["defect"] is equal to 1.0
    Assert equilibria[0].strategy_profile["player_1"]["defect"] is equal to 1.0

Test "test_check_pure_nash_equilibrium":
    Let game be setup_basic_two_player_game[]
    
    Note: Test (defect, defect) - should be Nash equilibrium
    Let nash_profile be Dictionary with:
        "player_0" as "defect"
        "player_1" as "defect"
    Let is_nash be check_pure_nash_equilibrium with game as game and strategy_profile as nash_profile
    Assert is_nash is true
    
    Note: Test (cooperate, cooperate) - should not be Nash equilibrium
    Let non_nash_profile be Dictionary with:
        "player_0" as "cooperate"
        "player_1" as "cooperate"
    Let is_not_nash be check_pure_nash_equilibrium with game as game and strategy_profile as non_nash_profile
    Assert is_not_nash is false

Test "test_check_best_response":
    Let game be setup_basic_two_player_game[]
    
    Note: Test best response when opponent plays cooperate
    Let strategy_profile be Dictionary with:
        "player_0" as "defect"
        "player_1" as "cooperate"
    
    Let is_best_response be check_best_response with game as game and player_id as "player_0" and current_strategy as "defect" and strategy_profile as strategy_profile
    Assert is_best_response is true
    
    Note: Test non-best response when opponent plays cooperate
    Let non_best_profile be Dictionary with:
        "player_0" as "cooperate"
        "player_1" as "cooperate"
    
    Let is_not_best_response be check_best_response with game as game and player_id as "player_0" and current_strategy as "cooperate" and strategy_profile as non_best_profile
    Assert is_not_best_response is false

Test "test_find_mixed_nash_equilibria":
    Note: Create a game with no pure Nash equilibria to force mixed strategy calculation
    Let player_configs be list containing
        Dictionary with:
            "type" as "rational"
            "strategy_space" as Dictionary with:
                "type" as "pure"
                "strategies" as list containing "heads", "tails"
            "utility_function" as Dictionary with:
                "type" as "cardinal"
            "beliefs" as Dictionary containing
        Dictionary with:
            "type" as "rational"
            "strategy_space" as Dictionary with:
                "type" as "pure"
                "strategies" as list containing "heads", "tails"
            "utility_function" as Dictionary with:
                "type" as "cardinal"
            "beliefs" as Dictionary containing
    
    Note: Matching pennies payoff matrix (zero-sum game)
    Let payoff_matrix be Dictionary with:
        "player_0,player_1" as Dictionary with:
            "heads,heads" as list containing 1, -1
            "heads,tails" as list containing -1, 1
            "tails,heads" as list containing -1, 1
            "tails,tails" as list containing 1, -1
    
    Let config be Dictionary with:
        "player_count" as 2
        "player_configs" as player_configs
        "payoff_matrix" as payoff_matrix
    
    Let game be create_normal_form_game with config as config
    Let equilibria be find_mixed_nash_equilibria with game as game
    
    Note: Matching pennies should have one mixed Nash equilibrium with 50-50 probabilities
    Assert length of equilibria is greater than 0
    If length of equilibria is greater than 0:
        Assert equilibria[0].equilibrium_type is equal to "mixed"
        Assert equilibria[0].strategy_profile["player_0"]["heads"] is approximately 0.5 with tolerance 0.1
        Assert equilibria[0].strategy_profile["player_0"]["tails"] is approximately 0.5 with tolerance 0.1
        Assert equilibria[0].strategy_profile["player_1"]["heads"] is approximately 0.5 with tolerance 0.1
        Assert equilibria[0].strategy_profile["player_1"]["tails"] is approximately 0.5 with tolerance 0.1

Test "test_find_nash_equilibria_complete":
    Let game be setup_basic_two_player_game[]
    Let equilibria be find_nash_equilibria with game as game
    
    Assert length of equilibria is greater than 0
    Assert game.equilibria is equal to equilibria
    
    Note: Verify equilibrium properties
    For each equilibrium in equilibria:
        Assert equilibrium.equilibrium_id is not equal to ""
        Assert equilibrium.computation_method is not equal to ""
        Assert equilibrium.stability_measure is greater than 0

Note: Auction Mechanism Tests
Test "test_create_auction_mechanism":
    Let auction be setup_auction_mechanism[]
    
    Assert auction.auction_type is equal to "second_price"
    Assert length of auction.bidders is equal to 2
    Assert length of auction.items is equal to 1
    Assert auction.allocation_rule is equal to "highest_bidder"
    Assert auction.payment_rule is equal to "second_price"
    Assert auction.bidders[0].bidder_id is equal to "bidder_1"
    Assert auction.bidders[1].bidder_id is equal to "bidder_2"
    Assert auction.bidders[0].budget_constraint is equal to 1000.0
    Assert auction.bidders[1].budget_constraint is equal to 1500.0

Test "test_create_bidder":
    Let config be Dictionary with:
        "bidder_id" as "test_bidder"
        "budget" as 2000.0
        "valuation_function" as Dictionary with:
            "type" as "common_value"
            "signal_precision" as 0.8
        "bidding_strategy" as Dictionary with:
            "type" as "strategic"
            "aggressiveness" as 0.7
        "private_info" as Dictionary with:
            "signal" as 85.0
        "risk_profile" as Dictionary with:
            "risk_aversion" as 0.5
    
    Let bidder be create_bidder with config as config
    
    Assert bidder.bidder_id is equal to "test_bidder"
    Assert bidder.budget_constraint is equal to 2000.0
    Assert bidder.private_information["signal"] is equal to 85.0
    Assert bidder.risk_profile["risk_aversion"] is equal to 0.5
    Assert length of bidder.bidding_history is equal to 0

Test "test_run_sealed_bid_auction":
    Let auction be setup_auction_mechanism[]
    Let result be run_sealed_bid_auction with auction as auction
    
    Assert result contains "bids"
    Assert result contains "allocation"
    Assert result contains "payments"
    Assert result contains "revenue"
    Assert length of result["bids"] is equal to 2
    Assert result["bids"] contains "bidder_1"
    Assert result["bids"] contains "bidder_2"
    Assert result["revenue"] is greater than or equal to 0

Test "test_generate_bid":
    Let auction be setup_auction_mechanism[]
    Let bidder be auction.bidders[0]
    Let items be auction.items
    Let auction_type be auction.auction_type
    
    Let bid be generate_bid with bidder as bidder and items as items and auction_type as auction_type
    
    Assert bid is not equal to Dictionary containing
    Assert bid contains "item_1" or bid contains "amount"

Test "test_determine_allocation":
    Let auction be setup_auction_mechanism[]
    
    Let bids be Dictionary with:
        "bidder_1" as Dictionary with:
            "item_1" as 75.0
        "bidder_2" as Dictionary with:
            "item_1" as 125.0
    
    Let allocation_result be determine_allocation with auction as auction and bids as bids
    
    Assert allocation_result is not equal to Dictionary containing
    Assert allocation_result contains "item_1" or allocation_result contains "winner"

Note: Cooperative Game Theory Tests
Test "test_create_cooperative_game":
    Let game be setup_cooperative_game[]
    
    Assert game.game_id is not equal to ""
    Assert length of game.solution_concepts is equal to 3
    Assert game.solution_concepts contains "core"
    Assert game.solution_concepts contains "shapley"
    Assert game.solution_concepts contains "nucleolus"

Test "test_calculate_shapley_value":
    Let game be setup_cooperative_game[]
    Let shapley_values be calculate_shapley_value with game as game
    
    Assert shapley_values contains "player_1"
    Assert shapley_values contains "player_2"  
    Assert shapley_values contains "player_3"
    Assert shapley_values["player_1"] is greater than 0
    Assert shapley_values["player_2"] is greater than 0
    Assert shapley_values["player_3"] is greater than 0
    
    Note: Shapley values should sum to grand coalition value (60.0)
    Let total_shapley be shapley_values["player_1"] plus shapley_values["player_2"] plus shapley_values["player_3"]
    Assert total_shapley is approximately 60.0 with tolerance 0.1

Test "test_calculate_core":
    Let game be setup_cooperative_game[]
    Let core_result be calculate_core with game as game
    
    Assert core_result contains "exists"
    If core_result["exists"]:
        Assert core_result contains "allocation"
        Assert core_result contains "stability"
        Assert core_result["stability"] is equal to "core_stable"

Test "test_shapley_value_properties":
    Let game be setup_cooperative_game[]
    Let shapley_values be calculate_shapley_value with game as game
    
    Note: Test efficiency property (values sum to grand coalition)
    Let total_value be shapley_values["player_1"] plus shapley_values["player_2"] plus shapley_values["player_3"]
    Assert total_value is approximately 60.0 with tolerance 0.01
    
    Note: Test individual rationality (each player gets at least their individual value)
    Assert shapley_values["player_1"] is greater than or equal to 10.0 minus 0.01
    Assert shapley_values["player_2"] is greater than or equal to 15.0 minus 0.01
    Assert shapley_values["player_3"] is greater than or equal to 20.0 minus 0.01

Note: Mechanism Design Tests
Test "test_design_truthful_mechanism":
    Let config be Dictionary with:
        "type" as "vcg"
        "participants" as list containing "agent_1", "agent_2", "agent_3"
        "outcomes" as list containing "outcome_A", "outcome_B", "outcome_C"
        "social_welfare_function" as "utilitarian"
    
    Let mechanism be design_truthful_mechanism with config as config
    
    Assert mechanism["mechanism_type"] is equal to "vcg"
    Assert mechanism["truthful"] is true
    Assert mechanism contains "allocation_rule"
    Assert mechanism contains "payment_rule"
    Assert mechanism contains "truthfulness_proof"

Test "test_design_vcg_payments":
    Let config be Dictionary with:
        "participants" as list containing "buyer_1", "buyer_2"
        "efficiency_requirement" as true
    
    Let allocation_rule be Dictionary with:
        "type" as "welfare_maximizing"
    
    Let payment_rule be design_vcg_payments with config as config and allocation_rule as allocation_rule
    
    Assert payment_rule["payment_type"] is equal to "vcg"
    Assert payment_rule["calculation_method"] is equal to "externality_based"
    Assert payment_rule["properties"] contains "truthful"
    Assert payment_rule["properties"] contains "individually_rational"
    Assert payment_rule["properties"] contains "efficient"

Note: Evolutionary Game Theory Tests
Test "test_create_evolutionary_game":
    Let game be setup_evolutionary_game[]
    
    Assert game["population_size"] is equal to 1000
    Assert game["strategy_types"] contains "hawk"
    Assert game["strategy_types"] contains "dove"
    Assert game["mutation_rate"] is equal to 0.01
    Assert game["selection_pressure"] is equal to 1.0
    Assert game["population_distribution"]["hawk"] is equal to 0.5
    Assert game["population_distribution"]["dove"] is equal to 0.5
    Assert length of game["dynamics_history"] is equal to 0

Test "test_run_evolutionary_dynamics":
    Let game be setup_evolutionary_game[]
    Let generations be 50
    Let result be run_evolutionary_dynamics with evolutionary_game as game and generations as generations
    
    Assert result contains "final_distribution"
    Assert result contains "evolutionary_stable_strategies"
    Assert result contains "dynamics"
    Assert length of result["dynamics"] is equal to 50
    
    Note: Check that dynamics history is recorded properly
    Assert result["dynamics"][0] contains "generation"
    Assert result["dynamics"][0] contains "distribution"
    Assert result["dynamics"][0] contains "fitness"
    Assert result["dynamics"][0] contains "diversity"
    Assert result["dynamics"][0]["generation"] is equal to 1
    Assert result["dynamics"][49]["generation"] is equal to 50

Test "test_evolutionary_stability":
    Let game be setup_evolutionary_game[]
    Let result be run_evolutionary_dynamics with evolutionary_game as game and generations as 100
    
    Note: For hawk-dove game, there should be a mixed ESS
    Let final_distribution be result["final_distribution"]
    Assert final_distribution["hawk"] is greater than 0
    Assert final_distribution["dove"] is greater than 0
    Assert final_distribution["hawk"] plus final_distribution["dove"] is approximately 1.0 with tolerance 0.01

Note: Game Theory System Integration Tests
Test "test_create_game_theory_system":
    Let configuration be Dictionary with:
        "supported_games" as list containing "normal_form", "extensive_form", "auction", "cooperative"
        "solution_concepts" as list containing "nash", "dominant_strategy", "correlated"
        "mechanism_design" as true
        "evolutionary" as true
    
    Let system be create_game_theory_system with configuration as configuration
    
    Assert system["game_types"] contains "normal_form"
    Assert system["game_types"] contains "auction"
    Assert system["game_types"] contains "cooperative"
    Assert system["solution_concepts"] contains "nash"
    Assert system["solution_concepts"] contains "dominant_strategy"
    Assert system["mechanism_design"] is true
    Assert system["evolutionary_dynamics"] is true

