    Let start_time be get_current_timestamp[]
    
    Let result be run_evolutionary_dynamics with evolutionary_game as game and generations as 100
    
    Let end_time be get_current_timestamp[]
    Let duration be end_time minus start_time
    
    Note: Should run 100 generations in reasonable time (< 5 seconds)
    Assert duration is less than 5000

