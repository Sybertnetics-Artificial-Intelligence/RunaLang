Import "../../../../../../src/stdlib/ai/decision/visualization.runa"
Import "../../../../../runtime/test_framework.runa"

Note:
Comprehensive Unit Tests for AI Decision Visualization System

Tests cover decision tree plots, risk heatmaps, interactive dashboards,
export functionality, and visualization generation.
:End Note

Process called "setup_visualization_config" returns Dictionary:
    Return Dictionary with:
        "chart_type" as "decision_tree"
        "output_format" as "svg"
        "width" as 800
        "height" as 600
        "interactive" as true

Test "test_create_decision_tree_visualization":
    Let config be setup_visualization_config[]
    Let viz be create_visualization with config as config
    
    Assert viz.viz_id is not equal to ""
    Assert viz.chart_type is equal to "decision_tree"
    Assert viz.output_format is equal to "svg"
    Assert viz.width is equal to 800
    Assert viz.height is equal to 600

Test "test_generate_risk_heatmap":
    Let risk_data be Dictionary with:
        "scenarios" as list containing "scenario_1", "scenario_2"
        "assets" as list containing "asset_1", "asset_2"
        "risk_values" as list containing
            list containing 0.1, 0.3
            list containing 0.2, 0.4
    
    Let heatmap be generate_risk_heatmap with data as risk_data and config as setup_visualization_config[]
    
    Assert heatmap.viz_type is equal to "heatmap"
    Assert heatmap.data_points is not equal to null

Process called "run_all_visualization_tests" returns Boolean:
    Let test_results be list containing
    
    Add run_test with test_name as "test_create_decision_tree_visualization" to test_results
    Add run_test with test_name as "test_generate_risk_heatmap" to test_results
    
    Let passed_count be 0
    For each result in test_results:
        If result:
            Set passed_count to passed_count plus 1
    
    Let total_tests be length of test_results
    Print "Decision Visualization Tests: " plus passed_count plus "/" plus total_tests plus " passed"
    
    Return passed_count is equal to total_tests