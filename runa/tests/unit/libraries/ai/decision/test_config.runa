Note: Edge Cases and Error Conditions Tests
Test "test_config_with_zero_values":
    Let config be setup_basic_config[]
    Set config.global_settings.max_iterations_global to 0
    Set config.global_settings.timeout_seconds to 0.0
    Set config.performance_settings.cache_size_mb to 0
    Set config.performance_settings.parallel_threads to 0
    
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is false

Test "test_config_with_extreme_values":
    Let config be setup_basic_config[]
    Set config.global_settings.max_iterations_global to 999999999
    Set config.global_settings.timeout_seconds to 86400.0  Note: 24 hours
    Set config.performance_settings.cache_size_mb to 65536  Note: 64GB
    Set config.performance_settings.parallel_threads to 1000
    
    Let validation_result be validate_config with config as config
    Note: Should still be valid despite extreme values
    Assert validation_result["is_valid"] is true

Test "test_config_with_boundary_thresholds":
    Let config be setup_basic_config[]
    Set config.quality_thresholds.accuracy_threshold to 0.0
    Set config.quality_thresholds.convergence_tolerance to 1.0
    Set config.quality_thresholds.consistency_threshold to 0.0
    Set config.quality_thresholds.reliability_threshold to 1.0
    
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is true

Test "test_config_with_out_of_bounds_thresholds":
    Let config be setup_basic_config[]
    Set config.quality_thresholds.accuracy_threshold to -0.1
    Set config.quality_thresholds.convergence_tolerance to 1.1
    Set config.quality_thresholds.consistency_threshold to 2.0
    
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is false
    Assert length of validation_result["errors"] is greater than or equal to 3

Test "test_empty_algorithm_configs":
    Let config be setup_basic_config[]
    Set config.algorithm_configs to Dictionary containing
    
    Note: Should still be valid even with no algorithm configs
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is true

Test "test_large_parameter_dictionary":
    Let config be setup_basic_config[]
    Let large_params be Dictionary containing
    
    Note: Add 100 parameters
    For i from 1 to 100:
        Set large_params["param_" with i] to i * 0.001
    
    Set config.algorithm_configs["game_theory"].parameters to large_params
    
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is true

Note: Performance and Stress Tests
Test "test_config_creation_performance":
    Note: Test rapid config creation
    Let start_time be get_current_timestamp[]
    
    For i from 1 to 1000:
        Let config be create_default_config[]
    
    Let end_time be get_current_timestamp[]
    Let duration be end_time minus start_time
    
    Note: Should create 1000 configs in reasonable time (< 1 second)
    Assert duration is less than 1000

Test "test_config_validation_performance":
    Let config be setup_basic_config[]
    Let start_time be get_current_timestamp[]
    
    For i from 1 to 100:
        Let validation_result be validate_config with config as config
    
    Let end_time be get_current_timestamp[]
    Let duration be end_time minus start_time
    
    Note: Should validate 100 configs in reasonable time (< 500ms)
    Assert duration is less than 500

Test "test_config_merge_performance":
    Let base_config be create_development_config[]
    Let override_config be create_production_config[]
    Let start_time be get_current_timestamp[]
    
    For i from 1 to 100:
        Let merged_config be merge_configs with base_config as base_config and override_config as override_config
    
    Let end_time be get_current_timestamp[]
    Let duration be end_time minus start_time
    
    Note: Should merge 100 configs in reasonable time (< 500ms)
    Assert duration is less than 500

Test "test_large_config_update":
    Let config be setup_basic_config[]
    
    Note: Add many algorithms
    For i from 1 to 50:
        Let algorithm_name be "algorithm_" with i
        Set config.algorithm_configs[algorithm_name] to create_game_theory_config[]
    
    Let validation_result be validate_config with config as config
    Assert validation_result["is_valid"] is true
    Assert length of config.algorithm_configs is equal to 56  Note: 6 default + 50 added

Note: Configuration State Consistency Tests
Test "test_config_immutability_check":
    Let config1 be create_default_config[]
    Let config2 be create_default_config[]
    
    Note: Different instances should have different IDs but same values
    Assert not config1.config_id is equal to config2.config_id
    Assert config1.environment_profile is equal to config2.environment_profile
    Assert config1.global_settings.default_precision is equal to config2.global_settings.default_precision

Test "test_config_update_preserves_structure":
    Let config be setup_basic_config[]
    Let original_algorithm_count be length of config.algorithm_configs
    
    Let updates be Dictionary with:
        "new_parameter" as 42
    
    Let updated_config be update_algorithm_config with config as config and algorithm_name as "game_theory" and updates as updates
    
    Note: Structure should be preserved
    Assert length of updated_config.algorithm_configs is equal to original_algorithm_count
    Assert updated_config.algorithm_configs contains "game_theory"
    Assert updated_config.algorithm_configs contains "multi_criteria"

Test "test_convergence_criteria_consistency":
    Let game_theory_config be create_game_theory_config[]
    Let multi_criteria_config be create_multi_criteria_config[]
    
    Note: All convergence criteria should have required fields
    Assert game_theory_config.convergence_criteria.tolerance is greater than 0
    Assert game_theory_config.convergence_criteria.max_iterations is greater than 0
    Assert multi_criteria_config.convergence_criteria.tolerance is greater than 0
    Assert multi_criteria_config.convergence_criteria.max_iterations is greater than 0

Test "test_resource_limits_consistency":
    Let standard_limits be create_standard_resource_limits[]
    Let enhanced_limits be create_enhanced_resource_limits[]
    
    Note: Enhanced limits should be higher than standard
    Assert enhanced_limits.max_memory_mb is greater than standard_limits.max_memory_mb
    Assert enhanced_limits.max_cpu_seconds is greater than standard_limits.max_cpu_seconds
    Assert enhanced_limits.max_threads is greater than standard_limits.max_threads
    Assert enhanced_limits.disk_space_mb is greater than standard_limits.disk_space_mb

Test "test_quality_requirements_hierarchy":
    Let standard_quality be create_standard_quality_requirements[]
    Let ml_quality be create_ml_quality_requirements[]
    Let financial_quality be create_financial_quality_requirements[]
    
    Note: Financial should have highest requirements, ML higher than standard
    Assert financial_quality.accuracy_threshold is greater than ml_quality.accuracy_threshold
    Assert ml_quality.accuracy_threshold is greater than standard_quality.accuracy_threshold
    Assert financial_quality.precision_threshold is greater than ml_quality.precision_threshold
    Assert ml_quality.precision_threshold is greater than standard_quality.precision_threshold

Note: Integration Tests
Test "test_full_config_lifecycle":
    Note: Test complete configuration lifecycle
    Let config be create_development_config[]
    
    Note: Validate initial config
    Let validation1 be validate_config with config as config
    Assert validation1["is_valid"] is true
    
    Note: Update algorithm settings
    Let updates be Dictionary with:
        "nash_equilibrium_tolerance" as 0.01
        "max_iterations_nash" as 500
    
    Let updated_config be update_algorithm_config with config as config and algorithm_name as "game_theory" and updates as updates
    
    Note: Validate updated config
    Let validation2 be validate_config with config as updated_config
    Assert validation2["is_valid"] is true
    
    Note: Merge with production settings
    Let prod_config be create_production_config[]
    Let merged_config be merge_configs with base_config as updated_config and override_config as prod_config
    
    Note: Final validation
    Let validation3 be validate_config with config as merged_config
    Assert validation3["is_valid"] is true
    
    Note: Verify final state
    Assert merged_config.environment_profile is equal to "production"
    Assert merged_config.algorithm_configs["game_theory"].parameters["nash_equilibrium_tolerance"] is equal to 0.01

Test "test_multi_environment_consistency":
    Let dev_config be create_development_config[]
    Let test_config be create_testing_config[]
    Let prod_config be create_production_config[]
    Let research_config be create_research_config[]
    
    Note: All configs should be valid
    Assert validate_config with config as dev_config with key "is_valid"
    Assert validate_config with config as test_config with key "is_valid"
    Assert validate_config with config as prod_config with key "is_valid"
    Assert validate_config with config as research_config with key "is_valid"
    
    Note: All should have same algorithm structure
    Assert length of dev_config.algorithm_configs is equal to length of prod_config.algorithm_configs
    Assert dev_config.algorithm_configs contains "game_theory"
    Assert test_config.algorithm_configs contains "multi_criteria"
    Assert prod_config.algorithm_configs contains "decision_trees"
    Assert research_config.algorithm_configs contains "risk_management"

