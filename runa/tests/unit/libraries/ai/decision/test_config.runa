Note: Configuration Management Tests
Test "test_get_config_for_environment":
    Let dev_config be get_config_for_environment with environment as "development"
    Assert dev_config.environment_profile is equal to "development"
    
    Let test_config be get_config_for_environment with environment as "testing"
    Assert test_config.environment_profile is equal to "testing"
    
    Let prod_config be get_config_for_environment with environment as "production"
    Assert prod_config.environment_profile is equal to "production"
    
    Let research_config be get_config_for_environment with environment as "research"
    Assert research_config.environment_profile is equal to "research"
    
    Let unknown_config be get_config_for_environment with environment as "unknown"
    Assert unknown_config.environment_profile is equal to "production"

Test "test_update_algorithm_config":
    Let config be setup_basic_config[]
    
    Let updates be Dictionary with:
        "nash_equilibrium_tolerance" as 0.005
        "max_iterations_nash" as 2000
        "auction_simulation_rounds" as 20000
    
    Let updated_config be update_algorithm_config with config as config and algorithm_name as "game_theory" and updates as updates
    
    Assert updated_config.algorithm_configs["game_theory"].parameters["nash_equilibrium_tolerance"] is equal to 0.005
    Assert updated_config.algorithm_configs["game_theory"].parameters["max_iterations_nash"] is equal to 2000
    Assert updated_config.algorithm_configs["game_theory"].parameters["auction_simulation_rounds"] is equal to 20000

Test "test_update_algorithm_config_nonexistent":
    Let config be setup_basic_config[]
    
    Let updates be Dictionary with:
        "some_parameter" as 123
    
    Let updated_config be update_algorithm_config with config as config and algorithm_name as "nonexistent_algorithm" and updates as updates
    
    Note: Config should remain unchanged for nonexistent algorithm
    Assert not updated_config.algorithm_configs contains "nonexistent_algorithm"

Note: Configuration Validation Tests
Test "test_validate_config_valid":
    Let config be setup_basic_config[]
    Let validation_result be validate_config with config as config
    
    Assert validation_result["is_valid"] is true
    Assert length of validation_result["errors"] is equal to 0

Test "test_validate_config_invalid_iterations":
    Let config be setup_basic_config[]
    Set config.global_settings.max_iterations_global to -1
    
    Let validation_result be validate_config with config as config
    
    Assert validation_result["is_valid"] is false
    Assert length of validation_result["errors"] is greater than 0

Test "test_validate_config_invalid_timeout":
    Let config be setup_basic_config[]
    Set config.global_settings.timeout_seconds to -10.0
    
    Let validation_result be validate_config with config as config
    
    Assert validation_result["is_valid"] is false
    Assert length of validation_result["errors"] is greater than 0

Test "test_validate_config_invalid_thresholds":
    Let config be setup_basic_config[]
    Set config.quality_thresholds.accuracy_threshold to 1.5
    Set config.quality_thresholds.convergence_tolerance to -0.1
    
    Let validation_result be validate_config with config as config
    
    Assert validation_result["is_valid"] is false
    Assert length of validation_result["errors"] is greater than or equal to 2

Test "test_validate_config_invalid_algorithm_convergence":
    Let config be setup_basic_config[]
    Set config.algorithm_configs["game_theory"].convergence_criteria.max_iterations to -5
    Set config.algorithm_configs["game_theory"].convergence_criteria.tolerance to -0.001
    
    Let validation_result be validate_config with config as config
    
    Assert validation_result["is_valid"] is false
    Assert length of validation_result["errors"] is greater than or equal to 2

Note: Configuration Merging Tests
Test "test_merge_configs":
    Let base_config be create_development_config[]
    Let override_config be create_production_config[]
    
    Let merged_config be merge_configs with base_config as base_config and override_config as override_config
    
    Note: Should take override values
    Assert merged_config.environment_profile is equal to "production"
    Assert merged_config.global_settings.debug_mode is false
    Assert merged_config.global_settings.logging_level is equal to "info"
    Assert merged_config.global_settings.max_iterations_global is equal to 10000
    Assert merged_config.quality_thresholds.accuracy_threshold is equal to 0.95
    Assert merged_config.performance_settings.enable_optimization is true
    Assert merged_config.performance_settings.optimization_level is equal to "aggressive"

Test "test_copy_config":
    Let original_config be setup_basic_config[]
    Let copied_config be copy_config with config as original_config
    
    Note: Should have different config_id but same values
    Assert not copied_config.config_id is equal to original_config.config_id
    Assert copied_config.environment_profile is equal to original_config.environment_profile
    Assert copied_config.global_settings.default_precision is equal to original_config.global_settings.default_precision
    Assert copied_config.quality_thresholds.accuracy_threshold is equal to original_config.quality_thresholds.accuracy_threshold

Note: Configuration Access Helper Tests
Test "test_get_default_config":
    Let config be get_default_config[]
    
    Assert config.environment_profile is equal to "production"
    Assert config.global_settings.max_iterations_global is equal to 1000

Test "test_get_config_for_algorithm":
    Let game_theory_config be get_config_for_algorithm with algorithm_name as "game_theory"
    Assert game_theory_config.algorithm_name is equal to "game_theory"
    
    Let multi_criteria_config be get_config_for_algorithm with algorithm_name as "multi_criteria"
    Assert multi_criteria_config.algorithm_name is equal to "multi_criteria"
    
    Let nonexistent_config be get_config_for_algorithm with algorithm_name as "nonexistent"
    Assert nonexistent_config.algorithm_name is equal to "game_theory"

Note: Utility Function Tests
Test "test_generate_config_id":
    Let id1 be generate_config_id[]
    Let id2 be generate_config_id[]
    
    Assert length of id1 is greater than 7
    Assert length of id2 is greater than 7
    Assert not id1 is equal to id2
    Assert id1 starts with "config_"
    Assert id2 starts with "config_"

Test "test_random_string":
    Let str1 be random_string with length as 10
    Let str2 be random_string with length as 10
    
    Assert length of str1 is equal to 10
    Assert length of str2 is equal to 10
    Assert not str1 is equal to str2

Test "test_random_string_different_lengths":
    Let short_str be random_string with length as 5
    Let long_str be random_string with length as 20
    
    Assert length of short_str is equal to 5
