Import "../../../../../../src/stdlib/ai/decision/utility.runa"
Import "../../../../../runtime/test_framework.runa"

Note:
Comprehensive Unit Tests for AI Decision Utility System

Tests cover multi-attribute utility functions, prospect theory, preference learning,
utility elicitation, and utility-based decision optimization.

Test Categories:
- Multi-Attribute Utility Functions
- Prospect Theory Implementation
- Preference Learning and Elicitation
- Utility Function Estimation
- Decision Optimization Under Uncertainty
- Behavioral Decision Models
- Performance and Mathematical Accuracy
- Edge Cases and Error Conditions
:End Note

Note: Test Fixtures and Setup
Process called "setup_utility_attributes" returns Dictionary:
    Return Dictionary with:
        "attributes" as list containing
            Dictionary with:
                "name" as "cost"
                "weight" as 0.4
                "direction" as "minimize"
                "range" as list containing 100.0, 1000.0
            Dictionary with:
                "name" as "quality"
                "weight" as 0.4
                "direction" as "maximize"
                "range" as list containing 1.0, 10.0
            Dictionary with:
                "name" as "time"
                "weight" as 0.2
                "direction" as "minimize"
                "range" as list containing 1.0, 30.0

Process called "setup_alternatives_with_utilities" returns List[Dictionary]:
    Return list containing
        Dictionary with:
            "id" as "alt_1"
            "values" as Dictionary with:
                "cost" as 200.0
                "quality" as 8.0
                "time" as 5.0
        Dictionary with:
            "id" as "alt_2"
            "values" as Dictionary with:
                "cost" as 300.0
                "quality" as 9.0
                "time" as 3.0
        Dictionary with:
            "id" as "alt_3"
            "values" as Dictionary with:
                "cost" as 150.0
                "quality" as 7.0
                "time" as 7.0

Process called "setup_prospect_theory_params" returns Dictionary:
    Return Dictionary with:
        "alpha" as 0.88
        "beta" as 0.88
        "lambda" as 2.25
        "reference_point" as 0.0

Process called "teardown_test_environment" returns Boolean:
    Return true

Note: Multi-Attribute Utility Function Tests
Test "test_create_utility_function":
    Let attributes be setup_utility_attributes[]
    Let utility_function be create_utility_function with attributes as attributes["attributes"]
    
    Assert utility_function.function_id is not equal to ""
    Assert utility_function.function_type is equal to "multi_attribute"
    Assert length of utility_function.attributes is equal to 3
    Assert utility_function.attributes[0].name is equal to "cost"
    Assert utility_function.attributes[1].name is equal to "quality"
    Assert utility_function.attributes[2].name is equal to "time"

Test "test_calculate_single_attribute_utility":
    Let attribute be Dictionary with:
        "name" as "quality"
        "direction" as "maximize"
        "range" as list containing 1.0, 10.0
        "utility_type" as "linear"
    
    Let value be 7.0
    Let utility be calculate_single_attribute_utility with attribute as attribute and value as value
    
    Note: Linear utility for maximize: (value - min) / (max - min)
    Let expected_utility be (7.0 - 1.0) / (10.0 - 1.0)
    Assert utility is approximately expected_utility with tolerance 0.001

Test "test_calculate_multi_attribute_utility":
    Let attributes be setup_utility_attributes[]
    Let alternatives be setup_alternatives_with_utilities[]
    
    Let utility_function be create_utility_function with attributes as attributes["attributes"]
    Let alternative be alternatives[0]
    
    Let total_utility be calculate_multi_attribute_utility with function as utility_function and alternative as alternative
    
    Assert total_utility is greater than 0
    Assert total_utility is less than or equal to 1

Test "test_exponential_utility_function":
    Let attribute be Dictionary with:
        "name" as "cost"
        "direction" as "minimize"
        "range" as list containing 100.0, 1000.0
        "utility_type" as "exponential"
        "risk_aversion" as 0.5
    
    Let value be 300.0
    Let utility be calculate_single_attribute_utility with attribute as attribute and value as value
    
    Assert utility is greater than 0
    Assert utility is less than or equal to 1

Note: Prospect Theory Tests
Test "test_prospect_theory_value_function":
    Let params be setup_prospect_theory_params[]
    
    Note: Test gain (positive outcome)
    Let gain_value be calculate_prospect_value with outcome as 100.0 and parameters as params
    Assert gain_value is greater than 0
    
    Note: Test loss (negative outcome)
    Let loss_value be calculate_prospect_value with outcome as -100.0 and parameters as params
    Assert loss_value is less than 0
    
    Note: Loss aversion: |v(-x)| > v(x) for same magnitude
    Let gain_magnitude be absolute_value of gain_value
    Let loss_magnitude be absolute_value of loss_value
    Assert loss_magnitude is greater than gain_magnitude

Test "test_prospect_theory_decision_weights":
    Let probabilities be list containing 0.1, 0.3, 0.6
    Let params be setup_prospect_theory_params[]
    
    Let decision_weights be calculate_decision_weights with probabilities as probabilities and parameters as params
    
    Assert length of decision_weights is equal to 3
    For each weight in decision_weights:
        Assert weight is greater than 0
        Assert weight is less than or equal to 1

Test "test_prospect_theory_lottery_evaluation":
    Let lottery be Dictionary with:
        "outcomes" as list containing 100.0, 0.0, -50.0
        "probabilities" as list containing 0.3, 0.4, 0.3
    
    Let params be setup_prospect_theory_params[]
    Let prospect_value be evaluate_lottery_prospect_theory with lottery as lottery and parameters as params
    
    Assert prospect_value is not equal to 0

Note: Preference Learning Tests
Test "test_preference_elicitation":
    Let alternatives be setup_alternatives_with_utilities[]
    Let pairwise_preferences be list containing
        Dictionary with:
            "preferred" as "alt_2"
            "non_preferred" as "alt_1"
            "strength" as 0.7
        Dictionary with:
            "preferred" as "alt_1"
            "non_preferred" as "alt_3"
            "strength" as 0.6
    
    Let learned_weights be learn_attribute_weights with alternatives as alternatives and preferences as pairwise_preferences
    
    Assert length of learned_weights is equal to 3
    Let weight_sum be learned_weights[0] plus learned_weights[1] plus learned_weights[2]
    Assert weight_sum is approximately 1.0 with tolerance 0.001

Test "test_utility_function_fitting":
    Let training_data be list containing
        Dictionary with:
            "attribute_values" as list containing 200.0, 8.0, 5.0
            "utility" as 0.75
        Dictionary with:
            "attribute_values" as list containing 300.0, 9.0, 3.0
            "utility" as 0.80
        Dictionary with:
            "attribute_values" as list containing 150.0, 7.0, 7.0
            "utility" as 0.65
    
    Let fitted_function be fit_utility_function with training_data as training_data and function_type as "linear"
    
    Assert fitted_function.function_id is not equal to ""
    Assert fitted_function.is_fitted is true
    Assert length of fitted_function.coefficients is equal to 3

Note: Cleanup and Test Runner
Process called "run_all_utility_tests" returns Boolean:
    Let test_results be list containing
    
    Add run_test with test_name as "test_create_utility_function" to test_results
    Add run_test with test_name as "test_calculate_single_attribute_utility" to test_results
    Add run_test with test_name as "test_calculate_multi_attribute_utility" to test_results
    Add run_test with test_name as "test_exponential_utility_function" to test_results
    Add run_test with test_name as "test_prospect_theory_value_function" to test_results
    Add run_test with test_name as "test_prospect_theory_decision_weights" to test_results
    Add run_test with test_name as "test_prospect_theory_lottery_evaluation" to test_results
    Add run_test with test_name as "test_preference_elicitation" to test_results
    Add run_test with test_name as "test_utility_function_fitting" to test_results
    
    Let cleanup_success be teardown_test_environment[]
    
    Let passed_count be 0
    For each result in test_results:
        If result:
            Set passed_count to passed_count plus 1
    
    Let total_tests be length of test_results
    Print "Decision Utility Tests: " plus passed_count plus "/" plus total_tests plus " passed"
    
    Return passed_count is equal to total_tests