Process called "display_master_test_results" that takes duration as Float:
    Display message "\n" plus "=" repeated 70 times
    Display message "🎯 HOT RELOAD LIBRARY TEST RESULTS"
    Display message "=" repeated 70 times
    
    Display message "\n📊 Module Test Summary:"
    For each module_name in keys of global_test_results:
        Let results be global_test_results[module_name]
        Display message "  " plus module_name plus ":"
        Display message "    Tests: " plus results["tests_run"] plus " | Passed: " plus results["tests_passed"] plus " | Failed: " plus results["tests_failed"]
        Display message "    Success Rate: " plus results["success_rate"] plus "% | Duration: " plus results["duration"] plus "ms"
    
    Display message "\n📈 Overall Statistics:"
    Display message "  Total Tests Run: " plus total_tests_run
    Display message "  Total Passed: " plus total_tests_passed  
    Display message "  Total Failed: " plus total_tests_failed
    
    Let overall_success_rate be (total_tests_passed as Float divided by total_tests_run as Float) multiplied by 100.0
    Display message "  Overall Success Rate: " plus overall_success_rate plus "%"
    Display message "  Total Duration: " plus duration plus "ms"
    Display message "  Average per Test: " plus (duration divided by total_tests_run as Float) plus "ms"

Process called "run_integration_tests":
    Display message "  🔄 Core + Dependency Tracking Integration"
    test_core_dependency_integration()
    
    Display message "  🔄 File Watching + Incremental Updates Integration"  
    test_file_watching_incremental_integration()
    
    Display message "  🔄 State Preservation + Production Core Integration"
    test_state_production_integration()
    
    Display message "  🔄 Full Hot Reload Workflow Integration"
    test_full_workflow_integration()
    
    Display message "  🔄 AI Development End-to-End Integration"
    test_ai_development_integration()

