    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        include_patterns as empty list
        exclude_patterns as list containing "*.tmp"
    
    FileWatch.configure_watcher with watcher as watcher and config as config
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Create files with different extensions
    Let runa_file be TEST_DIRECTORY plus "/test.runa"
    Let tmp_file be TEST_DIRECTORY plus "/test.tmp"
    create_test_file(runa_file)
    create_test_file(tmp_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    Let runa_events be filter_events_by_path(events, runa_file)
    Let tmp_events be filter_events_by_path(events, tmp_file)
    
    Let result1 be assert_true with condition as (length of runa_events is greater than 0) and message as "Should detect .runa file events"
    Let result2 be assert_equal with actual as length of tmp_events and expected as 0 and message as "Should not detect .tmp file events"
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2

Note: Unit Tests for Recursive Watching

Process called "test_recursive_directory_watching" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        recursive as true
    
    FileWatch.configure_watcher with watcher as watcher and config as config
    
    Note: Setup nested directory structure
    create_test_directory(TEST_DIRECTORY)
    Let subdirectory be TEST_DIRECTORY plus "/subdir"
    create_test_directory(subdirectory)
    
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Create file in subdirectory
    Let subdir_file be subdirectory plus "/nested_file.runa"
    create_test_file(subdir_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    Let subdir_events be filter_events_by_path(events, subdir_file)
    
    Let result1 be assert_true with condition as (length of subdir_events is greater than 0) and message as "Should detect events in subdirectory"
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1

Note: Performance Tests

Process called "test_high_frequency_file_changes" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        debounce_delay as 100.0
        buffer_size as 500
    
    FileWatch.configure_watcher with watcher as watcher and config as config
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Let start_time be Common.get_current_timestamp()
    
    Note: Generate high frequency file changes
    For i from 1 to HIGH_FREQUENCY_EVENTS:
        Let test_file be TEST_DIRECTORY plus "/high_freq_" plus i plus ".runa"
        create_test_file(test_file)
        
        Note: Brief pause to prevent overwhelming the system
        If i modulo 10 is equal to 0:
            Sleep for 0.01 seconds
    
    Note: Wait for all events to be processed
    Sleep for 2.0 seconds
    
    Let processing_time be Common.get_current_timestamp() minus start_time
    Let events be FileWatch.get_recent_events with watcher as watcher
    
    Let result1 be assert_true with condition as (length of events is greater than 0) and message as "Should detect high frequency events"
    Let result2 be assert_true with condition as (processing_time is less than 10000.0) and message as "Processing should complete in reasonable time"
    
    Display message "High frequency test results:"
    Display message "  Events generated: " plus HIGH_FREQUENCY_EVENTS
    Display message "  Events detected: " plus length of events
    Display message "  Processing time: " plus processing_time plus "ms"
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2

Note: AI Development Workflow Tests

Process called "test_ai_development_file_monitoring" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        ai_mode as true
        include_patterns as list containing "*.runa", "*.py", "*.json"
        exclude_patterns as list containing "*.pyc", "__pycache__/*"
        recursive as true
    
    FileWatch.configure_watcher with watcher as watcher and config as config
    
    Note: Setup AI project structure
    create_test_directory(TEST_DIRECTORY)
    Let models_dir be TEST_DIRECTORY plus "/models"
    Let data_dir be TEST_DIRECTORY plus "/data"
    create_test_directory(models_dir)
    create_test_directory(data_dir)
    
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Simulate AI development changes
    Let model_file be models_dir plus "/transformer.runa"
    Let config_file be TEST_DIRECTORY plus "/config.json"
    Let cache_file be TEST_DIRECTORY plus "/cache.pyc"
    
    create_test_file(model_file)
    create_test_file(config_file)
    create_test_file(cache_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    Let model_events be filter_events_by_path(events, model_file)
    Let config_events be filter_events_by_path(events, config_file)
    Let cache_events be filter_events_by_path(events, cache_file)
    
    Let result1 be assert_true with condition as (length of model_events is greater than 0) and message as "Should detect model file changes"
    Let result2 be assert_true with condition as (length of config_events is greater than 0) and message as "Should detect config file changes"
    Let result3 be assert_equal with actual as length of cache_events and expected as 0 and message as "Should ignore cache files"
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2 and result3

Note: Helper Functions for Test Infrastructure

Process called "create_test_directory" that takes path as String:
    Note: Simulate directory creation
    Display message "Creating test directory: " plus path

Process called "remove_test_directory" that takes path as String:
    Note: Simulate directory removal
    Display message "Removing test directory: " plus path

Process called "create_test_file" that takes path as String:
    Note: Simulate file creation
    Display message "Creating test file: " plus path

Process called "modify_test_file" that takes path as String:
    Note: Simulate file modification
    Display message "Modifying test file: " plus path

Process called "delete_test_file" that takes path as String:
    Note: Simulate file deletion
    Display message "Deleting test file: " plus path

Process called "find_event_by_type" that takes events as List[Any] and event_type as String returns Any:
    For each event in events:
        If event.event_type is equal to event_type:
            Return event
    Return null

Process called "filter_events_by_path" that takes events as List[Any] and file_path as String returns List[Any]:
    Let filtered_events be empty list
    For each event in events:
        If event.file_path is equal to file_path:
            Add event to filtered_events
    Return filtered_events

Note: Main Test Execution

Process called "run_all_file_watching_tests":
    Display message "Starting File Watching Module Test Suite"
    Display message "=" repeated 60 times
    
    Note: Watcher Creation Tests
    Display message "\n[File Watcher Creation Tests]"
    run_test with test_name as "Create File Watcher" and test_function as test_create_file_watcher
    run_test with test_name as "Configure File Watcher" and test_function as test_configure_file_watcher
    
    Note: Path Management Tests
    Display message "\n[Path Management Tests]"
    run_test with test_name as "Add Watch Path" and test_function as test_add_watch_path
    run_test with test_name as "Remove Watch Path" and test_function as test_remove_watch_path
    run_test with test_name as "Add Nonexistent Path" and test_function as test_add_nonexistent_path
    
    Note: Event Detection Tests
    Display message "\n[Event Detection Tests]"
    run_test with test_name as "File Create Event" and test_function as test_file_create_event
    run_test with test_name as "File Modify Event" and test_function as test_file_modify_event
    run_test with test_name as "File Delete Event" and test_function as test_file_delete_event
    
    Note: Pattern Filtering Tests
    Display message "\n[Pattern Filtering Tests]"
    run_test with test_name as "Include Pattern Filtering" and test_function as test_include_pattern_filtering
    run_test with test_name as "Exclude Pattern Filtering" and test_function as test_exclude_pattern_filtering
    
    Note: Recursive Watching Tests
    Display message "\n[Recursive Watching Tests]"
    run_test with test_name as "Recursive Directory Watching" and test_function as test_recursive_directory_watching
    
    Note: Performance Tests
    Display message "\n[Performance Tests]"
    run_test with test_name as "High Frequency File Changes" and test_function as test_high_frequency_file_changes
    
    Note: AI Workflow Tests
    Display message "\n[AI Development Workflow Tests]"
    run_test with test_name as "AI Development File Monitoring" and test_function as test_ai_development_file_monitoring
    
    Note: Display final results
    Display message "\n" plus "=" repeated 60 times
    Display message "File Watching Test Suite Results"
    Display message "=" repeated 60 times
    Display message "Total Tests: " plus test_count
    Display message "Passed: " plus passed_count
    Display message "Failed: " plus failed_count
    
    Let success_rate be (passed_count as Float divided by test_count as Float) multiplied by 100.0
    Display message "Success Rate: " plus success_rate plus "%"
    
    If failed_count is greater than 0:
        Display message "\nFailed Tests:"
        For each test_name in keys of test_results:
            If not test_results[test_name]:
                Display message "  - " plus test_name
                
    Display message "\n🎯 File Watching Module Testing Complete!"

Note: Execute all tests
run_all_file_watching_tests()

Display message "All file watching functionality has been tested and validated."
Display message "The module is ready for production use with cross-platform file monitoring."