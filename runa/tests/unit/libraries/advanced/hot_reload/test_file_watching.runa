Note:
Comprehensive Test Suite for Hot Reload File Watching Module

Tests all functionality of the file watching system including:
- Cross-platform file monitoring (Windows, macOS, Linux)
- Event detection and classification
- File pattern filtering and exclusions
- Recursive directory watching
- Performance under high file activity
- Error handling and recovery
- AI development workflow integration
:End Note

Import "../../../../../../src/stdlib/advanced/hot_reload/file_watching" as FileWatch
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration Constants
Let TEST_DIRECTORY be "/tmp/test_file_watching"
Let TEST_FILE_COUNT be 20
Let HIGH_FREQUENCY_EVENTS be 100

Note: Test Result Tracking
Let test_results be Dictionary[String, Boolean] containing
Let test_count be 0
Let passed_count be 0
Let failed_count be 0

Note: Helper Functions for Testing

Process called "run_test" that takes test_name as String and test_function as Function returns Boolean:
    Set test_count to test_count plus 1
    
    Try:
        Display message "Running test: " plus test_name
        Let result be test_function()
        
        If result:
            Set passed_count to passed_count plus 1
            Set test_results[test_name] to true
            Display message "  ✓ PASS: " plus test_name
        Otherwise:
            Set failed_count to failed_count plus 1
            Set test_results[test_name] to false
            Display message "  ✗ FAIL: " plus test_name
            
        Return result
        
    Catch error:
        Set failed_count to failed_count plus 1
        Set test_results[test_name] to false
        Display message "  ✗ ERROR: " plus test_name plus " - " plus error.message
        Return false

Process called "assert_true" that takes condition as Boolean and message as String returns Boolean:
    If not condition:
        Display message "    Assertion failed: " plus message
        Return false
    Return true

Process called "assert_equal" that takes actual as Any and expected as Any and message as String returns Boolean:
    If actual is not equal to expected:
        Display message "    Assertion failed: " plus message
        Display message "    Expected: " plus expected
        Display message "    Actual: " plus actual
        Return false
    Return true

Process called "assert_contains" that takes container as List[Any] and item as Any and message as String returns Boolean:
    If item not in container:
        Display message "    Assertion failed: " plus message
        Display message "    Item not found: " plus item
        Return false
    Return true

Note: Unit Tests for File Watcher Creation

Process called "test_create_file_watcher" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let result1 be assert_true with condition as (watcher is not null) and message as "Watcher should be created"
    Let result2 be assert_equal with actual as watcher.is_active and expected as false and message as "Watcher should start inactive"
    Let result3 be assert_equal with actual as length of watcher.watched_paths and expected as 0 and message as "No paths should be watched initially"
    Let result4 be assert_true with condition as ("platform" in watcher.metadata) and message as "Platform should be detected"
    
    Return result1 and result2 and result3 and result4

Process called "test_configure_file_watcher" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        recursive as true
        debounce_delay as 250.0
        buffer_size as 1000
        include_patterns as list containing "*.runa", "*.md"
        exclude_patterns as list containing "*.tmp", "*.log"
        ai_mode as true
    
    Let config_success be FileWatch.configure_watcher with watcher as watcher and config as config
    
    Let result1 be assert_true with condition as config_success and message as "Configuration should succeed"
    Let result2 be assert_equal with actual as watcher.config.recursive and expected as true and message as "Recursive option should be set"
    Let result3 be assert_equal with actual as watcher.config.debounce_delay and expected as 250.0 and message as "Debounce delay should be set"
    Let result4 be assert_equal with actual as length of watcher.config.include_patterns and expected as 2 and message as "Include patterns should be set"
    Let result5 be assert_equal with actual as length of watcher.config.exclude_patterns and expected as 2 and message as "Exclude patterns should be set"
    
    Return result1 and result2 and result3 and result4 and result5

Note: Unit Tests for Path Management

Process called "test_add_watch_path" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Note: Create test directory
    create_test_directory(TEST_DIRECTORY)
    
    Let add_success be FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    
    Let result1 be assert_true with condition as add_success and message as "Adding watch path should succeed"
    Let result2 be assert_equal with actual as length of watcher.watched_paths and expected as 1 and message as "Should have one watched path"
    Let result3 be assert_contains with container as watcher.watched_paths and item as TEST_DIRECTORY and message as "Test directory should be in watched paths"
    
    Note: Clean up
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2 and result3

Process called "test_remove_watch_path" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Note: Create and add test directory
    create_test_directory(TEST_DIRECTORY)
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    
    Let remove_success be FileWatch.remove_watch_path with watcher as watcher and path as TEST_DIRECTORY
    
    Let result1 be assert_true with condition as remove_success and message as "Removing watch path should succeed"
    Let result2 be assert_equal with actual as length of watcher.watched_paths and expected as 0 and message as "Should have no watched paths"
    
    Note: Clean up
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2

Process called "test_add_nonexistent_path" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let add_success be FileWatch.add_watch_path with watcher as watcher and path as "/nonexistent/path"
    
    Let result1 be assert_true with condition as (not add_success) and message as "Adding nonexistent path should fail"
    Let result2 be assert_equal with actual as length of watcher.watched_paths and expected as 0 and message as "Should have no watched paths"
    
    Return result1 and result2

Note: Unit Tests for Event Detection

Process called "test_file_create_event" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Create test file and capture events
    Let test_file be TEST_DIRECTORY plus "/test_file.runa"
    create_test_file(test_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    
    Let result1 be assert_true with condition as (length of events is greater than 0) and message as "Should detect file creation event"
    
    If length of events is greater than 0:
        Let create_event be find_event_by_type(events, "file_created")
        Let result2 be assert_true with condition as (create_event is not null) and message as "Should find file creation event"
        Let result3 be assert_equal with actual as create_event.file_path and expected as test_file and message as "Event should reference correct file"
        
        Note: Clean up
        FileWatch.stop_watching with watcher as watcher
        remove_test_directory(TEST_DIRECTORY)
        
        Return result1 and result2 and result3
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1

Process called "test_file_modify_event" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    Let test_file be TEST_DIRECTORY plus "/modify_test.runa"
    create_test_file(test_file)
    
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Wait for initial events to settle
    Sleep for 0.3 seconds
    FileWatch.clear_event_buffer with watcher as watcher
    
    Note: Modify test file
    modify_test_file(test_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    
    Let result1 be assert_true with condition as (length of events is greater than 0) and message as "Should detect file modification event"
    
    If length of events is greater than 0:
        Let modify_event be find_event_by_type(events, "file_modified")
        Let result2 be assert_true with condition as (modify_event is not null) and message as "Should find file modification event"
        
        Note: Clean up
        FileWatch.stop_watching with watcher as watcher
        remove_test_directory(TEST_DIRECTORY)
        
        Return result1 and result2
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1

Process called "test_file_delete_event" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    Let test_file be TEST_DIRECTORY plus "/delete_test.runa"
    create_test_file(test_file)
    
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Wait for initial events to settle
    Sleep for 0.3 seconds
    FileWatch.clear_event_buffer with watcher as watcher
    
    Note: Delete test file
    delete_test_file(test_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    
    Let result1 be assert_true with condition as (length of events is greater than 0) and message as "Should detect file deletion event"
    
    If length of events is greater than 0:
        Let delete_event be find_event_by_type(events, "file_deleted")
        Let result2 be assert_true with condition as (delete_event is not null) and message as "Should find file deletion event"
        
        Note: Clean up
        FileWatch.stop_watching with watcher as watcher
        remove_test_directory(TEST_DIRECTORY)
        
        Return result1 and result2
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1

Note: Unit Tests for Pattern Filtering

Process called "test_include_pattern_filtering" returns Boolean:
    Let watcher be FileWatch.create_file_watcher()
    
    Let config be FileWatch.FileWatchConfig with:
        include_patterns as list containing "*.runa"
        exclude_patterns as empty list
    
    FileWatch.configure_watcher with watcher as watcher and config as config
    
    Note: Setup test environment
    create_test_directory(TEST_DIRECTORY)
    FileWatch.add_watch_path with watcher as watcher and path as TEST_DIRECTORY
    FileWatch.start_watching with watcher as watcher
    
    Note: Create files with different extensions
    Let runa_file be TEST_DIRECTORY plus "/test.runa"
    Let txt_file be TEST_DIRECTORY plus "/test.txt"
    create_test_file(runa_file)
    create_test_file(txt_file)
    
    Note: Wait for event processing
    Sleep for 0.5 seconds
    
    Let events be FileWatch.get_recent_events with watcher as watcher
    Let runa_events be filter_events_by_path(events, runa_file)
    Let txt_events be filter_events_by_path(events, txt_file)
    
    Let result1 be assert_true with condition as (length of runa_events is greater than 0) and message as "Should detect .runa file events"
    Let result2 be assert_equal with actual as length of txt_events and expected as 0 and message as "Should not detect .txt file events"
    
    Note: Clean up
    FileWatch.stop_watching with watcher as watcher
    remove_test_directory(TEST_DIRECTORY)
    
    Return result1 and result2

