    Return results

Process called "test_create_plugin_context" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Let context be PluginAPI.create_plugin_context(test_plugin)
        
        If context.config is not None and context.state is not None and context.communication is not None:
            Return create_test_result("Create Plugin Context", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Plugin Context", "FAILED", start_time, true, false, "Context missing required components")
    
    Catch error:
        Return create_test_result("Create Plugin Context", "ERROR", start_time, true, false, error.message)

Process called "test_initialize_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Let context be PluginAPI.create_plugin_context(test_plugin)
        Let result be test_plugin.lifecycle.initialize(context)
        
        If result:
            Return create_test_result("Initialize Plugin", "PASSED", start_time, true, result, None)
        Else:
            Return create_test_result("Initialize Plugin", "FAILED", start_time, true, result, "Plugin initialization failed")
    
    Catch error:
        Return create_test_result("Initialize Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_lifecycle_hooks" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Let context be PluginAPI.create_plugin_context(test_plugin)
        
        Note: Test initialize hook
        Let init_result be test_plugin.lifecycle.initialize(context)
        
        Note: Test start hook
        Let start_result be test_plugin.lifecycle.start(context)
        
        Note: Test stop hook
        Let stop_result be test_plugin.lifecycle.stop(context)
        
        If init_result and start_result and stop_result:
            Return create_test_result("Plugin Lifecycle Hooks", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Plugin Lifecycle Hooks", "FAILED", start_time, true, false, "One or more lifecycle hooks failed")
    
    Catch error:
        Return create_test_result("Plugin Lifecycle Hooks", "ERROR", start_time, true, false, error.message)

Note: Plugin Communication Tests
Process called "test_plugin_communication" returns List[TestResult]:
    Let results be list containing
    
    Note: Test message sending
    Let test1 be run_test("Send Plugin Message", test_send_plugin_message)
    Append test1 to results
    
    Note: Test message receiving
    Let test2 be run_test("Receive Plugin Message", test_receive_plugin_message)
    Append test2 to results
    
    Note: Test bidirectional communication
    Let test3 be run_test("Bidirectional Communication", test_bidirectional_communication)
    Append test3 to results
    
    Return results

Process called "test_send_plugin_message" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let sender_plugin be create_valid_test_plugin()
        Set sender_plugin.plugin_id to "sender_plugin"
        Let receiver_plugin be create_valid_test_plugin()
        Set receiver_plugin.plugin_id to "receiver_plugin"
        
        PluginAPI.register_plugin(sender_plugin)
        PluginAPI.register_plugin(receiver_plugin)
        
        Let message be PluginAPI.PluginMessage with:
            message_id as PluginAPI.generate_uuid()
            sender as "sender_plugin"
            recipient as "receiver_plugin"
            payload as "Test message payload"
            timestamp as PluginAPI.current_timestamp()
            metadata as dictionary containing
        
        Let result be PluginAPI.send_plugin_message("receiver_plugin", message)
        
        If result:
            Return create_test_result("Send Plugin Message", "PASSED", start_time, true, result, None)
        Else:
            Return create_test_result("Send Plugin Message", "FAILED", start_time, true, result, "Message sending failed")
    
    Catch error:
        Return create_test_result("Send Plugin Message", "ERROR", start_time, true, false, error.message)

Process called "test_receive_plugin_message" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let receiver_plugin be create_valid_test_plugin()
        Set receiver_plugin.plugin_id to "message_receiver"
        
        PluginAPI.register_plugin(receiver_plugin)
        
        Note: Send a test message
        Let message be PluginAPI.PluginMessage with:
            message_id as PluginAPI.generate_uuid()
            sender as "test_sender"
            recipient as "message_receiver"
            payload as "Test receive message"
            timestamp as PluginAPI.current_timestamp()
            metadata as dictionary containing
        
        PluginAPI.send_plugin_message("message_receiver", message)
        
        Note: Receive the message
        Let received_messages be list containing
        PluginAPI.receive_plugin_message("message_receiver", function(msg):
            Append msg to received_messages
        )
        
        If length of received_messages is greater than 0:
            Return create_test_result("Receive Plugin Message", "PASSED", start_time, 1, length of received_messages, None)
        Else:
            Return create_test_result("Receive Plugin Message", "FAILED", start_time, 1, 0, "No messages received")
    
    Catch error:
        Return create_test_result("Receive Plugin Message", "ERROR", start_time, 1, 0, error.message)

Process called "test_bidirectional_communication" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let plugin_a be create_valid_test_plugin()
        Set plugin_a.plugin_id to "plugin_a"
        Let plugin_b be create_valid_test_plugin()
        Set plugin_b.plugin_id to "plugin_b"
        
        PluginAPI.register_plugin(plugin_a)
        PluginAPI.register_plugin(plugin_b)
        
        Note: A sends to B
        Let message_a_to_b be PluginAPI.PluginMessage with:
            message_id as PluginAPI.generate_uuid()
            sender as "plugin_a"
            recipient as "plugin_b"
            payload as "Message from A to B"
            timestamp as PluginAPI.current_timestamp()
            metadata as dictionary containing
        
        Let sent_a_to_b be PluginAPI.send_plugin_message("plugin_b", message_a_to_b)
        
        Note: B sends to A
        Let message_b_to_a be PluginAPI.PluginMessage with:
            message_id as PluginAPI.generate_uuid()
            sender as "plugin_b"
            recipient as "plugin_a"
            payload as "Message from B to A"
            timestamp as PluginAPI.current_timestamp()
            metadata as dictionary containing
        
        Let sent_b_to_a be PluginAPI.send_plugin_message("plugin_a", message_b_to_a)
        
        If sent_a_to_b and sent_b_to_a:
            Return create_test_result("Bidirectional Communication", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Bidirectional Communication", "FAILED", start_time, true, false, "Bidirectional messaging failed")
    
    Catch error:
        Return create_test_result("Bidirectional Communication", "ERROR", start_time, true, false, error.message)

Note: Event System Tests
Process called "test_event_system" returns List[TestResult]:
    Let results be list containing
    
    Note: Test event bus creation
    Let test1 be run_test("Create Event Bus", test_create_event_bus)
    Append test1 to results
    
    Note: Test event subscription
    Let test2 be run_test("Event Subscription", test_event_subscription)
    Append test2 to results
    
    Note: Test event publishing
    Let test3 be run_test("Event Publishing", test_event_publishing)
    Append test3 to results
    
    Note: Test event unsubscription
    Let test4 be run_test("Event Unsubscription", test_event_unsubscription)
    Append test4 to results
    
    Return results

Process called "test_create_event_bus" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let event_bus be PluginAPI.create_plugin_event_bus()
        
        If event_bus.subscribe is not None and event_bus.publish is not None and event_bus.unsubscribe is not None:
            Return create_test_result("Create Event Bus", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Event Bus", "FAILED", start_time, true, false, "Event bus missing required methods")
    
    Catch error:
        Return create_test_result("Create Event Bus", "ERROR", start_time, true, false, error.message)

Process called "test_event_subscription" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let event_bus be PluginAPI.create_plugin_event_bus()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "event_subscriber"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let received_events be list containing
        Let subscription be event_bus.subscribe("event_subscriber", "test_event", function(event):
            Append event to received_events
        )
        
        If subscription.subscription_id is not None and subscription.plugin_id is equal to "event_subscriber":
            Return create_test_result("Event Subscription", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Event Subscription", "FAILED", start_time, true, false, "Subscription creation failed")
    
    Catch error:
        Return create_test_result("Event Subscription", "ERROR", start_time, true, false, error.message)

Process called "test_event_publishing" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let event_bus be PluginAPI.create_plugin_event_bus()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "event_publisher"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let received_events be list containing
        event_bus.subscribe("event_publisher", "test_event", function(event):
            Append event to received_events
        )
        
        Let test_event be PluginAPI.PluginEvent with:
            event_id as PluginAPI.generate_uuid()
            event_type as "test_event"
            source_plugin as "event_publisher"
            timestamp as PluginAPI.current_timestamp()
            data as "Test event data"
            metadata as dictionary containing
        
        Let published be event_bus.publish(test_event)
        
        If published and length of received_events is greater than 0:
            Return create_test_result("Event Publishing", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Event Publishing", "FAILED", start_time, true, false, "Event publishing or receiving failed")
    
    Catch error:
        Return create_test_result("Event Publishing", "ERROR", start_time, true, false, error.message)

Process called "test_event_unsubscription" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let event_bus be PluginAPI.create_plugin_event_bus()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "event_unsubscriber"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let subscription be event_bus.subscribe("event_unsubscriber", "test_event", function(event):
            Note: Handler that should not be called after unsubscription
        )
        
        Let unsubscribed be event_bus.unsubscribe(subscription)
        
        If unsubscribed:
            Return create_test_result("Event Unsubscription", "PASSED", start_time, true, unsubscribed, None)
        Else:
            Return create_test_result("Event Unsubscription", "FAILED", start_time, true, unsubscribed, "Unsubscription failed")
    
    Catch error:
        Return create_test_result("Event Unsubscription", "ERROR", start_time, true, false, error.message)

