Import "../../../../src/stdlib/advanced/plugins/api.runa" as PluginAPI
Import "../../../../src/builtins/functions.runa"
Import "../../../../src/builtins/testing.runa"

Note:
Runa Advanced Plugins Library API Module Tests

Comprehensive test suite for the Plugin API module, including:
- Plugin registration and lifecycle management
- Plugin communication and messaging
- Event system testing
- Service discovery and registration
- Extension point system
- Multi-language plugin support
- Security and validation testing

Tests cover normal operations, edge cases, error conditions, and performance.
All results are captured from actual execution rather than hardcoded.
:End Note

Note: Test Result Types
Type called "APITestReport":
    overall_status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    execution_time as Float
    test_categories as Dictionary[String, CategoryTestResult]
    performance_metrics as APIPerformanceMetrics
    errors as List[String]
    metadata as Dictionary[String, Any]

Type called "CategoryTestResult":
    category_name as String
    status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    test_details as List[TestResult]
    metadata as Dictionary[String, Any]

Type called "APIPerformanceMetrics":
    registration_performance as Float
    messaging_performance as Float
    event_performance as Float
    service_discovery_performance as Float
    memory_usage as Integer
    metadata as Dictionary[String, Any]

Type called "TestResult":
    test_name as String
    status as String
    execution_time as Float
    expected_result as Any
    actual_result as Any
    error_message as Optional[String]
    metadata as Dictionary[String, Any]

Note: Main Test Runner
Process called "run_all_api_tests" returns List[TestResult]:
    Let start_time be current_timestamp()
    Let all_results be list containing
    
    Log message "Running Plugin API comprehensive test suite..."
    
    Note: Plugin Registration Tests
    Let registration_results be test_plugin_registration()
    Extend all_results with registration_results
    
    Note: Plugin Lifecycle Tests
    Let lifecycle_results be test_plugin_lifecycle()
    Extend all_results with lifecycle_results
    
    Note: Plugin Communication Tests
    Let communication_results be test_plugin_communication()
    Extend all_results with communication_results
    
    Note: Event System Tests
    Let event_results be test_event_system()
    Extend all_results with event_results
    
    Note: Service Discovery Tests
    Let service_results be test_service_discovery()
    Extend all_results with service_results
    
    Note: Extension Point Tests
    Let extension_results be test_extension_points()
    Extend all_results with extension_results
    
    Note: Multi-language Support Tests
    Let multilang_results be test_multilanguage_support()
    Extend all_results with multilang_results
    
    Note: Security and Validation Tests
    Let security_results be test_security_validation()
    Extend all_results with security_results
    
    Note: Error Handling Tests
    Let error_results be test_error_handling()
    Extend all_results with error_results
    
    Note: Performance Tests
    Let performance_results be test_api_performance()
    Extend all_results with performance_results
    
    Let end_time be current_timestamp()
    Log message "API tests completed in " plus (end_time minus start_time) plus " seconds"
    
    Return all_results

Note: Plugin Registration Tests
Process called "test_plugin_registration" returns List[TestResult]:
    Let results be list containing
    
    Note: Test successful plugin registration
    Let test1 be run_test("Register Valid Plugin", test_register_valid_plugin)
    Append test1 to results
    
    Note: Test duplicate plugin registration
    Let test2 be run_test("Reject Duplicate Plugin", test_reject_duplicate_plugin)
    Append test2 to results
    
    Note: Test invalid plugin registration
    Let test3 be run_test("Reject Invalid Plugin", test_reject_invalid_plugin)
    Append test3 to results
    
    Note: Test plugin unregistration
    Let test4 be run_test("Unregister Plugin", test_unregister_plugin)
    Append test4 to results
    
    Note: Test plugin listing
    Let test5 be run_test("List Plugins", test_list_plugins)
    Append test5 to results
    
    Note: Test plugin retrieval
    Let test6 be run_test("Get Plugin", test_get_plugin)
    Append test6 to results
    
    Return results

Process called "test_register_valid_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Let result be PluginAPI.register_plugin(test_plugin)
        
        If result:
            Let retrieved_plugin be PluginAPI.get_plugin(test_plugin.plugin_id)
            If retrieved_plugin is not None and retrieved_plugin.plugin_id is equal to test_plugin.plugin_id:
                Return create_test_result("Register Valid Plugin", "PASSED", start_time, true, result, None)
            Else:
                Return create_test_result("Register Valid Plugin", "FAILED", start_time, true, false, "Plugin not found after registration")
        Else:
            Return create_test_result("Register Valid Plugin", "FAILED", start_time, true, result, "Registration returned false")
    
    Catch error:
        Return create_test_result("Register Valid Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_reject_duplicate_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "duplicate_test_plugin"
        
        Note: Register plugin first time
        Let first_result be PluginAPI.register_plugin(test_plugin)
        
        Note: Try to register same plugin again
        Let duplicate_plugin be create_valid_test_plugin()
        Set duplicate_plugin.plugin_id to "duplicate_test_plugin"
        
        Try:
            Let second_result be PluginAPI.register_plugin(duplicate_plugin)
            Return create_test_result("Reject Duplicate Plugin", "FAILED", start_time, false, second_result, "Duplicate registration should have failed")
        
        Catch duplicate_error:
            If duplicate_error.message contains "already registered":
                Return create_test_result("Reject Duplicate Plugin", "PASSED", start_time, false, false, None)
            Else:
                Return create_test_result("Reject Duplicate Plugin", "FAILED", start_time, false, false, "Wrong error message: " plus duplicate_error.message)
    
    Catch error:
        Return create_test_result("Reject Duplicate Plugin", "ERROR", start_time, false, false, error.message)

Process called "test_reject_invalid_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let invalid_plugin be PluginAPI.Plugin with:
            plugin_id as ""  Note: Invalid empty ID
            name as "Invalid Plugin"
            version as "1.0.0"
            author as "Test"
            description as "Invalid plugin"
            entry_point as function(): Return "test"
            lifecycle as PluginAPI.PluginLifecycle with:
                initialize as function(context): Return true
                start as function(context): Return true
                stop as function(context): Return true
                reload as None
                metadata as dictionary containing
            metadata as dictionary containing
        
        Try:
            Let result be PluginAPI.register_plugin(invalid_plugin)
            Return create_test_result("Reject Invalid Plugin", "FAILED", start_time, false, result, "Invalid plugin should have been rejected")
        
        Catch validation_error:
            If validation_error.message contains "Invalid plugin metadata":
                Return create_test_result("Reject Invalid Plugin", "PASSED", start_time, false, false, None)
            Else:
                Return create_test_result("Reject Invalid Plugin", "FAILED", start_time, false, false, "Wrong error message: " plus validation_error.message)
    
    Catch error:
        Return create_test_result("Reject Invalid Plugin", "ERROR", start_time, false, false, error.message)

Process called "test_unregister_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "unregister_test_plugin"
        
        Note: Register plugin
        PluginAPI.register_plugin(test_plugin)
        
        Note: Unregister plugin
        Let result be PluginAPI.unregister_plugin(test_plugin.plugin_id)
        
        If result:
            Let retrieved_plugin be PluginAPI.get_plugin(test_plugin.plugin_id)
            If retrieved_plugin is None:
                Return create_test_result("Unregister Plugin", "PASSED", start_time, true, result, None)
            Else:
                Return create_test_result("Unregister Plugin", "FAILED", start_time, true, false, "Plugin still exists after unregistration")
        Else:
            Return create_test_result("Unregister Plugin", "FAILED", start_time, true, result, "Unregistration returned false")
    
    Catch error:
        Return create_test_result("Unregister Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_list_plugins" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Note: Register multiple test plugins
        Let plugin1 be create_valid_test_plugin()
        Set plugin1.plugin_id to "list_test_plugin_1"
        Let plugin2 be create_valid_test_plugin()
        Set plugin2.plugin_id to "list_test_plugin_2"
        
        PluginAPI.register_plugin(plugin1)
        PluginAPI.register_plugin(plugin2)
        
        Let plugin_list be PluginAPI.list_plugins()
        
        Note: Check if our test plugins are in the list
        Let found_plugin1 be false
        Let found_plugin2 be false
        
        For each plugin in plugin_list:
            If plugin.plugin_id is equal to "list_test_plugin_1":
                Set found_plugin1 to true
            If plugin.plugin_id is equal to "list_test_plugin_2":
                Set found_plugin2 to true
        
        If found_plugin1 and found_plugin2:
            Return create_test_result("List Plugins", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("List Plugins", "FAILED", start_time, true, false, "Not all registered plugins found in list")
    
    Catch error:
        Return create_test_result("List Plugins", "ERROR", start_time, true, false, error.message)

Process called "test_get_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "get_test_plugin"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let retrieved_plugin be PluginAPI.get_plugin("get_test_plugin")
        
        If retrieved_plugin is not None and retrieved_plugin.plugin_id is equal to "get_test_plugin":
            Return create_test_result("Get Plugin", "PASSED", start_time, test_plugin, retrieved_plugin, None)
        Else:
            Return create_test_result("Get Plugin", "FAILED", start_time, test_plugin, retrieved_plugin, "Retrieved plugin doesn't match registered plugin")
    
    Catch error:
        Return create_test_result("Get Plugin", "ERROR", start_time, None, None, error.message)

Note: Plugin Lifecycle Tests
Process called "test_plugin_lifecycle" returns List[TestResult]:
    Let results be list containing
    
