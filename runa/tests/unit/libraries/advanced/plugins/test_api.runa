Process called "test_register_service" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let service_registry be PluginAPI.create_plugin_service_registry()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "service_provider"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let test_service be PluginAPI.PluginService with:
            service_id as "test_service_" plus PluginAPI.generate_uuid()
            service_type as "test_service_type"
            plugin_id as "service_provider"
            interface as create_test_service_interface()
            metadata as dictionary containing
        
        Let registered be service_registry.register_service("service_provider", test_service)
        
        If registered:
            Return create_test_result("Register Service", "PASSED", start_time, true, registered, None)
        Else:
            Return create_test_result("Register Service", "FAILED", start_time, true, registered, "Service registration failed")
    
    Catch error:
        Return create_test_result("Register Service", "ERROR", start_time, true, false, error.message)

Process called "test_discover_services" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let service_registry be PluginAPI.create_plugin_service_registry()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "service_discoverer"
        
        PluginAPI.register_plugin(test_plugin)
        
        Note: Register a test service
        Let test_service be PluginAPI.PluginService with:
            service_id as "discoverable_service"
            service_type as "discoverable_type"
            plugin_id as "service_discoverer"
            interface as create_test_service_interface()
            metadata as dictionary containing
        
        service_registry.register_service("service_discoverer", test_service)
        
        Note: Discover services
        Let discovered_services be service_registry.discover_services("discoverable_type")
        
        If length of discovered_services is greater than 0:
            Return create_test_result("Discover Services", "PASSED", start_time, 1, length of discovered_services, None)
        Else:
            Return create_test_result("Discover Services", "FAILED", start_time, 1, 0, "No services discovered")
    
    Catch error:
        Return create_test_result("Discover Services", "ERROR", start_time, 1, 0, error.message)

Process called "test_unregister_service" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let service_registry be PluginAPI.create_plugin_service_registry()
        Let test_plugin be create_valid_test_plugin()
        Set test_plugin.plugin_id to "service_unregisterer"
        
        PluginAPI.register_plugin(test_plugin)
        
        Note: Register a service
        Let test_service be PluginAPI.PluginService with:
            service_id as "removable_service"
            service_type as "removable_type"
            plugin_id as "service_unregisterer"
            interface as create_test_service_interface()
            metadata as dictionary containing
        
        service_registry.register_service("service_unregisterer", test_service)
        
        Note: Unregister the service
        Let unregistered be service_registry.unregister_service("removable_service")
        
        If unregistered:
            Let remaining_services be service_registry.discover_services("removable_type")
            If length of remaining_services is equal to 0:
                Return create_test_result("Unregister Service", "PASSED", start_time, true, true, None)
            Else:
                Return create_test_result("Unregister Service", "FAILED", start_time, true, false, "Service still discoverable after unregistration")
        Else:
            Return create_test_result("Unregister Service", "FAILED", start_time, true, false, "Service unregistration failed")
    
    Catch error:
        Return create_test_result("Unregister Service", "ERROR", start_time, true, false, error.message)

