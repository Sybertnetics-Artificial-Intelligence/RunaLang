Process called "test_validate_plugin_metadata" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let valid_plugin be create_valid_test_plugin()
        Let is_valid be PluginAPI.validate_plugin_metadata(valid_plugin)
        
        Let invalid_plugin be PluginAPI.Plugin with:
            plugin_id as ""
            name as ""
            version as "invalid"
            author as ""
            description as "Test"
            entry_point as function(): Return "test"
            lifecycle as PluginAPI.PluginLifecycle with:
                initialize as function(context): Return true
                start as function(context): Return true
                stop as function(context): Return true
                reload as None
                metadata as dictionary containing
            metadata as dictionary containing
        
        Let is_invalid be PluginAPI.validate_plugin_metadata(invalid_plugin)
        
        If is_valid and not is_invalid:
            Return create_test_result("Validate Plugin Metadata", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Validate Plugin Metadata", "FAILED", start_time, true, false, "Metadata validation logic incorrect")
    
    Catch error:
        Return create_test_result("Validate Plugin Metadata", "ERROR", start_time, true, false, error.message)

