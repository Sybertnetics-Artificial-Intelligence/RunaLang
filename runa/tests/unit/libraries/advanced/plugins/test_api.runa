Process called "test_plugin_not_found_error" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Try:
            PluginAPI.receive_plugin_message("nonexistent_plugin", function(msg):
                Note: This should not be called
            )
            Return create_test_result("Plugin Not Found Error", "FAILED", start_time, "PluginNotFoundError", "No error", "Expected PluginNotFoundError")
        
        Catch error:
            If error.message contains "Plugin not found":
                Return create_test_result("Plugin Not Found Error", "PASSED", start_time, "PluginNotFoundError", error.message, None)
            Else:
                Return create_test_result("Plugin Not Found Error", "FAILED", start_time, "PluginNotFoundError", error.message, "Wrong error type")
    
    Catch error:
        Return create_test_result("Plugin Not Found Error", "ERROR", start_time, "PluginNotFoundError", error.message, error.message)

Process called "test_invalid_message_handling" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin be create_valid_test_plugin()
        PluginAPI.register_plugin(test_plugin)
        
        Note: Try to send invalid message (None)
        Let result be PluginAPI.send_plugin_message(test_plugin.plugin_id, None)
        
        If not result:
            Return create_test_result("Invalid Message Handling", "PASSED", start_time, false, result, None)
        Else:
            Return create_test_result("Invalid Message Handling", "FAILED", start_time, false, result, "Invalid message should have been rejected")
    
    Catch error:
        Return create_test_result("Invalid Message Handling", "ERROR", start_time, false, false, error.message)

Note: Performance Tests
Process called "test_api_performance" returns List[TestResult]:
    Let results be list containing
    
    Note: Test registration performance
    Let test1 be run_test("Registration Performance", test_registration_performance)
    Append test1 to results
    
    Note: Test messaging performance
    Let test2 be run_test("Messaging Performance", test_messaging_performance)
    Append test2 to results
    
    Note: Test memory usage
    Let test3 be run_test("Memory Usage", test_memory_usage)
    Append test3 to results
    
    Return results

Process called "test_registration_performance" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let plugin_count be 50
        Let registration_times be list containing
        
        For i from 1 to plugin_count:
            Let plugin_start be current_timestamp()
            Let test_plugin be create_valid_test_plugin()
            Set test_plugin.plugin_id to "perf_test_plugin_" plus i
            PluginAPI.register_plugin(test_plugin)
            Let plugin_end be current_timestamp()
            
            Append plugin_end minus plugin_start to registration_times
        
        Let total_time be sum_list(registration_times)
        Let average_time be total_time divided by plugin_count
        Let registrations_per_second be plugin_count divided by total_time
        
        If registrations_per_second is greater than 10.0:
            Return create_test_result("Registration Performance", "PASSED", start_time, 10.0, registrations_per_second, None)
        Else:
            Return create_test_result("Registration Performance", "FAILED", start_time, 10.0, registrations_per_second, "Registration performance below threshold")
    
    Catch error:
        Return create_test_result("Registration Performance", "ERROR", start_time, 10.0, 0.0, error.message)

Process called "test_messaging_performance" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let message_count be 1000
        Let sender_plugin be create_valid_test_plugin()
        Set sender_plugin.plugin_id to "perf_sender"
        Let receiver_plugin be create_valid_test_plugin()
        Set receiver_plugin.plugin_id to "perf_receiver"
        
        PluginAPI.register_plugin(sender_plugin)
        PluginAPI.register_plugin(receiver_plugin)
        
        Let messaging_start be current_timestamp()
        
        For i from 1 to message_count:
            Let message be PluginAPI.PluginMessage with:
                message_id as PluginAPI.generate_uuid()
                sender as "perf_sender"
                recipient as "perf_receiver"
                payload as "Performance test message " plus i
                timestamp as PluginAPI.current_timestamp()
                metadata as dictionary containing
            
            PluginAPI.send_plugin_message("perf_receiver", message)
        
        Let messaging_end be current_timestamp()
        Let total_time be messaging_end minus messaging_start
        Let messages_per_second be message_count divided by total_time
        
        If messages_per_second is greater than 100.0:
            Return create_test_result("Messaging Performance", "PASSED", start_time, 100.0, messages_per_second, None)
        Else:
            Return create_test_result("Messaging Performance", "FAILED", start_time, 100.0, messages_per_second, "Messaging performance below threshold")
    
    Catch error:
        Return create_test_result("Messaging Performance", "ERROR", start_time, 100.0, 0.0, error.message)

Process called "test_memory_usage" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let initial_memory be get_current_memory_usage()
        
        Note: Create and register multiple plugins
        For i from 1 to 100:
            Let test_plugin be create_valid_test_plugin()
            Set test_plugin.plugin_id to "memory_test_plugin_" plus i
            PluginAPI.register_plugin(test_plugin)
        
        Let final_memory be get_current_memory_usage()
        Let memory_increase be final_memory minus initial_memory
        Let memory_per_plugin be memory_increase divided by 100
        
        Note: Check if memory usage per plugin is reasonable (less than 10KB per plugin)
        If memory_per_plugin is less than 10240:
            Return create_test_result("Memory Usage", "PASSED", start_time, 10240, memory_per_plugin, None)
        Else:
            Return create_test_result("Memory Usage", "FAILED", start_time, 10240, memory_per_plugin, "Memory usage per plugin too high")
    
    Catch error:
        Return create_test_result("Memory Usage", "ERROR", start_time, 10240, 0, error.message)

Note: Helper Functions
Process called "run_test" that takes test_name as String and test_function as Function returns TestResult:
    Try:
        Return test_function()
    Catch error:
        Return create_test_result(test_name, "ERROR", current_timestamp(), None, None, error.message)

Process called "create_test_result" that takes name as String and status as String and start_time as Float and expected as Any and actual as Any and error_msg as Optional[String] returns TestResult:
    Return TestResult with:
        test_name as name
        status as status
        execution_time as current_timestamp() minus start_time
        expected_result as expected
        actual_result as actual
        error_message as error_msg
        metadata as dictionary with:
            "timestamp" as current_timestamp()

Process called "create_valid_test_plugin" returns PluginAPI.Plugin:
    Return PluginAPI.Plugin with:
        plugin_id as "test_plugin_" plus PluginAPI.generate_uuid()
        name as "Test Plugin"
        version as "1.0.0"
        author as "Test Author"
        description as "A valid test plugin for testing purposes"
        entry_point as function():
            Return "Test plugin entry point executed"
        lifecycle as PluginAPI.PluginLifecycle with:
            initialize as function(context):
                Return true
            start as function(context):
                Return true
            stop as function(context):
                Return true
            reload as None
            metadata as dictionary containing
        metadata as dictionary containing

Process called "create_test_service_interface" returns PluginAPI.ServiceInterface:
    Return PluginAPI.ServiceInterface with:
        methods as list containing PluginAPI.MethodSignature with:
            name as "test_method"
            parameters as list containing PluginAPI.ParameterSignature with:
                name as "param1"
                parameter_type as "String"
                required as true
                default_value as None
                metadata as dictionary containing
            return_type as "String"
            metadata as dictionary containing
        properties as list containing
        metadata as dictionary containing

Process called "extend" that takes target_list as List[TestResult] and source_list as List[TestResult] returns None:
    For each item in source_list:
        Append item to target_list
    Return None

Process called "sum_list" that takes numbers as List[Float] returns Float:
    Let sum be 0.0
    For each number in numbers:
        Set sum to sum plus number
    Return sum

Process called "get_current_memory_usage" returns Integer:
    Note: Simulate memory usage measurement
    Return 1024000 plus random_integer(0, 512000)

Process called "random_integer" that takes min as Integer and max as Integer returns Integer:
    Note: Simulate random integer generation
    Return min plus ((current_timestamp() times 1000) modulo (max minus min plus 1))

Note: Main Entry Point
Process called "main" returns APITestReport:
    Log message "=== Runa Plugin API Module Test Suite ==="
    
    Let test_results be run_all_api_tests()
    
    Let passed_count be 0
    Let failed_count be 0
    Let skipped_count be 0
    
    For each result in test_results:
        Match result.status:
            When "PASSED":
                Set passed_count to passed_count plus 1
            When "FAILED" or "ERROR":
                Set failed_count to failed_count plus 1
            When "SKIPPED":
                Set skipped_count to skipped_count plus 1
    
    Let overall_status be if failed_count is greater than 0 then "FAILED" else "PASSED"
    
    Log message "=== API TEST RESULTS ==="
    Log message "Overall Status: " plus overall_status
    Log message "Passed: " plus passed_count
    Log message "Failed: " plus failed_count
    Log message "Skipped: " plus skipped_count
    
    For each result in test_results:
        If result.status is equal to "FAILED" or result.status is equal to "ERROR":
            Log message "FAILED: " plus result.test_name plus " - " plus result.error_message
    
    Return APITestReport with:
        overall_status as overall_status
        tests_passed as passed_count
        tests_failed as failed_count
        tests_skipped as skipped_count
        execution_time as 0.0
        test_categories as dictionary containing
        performance_metrics as APIPerformanceMetrics with:
            registration_performance as 0.0
            messaging_performance as 0.0
            event_performance as 0.0
            service_discovery_performance as 0.0
            memory_usage as 0
            metadata as dictionary containing
        errors as list containing
        metadata as dictionary containing