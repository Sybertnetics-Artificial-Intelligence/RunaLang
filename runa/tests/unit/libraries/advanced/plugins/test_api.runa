        Let invalid_version1 be PluginAPI.is_valid_semver("1.2")
        Let invalid_version2 be PluginAPI.is_valid_semver("1.2.3.4")
        Let invalid_version3 be PluginAPI.is_valid_semver("a.b.c")
        
        If valid_version and not invalid_version1 and not invalid_version2 and not invalid_version3:
            Return create_test_result("Validate Semantic Version", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Validate Semantic Version", "FAILED", start_time, true, false, "Semantic version validation failed")
    
    Catch error:
        Return create_test_result("Validate Semantic Version", "ERROR", start_time, true, false, error.message)

