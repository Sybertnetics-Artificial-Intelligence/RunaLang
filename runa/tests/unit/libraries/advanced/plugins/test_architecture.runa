Process called "test_version_comparison" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let compatible_same be PluginArchitecture.is_compatible_version("1.0.0", "1.0.0")
        Let compatible_major be PluginArchitecture.is_compatible_version("1.1.0", "1.0.0")
        Let incompatible_major be PluginArchitecture.is_compatible_version("2.0.0", "1.0.0")
        
        If compatible_same and compatible_major and not incompatible_major:
            Return create_test_result("Version Comparison", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Version Comparison", "FAILED", start_time, true, false, "Version comparison logic incorrect")
    
    Catch error:
        Return create_test_result("Version Comparison", "ERROR", start_time, true, false, error.message)

