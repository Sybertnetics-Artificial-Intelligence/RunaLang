Process called "test_extension_point_with_schema" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let schema be create_test_extension_schema()
        Let extension_point be PluginArchitecture.create_extension_point_with_schema("test_extension_point", schema)
        
        If extension_point.extension_id is equal to "test_extension_point" and extension_point.name is equal to schema.name:
            Return create_test_result("Extension Point with Schema", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Extension Point with Schema", "FAILED", start_time, true, false, "Extension point with schema creation failed")
    
    Catch error:
        Return create_test_result("Extension Point with Schema", "ERROR", start_time, true, false, error.message)

Process called "test_register_extension" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let schema be create_test_extension_schema()
        Let extension_point be PluginArchitecture.create_extension_point_with_schema("register_test_point", schema)
        
        Let test_extension be create_test_extension()
        
        Note: Register extension using the extension point
        extension_point.register(test_extension)
        
        Return create_test_result("Register Extension", "PASSED", start_time, true, true, None)
    
    Catch error:
        Return create_test_result("Register Extension", "ERROR", start_time, true, false, error.message)

Process called "test_unregister_extension" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let schema be create_test_extension_schema()
        Let extension_point be PluginArchitecture.create_extension_point_with_schema("unregister_test_point", schema)
        
        Let test_extension_id be "test_extension_123"
        
        Note: Unregister extension using the extension point
        extension_point.unregister(test_extension_id)
        
        Return create_test_result("Unregister Extension", "PASSED", start_time, true, true, None)
    
    Catch error:
        Return create_test_result("Unregister Extension", "ERROR", start_time, true, false, error.message)

Process called "test_validate_extension" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let schema be create_test_extension_schema()
        Let valid_extension be create_valid_test_extension()
        
        Let is_valid be PluginArchitecture.validate_extension_against_schema(valid_extension, schema)
        
        If is_valid:
            Return create_test_result("Validate Extension", "PASSED", start_time, true, is_valid, None)
        Else:
            Return create_test_result("Validate Extension", "FAILED", start_time, true, is_valid, "Valid extension failed validation")
    
    Catch error:
        Return create_test_result("Validate Extension", "ERROR", start_time, true, false, error.message)

