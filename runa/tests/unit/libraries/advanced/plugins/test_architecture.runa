Note: Dependency Resolution Tests
Process called "test_dependency_resolution" returns List[TestResult]:
    Let results be list containing
    
    Note: Test complex dependency scenarios
    Let test1 be run_test("Complex Dependencies", test_complex_dependencies)
    Append test1 to results
    
    Note: Test dependency cycles
    Let test2 be run_test("Dependency Cycles", test_dependency_cycles)
    Append test2 to results
    
    Note: Test missing dependencies
    Let test3 be run_test("Missing Dependencies", test_missing_dependencies)
    Append test3 to results
    
    Note: Test load order resolution
    Let test4 be run_test("Load Order Resolution", test_load_order_resolution)
    Append test4 to results
    
    Return results

Process called "test_complex_dependencies" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let resolver be PluginArchitecture.create_dependency_resolver()
        Let complex_plugins be create_complex_dependency_plugins()
        
        Let graph be resolver.resolve_dependencies(complex_plugins)
        Let has_cycles be resolver.check_circular_dependencies(graph)
        
        If not has_cycles:
            Return create_test_result("Complex Dependencies", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Complex Dependencies", "FAILED", start_time, true, false, "Complex dependencies created unexpected cycles")
    
    Catch error:
        Return create_test_result("Complex Dependencies", "ERROR", start_time, true, false, error.message)

Process called "test_dependency_cycles" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let resolver be PluginArchitecture.create_dependency_resolver()
        Let cyclic_plugins be create_plugins_with_circular_dependencies()
        
        Let graph be resolver.resolve_dependencies(cyclic_plugins)
        Let has_cycles be resolver.check_circular_dependencies(graph)
        
        If has_cycles:
            Return create_test_result("Dependency Cycles", "PASSED", start_time, true, has_cycles, None)
        Else:
            Return create_test_result("Dependency Cycles", "FAILED", start_time, true, has_cycles, "Failed to detect dependency cycles")
    
    Catch error:
        Return create_test_result("Dependency Cycles", "ERROR", start_time, true, false, error.message)

Process called "test_missing_dependencies" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let plugin_system be PluginArchitecture.create_plugin_system()
        Let plugin_with_missing_deps be create_plugin_with_missing_dependencies()
        
        Try:
            PluginArchitecture.resolve_plugin_dependencies(plugin_system, plugin_with_missing_deps.plugin_id)
            Return create_test_result("Missing Dependencies", "FAILED", start_time, "Error", "Success", "Should have failed with missing dependencies")
        
        Catch resolution_error:
            If resolution_error.message contains "Missing dependency":
                Return create_test_result("Missing Dependencies", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Missing Dependencies", "FAILED", start_time, "Error", resolution_error.message, "Wrong error type")
    
    Catch error:
        Return create_test_result("Missing Dependencies", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_load_order_resolution" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let resolver be PluginArchitecture.create_dependency_resolver()
        Let ordered_plugins be create_ordered_dependency_plugins()
        
        Let graph be resolver.resolve_dependencies(ordered_plugins)
        Let load_order be resolver.resolve_load_order(graph)
        
        Note: Check that dependencies are loaded before dependents
        Let plugin_a_index be find_plugin_index(load_order, "plugin_a")
        Let plugin_b_index be find_plugin_index(load_order, "plugin_b")
        Let plugin_c_index be find_plugin_index(load_order, "plugin_c")
        
        If plugin_a_index is less than plugin_b_index and plugin_b_index is less than plugin_c_index:
            Return create_test_result("Load Order Resolution", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Load Order Resolution", "FAILED", start_time, true, false, "Load order resolution incorrect")
    
    Catch error:
        Return create_test_result("Load Order Resolution", "ERROR", start_time, true, false, error.message)

