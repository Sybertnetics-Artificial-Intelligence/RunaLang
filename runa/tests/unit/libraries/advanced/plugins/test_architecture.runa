Process called "test_resolve_dependencies" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let plugin_system be PluginArchitecture.create_plugin_system()
        Let test_plugin be create_test_plugin_for_architecture()
        
        Note: Add plugin to system
        Set plugin_system.plugins[test_plugin.plugin_id] to test_plugin
        
        Let resolved be PluginArchitecture.resolve_plugin_dependencies(plugin_system, test_plugin.plugin_id)
        
        If resolved:
            Return create_test_result("Resolve Dependencies", "PASSED", start_time, true, resolved, None)
        Else:
            Return create_test_result("Resolve Dependencies", "FAILED", start_time, true, resolved, "Dependency resolution failed")
    
    Catch error:
        Return create_test_result("Resolve Dependencies", "ERROR", start_time, true, false, error.message)

Process called "test_create_dependency_resolver" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let resolver be PluginArchitecture.create_dependency_resolver()
        
        If resolver.resolve_dependencies is not None and resolver.check_circular_dependencies is not None and resolver.resolve_load_order is not None:
            Return create_test_result("Create Dependency Resolver", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Dependency Resolver", "FAILED", start_time, true, false, "Dependency resolver missing required methods")
    
    Catch error:
        Return create_test_result("Create Dependency Resolver", "ERROR", start_time, true, false, error.message)

Process called "test_build_dependency_graph" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugins be create_test_plugins_with_dependencies()
        Let graph be PluginArchitecture.build_dependency_graph(test_plugins)
        
        If length of keys(graph.nodes) is equal to length of test_plugins:
            Return create_test_result("Build Dependency Graph", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Build Dependency Graph", "FAILED", start_time, true, false, "Dependency graph building failed")
    
    Catch error:
        Return create_test_result("Build Dependency Graph", "ERROR", start_time, true, false, error.message)

Process called "test_detect_circular_dependencies" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let circular_plugins be create_plugins_with_circular_dependencies()
        Let graph be PluginArchitecture.build_dependency_graph(circular_plugins)
        Let has_cycles be PluginArchitecture.detect_cycles_in_graph(graph)
        
        If has_cycles:
            Return create_test_result("Detect Circular Dependencies", "PASSED", start_time, true, has_cycles, None)
        Else:
            Return create_test_result("Detect Circular Dependencies", "FAILED", start_time, true, has_cycles, "Failed to detect circular dependencies")
    
    Catch error:
        Return create_test_result("Detect Circular Dependencies", "ERROR", start_time, true, false, error.message)

Process called "test_topological_sort" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugins be create_test_plugins_with_dependencies()
        Let graph be PluginArchitecture.build_dependency_graph(test_plugins)
        Let load_order be PluginArchitecture.topological_sort(graph)
        
        If length of load_order is equal to length of test_plugins:
            Return create_test_result("Topological Sort", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Topological Sort", "FAILED", start_time, true, false, "Topological sort failed")
    
    Catch error:
        Return create_test_result("Topological Sort", "ERROR", start_time, true, false, error.message)

