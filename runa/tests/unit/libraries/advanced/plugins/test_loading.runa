Process called "test_unload_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let test_plugin_path be create_valid_plugin_directory()
        
        Note: Load plugin first
        Let loaded_plugin be loader.load_plugin(test_plugin_path)
        
        Note: Unload the plugin
        Let unloaded be loader.unload_plugin(loaded_plugin.plugin_id)
        
        If unloaded:
            Return create_test_result("Unload Plugin", "PASSED", start_time, true, unloaded, None)
        Else:
            Return create_test_result("Unload Plugin", "FAILED", start_time, true, unloaded, "Plugin unloading failed")
    
    Catch error:
        Return create_test_result("Unload Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_unload_module" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_plugin_id be "unload_module_test"
        
        Note: Test module unloading function
        PluginLoading.unload_plugin_module(test_plugin_id)
        
        Note: Module unloading should complete without error
        Return create_test_result("Unload Module", "PASSED", start_time, true, true, None)
    
    Catch error:
        Return create_test_result("Unload Module", "ERROR", start_time, true, false, error.message)

Process called "test_resource_cleanup_on_unload" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let test_plugin_path be create_valid_plugin_directory()
        
        Let initial_memory be get_current_memory_usage()
        
        Note: Load and unload plugin
        Let loaded_plugin be loader.load_plugin(test_plugin_path)
        loader.unload_plugin(loaded_plugin.plugin_id)
        
        Let final_memory be get_current_memory_usage()
        Let memory_difference be final_memory minus initial_memory
        
        Note: Memory should not increase significantly (less than 100KB)
        If memory_difference is less than 102400:
            Return create_test_result("Resource Cleanup on Unload", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Resource Cleanup on Unload", "FAILED", start_time, true, false, "Memory not properly cleaned up: " plus memory_difference plus " bytes")
    
    Catch error:
        Return create_test_result("Resource Cleanup on Unload", "ERROR", start_time, true, false, error.message)

Process called "test_unload_nonexistent_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let unloaded be loader.unload_plugin("nonexistent_plugin_id")
        
        If not unloaded:
            Return create_test_result("Unload Non-existent Plugin", "PASSED", start_time, false, unloaded, None)
        Else:
            Return create_test_result("Unload Non-existent Plugin", "FAILED", start_time, false, unloaded, "Should not be able to unload non-existent plugin")
    
    Catch error:
        Return create_test_result("Unload Non-existent Plugin", "ERROR", start_time, false, false, error.message)

