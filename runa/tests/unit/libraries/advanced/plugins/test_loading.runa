    Let module_file be temp_dir plus "/test_module_" plus generate_uuid() plus ".runa"
    write_file(module_file, "Process called \"main\" returns String: Return \"test module\"")
    Return module_file

Process called "create_test_plugin_for_loading" returns PluginAPI.Plugin:
