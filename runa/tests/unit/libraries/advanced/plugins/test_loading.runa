Process called "test_create_hot_reloader" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let hot_reloader be PluginLoading.create_plugin_hot_reloader()
        
        If hot_reloader.enable_hot_reload is not None and hot_reloader.disable_hot_reload is not None and hot_reloader.reload_plugin is not None:
            Return create_test_result("Create Hot Reloader", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Hot Reloader", "FAILED", start_time, true, false, "Hot reloader missing required methods")
    
    Catch error:
        Return create_test_result("Create Hot Reloader", "ERROR", start_time, true, false, error.message)

Process called "test_enable_hot_reload" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let hot_reloader be PluginLoading.create_plugin_hot_reloader()
        Let test_plugin be create_test_plugin_for_loading()
        
        Note: Load plugin first
        PluginAPI.register_plugin(test_plugin)
        
        Let enabled be hot_reloader.enable_hot_reload(test_plugin.plugin_id)
        
        If enabled:
            Return create_test_result("Enable Hot Reload", "PASSED", start_time, true, enabled, None)
        Else:
            Return create_test_result("Enable Hot Reload", "FAILED", start_time, true, enabled, "Hot reload enable failed")
    
    Catch error:
        Return create_test_result("Enable Hot Reload", "ERROR", start_time, true, false, error.message)

