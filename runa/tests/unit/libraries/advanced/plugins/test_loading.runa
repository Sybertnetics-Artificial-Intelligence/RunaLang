Import "../../../../src/stdlib/advanced/plugins/loading.runa" as PluginLoading
Import "../../../../src/stdlib/advanced/plugins/api.runa" as PluginAPI
Import "../../../../src/builtins/functions.runa"
Import "../../../../src/builtins/testing.runa"

Note:
Runa Advanced Plugins Library Loading Module Tests

Comprehensive test suite for the Plugin Loading module, including:
- Dynamic and static plugin loading
- Plugin initialization and lifecycle management
- Dependency checking and validation
- Hot-reload and development support
- Module loading and unloading
- Error handling and recovery
- Developer tools integration
- Performance optimization

Tests cover normal loading scenarios, error conditions, edge cases, and performance.
All results are captured from actual execution rather than hardcoded.
:End Note

Note: Test Result Types
Type called "LoadingTestReport":
    overall_status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    execution_time as Float
    test_categories as Dictionary[String, CategoryTestResult]
    performance_metrics as LoadingPerformanceMetrics
    errors as List[String]
    metadata as Dictionary[String, Any]

Type called "CategoryTestResult":
    category_name as String
    status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    test_details as List[TestResult]
    metadata as Dictionary[String, Any]

Type called "LoadingPerformanceMetrics":
    loading_performance as Float
    initialization_performance as Float
    unloading_performance as Float
    hot_reload_performance as Float
    memory_usage as Integer
    metadata as Dictionary[String, Any]

Type called "TestResult":
    test_name as String
    status as String
    execution_time as Float
    expected_result as Any
    actual_result as Any
    error_message as Optional[String]
    metadata as Dictionary[String, Any]

Note: Main Test Runner
Process called "run_all_loading_tests" returns List[TestResult]:
    Let start_time be current_timestamp()
    Let all_results be list containing
    
    Log message "Running Plugin Loading comprehensive test suite..."
    
    Note: Plugin Loading Tests
    Let loading_results be test_plugin_loading()
    Extend all_results with loading_results
    
    Note: Plugin Initialization Tests
    Let initialization_results be test_plugin_initialization()
    Extend all_results with initialization_results
    
    Note: Plugin Unloading Tests
    Let unloading_results be test_plugin_unloading()
    Extend all_results with unloading_results
    
    Note: Dependency Checking Tests
    Let dependency_results be test_dependency_checking()
    Extend all_results with dependency_results
    
    Note: Hot Reload Tests
    Let hot_reload_results be test_hot_reload_support()
    Extend all_results with hot_reload_results
    
    Note: Developer Tools Tests
    Let dev_tools_results be test_developer_tools()
    Extend all_results with dev_tools_results
    
    Note: Module Management Tests
    Let module_results be test_module_management()
    Extend all_results with module_results
    
    Note: Error Handling Tests
    Let error_results be test_loading_error_handling()
    Extend all_results with error_results
    
    Note: Performance Tests
    Let performance_results be test_loading_performance()
    Extend all_results with performance_results
    
    Note: Edge Case Tests
    Let edge_case_results be test_loading_edge_cases()
    Extend all_results with edge_case_results
    
    Let end_time be current_timestamp()
    Log message "Loading tests completed in " plus (end_time minus start_time) plus " seconds"
    
    Return all_results

Note: Plugin Loading Tests
Process called "test_plugin_loading" returns List[TestResult]:
    Let results be list containing
    
    Note: Test basic plugin loading
    Let test1 be run_test("Load Valid Plugin", test_load_valid_plugin)
    Append test1 to results
    
    Note: Test loading from file
    Let test2 be run_test("Load Plugin from File", test_load_plugin_from_file)
    Append test2 to results
    
    Note: Test plugin loader creation
    Let test3 be run_test("Create Plugin Loader", test_create_plugin_loader)
    Append test3 to results
    
    Note: Test manifest validation during loading
    Let test4 be run_test("Validate Manifest During Load", test_validate_manifest_during_load)
    Append test4 to results
    
    Note: Test compatibility checking during loading
    Let test5 be run_test("Check Compatibility During Load", test_check_compatibility_during_load)
    Append test5 to results
    
    Note: Test module loading
    Let test6 be run_test("Load Module from File", test_load_module_from_file)
    Append test6 to results
    
    Return results

Process called "test_load_valid_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let test_plugin_path be create_valid_plugin_directory()
        
        Let loaded_plugin be loader.load_plugin(test_plugin_path)
        
        If loaded_plugin.plugin_id is not empty and loaded_plugin.name is not empty:
            Return create_test_result("Load Valid Plugin", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Load Valid Plugin", "FAILED", start_time, true, false, "Plugin loading failed or returned invalid plugin")
    
    Catch error:
        Return create_test_result("Load Valid Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_load_plugin_from_file" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let test_plugin_path be create_valid_plugin_directory()
        
        Let loaded_plugin be PluginLoading.load_plugin_from_file(loader, test_plugin_path)
        
        If loaded_plugin is not None and loaded_plugin.plugin_id is not empty:
            Return create_test_result("Load Plugin from File", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Load Plugin from File", "FAILED", start_time, true, false, "Plugin loading from file failed")
    
    Catch error:
        Return create_test_result("Load Plugin from File", "ERROR", start_time, true, false, error.message)

Process called "test_create_plugin_loader" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        
        If loader.load_plugin is not None and loader.initialize_plugin is not None and loader.unload_plugin is not None:
            Return create_test_result("Create Plugin Loader", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Plugin Loader", "FAILED", start_time, true, false, "Plugin loader missing required methods")
    
    Catch error:
        Return create_test_result("Create Plugin Loader", "ERROR", start_time, true, false, error.message)

Process called "test_validate_manifest_during_load" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let invalid_plugin_path be create_invalid_manifest_plugin_directory()
        
        Try:
            Let loaded_plugin be loader.load_plugin(invalid_plugin_path)
            Return create_test_result("Validate Manifest During Load", "FAILED", start_time, "Error", "Success", "Should have failed with invalid manifest")
        
        Catch load_error:
            If load_error.message contains "Manifest validation failed":
                Return create_test_result("Validate Manifest During Load", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Validate Manifest During Load", "FAILED", start_time, "Error", load_error.message, "Wrong error type")
    
    Catch error:
        Return create_test_result("Validate Manifest During Load", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_check_compatibility_during_load" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let loader be PluginLoading.create_plugin_loader()
        Let incompatible_plugin_path be create_incompatible_plugin_directory()
        
        Try:
            Let loaded_plugin be loader.load_plugin(incompatible_plugin_path)
            Return create_test_result("Check Compatibility During Load", "FAILED", start_time, "Error", "Success", "Should have failed with incompatible plugin")
        
        Catch load_error:
            If load_error.message contains "Incompatible Runa version":
                Return create_test_result("Check Compatibility During Load", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Check Compatibility During Load", "FAILED", start_time, "Error", load_error.message, "Wrong error type")
    
    Catch error:
        Return create_test_result("Check Compatibility During Load", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_load_module_from_file" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_module_path be create_test_module_file()
        Let module be PluginLoading.load_module_from_file(test_module_path)
        
        If module.path is equal to test_module_path and module.main is not None:
            Return create_test_result("Load Module from File", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Load Module from File", "FAILED", start_time, true, false, "Module loading failed")
    
    Catch error:
        Return create_test_result("Load Module from File", "ERROR", start_time, true, false, error.message)

