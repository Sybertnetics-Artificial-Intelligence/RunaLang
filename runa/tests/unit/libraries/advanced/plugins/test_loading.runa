        plugin_id as "loading_test_plugin_" plus generate_uuid()
        name as "Loading Test Plugin"
        version as "1.0.0"
        author as "Test Author"
        description as "A test plugin for loading tests"
        entry_point as function():
            Return "Loading test plugin executed"
        lifecycle as PluginAPI.PluginLifecycle with:
            initialize as function(context):
                Return true
            start as function(context):
                Return true
            stop as function(context):
                Return true
            reload as None
            metadata as dictionary containing
        metadata as dictionary containing

