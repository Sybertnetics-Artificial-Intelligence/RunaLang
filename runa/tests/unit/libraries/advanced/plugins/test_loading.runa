Note: Test Data Creation Functions
Process called "create_valid_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/valid_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let manifest_content be create_valid_plugin_manifest()
    write_file(plugin_dir plus "/plugin.toml", manifest_content)
    write_file(plugin_dir plus "/main.runa", "Process called \"main\" returns String: Return \"valid loading plugin\"")
    
    Return plugin_dir

Process called "create_invalid_manifest_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/invalid_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let invalid_manifest be "[plugin]\nid = \"\"\nname = \"\""  Note: Invalid empty fields
    write_file(plugin_dir plus "/plugin.toml", invalid_manifest)
    
    Return plugin_dir

Process called "create_incompatible_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/incompatible_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let incompatible_manifest be "[plugin]\nid = \"incompatible.plugin\"\nname = \"Incompatible Plugin\"\nversion = \"1.0.0\"\nauthor = \"Test\"\ndescription = \"Incompatible\"\nentry_point = \"main.runa\"\n[compatibility]\nruna_version = \">=999.0.0\""
    write_file(plugin_dir plus "/plugin.toml", incompatible_manifest)
    
    Return plugin_dir

Process called "create_plugin_with_dependencies_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/deps_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let deps_manifest be "[plugin]\nid = \"deps.plugin\"\nname = \"Plugin With Dependencies\"\nversion = \"1.0.0\"\nauthor = \"Test\"\ndescription = \"Has dependencies\"\nentry_point = \"main.runa\"\n[compatibility]\nruna_version = \">=1.0.0\"\n[dependencies]\nnonexistent_dep = \">=1.0.0\""
    write_file(plugin_dir plus "/plugin.toml", deps_manifest)
    
    Return plugin_dir

Process called "create_plugin_with_bad_dependencies_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/bad_deps_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let bad_deps_manifest be "[plugin]\nid = \"bad.deps.plugin\"\nname = \"Plugin With Bad Dependencies\"\nversion = \"1.0.0\"\nauthor = \"Test\"\ndescription = \"Has bad dependencies\"\nentry_point = \"main.runa\"\n[compatibility]\nruna_version = \">=1.0.0\"\n[dependencies]\nmissing_dep = \">=1.0.0\"\nanother_missing = \">=2.0.0\""
    write_file(plugin_dir plus "/plugin.toml", bad_deps_manifest)
    
    Return plugin_dir

Process called "create_corrupted_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/corrupted_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Let corrupted_manifest be "corrupted toml content {"
    write_file(plugin_dir plus "/plugin.toml", corrupted_manifest)
    
    Return plugin_dir

Process called "create_plugin_with_tests_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/tests_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    write_file(plugin_dir plus "/plugin.toml", create_valid_plugin_manifest())
    
    Note: Create tests directory
    create_directory(plugin_dir plus "/tests")
    write_file(plugin_dir plus "/tests/test_main.runa", "Process called \"test_main\" returns Boolean: Return true")
    write_file(plugin_dir plus "/tests/test_utils.runa", "Process called \"test_utils\" returns Boolean: Return true")
    
    Return plugin_dir

Process called "create_large_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/large_loading_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    write_file(plugin_dir plus "/plugin.toml", create_valid_plugin_manifest())
    
    Note: Create a large main file
    Let large_content be "Process called \"main\" returns String:" plus "\n"
    For i from 1 to 100:
        Set large_content to large_content plus "    Log message \"Line " plus i plus "\"" plus "\n"
    Set large_content to large_content plus "    Return \"large plugin\""
    
    write_file(plugin_dir plus "/main.runa", large_content)
    
    Return plugin_dir

Process called "create_multiple_plugin_directories" that takes count as Integer returns List[String]:
    Let plugin_paths be list containing
    
    For i from 1 to count:
        Let plugin_path be create_valid_plugin_directory()
        Append plugin_path to plugin_paths
    
    Return plugin_paths

