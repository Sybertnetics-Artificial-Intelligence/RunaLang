    Set plugin.metadata["dependencies"] to dictionary with:
        "dep1" as ">=1.0.0"
        "dep2" as "=2.0.0"
        "dep3" as "<=3.0.0"
    Return plugin

Process called "create_failing_plugin" returns PluginAPI.Plugin:
    Return PluginAPI.Plugin with:
        plugin_id as "failing_loading_plugin"
        name as "Failing Loading Plugin"
        version as "1.0.0"
        author as "Test Author"
        description as "A plugin that fails to initialize"
        entry_point as function():
            Throw Exception with message "Plugin execution failed"
        lifecycle as PluginAPI.PluginLifecycle with:
            initialize as function(context):
                Throw Exception with message "Initialization failed"
            start as function(context):
                Throw Exception with message "Start failed"
            stop as function(context):
                Return true
            reload as None
            metadata as dictionary containing
        metadata as dictionary containing

