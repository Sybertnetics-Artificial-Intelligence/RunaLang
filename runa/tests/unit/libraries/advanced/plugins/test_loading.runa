    Return PluginLoading.Module with:
        path as "/test/module/path.runa"
        main as function():
            Return "test module main"
        metadata as dictionary containing

Process called "create_test_context" returns PluginAPI.PluginContext:
    Return PluginAPI.PluginContext with:
        config as PluginAPI.PluginConfig with:
            settings as dictionary containing
            environment as dictionary containing
            metadata as dictionary containing
        state as dictionary containing
        communication as PluginAPI.PluginCommunication with:
            send_message as function(message):
                Return None
            receive_message as function(handler):
                Return None
            metadata as dictionary containing
        metadata as dictionary containing

Note: Helper Functions
Process called "run_test" that takes test_name as String and test_function as Function returns TestResult:
    Try:
        Return test_function()
    Catch error:
        Return create_test_result(test_name, "ERROR", current_timestamp(), None, None, error.message)

Process called "create_test_result" that takes name as String and status as String and start_time as Float and expected as Any and actual as Any and error_msg as Optional[String] returns TestResult:
    Return TestResult with:
        test_name as name
        status as status
        execution_time as current_timestamp() minus start_time
        expected_result as expected
        actual_result as actual
        error_message as error_msg
        metadata as dictionary with:
            "timestamp" as current_timestamp()

Process called "extend" that takes target_list as List[TestResult] and source_list as List[TestResult] returns None:
    For each item in source_list:
        Append item to target_list
    Return None

Process called "sum_list" that takes numbers as List[Float] returns Float:
    Let sum be 0.0
    For each number in numbers:
        Set sum to sum plus number
    Return sum

Process called "get_current_memory_usage" returns Integer:
    Note: Simulate memory usage measurement
    Return 1024000 plus random_integer(0, 512000)

Process called "random_integer" that takes min as Integer and max as Integer returns Integer:
    Note: Simulate random integer generation
    Return min plus ((current_timestamp() times 1000) modulo (max minus min plus 1))

Process called "generate_uuid" returns String:
    Return "test_uuid_" plus current_timestamp()

Process called "create_valid_plugin_manifest" returns String:
    Return "[plugin]" plus "\n" plus 
           "id = \"valid.loading.plugin\"" plus "\n" plus
           "name = \"Valid Loading Plugin\"" plus "\n" plus
           "version = \"1.0.0\"" plus "\n" plus
           "author = \"Test Author\"" plus "\n" plus
           "description = \"A valid plugin for loading tests\"" plus "\n" plus
           "entry_point = \"main.runa\"" plus "\n" plus
           "\n" plus
           "[compatibility]" plus "\n" plus
           "runa_version = \">=1.0.0\"" plus "\n" plus
           "\n" plus
           "[capabilities]" plus "\n" plus
           "requires = []" plus "\n" plus
           "provides = []"

Note: Main Entry Point
Process called "main" returns LoadingTestReport:
    Log message "=== Runa Plugin Loading Module Test Suite ==="
    
    Let test_results be run_all_loading_tests()
    
    Let passed_count be 0
    Let failed_count be 0
    Let skipped_count be 0
    
    For each result in test_results:
        Match result.status:
            When "PASSED":
                Set passed_count to passed_count plus 1
            When "FAILED" or "ERROR":
                Set failed_count to failed_count plus 1
            When "SKIPPED":
                Set skipped_count to skipped_count plus 1
    
    Let overall_status be if failed_count is greater than 0 then "FAILED" else "PASSED"
    
    Log message "=== LOADING TEST RESULTS ==="
    Log message "Overall Status: " plus overall_status
    Log message "Passed: " plus passed_count
    Log message "Failed: " plus failed_count
    Log message "Skipped: " plus skipped_count
    
    For each result in test_results:
        If result.status is equal to "FAILED" or result.status is equal to "ERROR":
            Log message "FAILED: " plus result.test_name plus " - " plus result.error_message
    
    Return LoadingTestReport with:
        overall_status as overall_status
        tests_passed as passed_count
        tests_failed as failed_count
        tests_skipped as skipped_count
        execution_time as 0.0
        test_categories as dictionary containing
        performance_metrics as LoadingPerformanceMetrics with:
            loading_performance as 0.0
            initialization_performance as 0.0
            unloading_performance as 0.0
            hot_reload_performance as 0.0
            memory_usage as 0
            metadata as dictionary containing
        errors as list containing
        metadata as dictionary containing