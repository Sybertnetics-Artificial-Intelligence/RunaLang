Process called "test_file_watching" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let hot_reloader be PluginLoading.create_plugin_hot_reloader()
        Let test_paths be list containing "/test/plugin/path"
        
        Let file_watcher be hot_reloader.watch_files("test_watch_plugin", test_paths)
        
        If file_watcher.on_change is not None and file_watcher.stop is not None:
            file_watcher.stop()
            Return create_test_result("File Watching", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("File Watching", "FAILED", start_time, true, false, "File watcher missing required methods")
    
    Catch error:
        Return create_test_result("File Watching", "ERROR", start_time, true, false, error.message)

Process called "test_safe_plugin_reload" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let hot_reloader be PluginLoading.create_plugin_hot_reloader()
        Let test_plugin be create_test_plugin_for_loading()
        Set test_plugin.plugin_id to "safe_reload_plugin"
        
        PluginAPI.register_plugin(test_plugin)
        
        Let reloaded be hot_reloader.reload_plugin(test_plugin.plugin_id)
        
        If reloaded:
            Return create_test_result("Safe Plugin Reload", "PASSED", start_time, true, reloaded, None)
        Else:
            Return create_test_result("Safe Plugin Reload", "FAILED", start_time, true, reloaded, "Safe plugin reload failed")
    
    Catch error:
        Return create_test_result("Safe Plugin Reload", "ERROR", start_time, true, false, error.message)

