Process called "extend" that takes target_list as List[TestResult] and source_list as List[TestResult] returns None:
    For each item in source_list:
        Append item to target_list
    Return None

Process called "get_current_memory_usage" returns Integer:
    Note: Simulate memory usage measurement
    Return 1024000 plus random_integer(0, 512000)

Process called "random_integer" that takes min as Integer and max as Integer returns Integer:
    Note: Simulate random integer generation
    Return min plus ((current_timestamp() times 1000) modulo (max minus min plus 1))

Process called "generate_uuid" returns String:
    Return "test_uuid_" plus current_timestamp()

Note: Main Entry Point
Process called "main" returns ManagementTestReport:
    Log message "=== Runa Plugin Management Module Test Suite ==="
    
    Let test_results be run_all_management_tests()
    
    Let passed_count be 0
    Let failed_count be 0
    Let skipped_count be 0
    
    For each result in test_results:
        Match result.status:
            When "PASSED":
                Set passed_count to passed_count plus 1
            When "FAILED" or "ERROR":
                Set failed_count to failed_count plus 1
            When "SKIPPED":
                Set skipped_count to skipped_count plus 1
    
    Let overall_status be if failed_count is greater than 0 then "FAILED" else "PASSED"
    
    Log message "=== MANAGEMENT TEST RESULTS ==="
    Log message "Overall Status: " plus overall_status
    Log message "Passed: " plus passed_count
    Log message "Failed: " plus failed_count
    Log message "Skipped: " plus skipped_count
    
    For each result in test_results:
        If result.status is equal to "FAILED" or result.status is equal to "ERROR":
            Log message "FAILED: " plus result.test_name plus " - " plus result.error_message
    
    Return ManagementTestReport with:
        overall_status as overall_status
        tests_passed as passed_count
        tests_failed as failed_count
        tests_skipped as skipped_count
        execution_time as 0.0
        test_categories as dictionary containing
        performance_metrics as ManagementPerformanceMetrics with:
            enable_disable_performance as 0.0
            update_performance as 0.0
            monitoring_performance as 0.0
            registry_performance as 0.0
            memory_usage as 0
            metadata as dictionary containing
        errors as list containing
        metadata as dictionary containing