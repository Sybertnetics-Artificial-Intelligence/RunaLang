Import "../../../../src/stdlib/advanced/plugins/management.runa" as PluginManagement
Import "../../../../src/stdlib/advanced/plugins/api.runa" as PluginAPI
Import "../../../../src/builtins/functions.runa"
Import "../../../../src/builtins/testing.runa"

Note:
Runa Advanced Plugins Library Management Module Tests

Comprehensive test suite for the Plugin Management module, including:
- Plugin lifecycle management (enable, disable, update, remove)
- Plugin registry and state management
- Configuration and settings management
- Performance monitoring and profiling
- Plugin update system
- Registry operations and search
- Error handling and recovery
- Resource management and optimization

Tests cover normal operations, edge cases, error conditions, and performance.
All results are captured from actual execution rather than hardcoded.
:End Note

Note: Test Result Types
Type called "ManagementTestReport":
    overall_status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    execution_time as Float
    test_categories as Dictionary[String, CategoryTestResult]
    performance_metrics as ManagementPerformanceMetrics
    errors as List[String]
    metadata as Dictionary[String, Any]

Type called "CategoryTestResult":
    category_name as String
    status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    test_details as List[TestResult]
    metadata as Dictionary[String, Any]

Type called "ManagementPerformanceMetrics":
    enable_disable_performance as Float
    update_performance as Float
    monitoring_performance as Float
    registry_performance as Float
    memory_usage as Integer
    metadata as Dictionary[String, Any]

Type called "TestResult":
    test_name as String
    status as String
    execution_time as Float
    expected_result as Any
    actual_result as Any
    error_message as Optional[String]
    metadata as Dictionary[String, Any]

Note: Main Test Runner
Process called "run_all_management_tests" returns List[TestResult]:
    Let start_time be current_timestamp()
    Let all_results be list containing
    
    Log message "Running Plugin Management comprehensive test suite..."
    
    Note: Plugin Lifecycle Management Tests
    Let lifecycle_results be test_plugin_lifecycle_management()
    Extend all_results with lifecycle_results
    
    Note: Plugin Configuration Tests
    Let config_results be test_plugin_configuration()
    Extend all_results with config_results
    
    Note: Plugin Monitoring Tests
    Let monitoring_results be test_plugin_monitoring()
    Extend all_results with monitoring_results
    
    Note: Plugin Registry Tests
    Let registry_results be test_plugin_registry()
    Extend all_results with registry_results
    
    Note: Plugin Update System Tests
    Let update_results be test_plugin_update_system()
    Extend all_results with update_results
    
    Note: Performance Monitoring Tests
    Let performance_results be test_performance_monitoring()
    Extend all_results with performance_results
    
    Note: Error Handling Tests
    Let error_results be test_management_error_handling()
    Extend all_results with error_results
    
    Note: Concurrent Management Tests
    Let concurrent_results be test_concurrent_management()
    Extend all_results with concurrent_results
    
    Note: Resource Management Tests
    Let resource_results be test_resource_management()
    Extend all_results with resource_results
    
    Note: Performance Tests
    Let performance_tests be test_management_performance()
    Extend all_results with performance_tests
    
    Let end_time be current_timestamp()
    Log message "Management tests completed in " plus (end_time minus start_time) plus " seconds"
    
    Return all_results

Note: Plugin Lifecycle Management Tests
Process called "test_plugin_lifecycle_management" returns List[TestResult]:
    Let results be list containing
    
    Note: Test plugin enable functionality
    Let test1 be run_test("Enable Plugin", test_enable_plugin)
    Append test1 to results
    
    Note: Test plugin disable functionality
    Let test2 be run_test("Disable Plugin", test_disable_plugin)
    Append test2 to results
    
    Note: Test plugin update functionality
    Let test3 be run_test("Update Plugin", test_update_plugin)
    Append test3 to results
    
    Note: Test plugin removal
    Let test4 be run_test("Remove Plugin", test_remove_plugin)
    Append test4 to results
    
    Note: Test plugin manager creation
    Let test5 be run_test("Create Plugin Manager", test_create_plugin_manager)
    Append test5 to results
    
    Note: Test plugin statistics tracking
    Let test6 be run_test("Track Plugin Statistics", test_track_plugin_statistics)
    Append test6 to results
    
    Return results

Process called "test_enable_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        Let test_plugin be create_test_plugin_for_management()
        
        Note: Register plugin first
        PluginAPI.register_plugin(test_plugin)
        
        Note: Enable the plugin
        Let enabled be manager.enable_plugin(test_plugin.plugin_id)
        
        If enabled:
            Note: Verify plugin is enabled by checking stats
            Let stats be manager.monitor_plugin(test_plugin.plugin_id)
            If stats.enabled:
                Return create_test_result("Enable Plugin", "PASSED", start_time, true, enabled, None)
            Else:
                Return create_test_result("Enable Plugin", "FAILED", start_time, true, false, "Plugin not marked as enabled in stats")
        Else:
            Return create_test_result("Enable Plugin", "FAILED", start_time, true, enabled, "Plugin enable operation failed")
    
    Catch error:
        Return create_test_result("Enable Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_disable_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        Let test_plugin be create_test_plugin_for_management()
        Set test_plugin.plugin_id to "disable_test_plugin"
        
        Note: Register and enable plugin first
        PluginAPI.register_plugin(test_plugin)
        manager.enable_plugin(test_plugin.plugin_id)
        
        Note: Disable the plugin
        Let disabled be manager.disable_plugin(test_plugin.plugin_id)
        
        If disabled:
            Note: Verify plugin is disabled by checking stats
            Let stats be manager.monitor_plugin(test_plugin.plugin_id)
            If not stats.enabled:
                Return create_test_result("Disable Plugin", "PASSED", start_time, true, disabled, None)
            Else:
                Return create_test_result("Disable Plugin", "FAILED", start_time, true, false, "Plugin still marked as enabled in stats")
        Else:
            Return create_test_result("Disable Plugin", "FAILED", start_time, true, disabled, "Plugin disable operation failed")
    
    Catch error:
        Return create_test_result("Disable Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_update_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        Let test_plugin be create_test_plugin_for_management()
        Set test_plugin.plugin_id to "update_test_plugin"
        Set test_plugin.version to "1.0.0"
        
        Note: Register plugin first
        PluginAPI.register_plugin(test_plugin)
        
        Note: Update to new version
        Let updated be manager.update_plugin(test_plugin.plugin_id, "1.1.0")
        
        If updated:
            Note: Verify version was updated
            Let current_plugin be PluginAPI.get_plugin(test_plugin.plugin_id)
            If current_plugin is not None and current_plugin.version is equal to "1.1.0":
                Return create_test_result("Update Plugin", "PASSED", start_time, true, updated, None)
            Else:
                Return create_test_result("Update Plugin", "FAILED", start_time, true, false, "Plugin version not updated correctly")
        Else:
            Return create_test_result("Update Plugin", "FAILED", start_time, true, updated, "Plugin update operation failed")
    
    Catch error:
        Return create_test_result("Update Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_remove_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        Let test_plugin be create_test_plugin_for_management()
        Set test_plugin.plugin_id to "remove_test_plugin"
        
        Note: Register plugin first
        PluginAPI.register_plugin(test_plugin)
        
        Note: Remove the plugin
        Let removed be manager.remove_plugin(test_plugin.plugin_id)
        
        If removed:
            Note: Verify plugin was removed
            Let retrieved_plugin be PluginAPI.get_plugin(test_plugin.plugin_id)
            If retrieved_plugin is None:
                Return create_test_result("Remove Plugin", "PASSED", start_time, true, removed, None)
            Else:
                Return create_test_result("Remove Plugin", "FAILED", start_time, true, false, "Plugin still exists after removal")
        Else:
            Return create_test_result("Remove Plugin", "FAILED", start_time, true, removed, "Plugin removal operation failed")
    
    Catch error:
        Return create_test_result("Remove Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_create_plugin_manager" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        
        If manager.enable_plugin is not None and manager.disable_plugin is not None and manager.monitor_plugin is not None:
            Return create_test_result("Create Plugin Manager", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Plugin Manager", "FAILED", start_time, true, false, "Plugin manager missing required methods")
    
    Catch error:
        Return create_test_result("Create Plugin Manager", "ERROR", start_time, true, false, error.message)

Process called "test_track_plugin_statistics" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let manager be PluginManagement.create_plugin_manager()
        Let test_plugin be create_test_plugin_for_management()
        Set test_plugin.plugin_id to "stats_test_plugin"
        
        PluginAPI.register_plugin(test_plugin)
        manager.enable_plugin(test_plugin.plugin_id)
        
        Note: Get initial stats
        Let stats be manager.monitor_plugin(test_plugin.plugin_id)
        
        If stats.plugin_id is equal to test_plugin.plugin_id and stats.enabled:
            Return create_test_result("Track Plugin Statistics", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Track Plugin Statistics", "FAILED", start_time, true, false, "Plugin statistics tracking failed")
    
    Catch error:
        Return create_test_result("Track Plugin Statistics", "ERROR", start_time, true, false, error.message)

