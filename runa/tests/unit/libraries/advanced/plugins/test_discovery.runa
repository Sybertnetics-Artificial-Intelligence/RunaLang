Process called "test_scanning_performance" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let large_plugin_dir be create_large_plugin_directory()
        
        Let scan_start be current_timestamp()
        Let plugins be discovery.scan_plugins(large_plugin_dir)
        Let scan_end be current_timestamp()
        
        Let scan_time be scan_end minus scan_start
        Let plugins_per_second be length of plugins divided by scan_time
        
        If plugins_per_second is greater than 5.0:
            Return create_test_result("Scanning Performance", "PASSED", start_time, 5.0, plugins_per_second, None)
        Else:
            Return create_test_result("Scanning Performance", "FAILED", start_time, 5.0, plugins_per_second, "Scanning performance below threshold")
    
    Catch error:
        Return create_test_result("Scanning Performance", "ERROR", start_time, 5.0, 0.0, error.message)

Process called "test_metadata_extraction_performance" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let test_plugin_paths be create_multiple_test_plugin_directories(20)
        
        Let extraction_start be current_timestamp()
        For each plugin_path in test_plugin_paths:
            discovery.extract_metadata(plugin_path)
        Let extraction_end be current_timestamp()
        
        Let extraction_time be extraction_end minus extraction_start
        Let extractions_per_second be length of test_plugin_paths divided by extraction_time
        
        If extractions_per_second is greater than 10.0:
            Return create_test_result("Metadata Extraction Performance", "PASSED", start_time, 10.0, extractions_per_second, None)
        Else:
            Return create_test_result("Metadata Extraction Performance", "FAILED", start_time, 10.0, extractions_per_second, "Metadata extraction performance below threshold")
    
    Catch error:
        Return create_test_result("Metadata Extraction Performance", "ERROR", start_time, 10.0, 0.0, error.message)

Process called "test_validation_performance" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_manifests be create_multiple_test_manifests(50)
        
        Let validation_start be current_timestamp()
        For each manifest in test_manifests:
            PluginDiscovery.validate_plugin_manifest(manifest)
        Let validation_end be current_timestamp()
        
        Let validation_time be validation_end minus validation_start
        Let validations_per_second be length of test_manifests divided by validation_time
        
        If validations_per_second is greater than 20.0:
            Return create_test_result("Validation Performance", "PASSED", start_time, 20.0, validations_per_second, None)
        Else:
            Return create_test_result("Validation Performance", "FAILED", start_time, 20.0, validations_per_second, "Validation performance below threshold")
    
    Catch error:
        Return create_test_result("Validation Performance", "ERROR", start_time, 20.0, 0.0, error.message)

