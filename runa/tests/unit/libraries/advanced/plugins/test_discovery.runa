                requires as list containing
                provides as list containing
            configuration as PluginDiscovery.ConfigurationInfo with:
                default_config as None
                schema as None
            build as PluginDiscovery.BuildInfo with:
                build_script as None
                assets as list containing
                exclude as list containing
        
        Append manifest to manifests
    
    Return manifests

Process called "create_empty_manifest_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/empty_manifest_" plus generate_uuid()
    create_directory(plugin_dir)
    
    Note: Create empty manifest file
    write_file(plugin_dir plus "/plugin.toml", "")
    
    Return plugin_dir

Process called "create_special_character_plugin_directory" returns String:
    Let temp_dir be get_system_temp_directory()
    Let plugin_dir be temp_dir plus "/special_chars_plugin_" plus generate_uuid()
    create_directory(plugin_dir)
    
    write_file(plugin_dir plus "/plugin.toml", create_test_manifest_content())
    write_file(plugin_dir plus "/main.runa", "Process called \"main\" returns String: Return \"special chars\"")
    
    Return plugin_dir

Note: Main Entry Point
Process called "main" returns DiscoveryTestReport:
    Log message "=== Runa Plugin Discovery Module Test Suite ==="
    
    Let test_results be run_all_discovery_tests()
    
    Let passed_count be 0
    Let failed_count be 0
    Let skipped_count be 0
    
    For each result in test_results:
        Match result.status:
            When "PASSED":
                Set passed_count to passed_count plus 1
            When "FAILED" or "ERROR":
                Set failed_count to failed_count plus 1
            When "SKIPPED":
                Set skipped_count to skipped_count plus 1
    
    Let overall_status be if failed_count is greater than 0 then "FAILED" else "PASSED"
    
    Log message "=== DISCOVERY TEST RESULTS ==="
    Log message "Overall Status: " plus overall_status
    Log message "Passed: " plus passed_count
    Log message "Failed: " plus failed_count
    Log message "Skipped: " plus skipped_count
    
    For each result in test_results:
        If result.status is equal to "FAILED" or result.status is equal to "ERROR":
            Log message "FAILED: " plus result.test_name plus " - " plus result.error_message
    
    Return DiscoveryTestReport with:
        overall_status as overall_status
        tests_passed as passed_count
        tests_failed as failed_count
        tests_skipped as skipped_count
        execution_time as 0.0
        test_categories as dictionary containing
        performance_metrics as DiscoveryPerformanceMetrics with:
            scanning_performance as 0.0
            metadata_extraction_performance as 0.0
            validation_performance as 0.0
            compatibility_check_performance as 0.0
            memory_usage as 0
            metadata as dictionary containing
        errors as list containing
        metadata as dictionary containing