    Let manifests be list containing
    
    For i from 1 to count:
        Let manifest be PluginDiscovery.PluginManifest with:
            plugin as PluginDiscovery.PluginInfo with:
                id as "multi.test.plugin." plus i
                name as "Multi Test Plugin " plus i
                version as "1.0.0"
                author as "Test Author"
                description as "Multiple test plugin " plus i
                license as "MIT"
                repository as None
                homepage as None
                entry_point as "main.runa"
            compatibility as PluginDiscovery.CompatibilityInfo with:
                runa_version as ">=1.0.0"
                platform as list containing "linux"
                architecture as list containing "x86_64"
            dependencies as dictionary containing
