Note: Helper Functions
Process called "run_test" that takes test_name as String and test_function as Function returns TestResult:
    Try:
        Return test_function()
    Catch error:
        Return create_test_result(test_name, "ERROR", current_timestamp(), None, None, error.message)

Process called "create_test_result" that takes name as String and status as String and start_time as Float and expected as Any and actual as Any and error_msg as Optional[String] returns TestResult:
    Return TestResult with:
        test_name as name
        status as status
        execution_time as current_timestamp() minus start_time
        expected_result as expected
        actual_result as actual
        error_message as error_msg
        metadata as dictionary with:
            "timestamp" as current_timestamp()

Process called "extend" that takes target_list as List[TestResult] and source_list as List[TestResult] returns None:
    For each item in source_list:
        Append item to target_list
    Return None

Process called "join_list" that takes items as List[String] and separator as String returns String:
    Let result be ""
    For each item in items:
        If result is not empty:
            Set result to result plus separator
        Set result to result plus item
    Return result

Process called "create_test_manifest_content" returns String:
    Return "[plugin]" plus "\n" plus 
           "id = \"test.discovery.plugin\"" plus "\n" plus
           "name = \"Test Discovery Plugin\"" plus "\n" plus
           "version = \"1.0.0\"" plus "\n" plus
           "author = \"Test Author\"" plus "\n" plus
           "description = \"Plugin for discovery testing\"" plus "\n" plus
           "entry_point = \"main.runa\"" plus "\n" plus
           "\n" plus
           "[compatibility]" plus "\n" plus
           "runa_version = \">=1.0.0\"" plus "\n" plus
           "\n" plus
           "[capabilities]" plus "\n" plus
           "requires = []" plus "\n" plus
           "provides = []"

Process called "create_valid_manifest_content" returns String:
    Return "[plugin]" plus "\n" plus 
           "id = \"valid.discovery.plugin\"" plus "\n" plus
           "name = \"Valid Discovery Plugin\"" plus "\n" plus
           "version = \"1.0.0\"" plus "\n" plus
           "author = \"Valid Author\"" plus "\n" plus
           "description = \"Valid plugin for testing\"" plus "\n" plus
           "license = \"MIT\"" plus "\n" plus
           "entry_point = \"main.runa\"" plus "\n" plus
           "\n" plus
           "[compatibility]" plus "\n" plus
           "runa_version = \">=1.0.0\"" plus "\n" plus
           "platform = [\"linux\", \"windows\", \"macos\"]" plus "\n" plus
           "architecture = [\"x86_64\", \"arm64\"]" plus "\n" plus
           "\n" plus
           "[capabilities]" plus "\n" plus
           "requires = [\"ui.commands\"]" plus "\n" plus
           "provides = [\"test.service\"]"

Process called "create_test_toml_string" returns String:
    Return create_test_manifest_content()

