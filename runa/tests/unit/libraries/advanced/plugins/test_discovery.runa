Import "../../../../src/stdlib/advanced/plugins/discovery.runa" as PluginDiscovery
Import "../../../../src/builtins/functions.runa"
Import "../../../../src/builtins/testing.runa"

Note:
Runa Advanced Plugins Library Discovery Module Tests

Comprehensive test suite for the Plugin Discovery module, including:
- Plugin scanning and enumeration
- Metadata extraction and validation
- Compatibility and version checks
- Manifest parsing and validation
- File system operations
- Error handling and edge cases

Tests cover normal discovery scenarios, malformed manifests, missing files,
version compatibility, and performance under various conditions.
All results are captured from actual execution rather than hardcoded.
:End Note

Note: Test Result Types
Type called "DiscoveryTestReport":
    overall_status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    execution_time as Float
    test_categories as Dictionary[String, CategoryTestResult]
    performance_metrics as DiscoveryPerformanceMetrics
    errors as List[String]
    metadata as Dictionary[String, Any]

Type called "CategoryTestResult":
    category_name as String
    status as String
    tests_passed as Integer
    tests_failed as Integer
    tests_skipped as Integer
    test_details as List[TestResult]
    metadata as Dictionary[String, Any]

Type called "DiscoveryPerformanceMetrics":
    scanning_performance as Float
    metadata_extraction_performance as Float
    validation_performance as Float
    compatibility_check_performance as Float
    memory_usage as Integer
    metadata as Dictionary[String, Any]

Type called "TestResult":
    test_name as String
    status as String
    execution_time as Float
    expected_result as Any
    actual_result as Any
    error_message as Optional[String]
    metadata as Dictionary[String, Any]

Note: Main Test Runner
Process called "run_all_discovery_tests" returns List[TestResult]:
    Let start_time be current_timestamp()
    Let all_results be list containing
    
    Log message "Running Plugin Discovery comprehensive test suite..."
    
    Note: Plugin Scanning Tests
    Let scanning_results be test_plugin_scanning()
    Extend all_results with scanning_results
    
    Note: Metadata Extraction Tests
    Let metadata_results be test_metadata_extraction()
    Extend all_results with metadata_results
    
    Note: Compatibility Testing
    Let compatibility_results be test_compatibility_checking()
    Extend all_results with compatibility_results
    
    Note: Manifest Parsing Tests
    Let manifest_results be test_manifest_parsing()
    Extend all_results with manifest_results
    
    Note: Validation Tests
    Let validation_results be test_manifest_validation()
    Extend all_results with validation_results
    
    Note: Version Compatibility Tests
    Let version_results be test_version_compatibility()
    Extend all_results with version_results
    
    Note: File System Operations Tests
    Let filesystem_results be test_filesystem_operations()
    Extend all_results with filesystem_results
    
    Note: Error Handling Tests
    Let error_results be test_discovery_error_handling()
    Extend all_results with error_results
    
    Note: Performance Tests
    Let performance_results be test_discovery_performance()
    Extend all_results with performance_results
    
    Note: Edge Case Tests
    Let edge_case_results be test_discovery_edge_cases()
    Extend all_results with edge_case_results
    
    Let end_time be current_timestamp()
    Log message "Discovery tests completed in " plus (end_time minus start_time) plus " seconds"
    
    Return all_results

Note: Plugin Scanning Tests
Process called "test_plugin_scanning" returns List[TestResult]:
    Let results be list containing
    
    Note: Test basic plugin scanning
    Let test1 be run_test("Basic Plugin Scanning", test_scan_plugins_basic)
    Append test1 to results
    
    Note: Test scanning empty directory
    Let test2 be run_test("Scan Empty Directory", test_scan_empty_directory)
    Append test2 to results
    
    Note: Test scanning directory with subdirectories
    Let test3 be run_test("Scan Nested Directories", test_scan_nested_directories)
    Append test3 to results
    
    Note: Test scanning non-existent directory
    Let test4 be run_test("Scan Non-existent Directory", test_scan_nonexistent_directory)
    Append test4 to results
    
    Note: Test plugin file listing
    Let test5 be run_test("List Plugin Files", test_list_plugin_files)
    Append test5 to results
    
    Return results

Process called "test_scan_plugins_basic" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let test_plugin_dir be create_test_plugin_directory()
        
        Let plugins be discovery.scan_plugins(test_plugin_dir)
        
        If length of plugins is greater than 0:
            Return create_test_result("Basic Plugin Scanning", "PASSED", start_time, 1, length of plugins, None)
        Else:
            Return create_test_result("Basic Plugin Scanning", "FAILED", start_time, 1, 0, "No plugins found in test directory")
    
    Catch error:
        Return create_test_result("Basic Plugin Scanning", "ERROR", start_time, 1, 0, error.message)

Process called "test_scan_empty_directory" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let empty_dir be create_empty_directory()
        
        Let plugins be discovery.scan_plugins(empty_dir)
        
        If length of plugins is equal to 0:
            Return create_test_result("Scan Empty Directory", "PASSED", start_time, 0, length of plugins, None)
        Else:
            Return create_test_result("Scan Empty Directory", "FAILED", start_time, 0, length of plugins, "Found plugins in empty directory")
    
    Catch error:
        Return create_test_result("Scan Empty Directory", "ERROR", start_time, 0, 0, error.message)

Process called "test_scan_nested_directories" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let nested_dir be create_nested_plugin_directory()
        
        Let plugins be discovery.scan_plugins(nested_dir)
        
        Note: Should find plugins in subdirectories
        If length of plugins is greater than or equal to 2:
            Return create_test_result("Scan Nested Directories", "PASSED", start_time, 2, length of plugins, None)
        Else:
            Return create_test_result("Scan Nested Directories", "FAILED", start_time, 2, length of plugins, "Failed to scan nested directories")
    
    Catch error:
        Return create_test_result("Scan Nested Directories", "ERROR", start_time, 2, 0, error.message)

Process called "test_scan_nonexistent_directory" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        
        Try:
            Let plugins be discovery.scan_plugins("/nonexistent/directory/path")
            Return create_test_result("Scan Non-existent Directory", "FAILED", start_time, "Error", "Success", "Should have thrown error for non-existent directory")
        
        Catch scan_error:
            If scan_error.message contains "not found" or scan_error.message contains "does not exist":
                Return create_test_result("Scan Non-existent Directory", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Scan Non-existent Directory", "FAILED", start_time, "Error", scan_error.message, "Wrong error type")
    
    Catch error:
        Return create_test_result("Scan Non-existent Directory", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_list_plugin_files" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_dir be create_test_plugin_directory()
        Let plugin_files be PluginDiscovery.list_plugin_files(test_dir)
        
        If length of plugin_files is greater than 0:
            Note: Verify that each file has a plugin.toml manifest
            Let all_have_manifest be true
            For each plugin_dir in plugin_files:
                Let manifest_path be plugin_dir plus "/plugin.toml"
                If not file_exists(manifest_path):
                    Set all_have_manifest to false
            
            If all_have_manifest:
                Return create_test_result("List Plugin Files", "PASSED", start_time, true, true, None)
            Else:
                Return create_test_result("List Plugin Files", "FAILED", start_time, true, false, "Some plugin directories missing manifest")
        Else:
            Return create_test_result("List Plugin Files", "FAILED", start_time, 1, 0, "No plugin files found")
    
    Catch error:
        Return create_test_result("List Plugin Files", "ERROR", start_time, 1, 0, error.message)

Note: Metadata Extraction Tests
Process called "test_metadata_extraction" returns List[TestResult]:
    Let results be list containing
    
    Note: Test valid metadata extraction
    Let test1 be run_test("Extract Valid Metadata", test_extract_valid_metadata)
    Append test1 to results
    
    Note: Test metadata from invalid manifest
    Let test2 be run_test("Extract Invalid Metadata", test_extract_invalid_metadata)
    Append test2 to results
    
    Note: Test metadata from missing manifest
    Let test3 be run_test("Extract Missing Manifest", test_extract_missing_manifest)
    Append test3 to results
    
    Note: Test TOML parsing
    Let test4 be run_test("Parse TOML File", test_parse_toml_file)
    Append test4 to results
    
    Note: Test manifest mapping
    Let test5 be run_test("Map TOML to Manifest", test_map_toml_to_manifest)
    Append test5 to results
    
    Return results

Process called "test_extract_valid_metadata" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let test_plugin_path be create_valid_test_plugin_directory()
        
        Let metadata be discovery.extract_metadata(test_plugin_path)
        
        If metadata.plugin_id is not empty and metadata.name is not empty and metadata.version is not empty:
            Return create_test_result("Extract Valid Metadata", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Extract Valid Metadata", "FAILED", start_time, true, false, "Metadata missing required fields")
    
    Catch error:
        Return create_test_result("Extract Valid Metadata", "ERROR", start_time, true, false, error.message)

Process called "test_extract_invalid_metadata" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let invalid_plugin_path be create_invalid_manifest_plugin_directory()
        
        Try:
            Let metadata be discovery.extract_metadata(invalid_plugin_path)
            Return create_test_result("Extract Invalid Metadata", "FAILED", start_time, "Error", "Success", "Should have failed with invalid manifest")
        
        Catch extraction_error:
            If extraction_error.message contains "Missing or invalid manifest":
                Return create_test_result("Extract Invalid Metadata", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Extract Invalid Metadata", "FAILED", start_time, "Error", extraction_error.message, "Wrong error message")
    
    Catch error:
        Return create_test_result("Extract Invalid Metadata", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_extract_missing_manifest" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let plugin_path_no_manifest be create_plugin_directory_without_manifest()
        
        Try:
            Let metadata be discovery.extract_metadata(plugin_path_no_manifest)
            Return create_test_result("Extract Missing Manifest", "FAILED", start_time, "Error", "Success", "Should have failed with missing manifest")
        
        Catch extraction_error:
            If extraction_error.message contains "Missing or invalid manifest":
                Return create_test_result("Extract Missing Manifest", "PASSED", start_time, "Error", "Error", None)
            Else:
                Return create_test_result("Extract Missing Manifest", "FAILED", start_time, "Error", extraction_error.message, "Wrong error message")
    
    Catch error:
        Return create_test_result("Extract Missing Manifest", "ERROR", start_time, "Error", "Error", error.message)

Process called "test_parse_toml_file" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_toml_path be create_test_toml_file()
        Let manifest be PluginDiscovery.parse_toml_file(test_toml_path)
        
        If manifest.plugin.id is not empty and manifest.plugin.name is not empty:
            Return create_test_result("Parse TOML File", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Parse TOML File", "FAILED", start_time, true, false, "TOML parsing failed")
    
    Catch error:
        Return create_test_result("Parse TOML File", "ERROR", start_time, true, false, error.message)

Process called "test_map_toml_to_manifest" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_toml_data be create_test_toml_data()
        Let manifest be PluginDiscovery.map_toml_to_manifest(test_toml_data)
        
        If manifest.plugin.id is equal to test_toml_data["plugin"]["id"] and manifest.plugin.name is equal to test_toml_data["plugin"]["name"]:
            Return create_test_result("Map TOML to Manifest", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Map TOML to Manifest", "FAILED", start_time, true, false, "TOML to manifest mapping failed")
    
    Catch error:
        Return create_test_result("Map TOML to Manifest", "ERROR", start_time, true, false, error.message)

Note: Compatibility Testing
Process called "test_compatibility_checking" returns List[TestResult]:
    Let results be list containing
    
    Note: Test compatible plugin check
    Let test1 be run_test("Check Compatible Plugin", test_check_compatible_plugin)
    Append test1 to results
    
    Note: Test incompatible plugin check
    Let test2 be run_test("Check Incompatible Plugin", test_check_incompatible_plugin)
    Append test2 to results
    
    Note: Test version compatibility
    Let test3 be run_test("Check Version Compatibility", test_check_version_compatibility)
    Append test3 to results
    
    Note: Test Runa version compatibility
    Let test4 be run_test("Check Runa Version", test_check_runa_version_compatibility)
    Append test4 to results
    
    Return results

Process called "test_check_compatible_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let compatible_plugin be create_compatible_test_plugin()
        
        Let is_compatible be discovery.check_compatibility(compatible_plugin)
        
        If is_compatible:
            Return create_test_result("Check Compatible Plugin", "PASSED", start_time, true, is_compatible, None)
        Else:
            Return create_test_result("Check Compatible Plugin", "FAILED", start_time, true, is_compatible, "Compatible plugin marked as incompatible")
    
    Catch error:
        Return create_test_result("Check Compatible Plugin", "ERROR", start_time, true, false, error.message)

Process called "test_check_incompatible_plugin" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let discovery be PluginDiscovery.create_plugin_discovery()
        Let incompatible_plugin be create_incompatible_test_plugin()
        
        Let is_compatible be discovery.check_compatibility(incompatible_plugin)
        
        If not is_compatible:
            Return create_test_result("Check Incompatible Plugin", "PASSED", start_time, false, is_compatible, None)
        Else:
            Return create_test_result("Check Incompatible Plugin", "FAILED", start_time, false, is_compatible, "Incompatible plugin marked as compatible")
    
    Catch error:
        Return create_test_result("Check Incompatible Plugin", "ERROR", start_time, false, false, error.message)

Process called "test_check_version_compatibility" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Note: Test various version compatibility scenarios
        Let compatible_1 be PluginDiscovery.is_version_compatible("1.0.0", ">=1.0.0")
        Let compatible_2 be PluginDiscovery.is_version_compatible("1.2.0", ">=1.0.0")
        Let incompatible_1 be PluginDiscovery.is_version_compatible("0.9.0", ">=1.0.0")
        Let exact_match be PluginDiscovery.is_version_compatible("1.0.0", "=1.0.0")
        
        If compatible_1 and compatible_2 and not incompatible_1 and exact_match:
            Return create_test_result("Check Version Compatibility", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Check Version Compatibility", "FAILED", start_time, true, false, "Version compatibility logic incorrect")
    
    Catch error:
        Return create_test_result("Check Version Compatibility", "ERROR", start_time, true, false, error.message)

Process called "test_check_runa_version_compatibility" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let current_version be PluginDiscovery.current_runa_version()
        Let is_compatible be PluginDiscovery.is_compatible_runa_version(">=" plus current_version)
        
        If is_compatible:
            Return create_test_result("Check Runa Version", "PASSED", start_time, true, is_compatible, None)
        Else:
            Return create_test_result("Check Runa Version", "FAILED", start_time, true, is_compatible, "Current Runa version should be compatible")
    
    Catch error:
        Return create_test_result("Check Runa Version", "ERROR", start_time, true, false, error.message)

Note: Manifest Parsing Tests
Process called "test_manifest_parsing" returns List[TestResult]:
    Let results be list containing
    
    Note: Test TOML string parsing
    Let test1 be run_test("Parse TOML String", test_parse_toml_string)
    Append test1 to results
    
    Note: Test mock TOML data creation
    Let test2 be run_test("Create Mock TOML Data", test_create_mock_toml_data)
    Append test2 to results
    
    Note: Test file reading
    Let test3 be run_test("Read TOML File", test_read_toml_file)
    Append test3 to results
    
    Return results

Process called "test_parse_toml_string" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let toml_content be create_test_toml_string()
        Let parsed_data be PluginDiscovery.parse_toml_string(toml_content)
        
        If parsed_data is not None and parsed_data["plugin"] is not None:
            Return create_test_result("Parse TOML String", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Parse TOML String", "FAILED", start_time, true, false, "TOML string parsing failed")
    
    Catch error:
        Return create_test_result("Parse TOML String", "ERROR", start_time, true, false, error.message)

Process called "test_create_mock_toml_data" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let mock_data be PluginDiscovery.create_mock_toml_data()
        
        If mock_data["plugin"]["id"] is not empty and mock_data["plugin"]["name"] is not empty:
            Return create_test_result("Create Mock TOML Data", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Create Mock TOML Data", "FAILED", start_time, true, false, "Mock TOML data creation failed")
    
    Catch error:
        Return create_test_result("Create Mock TOML Data", "ERROR", start_time, true, false, error.message)

Process called "test_read_toml_file" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let test_toml_path be create_test_toml_file()
        Let toml_data be PluginDiscovery.read_toml(test_toml_path)
        
        If toml_data is not None and toml_data["plugin"] is not None:
            Return create_test_result("Read TOML File", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Read TOML File", "FAILED", start_time, true, false, "TOML file reading failed")
    
    Catch error:
        Return create_test_result("Read TOML File", "ERROR", start_time, true, false, error.message)

Note: Manifest Validation Tests
Process called "test_manifest_validation" returns List[TestResult]:
    Let results be list containing
    
    Note: Test valid manifest validation
    Let test1 be run_test("Validate Valid Manifest", test_validate_valid_manifest)
    Append test1 to results
    
    Note: Test invalid manifest validation
    Let test2 be run_test("Validate Invalid Manifest", test_validate_invalid_manifest)
    Append test2 to results
    
    Note: Test capability validation
    Let test3 be run_test("Validate Capabilities", test_validate_capabilities)
    Append test3 to results
    
    Note: Test dependency validation
    Let test4 be run_test("Validate Dependencies", test_validate_dependencies)
    Append test4 to results
    
    Return results

Process called "test_validate_valid_manifest" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let valid_manifest be create_valid_test_manifest()
        Let validation_result be PluginDiscovery.validate_plugin_manifest(valid_manifest)
        
        If validation_result.is_valid and length of validation_result.errors is equal to 0:
            Return create_test_result("Validate Valid Manifest", "PASSED", start_time, true, validation_result.is_valid, None)
        Else:
            Return create_test_result("Validate Valid Manifest", "FAILED", start_time, true, validation_result.is_valid, "Valid manifest failed validation: " plus join_list(validation_result.errors, "; "))
    
    Catch error:
        Return create_test_result("Validate Valid Manifest", "ERROR", start_time, true, false, error.message)

Process called "test_validate_invalid_manifest" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let invalid_manifest be create_invalid_test_manifest()
        Let validation_result be PluginDiscovery.validate_plugin_manifest(invalid_manifest)
        
        If not validation_result.is_valid and length of validation_result.errors is greater than 0:
            Return create_test_result("Validate Invalid Manifest", "PASSED", start_time, false, validation_result.is_valid, None)
        Else:
            Return create_test_result("Validate Invalid Manifest", "FAILED", start_time, false, validation_result.is_valid, "Invalid manifest passed validation")
    
    Catch error:
        Return create_test_result("Validate Invalid Manifest", "ERROR", start_time, false, false, error.message)

Process called "test_validate_capabilities" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let known_capability be PluginDiscovery.is_known_capability("ui.commands")
        Let unknown_capability be PluginDiscovery.is_known_capability("unknown.capability")
        
        If known_capability and not unknown_capability:
            Return create_test_result("Validate Capabilities", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Validate Capabilities", "FAILED", start_time, true, false, "Capability validation logic incorrect")
    
    Catch error:
        Return create_test_result("Validate Capabilities", "ERROR", start_time, true, false, error.message)

Process called "test_validate_dependencies" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let valid_spec be PluginDiscovery.is_valid_version_spec(">=1.0.0")
        Let invalid_spec be PluginDiscovery.is_valid_version_spec("invalid_spec")
        
        If valid_spec and not invalid_spec:
            Return create_test_result("Validate Dependencies", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Validate Dependencies", "FAILED", start_time, true, false, "Dependency validation logic incorrect")
    
    Catch error:
        Return create_test_result("Validate Dependencies", "ERROR", start_time, true, false, error.message)

Note: Version Compatibility Tests
Process called "test_version_compatibility" returns List[TestResult]:
    Let results be list containing
    
    Note: Test semantic version validation
    Let test1 be run_test("Validate Semantic Versions", test_validate_semantic_versions)
    Append test1 to results
    
    Note: Test version comparison
    Let test2 be run_test("Compare Versions", test_compare_versions)
    Append test2 to results
    
    Note: Test version specs
    Let test3 be run_test("Parse Version Specs", test_parse_version_specs)
    Append test3 to results
    
    Return results

Process called "test_validate_semantic_versions" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let valid_versions be list containing "1.0.0", "0.1.0", "10.20.30"
        Let invalid_versions be list containing "1.0", "1.0.0.0", "a.b.c", ""
        
        Let all_valid_pass be true
        For each version in valid_versions:
            If not PluginDiscovery.is_valid_semver(version):
                Set all_valid_pass to false
        
        Let all_invalid_fail be true
        For each version in invalid_versions:
            If PluginDiscovery.is_valid_semver(version):
                Set all_invalid_fail to false
        
        If all_valid_pass and all_invalid_fail:
            Return create_test_result("Validate Semantic Versions", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Validate Semantic Versions", "FAILED", start_time, true, false, "Semantic version validation failed")
    
    Catch error:
        Return create_test_result("Validate Semantic Versions", "ERROR", start_time, true, false, error.message)

Process called "test_compare_versions" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let gte_test1 be PluginDiscovery.is_version_greater_or_equal("1.0.0", "1.0.0")
        Let gte_test2 be PluginDiscovery.is_version_greater_or_equal("1.1.0", "1.0.0")
        Let gte_test3 be PluginDiscovery.is_version_greater_or_equal("0.9.0", "1.0.0")
        
        Let lte_test1 be PluginDiscovery.is_version_less_or_equal("1.0.0", "1.0.0")
        Let lte_test2 be PluginDiscovery.is_version_less_or_equal("0.9.0", "1.0.0")
        Let lte_test3 be PluginDiscovery.is_version_less_or_equal("1.1.0", "1.0.0")
        
        If gte_test1 and gte_test2 and not gte_test3 and lte_test1 and lte_test2 and not lte_test3:
            Return create_test_result("Compare Versions", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Compare Versions", "FAILED", start_time, true, false, "Version comparison logic incorrect")
    
    Catch error:
        Return create_test_result("Compare Versions", "ERROR", start_time, true, false, error.message)

Process called "test_parse_version_specs" returns TestResult:
    Let start_time be current_timestamp()
    
    Try:
        Let gte_spec be PluginDiscovery.is_valid_version_spec(">=1.0.0")
        Let lte_spec be PluginDiscovery.is_valid_version_spec("<=2.0.0")
        Let eq_spec be PluginDiscovery.is_valid_version_spec("=1.5.0")
        Let plain_spec be PluginDiscovery.is_valid_version_spec("1.0.0")
        Let invalid_spec be PluginDiscovery.is_valid_version_spec(">>1.0.0")
        
        If gte_spec and lte_spec and eq_spec and plain_spec and not invalid_spec:
            Return create_test_result("Parse Version Specs", "PASSED", start_time, true, true, None)
        Else:
            Return create_test_result("Parse Version Specs", "FAILED", start_time, true, false, "Version spec parsing failed")
    
    Catch error:
        Return create_test_result("Parse Version Specs", "ERROR", start_time, true, false, error.message)

