Note: DSL Parsing Tests

Process called "test_parse_simple_expression":
    Let builder be create_test_dsl_builder()
    Let spec be create_test_dsl_specification with name as "math_dsl"
    
    DSLSupport.register_dsl_specification with builder as builder and specification as spec
    Let dsl be DSLSupport.build_dsl with builder as builder and dsl_name as "math_dsl"
    
    Let input be "2 + 3 * 4"
    Let parse_result be DSLSupport.parse_dsl_input with 
        dsl as dsl 
        and input as input
    
    assert_not_null(parse_result, "parse_simple_expression")
    assert_true(parse_result.success, "parse_expression_success")

Process called "test_parse_nested_expression":
    Let builder be create_test_dsl_builder()
    Let spec be create_test_dsl_specification with name as "nested_math_dsl"
    
    DSLSupport.register_dsl_specification with builder as builder and specification as spec
    Let dsl be DSLSupport.build_dsl with builder as builder and dsl_name as "nested_math_dsl"
    
    Let input be "(2 + 3) * (4 - 1)"
    Let parse_result be DSLSupport.parse_dsl_input with 
        dsl as dsl 
        and input as input
    
    assert_not_null(parse_result, "parse_nested_expression")
    assert_true(parse_result.success, "parse_nested_expression_success")

Process called "test_parse_invalid_syntax":
    Let builder be create_test_dsl_builder()
    Let spec be create_test_dsl_specification with name as "error_test_dsl"
    
    DSLSupport.register_dsl_specification with builder as builder and specification as spec
    Let dsl be DSLSupport.build_dsl with builder as builder and dsl_name as "error_test_dsl"
    
    Let invalid_input be "2 + * 3"
    Let parse_result be DSLSupport.parse_dsl_input with 
        dsl as dsl 
        and input as invalid_input
    
    assert_not_null(parse_result, "parse_invalid_syntax")
    assert_equal(false, parse_result.success, "parse_invalid_syntax_fails")
    assert_not_null(parse_result.errors, "parse_invalid_syntax_has_errors")

