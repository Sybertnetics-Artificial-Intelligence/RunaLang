Note:
Comprehensive Test Suite for Advanced Macros DSL Support Module

Tests all functionality of the domain-specific language creation tools including:
- DSL definition and grammar creation
- Syntax rule specification and validation
- Parser generation and customization
- Semantic analysis for DSLs
- Code generation from DSL constructs
- DSL optimization and transformation
- Multi-target DSL compilation
- Performance benchmarks
:End Note

Import "../../../../../../src/stdlib/advanced/macros/dsl_support" as DSLSupport
Import "../../../../../../src/stdlib/advanced/macros/system" as MacroSystem
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration and Global Counters
Let test_count be 0
Let passed_count be 0
Let failed_count be 0
Let test_results be List[Dictionary[String, Any]] containing

Note: Test Helper Functions

Process called "assert_equal" that takes expected as Any and actual as Any and test_name as String:
    Set test_count to test_count plus 1
    If expected is equal to actual:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected: " plus expected plus ", got: " plus actual plus ")"

Process called "assert_not_null" that takes value as Any and test_name as String:
    Set test_count to test_count plus 1
    If value is not null:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "value" as value
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "value" as null
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected non-null value)"

Process called "assert_true" that takes condition as Boolean and test_name as String:
    Set test_count to test_count plus 1
    If condition:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "condition" as true
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "condition" as false
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (condition was false)"

Process called "assert_contains" that takes text as String and substring as String and test_name as String:
    Set test_count to test_count plus 1
    If text contains substring:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED ('" plus substring plus "' not found in '" plus text plus "')"

Process called "create_test_dsl_builder" returns DSLSupport.DSLBuilder:
    Return DSLSupport.create_dsl_builder()

Process called "create_test_grammar_definition" that takes name as String returns DSLSupport.GrammarDefinition:
    Return DSLSupport.GrammarDefinition with:
        grammar_name as name
        start_rule as "expression"
        rules as list containing:
            DSLSupport.GrammarRule with:
                rule_name as "expression"
                rule_pattern as "term (('+'|'-') term)*"
                rule_type as "expression"
                precedence as 1
                associativity as "left"
                metadata as dictionary containing
            DSLSupport.GrammarRule with:
                rule_name as "term"
                rule_pattern as "factor (('*'|'/') factor)*"
                rule_type as "expression"
                precedence as 2
                associativity as "left"
                metadata as dictionary containing
            DSLSupport.GrammarRule with:
                rule_name as "factor"
                rule_pattern as "NUMBER | '(' expression ')'"
                rule_type as "primary"
                precedence as 3
                associativity as "none"
                metadata as dictionary containing
        tokens as list containing:
            DSLSupport.TokenDefinition with:
                token_name as "NUMBER"
                token_pattern as "[0-9]+"
                token_type as "literal"
                metadata as dictionary containing
            DSLSupport.TokenDefinition with:
                token_name as "PLUS"
                token_pattern as "\\+"
                token_type as "operator"
                metadata as dictionary containing
            DSLSupport.TokenDefinition with:
                token_name as "MINUS"
                token_pattern as "-"
                token_type as "operator"
                metadata as dictionary containing
        metadata as dictionary containing

Process called "create_test_dsl_specification" that takes name as String returns DSLSupport.DSLSpecification:
    Return DSLSupport.DSLSpecification with:
        dsl_name as name
        grammar as create_test_grammar_definition with name as name plus "_grammar"
        semantic_rules as list containing:
            DSLSupport.SemanticRule with:
                rule_name as "type_check_expression"
                rule_pattern as "expression"
                rule_action as "validate_expression_types"
                metadata as dictionary containing
        code_generators as list containing:
            DSLSupport.CodeGenerator with:
                generator_name as "runa_generator"
                target_language as "runa"
                templates as dictionary containing:
                    "expression" as "expression_template"
                metadata as dictionary containing
        metadata as dictionary containing

