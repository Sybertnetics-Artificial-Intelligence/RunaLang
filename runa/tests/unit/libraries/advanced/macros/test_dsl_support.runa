Note: Integration Tests

Process called "test_full_dsl_pipeline":
    Let builder be create_test_dsl_builder()
    
    Note: Create comprehensive DSL specification
    Let calc_dsl_spec be DSLSupport.DSLSpecification with:
        dsl_name as "calculator_dsl"
        grammar as create_test_grammar_definition with name as "calculator_grammar"
        semantic_rules as list containing:
            DSLSupport.SemanticRule with:
                rule_name as "number_validation"
                rule_pattern as "NUMBER"
                rule_action as "validate_number_range"
                metadata as dictionary containing
        code_generators as list containing:
            DSLSupport.CodeGenerator with:
                generator_name as "runa_calc_generator"
                target_language as "runa"
                templates as dictionary containing:
                    "expression" as "calc_expression_template"
                metadata as dictionary containing
        metadata as dictionary containing
    
    Note: Register and build DSL
    DSLSupport.register_dsl_specification with builder as builder and specification as calc_dsl_spec
    Let calculator_dsl be DSLSupport.build_dsl with builder as builder and dsl_name as "calculator_dsl"
    
    Note: Parse DSL input
    Let calc_input be "10 + 5 * 2"
    Let parse_result be DSLSupport.parse_dsl_input with dsl as calculator_dsl and input as calc_input
    
    Note: Perform semantic analysis
    Let semantic_result be DSLSupport.analyze_semantics with dsl as calculator_dsl and ast as parse_result.ast
    
    Note: Generate code
    Let code_result be DSLSupport.generate_target_code with 
        dsl as calculator_dsl 
        and ast as semantic_result.ast 
        and target_language as "runa"
    
    assert_not_null(parse_result, "full_pipeline_parse")
    assert_true(parse_result.success, "full_pipeline_parse_success")
    assert_not_null(semantic_result, "full_pipeline_semantic_analysis")
    assert_not_null(code_result, "full_pipeline_code_generation")

Process called "test_dsl_to_dsl_transformation":
    Let transformer be DSLSupport.create_dsl_transformer()
    
    Note: Transform from math DSL to functional DSL
    Let math_ast be DSLSupport.ASTNode with:
        node_type as "binary_expression"
        operator as "plus"
        left_child as DSLSupport.ASTNode with:
            node_type as "number_literal"
            value as 1
            children as list containing
