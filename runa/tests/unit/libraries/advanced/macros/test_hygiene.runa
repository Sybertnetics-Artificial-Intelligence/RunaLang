    assert_equal("macro_expansion", new_scope.scope_type, "scope_type_set")

Process called "test_push_scope":
    Let scope_manager be MacroHygiene.create_scope_manager()
    Let scope be create_test_scope with name as "push_test"
    
    Let push_result be MacroHygiene.push_scope with 
        scope_manager as scope_manager 
        and scope as scope
    
    assert_true(push_result, "push_scope")
    assert_equal(1, length of scope_manager.scope_stack, "scope_stack_size_after_push")

Process called "test_pop_scope":
    Let scope_manager be MacroHygiene.create_scope_manager()
    Let scope1 be create_test_scope with name as "pop_test_1"
    Let scope2 be create_test_scope with name as "pop_test_2"
    
    MacroHygiene.push_scope with scope_manager as scope_manager and scope as scope1
    MacroHygiene.push_scope with scope_manager as scope_manager and scope as scope2
    
    Let popped_scope be MacroHygiene.pop_scope with scope_manager as scope_manager
    
    assert_not_null(popped_scope, "pop_scope")
    assert_equal("pop_test_2", popped_scope.scope_name, "popped_scope_correct")
    assert_equal(1, length of scope_manager.scope_stack, "scope_stack_size_after_pop")

Process called "test_get_current_scope":
    Let scope_manager be MacroHygiene.create_scope_manager()
    Let scope be create_test_scope with name as "current_test"
    
    MacroHygiene.push_scope with scope_manager as scope_manager and scope as scope
    
    Let current_scope be MacroHygiene.get_current_scope with scope_manager as scope_manager
    
    assert_not_null(current_scope, "get_current_scope")
    assert_equal("current_test", current_scope.scope_name, "current_scope_correct")

Process called "test_find_scope_by_name":
    Let scope_manager be MacroHygiene.create_scope_manager()
    Let scope1 be create_test_scope with name as "findable_scope_1"
    Let scope2 be create_test_scope with name as "findable_scope_2"
    
    MacroHygiene.push_scope with scope_manager as scope_manager and scope as scope1
    MacroHygiene.push_scope with scope_manager as scope_manager and scope as scope2
    
    Let found_scope be MacroHygiene.find_scope_by_name with 
        scope_manager as scope_manager 
        and scope_name as "findable_scope_1"
    
    assert_not_null(found_scope, "find_scope_by_name")
    assert_equal("findable_scope_1", found_scope.scope_name, "found_scope_correct")

