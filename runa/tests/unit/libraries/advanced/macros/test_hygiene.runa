Process called "test_empty_scope_handling":
    Let manager be create_test_hygiene_manager()
    Let empty_scope be create_test_scope with name as "empty_scope"
    
    Let empty_scope_result be MacroHygiene.apply_hygiene_rules with 
        manager as manager 
        and scope as empty_scope
    
    assert_not_null(empty_scope_result, "empty_scope_handling")
    assert_true(empty_scope_result.rules_applied is equal to 0, "no_rules_applied_to_empty_scope")

Process called "test_circular_scope_reference_detection":
    Let manager be create_test_hygiene_manager()
    
    Let scope1 be create_test_scope with name as "circular_scope_1"
    Let scope2 be create_test_scope with name as "circular_scope_2"
    
    Set scope1.parent_scope to scope2
    Set scope2.parent_scope to scope1
    
    Let circular_detection_result be MacroHygiene.detect_circular_scope_references with 
        manager as manager 
        and scope as scope1
    
    assert_not_null(circular_detection_result, "circular_scope_reference_detection")
    assert_true(circular_detection_result.circular_reference_found, "circular_reference_detected")

Process called "test_deep_scope_nesting":
    Let manager be create_test_hygiene_manager()
    
    Let root_scope be create_test_scope with name as "deep_root_scope"
    Let current_scope be root_scope
    
    For i from 1 to 50:
        Let nested_scope be create_test_scope with name as "deep_nested_scope_" plus i
        Set nested_scope.parent_scope to current_scope
        Set current_scope to nested_scope
    
    Let deep_nesting_result be MacroHygiene.apply_hygiene_rules with 
        manager as manager 
        and scope as current_scope
    
    assert_not_null(deep_nesting_result, "deep_scope_nesting")

