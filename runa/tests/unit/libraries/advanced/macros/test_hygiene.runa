Note: Hygiene Violation Detection Tests

Process called "test_hygiene_violation_detection":
    Let manager be create_test_hygiene_manager()
    
    Note: Create a scenario with hygiene violations
    Let violation_scope be create_test_scope with name as "violation_scope"
    Set violation_scope.variables["unhygienic_var"] to MacroHygiene.Variable with:
        name as "unhygienic_var"
        variable_type as "captured"
        value as "captured_value"
        metadata as dictionary containing:
            "source" as "external_scope"
            "violation_type" as "unintended_capture"
    
    Let violation_analysis be MacroHygiene.detect_hygiene_violations with 
        manager as manager 
        and scope as violation_scope
    
    assert_not_null(violation_analysis, "hygiene_violation_detection")
    assert_true((violation_analysis.violations_found is greater than 0), "hygiene_violations_detected")

Process called "test_hygiene_violation_reporting":
