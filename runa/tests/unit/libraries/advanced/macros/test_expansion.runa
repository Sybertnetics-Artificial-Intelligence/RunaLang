    assert_not_null(match_result, "match_pattern_simple")

Process called "test_match_pattern_with_constraints":
    Let matcher be MacroExpansion.create_pattern_matcher()
    
    Let constrained_pattern be MacroSystem.MacroPattern with:
        syntax as "constrained_pattern"
        tokens as create_test_tokens with count as 2
        variables as list containing "var1"
        constraints as list containing:
            MacroSystem.PatternConstraint with:
                constraint_type as "type_constraint"
                variable as "var1"
                condition as "identifier"
                metadata as dictionary containing
        metadata as dictionary containing
    
    Let tokens be create_test_tokens with count as 2
    Let match_result be MacroExpansion.match_pattern with 
        matcher as matcher 
        and pattern as constrained_pattern 
        and tokens as tokens
    
    assert_not_null(match_result, "match_pattern_with_constraints")

Process called "test_extract_variables_from_pattern":
    Let matcher be MacroExpansion.create_pattern_matcher()
    Let pattern be create_test_macro_pattern with name as "variable_extraction"
    Let tokens be create_test_tokens with count as 5
    
    Let extracted_variables be MacroExpansion.extract_variables_from_match with 
        matcher as matcher 
        and pattern as pattern 
