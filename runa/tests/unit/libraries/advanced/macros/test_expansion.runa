        ast_template as MacroSystem.ASTNode with:
            node_type as "recursive_root"
            value as "recursive"
            children as list containing
            position as MacroSystem.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing
        variable_mappings as dictionary containing:
            "arg" as "recursive_arg"
        conditional_sections as list containing
        metadata as dictionary containing
    
    Let pattern be create_test_macro_pattern with name as "recursive_test"
    Let tokens be create_test_tokens with count as 2
    
    Let expansion_result be MacroExpansion.expand_with_recursion_detection with 
        engine as engine 
        and pattern as pattern 
        and template as recursive_template 
        and input_tokens as tokens
    
    assert_not_null(expansion_result, "recursive_expansion")

