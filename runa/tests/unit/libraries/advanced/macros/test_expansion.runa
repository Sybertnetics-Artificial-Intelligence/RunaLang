Process called "test_check_performance_thresholds":
    Let monitor be MacroExpansion.create_expansion_performance_monitor()
    
    Set monitor.thresholds["expansion_time"] to 100.0
    
    Let metric = MacroExpansion.PerformanceMetric with:
        metric_name as "expansion_time"
        value as 150.0
        timestamp as Common.get_current_time()
        metadata as dictionary containing
    
    MacroExpansion.record_performance_metric with monitor as monitor and metric as metric
    Let threshold_exceeded be MacroExpansion.check_performance_thresholds with monitor as monitor
    
    assert_true(threshold_exceeded, "performance_threshold_exceeded")

