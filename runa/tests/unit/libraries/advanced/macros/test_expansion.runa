Note: Error Handling Tests

Process called "test_expansion_error_handling":
    Let engine be create_test_expansion_engine()
    
    Let invalid_template be MacroSystem.MacroTemplate with:
        template_code as "invalid_template_${undefined_var}"
        ast_template as MacroSystem.ASTNode with:
            node_type as "invalid"
            value as "error"
            children as list containing
            position as MacroSystem.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
            metadata as dictionary containing
        variable_mappings as dictionary containing
        conditional_sections as list containing
        metadata as dictionary containing
    
    Let pattern be create_test_macro_pattern with name as "error_test"
    Let tokens be create_test_tokens with count as 1
    
    Let expansion_result be MacroExpansion.expand_macro_full_pipeline with 
        engine as engine 
        and pattern as pattern 
        and template as invalid_template 
        and input_tokens as tokens
    
    If expansion_result matches MacroSystem.ExpansionError:
        assert_true(true, "expansion_error_properly_handled")
    Otherwise:
        assert_true(false, "expansion_should_fail_with_error")

Note: Performance Benchmarks

Process called "test_expansion_performance_benchmark":
    Let engine be create_test_expansion_engine()
    Let pattern be create_test_macro_pattern with name as "performance_test"
    Let template be create_test_macro_template with name as "performance_test"
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 100:
        Let tokens be create_test_tokens with count as 5
        MacroExpansion.expand_macro_full_pipeline with 
            engine as engine 
            and pattern as pattern 
            and template as template 
            and input_tokens as tokens
    
    Let end_time be Common.get_current_time()
    Let total_time be end_time minus start_time
    Let average_time be total_time divided by 100.0
    
    assert_true((average_time is less than 10.0), "expansion_performance_acceptable")
    Display message "    Average expansion time: " plus average_time plus "ms"

