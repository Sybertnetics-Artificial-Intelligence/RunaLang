Process called "test_expand_template_simple":
    Let expander be MacroExpansion.create_template_expander()
    Let template be create_test_macro_template with name as "simple"
    Let variable_bindings be dictionary containing:
        "var1" as "value1"
        "var2" as "value2"
    
    Let expanded_tokens be MacroExpansion.expand_template with 
        expander as expander 
        and template as template 
        and bindings as variable_bindings
    
    assert_not_null(expanded_tokens, "expand_template_simple")
    assert_true((length of expanded_tokens is greater than 0), "expanded_tokens_not_empty")

Process called "test_substitute_variables_in_template":
    Let expander be MacroExpansion.create_template_expander()
    Let template_code be "Hello ${name}, you have ${count} messages"
    Let variable_bindings be dictionary containing:
        "name" as "User"
        "count" as "5"
    
    Let substituted_code be MacroExpansion.substitute_variables with 
        expander as expander 
        and template_code as template_code 
        and bindings as variable_bindings
    
    assert_not_null(substituted_code, "substitute_variables_in_template")
    assert_equal("Hello User, you have 5 messages", substituted_code, "variable_substitution_correct")

