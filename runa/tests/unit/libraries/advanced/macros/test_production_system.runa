Process called "test_blue_green_deployment":
    Let manager be create_test_production_manager()
    Let blue_package be create_test_deployment_package with name as "blue_deployment"
    Set blue_package.package_version to "1.0.0"
    
    Let green_package be create_test_deployment_package with name as "blue_deployment"
    Set green_package.package_version to "1.1.0"
    
    ProductionSystem.initialize_production_environment with manager as manager
    
    Note: Deploy blue version
    ProductionSystem.deploy_macro_package with manager as manager and package as blue_package
    
    Note: Deploy green version using blue-green strategy
    Let blue_green_result be ProductionSystem.deploy_with_blue_green_strategy with 
        manager as manager 
        and new_package as green_package 
        and current_package as blue_package
    
    assert_not_null(blue_green_result, "blue_green_deployment")
    assert_true(blue_green_result.deployment_success, "blue_green_deployment_successful")

