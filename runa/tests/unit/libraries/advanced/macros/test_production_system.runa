            execution_context as ProductionSystem.ExecutionContext with:
                priority as "normal"
                timeout_ms as 1000
                retry_count as 1
                metadata as dictionary containing
            metadata as dictionary containing
        
        ProductionSystem.execute_macro_production with manager as manager and request as sla_request
    
