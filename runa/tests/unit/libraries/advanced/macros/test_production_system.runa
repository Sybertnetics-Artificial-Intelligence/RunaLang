            input_parameters as dictionary containing:
                "input" as "concurrent_test_" plus i
            execution_context as ProductionSystem.ExecutionContext with:
                priority as "normal"
                timeout_ms as 5000
                retry_count as 1
                metadata as dictionary containing
            metadata as dictionary containing
        Add execution_request to concurrent_executions
    
    Let start_time be Common.get_current_time()
    Let concurrent_results be ProductionSystem.execute_macros_concurrent with 
        manager as manager 
        and requests as concurrent_executions
    Let end_time be Common.get_current_time()
    
