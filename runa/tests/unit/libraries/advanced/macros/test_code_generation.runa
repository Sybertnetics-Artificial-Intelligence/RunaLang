Process called "test_template_inheritance":
    Let engine be CodeGen.create_template_engine()
    
    Let base_template be CodeGen.CodeTemplate with:
        template_name as "base_function"
        template_code as "Process called \"${function_name}\": ${body}"
        template_ast as CodeGen.TemplateASTNode with:
            node_type as "base_function"
            placeholders as list containing "${function_name}", "${body}"
            children as list containing
            metadata as dictionary containing
        variable_bindings as dictionary containing
        metadata as dictionary containing
    
    Let derived_template be CodeGen.CodeTemplate with:
        template_name as "derived_function"
        template_code as "Process called \"${function_name}\" that takes ${parameters} returns ${return_type}: ${body}"
        template_ast as CodeGen.TemplateASTNode with:
            node_type as "derived_function"
            placeholders as list containing "${function_name}", "${parameters}", "${return_type}", "${body}"
            children as list containing
            metadata as dictionary containing
        variable_bindings as dictionary containing
        metadata as dictionary containing:
            "parent_template" as "base_function"
    
    CodeGen.load_template with engine as engine and template as base_template
    CodeGen.load_template with engine as engine and template as derived_template
    
    Let variables be dictionary containing:
        "function_name" as "derived_test"
        "parameters" as "x as Integer"
        "return_type" as "Integer"
        "body" as "Return x"
    
    Let derived_code be CodeGen.process_template with 
        engine as engine 
        and template_name as "derived_function" 
        and variables as variables
    
    assert_not_null(derived_code, "template_inheritance")
    assert_contains(derived_code, "derived_test", "inherited_template_processed")

