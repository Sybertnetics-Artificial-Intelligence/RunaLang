Note: Integration Tests

Process called "test_full_code_generation_pipeline":
    Let generator be create_test_code_generator()
    
    Note: Register multiple templates
    Let function_template be create_test_code_template with name as "function_template"
    Let type_template be CodeGen.CodeTemplate with:
        template_name as "type_template"
        template_code as "Type called \"${type_name}\": ${fields}"
        template_ast as CodeGen.TemplateASTNode with:
            node_type as "type_declaration"
            placeholders as list containing "${type_name}", "${fields}"
            children as list containing
            metadata as dictionary containing
        variable_bindings as dictionary containing
        metadata as dictionary containing
    
    CodeGen.register_code_template with generator as generator and template as function_template
    CodeGen.register_code_template with generator as generator and template as type_template
    
    Note: Generate type
    Let type_variables be dictionary containing:
        "type_name" as "TestType"
        "fields" as "field1 as String\n    field2 as Integer"
    
    Let generated_type be CodeGen.generate_code_from_template with 
        generator as generator 
        and template_name as "type_template" 
        and bindings as type_variables
    
    Note: Generate function that uses the type
    Let function_variables be dictionary containing:
        "function_name" as "process_test_type"
        "parameters" as "obj as TestType"
        "body" as "Return obj.field1 plus obj.field2"
    
    Let generated_function be CodeGen.generate_code_from_template with 
        generator as generator 
        and template_name as "function_template" 
        and bindings as function_variables
    
    assert_not_null(generated_type, "full_pipeline_type_generation")
    assert_not_null(generated_function, "full_pipeline_function_generation")
    assert_contains(generated_type.code, "TestType", "type_generation_includes_name")
    assert_contains(generated_function.code, "process_test_type", "function_generation_includes_name")

Note: Performance Benchmarks

Process called "test_code_generation_performance_benchmark":
    Let generator be create_test_code_generator()
    Let template be create_test_code_template with name as "benchmark_template"
    
    CodeGen.register_code_template with generator as generator and template as template
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 1000:
        Let variables be dictionary containing:
            "function_name" as "benchmark_function_" plus i
            "parameters" as "x as Integer, y as String"
            "body" as "Return x plus length of y"
        
        CodeGen.generate_code_from_template with 
            generator as generator 
            and template_name as "benchmark_template" 
            and bindings as variables
    
    Let end_time be Common.get_current_time()
    Let total_time be end_time minus start_time
    Let average_time be total_time divided by 1000.0
    
    assert_true((average_time is less than 5.0), "code_generation_performance_acceptable")
    Display message "    Average code generation time: " plus average_time plus "ms"

