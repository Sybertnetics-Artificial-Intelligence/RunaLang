Note: Performance and Optimization Tests

Process called "test_syntax_extension_performance":
    Let manager be create_test_syntax_extension_manager()
    
    Note: Register multiple syntax extensions
    For i from 1 to 10:
        Let perf_syntax be create_test_custom_syntax_definition with name as "perf_syntax_" plus i
        SyntaxExtensions.register_custom_syntax with manager as manager and syntax as perf_syntax
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 100:
        Let test_input be "custom_perf_syntax_1 test_func => String"
        SyntaxExtensions.transform_custom_syntax with manager as manager and input as test_input
    
    Let end_time be Common.get_current_time()
    Let total_time be end_time minus start_time
    Let average_time be total_time divided by 100.0
    
    assert_true((average_time is less than 10.0), "syntax_extension_performance_acceptable")
    Display message "    Average syntax transformation time: " plus average_time plus "ms"

Process called "test_syntax_caching":
    Let manager be create_test_syntax_extension_manager()
    
    Let cacheable_config be SyntaxExtensions.SyntaxExtensionConfig with:
        enable_custom_syntax as true
        enable_lexer_extensions as true
        enable_parser_extensions as true
        enable_syntax_validation as true
        performance_mode as "high"
        metadata as dictionary containing:
            "enable_caching" as true
            "cache_size" as 1000
    
    SyntaxExtensions.reconfigure_syntax_manager with manager as manager and config as cacheable_config
    
    Let cached_syntax be create_test_custom_syntax_definition with name as "cached_test"
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as cached_syntax
    
    Let test_input be "custom_cached_test func => Integer"
    
    Note: First transformation should populate cache
    Let first_result be SyntaxExtensions.transform_custom_syntax with manager as manager and input as test_input
    
    Note: Second transformation should use cache
    Let second_result be SyntaxExtensions.transform_custom_syntax with manager as manager and input as test_input
    
    assert_not_null(first_result, "syntax_caching_first_run")
    assert_not_null(second_result, "syntax_caching_second_run")

Note: Integration Tests

Process called "test_full_syntax_extension_pipeline":
    Let manager = create_test_syntax_extension_manager()
    
    Note: Register lexer extension
    Let lexer_ext be create_test_lexer_extension with name as "pipeline_lexer"
    SyntaxExtensions.register_lexer_extension with manager as manager and extension as lexer_ext
    
    Note: Register parser extension
    Let parser_ext be create_test_parser_extension with name as "pipeline_parser"
    SyntaxExtensions.register_parser_extension with manager as manager and extension as parser_ext
    
    Note: Register custom syntax
    Let custom_syntax be create_test_custom_syntax_definition with name as "pipeline_syntax"
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as custom_syntax
    
    Note: Process input through full pipeline
    Let pipeline_input be "custom_pipeline_syntax test_function => @pipeline_lexer{data} pipeline_parser_operator value"
    
    Let tokenization_result be SyntaxExtensions.tokenize_with_extensions with 
        manager as manager 
        and input as pipeline_input
    
    Let parse_result be SyntaxExtensions.parse_with_extensions with 
        manager as manager 
        and input as pipeline_input
    
    Let transformation_result be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as pipeline_input
    
    assert_not_null(tokenization_result, "full_pipeline_tokenization")
    assert_not_null(parse_result, "full_pipeline_parsing")
    assert_not_null(transformation_result, "full_pipeline_transformation")

Process called "test_syntax_extension_interaction":
    Let manager be create_test_syntax_extension_manager()
    
    Note: Create interacting syntax extensions
    Let base_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "base_interaction"
        syntax_pattern as "base ${param}"
        token_definitions as list containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "base_transform"
                source_pattern as "base ${param}"
                target_pattern as "Let base_value be ${param}"
                transformation_type as "syntax_sugar"
                metadata as dictionary containing
        metadata as dictionary containing
    
    Let extending_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "extending_interaction"
        syntax_pattern as "extend base ${param} with ${additional}"
        token_definitions as list containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "extending_transform"
                source_pattern as "extend base ${param} with ${additional}"
                target_pattern as "base ${param}; Let extension be ${additional}"
                transformation_type as "extension"
                metadata as dictionary containing:
                    "depends_on" as "base_interaction"
        metadata as dictionary containing
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as base_syntax
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as extending_syntax
    
    Let interaction_input be "extend base test_value with additional_data"
    Let interaction_result be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as interaction_input
    
    assert_not_null(interaction_result, "syntax_extension_interaction")

Note: Error Handling and Edge Cases

Process called "test_invalid_syntax_handling":
    Let manager be create_test_syntax_extension_manager()
    
    Let invalid_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "invalid_test"
        syntax_pattern as "invalid syntax ${unclosed_variable"
        token_definitions as list containing
        syntax_rules as list containing:
            SyntaxExtensions.SyntaxRule with:
                rule_name as "invalid_rule"
                rule_pattern as "INVALID_TOKEN +"
                rule_action as "invalid_action"
                precedence as -1
                associativity as "invalid"
                metadata as dictionary containing
        transformations as list containing
        metadata as dictionary containing
    
    Let register_result be SyntaxExtensions.register_custom_syntax with 
        manager as manager 
        and syntax as invalid_syntax
    
    assert_equal(false, register_result, "invalid_syntax_rejected")

Process called "test_syntax_extension_conflict_resolution":
    Let manager be create_test_syntax_extension_manager()
    
    Let syntax1 be create_test_custom_syntax_definition with name as "conflict_1"
    Let syntax2 be create_test_custom_syntax_definition with name as "conflict_2"
    
    Note: Set same syntax pattern to create conflict
    Set syntax2.syntax_pattern to syntax1.syntax_pattern
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as syntax1
    
    Let conflict_result be SyntaxExtensions.register_custom_syntax with 
        manager as manager 
        and syntax as syntax2
    
    assert_equal(false, conflict_result, "syntax_extension_conflict_resolution")

Process called "test_recursive_syntax_detection":
    Let manager be create_test_syntax_extension_manager()
    
    Let recursive_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "recursive_test"
        syntax_pattern as "recursive ${param}"
        token_definitions as list containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "recursive_transform"
                source_pattern as "recursive ${param}"
                target_pattern as "recursive ${param}_extended"
                transformation_type as "recursive"
                metadata as dictionary containing
        metadata as dictionary containing
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as recursive_syntax
    
    Let recursive_input be "recursive test_param"
    
    Try:
        Let recursive_result be SyntaxExtensions.transform_custom_syntax with 
            manager as manager 
            and input as recursive_input
        assert_true(false, "recursive_syntax_should_be_detected")
    
    Catch error:
        assert_true(true, "recursive_syntax_detection_working")

