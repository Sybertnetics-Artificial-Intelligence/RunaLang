Process called "test_tokenize_with_custom_lexer":
    Let manager be create_test_syntax_extension_manager()
    Let lexer_extension be create_test_lexer_extension with name as "json_literals"
    
    SyntaxExtensions.register_lexer_extension with manager as manager and extension as lexer_extension
    
    Let input_text be "let data = @json_literals{\"name\": \"test\", \"value\": 42}"
    Let tokenization_result be SyntaxExtensions.tokenize_with_extensions with 
        manager as manager 
        and input as input_text
    
    assert_not_null(tokenization_result, "tokenize_with_custom_lexer")
    assert_true((tokenization_result.tokens_found is greater than 0), "custom_tokens_recognized")

Process called "test_custom_token_recognition":
