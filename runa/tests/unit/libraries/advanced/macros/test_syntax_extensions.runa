Note: Syntax Transformation Tests

Process called "test_syntax_transformation":
    Let manager be create_test_syntax_extension_manager()
    Let custom_syntax be create_test_custom_syntax_definition with name as "shorthand"
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as custom_syntax
    
    Let input_with_custom_syntax be "custom_shorthand func => String"
    Let transformation_result be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as input_with_custom_syntax
    
    assert_not_null(transformation_result, "syntax_transformation")
    assert_contains(transformation_result.transformed_code, "Process called", "syntax_transformed_correctly")

Process called "test_multi_step_transformation":
    Let manager be create_test_syntax_extension_manager()
    
    Note: Define a syntax that requires multiple transformation steps
    Let multi_step_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "multi_step"
        syntax_pattern as "async def ${name}(${params}) -> ${return_type}"
        token_definitions as list containing:
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "ASYNC"
                token_pattern as "async"
                token_type as "keyword"
                precedence as 1
                metadata as dictionary containing
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "DEF"
                token_pattern as "def"
                token_type as "keyword"
                precedence as 1
                metadata as dictionary containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "step1_async_to_process"
                source_pattern as "async def ${name}(${params}) -> ${return_type}"
                target_pattern as "async_def ${name}(${params}) -> ${return_type}"
                transformation_type as "preprocessing"
                metadata as dictionary containing
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "step2_def_to_process"
                source_pattern as "async_def ${name}(${params}) -> ${return_type}"
                target_pattern as "Process called \"${name}\" that takes ${params} returns ${return_type}"
                transformation_type as "syntax_sugar"
                metadata as dictionary containing
        metadata as dictionary containing
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as multi_step_syntax
    
    Let multi_step_input be "async def process_data(data as List[String]) -> Integer"
    Let multi_step_result be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as multi_step_input
    
    assert_not_null(multi_step_result, "multi_step_transformation")

Process called "test_conditional_transformation":
    Let manager be create_test_syntax_extension_manager()
    
    Let conditional_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "conditional_transform"
        syntax_pattern as "?${condition} : ${true_value} | ${false_value}"
        token_definitions as list containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "ternary_to_if"
                source_pattern as "?${condition} : ${true_value} | ${false_value}"
                target_pattern as "If ${condition}: ${true_value} Otherwise: ${false_value}"
                transformation_type as "conditional"
                metadata as dictionary containing:
                    "condition_check" as "validate_boolean_expression"
        metadata as dictionary containing
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as conditional_syntax
    
    Let ternary_input be "?x > 0 : \"positive\" | \"non-positive\""
    Let conditional_result be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as ternary_input
    
    assert_not_null(conditional_result, "conditional_transformation")

Note: Multi-Language Support Tests

Process called "test_python_like_syntax_extension":
    Let manager be create_test_syntax_extension_manager()
    
    Let python_syntax be SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as "python_like"
        syntax_pattern as "def ${name}(${params}):\n    ${body}"
        token_definitions as list containing:
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "DEF"
                token_pattern as "def"
                token_type as "keyword"
                precedence as 1
                metadata as dictionary containing
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "COLON"
                token_pattern as ":"
                token_type as "punctuation"
                precedence as 2
                metadata as dictionary containing
        syntax_rules as list containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as "python_to_runa"
                source_pattern as "def ${name}(${params}):\n    ${body}"
                target_pattern as "Process called \"${name}\" that takes ${params}:\n    ${body}"
                transformation_type as "language_bridge"
                metadata as dictionary containing
        metadata as dictionary containing
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as python_syntax
    
    Let python_input be "def calculate(x, y):\n    return x + y"
    Let python_transformation be SyntaxExtensions.transform_custom_syntax with 
        manager as manager 
        and input as python_input
    
    assert_not_null(python_transformation, "python_like_syntax_extension")

