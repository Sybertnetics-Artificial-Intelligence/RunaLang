Process called "test_syntax_rule_precedence":
    Let custom_syntax be create_test_custom_syntax_definition with name as "precedence_test"
    
    Let high_precedence_rule be SyntaxExtensions.SyntaxRule with:
        rule_name as "high_precedence"
        rule_pattern as "IDENTIFIER '*' IDENTIFIER"
        rule_action as "multiply"
        precedence as 10
        associativity as "left"
        metadata as dictionary containing
    
    Let low_precedence_rule be SyntaxExtensions.SyntaxRule with:
        rule_name as "low_precedence"
        rule_pattern as "IDENTIFIER '+' IDENTIFIER"
        rule_action as "add"
        precedence as 5
        associativity as "left"
        metadata as dictionary containing
    
    Add high_precedence_rule to custom_syntax.syntax_rules
    Add low_precedence_rule to custom_syntax.syntax_rules
    
    Let precedence_analysis be SyntaxExtensions.analyze_syntax_precedence with syntax as custom_syntax
    
    assert_not_null(precedence_analysis, "syntax_rule_precedence_analysis")

