Note:
Comprehensive Test Suite for Advanced Macros Syntax Extensions Module

Tests all functionality of the custom syntax extension framework including:
- Custom syntax definition and registration
- Syntax rule creation and validation
- Parser extension and modification
- Lexer customization and token handling
- Syntax transformation and normalization
- Multi-language syntax support
- Performance optimization for custom syntax
- Production-grade reliability
:End Note

Import "../../../../../../src/stdlib/advanced/macros/syntax_extensions" as SyntaxExtensions
Import "../../../../../../src/stdlib/advanced/macros/system" as MacroSystem
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration and Global Counters
Let test_count be 0
Let passed_count be 0
Let failed_count be 0
Let test_results be List[Dictionary[String, Any]] containing

Note: Test Helper Functions

Process called "assert_equal" that takes expected as Any and actual as Any and test_name as String:
    Set test_count to test_count plus 1
    If expected is equal to actual:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected: " plus expected plus ", got: " plus actual plus ")"

Process called "assert_not_null" that takes value as Any and test_name as String:
    Set test_count to test_count plus 1
    If value is not null:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "value" as value
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "value" as null
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected non-null value)"

Process called "assert_true" that takes condition as Boolean and test_name as String:
    Set test_count to test_count plus 1
    If condition:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "condition" as true
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "condition" as false
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (condition was false)"

Process called "assert_contains" that takes text as String and substring as String and test_name as String:
    Set test_count to test_count plus 1
    If text contains substring:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED ('" plus substring plus "' not found in '" plus text plus "')"

Process called "create_test_syntax_extension_manager" returns SyntaxExtensions.SyntaxExtensionManager:
    Return SyntaxExtensions.create_syntax_extension_manager()

Process called "create_test_custom_syntax_definition" that takes name as String returns SyntaxExtensions.CustomSyntaxDefinition:
    Return SyntaxExtensions.CustomSyntaxDefinition with:
        syntax_name as name
        syntax_pattern as "custom_" plus name plus " ${param1} => ${param2}"
        token_definitions as list containing:
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "CUSTOM_KEYWORD"
                token_pattern as "custom_" plus name
                token_type as "keyword"
                precedence as 1
                metadata as dictionary containing
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "ARROW"
                token_pattern as "=>"
                token_type as "operator"
                precedence as 2
                metadata as dictionary containing
        syntax_rules as list containing:
            SyntaxExtensions.SyntaxRule with:
                rule_name as name plus "_rule"
                rule_pattern as "CUSTOM_KEYWORD IDENTIFIER ARROW IDENTIFIER"
                rule_action as "transform_to_function_call"
                precedence as 1
                associativity as "left"
                metadata as dictionary containing
        transformations as list containing:
            SyntaxExtensions.SyntaxTransformation with:
                transformation_name as name plus "_transform"
                source_pattern as "custom_${name} ${param1} => ${param2}"
                target_pattern as "Process called \"${param1}\" returns ${param2}"
                transformation_type as "syntax_sugar"
                metadata as dictionary containing
        metadata as dictionary containing

Process called "create_test_lexer_extension" that takes name as String returns SyntaxExtensions.LexerExtension:
    Return SyntaxExtensions.LexerExtension with:
        extension_name as name
        extension_type as "token_recognition"
        custom_tokens as list containing:
            SyntaxExtensions.CustomTokenDefinition with:
                token_name as "CUSTOM_LITERAL_" plus name
                token_pattern as "@" plus name plus "{[^}]*}"
                token_type as "literal"
                precedence as 5
                metadata as dictionary containing
        token_handlers as dictionary containing:
            "CUSTOM_LITERAL_" plus name as "handle_custom_literal"
        metadata as dictionary containing

Process called "create_test_parser_extension" that takes name as String returns SyntaxExtensions.ParserExtension:
    Return SyntaxExtensions.ParserExtension with:
        extension_name as name
        extension_type as "grammar_extension"
        grammar_additions as list containing:
            SyntaxExtensions.GrammarAddition with:
                rule_name as name plus "_expression"
                rule_pattern as "IDENTIFIER " plus name plus "_operator IDENTIFIER"
                rule_type as "binary_expression"
                precedence as 10
                associativity as "left"
                metadata as dictionary containing
        parse_handlers as dictionary containing:
            name plus "_expression" as "parse_custom_expression"
        metadata as dictionary containing

Note: Syntax Extension Manager Core Tests

Process called "test_create_syntax_extension_manager":
    Let manager be SyntaxExtensions.create_syntax_extension_manager()
    assert_not_null(manager, "create_syntax_extension_manager")
    assert_not_null(manager.custom_syntaxes, "manager_has_custom_syntaxes")
    assert_not_null(manager.lexer_extensions, "manager_has_lexer_extensions")
    assert_not_null(manager.parser_extensions, "manager_has_parser_extensions")

Process called "test_syntax_extension_manager_configuration":
    Let config be SyntaxExtensions.SyntaxExtensionConfig with:
        enable_custom_syntax as true
        enable_lexer_extensions as true
        enable_parser_extensions as true
        enable_syntax_validation as true
        performance_mode as "high"
        metadata as dictionary containing
    
    Let manager be SyntaxExtensions.create_syntax_extension_manager_with_config with config as config
    assert_not_null(manager, "create_syntax_extension_manager_with_config")
    assert_true(manager.config.enable_custom_syntax, "manager_custom_syntax_enabled")

Process called "test_register_custom_syntax":
    Let manager be create_test_syntax_extension_manager()
    Let custom_syntax be create_test_custom_syntax_definition with name as "test_syntax"
    
    Let register_result be SyntaxExtensions.register_custom_syntax with 
        manager as manager 
        and syntax as custom_syntax
    
    assert_true(register_result, "register_custom_syntax")

Process called "test_unregister_custom_syntax":
    Let manager be create_test_syntax_extension_manager()
    Let custom_syntax be create_test_custom_syntax_definition with name as "removable_syntax"
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as custom_syntax
    
    Let unregister_result be SyntaxExtensions.unregister_custom_syntax with 
        manager as manager 
        and syntax_name as "removable_syntax"
    
    assert_true(unregister_result, "unregister_custom_syntax")

Process called "test_list_registered_syntaxes":
    Let manager be create_test_syntax_extension_manager()
    
    Let syntax1 be create_test_custom_syntax_definition with name as "syntax_1"
    Let syntax2 be create_test_custom_syntax_definition with name as "syntax_2"
    Let syntax3 be create_test_custom_syntax_definition with name as "syntax_3"
    
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as syntax1
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as syntax2
    SyntaxExtensions.register_custom_syntax with manager as manager and syntax as syntax3
    
    Let syntax_list be SyntaxExtensions.list_registered_syntaxes with manager as manager
    
    assert_not_null(syntax_list, "list_registered_syntaxes")
    assert_equal(3, length of syntax_list, "registered_syntax_count")

