                token_name as "REGEX_LITERAL"
                token_pattern as "/[^/]+/[gimuy]*"
                token_type as "literal"
                precedence as 8
                metadata as dictionary containing
        token_handlers as dictionary containing:
            "REGEX_LITERAL" as "handle_regex_literal"
        metadata as dictionary containing
    
    SyntaxExtensions.register_lexer_extension with manager as manager and extension as regex_extension
    
    Let regex_input be "let pattern = /[a-zA-Z]+/g"
    Let tokenization_result be SyntaxExtensions.tokenize_with_extensions with 
        manager as manager 
        and input as regex_input
    
