Process called "test_builtin_for_loop_macro":
    Let context be create_test_compile_time_context()
    Let var_ast be create_test_identifier_ast with name as "i"
    Let iterable_ast be create_test_ast_node with node_type as "Literal" and value as list containing 1, 2, 3
    Let body_ast be create_test_ast_node with node_type as "Block" and value as None
    
    Let result be CompileTime.builtin_for_loop_macro with context as context and args as list containing var_ast, iterable_ast, body_ast
    
    assert_not_null(result, "for_loop_macro_returns_result")
    assert_equal("ForEachStatement", result.node_type, "for_loop_returns_foreach_statement")

