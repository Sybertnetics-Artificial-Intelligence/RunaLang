Note:
Comprehensive Test Suite for Advanced Metaprogramming Compile-Time Module

Tests all functionality of the compile-time metaprogramming engine including:
- Compile-time evaluation and constant folding
- Static assertions and error reporting
- Type introspection and analysis
- Compile-time code generation
- Hygienic macro system implementation
- Macro registration and expansion
- Variable binding and hygiene
- Built-in macro functionality
- Performance benchmarks
:End Note

Import "../../../../../../src/stdlib/advanced/metaprogramming/compile_time" as CompileTime
Import "../../../../../../src/stdlib/advanced/metaprogramming/ast_manipulation" as ASTManip
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration and Global Counters
Let test_count be 0
Let passed_count be 0
Let failed_count be 0
Let test_results be List[Dictionary[String, Any]] containing

Note: Test Helper Functions

Process called "assert_equal" that takes expected as Any and actual as Any and test_name as String:
    Set test_count to test_count plus 1
    If expected is equal to actual:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected: " plus expected plus ", got: " plus actual plus ")"

Process called "assert_not_null" that takes value as Any and test_name as String:
    Set test_count to test_count plus 1
    If value is not null:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "value" as value
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "value" as null
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected non-null value)"

Process called "assert_true" that takes condition as Boolean and test_name as String:
    Set test_count to test_count plus 1
    If condition:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "condition" as true
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "condition" as false
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (condition was false)"

Process called "assert_throws" that takes test_function as Function and test_name as String:
    Set test_count to test_count plus 1
    Try:
        test_function()
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as "exception"
            "actual" as "no exception"
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected exception)"
    Catch error:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "exception" as error.message
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"

Process called "create_test_compile_time_context" returns CompileTime.CompileTimeContext:
    Return CompileTime.CompileTimeContext with:
        config as CompileTime.CompileTimeConfig with:
            enable_constant_folding as true
            enable_type_introspection as true
            enable_static_assertions as true
            enable_code_generation as true
            enable_macros as true
            ai_mode as false
            metadata as dictionary containing
        stats as CompileTime.CompileTimeStats with:
            total_evaluated as 0
            total_assertions as 0
            total_errors as 0
            total_warnings as 0
            metadata as dictionary containing
        metadata as dictionary containing

Process called "create_test_binary_operation" that takes left as Any and operator as String and right as Any returns Dictionary[String, Any]:
    Return Dictionary[String, Any] containing:
        "left" as left
        "right" as right
        "op" as operator

Process called "create_test_ast_node" that takes node_type as String and value as Any returns ASTManip.ASTNode:
    Return ASTManip.create_ast_node with:
        node_type as node_type
        value as value
        children as list containing
        position as ASTManip.Position with:
            line as 1
            column as 1
            offset as 0
            metadata as dictionary containing

Process called "create_test_identifier_ast" that takes name as String returns ASTManip.ASTNode:
    Let node be create_test_ast_node with node_type as "Identifier" and value as name
    Set node.name to name
    Return node

Process called "create_test_macro_call_ast" that takes name as String and args as List[ASTManip.ASTNode] returns ASTManip.ASTNode:
    Let node be create_test_ast_node with node_type as "MacroCall" and value as name
    Set node.name to name
    Set node.arguments to args
    Return node

Note: Compile-Time Context Tests

Process called "test_create_compile_time_context":
    Let context be create_test_compile_time_context()
    
    assert_not_null(context, "create_compile_time_context")
    assert_not_null(context.config, "context_has_config")
    assert_not_null(context.stats, "context_has_stats")
    assert_equal(true, context.config.enable_constant_folding, "constant_folding_enabled")
    assert_equal(true, context.config.enable_macros, "macros_enabled")

Process called "test_compile_time_config":
    Let config be CompileTime.CompileTimeConfig with:
        enable_constant_folding as false
        enable_type_introspection as true
        enable_static_assertions as false
        enable_code_generation as true
        enable_macros as false
        ai_mode as true
        metadata as dictionary containing
    
    assert_not_null(config, "create_compile_time_config")
    assert_equal(false, config.enable_constant_folding, "constant_folding_disabled")
    assert_equal(true, config.ai_mode, "ai_mode_enabled")

Note: Compile-Time Evaluation Tests

Process called "test_evaluate_at_compile_time_simple":
    Let context be create_test_compile_time_context()
    
    Let result be CompileTime.evaluate_at_compile_time with context as context and expr as 42
    
    assert_equal(42, result, "evaluate_simple_integer")

Process called "test_evaluate_at_compile_time_with_folding_disabled":
    Let context be create_test_compile_time_context()
    Set context.config.enable_constant_folding to false
    
    Let expr be create_test_binary_operation with left as 5 and operator as "+" and right as 3
    Let result be CompileTime.evaluate_at_compile_time with context as context and expr as expr
    
    assert_equal(expr, result, "evaluation_returns_original_when_folding_disabled")

Note: Static Assertion Tests

Process called "test_static_assert_success":
    Let context be create_test_compile_time_context()
    
    CompileTime.static_assert with context as context and condition as true and message as "This should pass"
    
    assert_equal(1, context.stats.total_assertions, "assertion_count_incremented")

Process called "test_static_assert_failure":
    Let context be create_test_compile_time_context()
    
    assert_throws(Function that:
        CompileTime.static_assert with context as context and condition as false and message as "This should fail"
    , "static_assert_throws_on_false")

Note: Constant Folding Tests

Process called "test_constant_fold_integer":
    Let context be create_test_compile_time_context()
    
    Let result be CompileTime.constant_fold with context as context and expr as 42
    
    assert_equal(42, result, "constant_fold_integer")

Process called "test_constant_fold_string":
    Let context be create_test_compile_time_context()
    
    Let result be CompileTime.constant_fold with context as context and expr as "hello"
    
    assert_equal("hello", result, "constant_fold_string")

Process called "test_constant_fold_list":
    Let context be create_test_compile_time_context()
    Let list_expr be list containing 1, 2, 3
    
    Let result be CompileTime.constant_fold with context as context and expr as list_expr
    
    assert_equal(list_expr, result, "constant_fold_list")

Process called "test_constant_fold_binary_addition":
    Let context be create_test_compile_time_context()
    Let expr be create_test_binary_operation with left as 5 and operator as "+" and right as 3
    
    Let result be CompileTime.constant_fold with context as context and expr as expr
    
    assert_equal(8, result, "constant_fold_addition")

Process called "test_constant_fold_binary_subtraction":
    Let context be create_test_compile_time_context()
    Let expr be create_test_binary_operation with left as 10 and operator as "-" and right as 4
    
    Let result be CompileTime.constant_fold with context as context and expr as expr
    
    assert_equal(6, result, "constant_fold_subtraction")

Process called "test_constant_fold_binary_multiplication":
    Let context be create_test_compile_time_context()
    Let expr be create_test_binary_operation with left as 6 and operator as "*" and right as 7
    
    Let result be CompileTime.constant_fold with context as context and expr as expr
    
    assert_equal(42, result, "constant_fold_multiplication")

Process called "test_constant_fold_binary_division":
    Let context be create_test_compile_time_context()
    Let expr be create_test_binary_operation with left as 15 and operator as "/" and right as 3
    
    Let result be CompileTime.constant_fold with context as context and expr as expr
    
    assert_equal(5, result, "constant_fold_division")

Process called "test_constant_fold_division_by_zero":
    Let context be create_test_compile_time_context()
    Let expr be create_test_binary_operation with left as 10 and operator as "/" and right as 0
    
    assert_throws(Function that:
        CompileTime.constant_fold with context as context and expr as expr
    , "constant_fold_division_by_zero_throws")

Note: Type Introspection Tests

Process called "test_type_introspect_integer":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as 42
    
    assert_equal("Integer", type_info.type_id, "integer_type_id")
    assert_equal("primitive", type_info.type_kind, "integer_type_kind")
    assert_equal(8, type_info.size, "integer_size")
    assert_equal(true, type_info.is_primitive, "integer_is_primitive")

Process called "test_type_introspect_float":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as 3.14
    
    assert_equal("Float", type_info.type_id, "float_type_id")
    assert_equal("primitive", type_info.type_kind, "float_type_kind")
    assert_equal(8, type_info.size, "float_size")

Process called "test_type_introspect_boolean":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as true
    
    assert_equal("Boolean", type_info.type_id, "boolean_type_id")
    assert_equal(1, type_info.size, "boolean_size")

Process called "test_type_introspect_string":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as "test"
    
    assert_equal("String", type_info.type_id, "string_type_id")
    assert_equal("reference", type_info.type_kind, "string_type_kind")
    assert_equal(false, type_info.is_primitive, "string_not_primitive")
    assert_equal(true, type_info.is_reference, "string_is_reference")

Process called "test_type_introspect_list":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as list containing
    
    assert_equal("List", type_info.type_id, "list_type_id")
    assert_equal("collection", type_info.type_kind, "list_type_kind")

Process called "test_type_introspect_dictionary":
    Let context be create_test_compile_time_context()
    
    Let type_info be CompileTime.type_introspect with context as context and type_info as dictionary containing
    
    assert_equal("Dictionary", type_info.type_id, "dictionary_type_id")
    assert_equal("collection", type_info.type_kind, "dictionary_type_kind")

Note: Code Generation Tests

Process called "test_generate_code_at_compile_time_string":
    Let context be create_test_compile_time_context()
    
    Let result be CompileTime.generate_code_at_compile_time with context as context and spec as "Let x be 42"
    
    assert_equal("Let x be 42", result, "generate_code_string")

Process called "test_generate_code_at_compile_time_list":
    Let context be create_test_compile_time_context()
    Let spec be list containing "Let x be 1", "Let y be 2"
    
    Let result be CompileTime.generate_code_at_compile_time with context as context and spec as spec
    
    assert_not_null(result, "generate_code_list")
    assert_true((result contains "Let x be 1"), "contains_first_line")
    assert_true((result contains "Let y be 2"), "contains_second_line")

Process called "test_generate_code_at_compile_time_template":
    Let context be create_test_compile_time_context()
    Let spec be dictionary containing:
        "template" as "Let {{name}} be {{value}}"
        "values" as dictionary containing:
            "name" as "test_var"
            "value" as "42"
    
    Let result be CompileTime.generate_code_at_compile_time with context as context and spec as spec
    
    assert_equal("Let test_var be 42", result, "generate_code_template")

Process called "test_generate_code_disabled":
    Let context be create_test_compile_time_context()
    Set context.config.enable_code_generation to false
    
    assert_throws(Function that:
        CompileTime.generate_code_at_compile_time with context as context and spec as "test"
    , "generate_code_throws_when_disabled")

Process called "test_interpolate_template":
    Let template be "Hello {{name}}, you have {{count}} messages"
    Let values be dictionary containing:
        "name" as "User"
        "count" as "5"
    
    Let result be CompileTime.interpolate_template with template as template and values as values
    
    assert_equal("Hello User, you have 5 messages", result, "interpolate_template")

Note: Macro Registry Tests

Process called "test_create_macro_registry":
    Let registry be CompileTime.create_macro_registry()
    
    assert_not_null(registry, "create_macro_registry")
    assert_not_null(registry.macros, "registry_has_macros")
    assert_not_null(registry.builtin_macros, "registry_has_builtin_macros")
    assert_true((registry.builtin_macros contains "identity"), "has_identity_macro")
    assert_true((registry.builtin_macros contains "debug_print"), "has_debug_print_macro")
    assert_equal(0, registry.hygiene_counter, "initial_hygiene_counter")

Process called "test_register_macro":
    Let registry be CompileTime.create_macro_registry()
    
    Let macro_def be CompileTime.MacroDefinition with:
        name as "test_macro"
        parameters as list containing
        body as create_test_ast_node with node_type as "Block" and value as None
        hygiene_scope as CompileTime.HygieneScope with:
            scope_id as "test_scope"
            parent_scope as None
            bound_variables as dictionary containing
            introduced_variables as list containing
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let success be CompileTime.register_macro with registry as registry and macro_def as macro_def
    
    assert_true(success, "register_macro_success")
    assert_true((registry.macros contains "test_macro"), "macro_registered")

Process called "test_register_duplicate_macro":
    Let registry be CompileTime.create_macro_registry()
    
    Let macro_def be CompileTime.MacroDefinition with:
        name as "duplicate_macro"
        parameters as list containing
        body as create_test_ast_node with node_type as "Block" and value as None
        hygiene_scope as CompileTime.HygieneScope with:
            scope_id as "test_scope"
            parent_scope as None
            bound_variables as dictionary containing
            introduced_variables as list containing
            metadata as dictionary containing
        metadata as dictionary containing
    
    CompileTime.register_macro with registry as registry and macro_def as macro_def
    Let duplicate_result be CompileTime.register_macro with registry as registry and macro_def as macro_def
    
    assert_true((not duplicate_result), "register_duplicate_macro_fails")

Note: Hygiene Scope Tests

Process called "test_create_hygiene_scope":
    Let registry be CompileTime.create_macro_registry()
    
    Let scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    
    assert_not_null(scope, "create_hygiene_scope")
    assert_not_null(scope.scope_id, "scope_has_id")
    assert_equal(None, scope.parent_scope, "no_parent_scope")
    assert_equal(1, registry.hygiene_counter, "hygiene_counter_incremented")

Process called "test_create_hygiene_scope_with_parent":
    Let registry be CompileTime.create_macro_registry()
    
    Let parent_scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    Let child_scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as parent_scope.scope_id
    
    assert_equal(parent_scope.scope_id, child_scope.parent_scope, "child_has_parent")

Process called "test_bind_variable":
    Let registry be CompileTime.create_macro_registry()
    Let scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    
    CompileTime.bind_variable with scope as scope and original_name as "x" and new_name as "x_hygienized"
    
    assert_true((scope.bound_variables contains "x"), "variable_bound")
    assert_equal("x_hygienized", scope.bound_variables["x"], "correct_binding")

Process called "test_introduce_variable":
    Let registry be CompileTime.create_macro_registry()
    Let scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    
    Let unique_name be CompileTime.introduce_variable with scope as scope and var_name as "test_var"
    
    assert_not_null(unique_name, "introduce_variable_returns_name")
    assert_true((unique_name contains "test_var"), "contains_original_name")
    assert_true((unique_name contains scope.scope_id), "contains_scope_id")
    assert_true((scope.introduced_variables contains unique_name), "variable_added_to_introduced")

Process called "test_resolve_variable_bound":
    Let registry be CompileTime.create_macro_registry()
    Let scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    
    CompileTime.bind_variable with scope as scope and original_name as "x" and new_name as "x_bound"
    
    Let resolved be CompileTime.resolve_variable with scope as scope and var_name as "x"
    
    assert_equal("x_bound", resolved, "resolve_bound_variable")

Process called "test_resolve_variable_unbound":
    Let registry be CompileTime.create_macro_registry()
    Let scope be CompileTime.create_hygiene_scope with registry as registry and parent_scope as None
    
    Let resolved be CompileTime.resolve_variable with scope as scope and var_name as "unbound_var"
    
    assert_equal("unbound_var", resolved, "resolve_unbound_variable_returns_original")

Note: Built-in Macro Tests

Process called "test_builtin_identity_macro":
    Let context be create_test_compile_time_context()
    Let arg be create_test_ast_node with node_type as "Literal" and value as 42
    
    Let result be CompileTime.builtin_identity_macro with context as context and args as list containing arg
    
    assert_not_null(result, "identity_macro_returns_result")
    assert_equal(arg.node_type, result.node_type, "identity_preserves_node_type")
    assert_equal(arg.value, result.value, "identity_preserves_value")

Process called "test_builtin_identity_macro_wrong_args":
    Let context be create_test_compile_time_context()
    
    assert_throws(Function that:
        CompileTime.builtin_identity_macro with context as context and args as list containing
    , "identity_macro_throws_on_empty_args")

