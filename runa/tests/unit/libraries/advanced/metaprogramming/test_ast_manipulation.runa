Note:
Comprehensive Test Suite for Advanced Metaprogramming AST Manipulation Module

Tests all functionality of the AST manipulation engine including:
- AST node creation and construction
- Tree traversal and transformation
- Pattern matching and rewriting
- AST annotation and metadata
- Validation and verification
- Diffing and merging
- Deep copying and immutability
- Performance benchmarks
:End Note

Import "../../../../../../src/stdlib/advanced/metaprogramming/ast_manipulation" as ASTManip
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration and Global Counters
Let test_count be 0
Let passed_count be 0
Let failed_count be 0
Let test_results be List[Dictionary[String, Any]] containing

Note: Test Helper Functions

Process called "assert_equal" that takes expected as Any and actual as Any and test_name as String:
    Set test_count to test_count plus 1
    If expected is equal to actual:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected: " plus expected plus ", got: " plus actual plus ")"

Process called "assert_not_null" that takes value as Any and test_name as String:
    Set test_count to test_count plus 1
    If value is not null:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "value" as value
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "value" as null
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected non-null value)"

Process called "assert_true" that takes condition as Boolean and test_name as String:
    Set test_count to test_count plus 1
    If condition:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "condition" as true
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "condition" as false
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (condition was false)"

Process called "create_test_position" returns ASTManip.Position:
    Return ASTManip.Position with:
        line as 1
        column as 1
        offset as 0
        metadata as dictionary containing

Process called "create_test_annotation" that takes annotation_type as String returns ASTManip.Annotation:
    Return ASTManip.Annotation with:
        annotation_type as annotation_type
        value as "test_value"
        metadata as dictionary containing

Process called "create_simple_ast_node" that takes node_type as String returns ASTManip.ASTNode:
    Return ASTManip.create_ast_node with:
        node_type as node_type
        value as "test_value"
        children as list containing
        position as create_test_position()

Process called "create_complex_ast_tree" returns ASTManip.ASTNode:
    Let leaf1 be create_simple_ast_node with node_type as "leaf1"
    Let leaf2 be create_simple_ast_node with node_type as "leaf2"
    Let branch1 be ASTManip.create_ast_node with:
        node_type as "branch1"
        value as "branch_value"
        children as list containing leaf1, leaf2
        position as create_test_position()
    
    Let root be ASTManip.create_ast_node with:
        node_type as "root"
        value as "root_value"
        children as list containing branch1
        position as create_test_position()
    
    Return root

Note: AST Node Creation Tests

Process called "test_create_ast_node":
    Let node be ASTManip.create_ast_node with:
        node_type as "test_node"
        value as "test_value"
        children as list containing
        position as create_test_position()
    
    assert_not_null(node, "create_ast_node")
    assert_equal("test_node", node.node_type, "node_type_correct")
    assert_equal("test_value", node.value, "node_value_correct")
    assert_equal(0, length of node.children, "children_empty")
    assert_not_null(node.position, "position_set")
    assert_not_null(node.annotations, "annotations_list_exists")
    assert_not_null(node.metadata, "metadata_dict_exists")

Process called "test_create_ast_node_with_children":
    Let child1 be create_simple_ast_node with node_type as "child1"
    Let child2 be create_simple_ast_node with node_type as "child2"
    
    Let parent be ASTManip.create_ast_node with:
        node_type as "parent"
        value as "parent_value"
        children as list containing child1, child2
        position as create_test_position()
    
    assert_not_null(parent, "create_parent_node")
    assert_equal(2, length of parent.children, "correct_children_count")
    assert_equal("child1", parent.children[0].node_type, "first_child_correct")
    assert_equal("child2", parent.children[1].node_type, "second_child_correct")

Process called "test_create_immutable_ast_node":
    Let node be ASTManip.create_immutable_ast_node with:
        node_type as "immutable_test"
        value as "immutable_value"
        children as list containing
        position as create_test_position()
        annotations as list containing
        metadata as dictionary containing

    assert_not_null(node, "create_immutable_ast_node")
    assert_equal("immutable_test", node.node_type, "immutable_node_type")
    assert_equal("immutable_value", node.value, "immutable_node_value")

Note: AST Traversal Tests

Process called "test_traverse_ast_simple":
    Let node be create_simple_ast_node with node_type as "traverse_test"
    Let visited_nodes be list containing
    
    Let visitor be Function that takes node as ASTManip.ASTNode:
        Add node.node_type to visited_nodes
    
    ASTManip.traverse_ast with node as node and visitor as visitor
    
    assert_equal(1, length of visited_nodes, "single_node_visited")
    assert_equal("traverse_test", visited_nodes[0], "correct_node_visited")

Process called "test_traverse_ast_complex":
    Let tree be create_complex_ast_tree()
    Let visited_nodes be list containing
    
    Let visitor be Function that takes node as ASTManip.ASTNode:
        Add node.node_type to visited_nodes
    
    ASTManip.traverse_ast with node as tree and visitor as visitor
    
    assert_equal(4, length of visited_nodes, "all_nodes_visited")
    assert_equal("root", visited_nodes[0], "root_visited_first")
    assert_equal("branch1", visited_nodes[1], "branch_visited_second")

Process called "test_traverse_ast_with_depth_tracking":
    Let tree be create_complex_ast_tree()
    Let depth_map be dictionary containing
    Let current_depth be 0
    
    Let depth_visitor be Function that takes node as ASTManip.ASTNode:
        Set depth_map[node.node_type] to current_depth
        Set current_depth to current_depth plus 1
    
    ASTManip.traverse_ast with node as tree and visitor as depth_visitor
    
    assert_true((depth_map contains "root"), "root_depth_tracked")
    assert_true((depth_map contains "branch1"), "branch_depth_tracked")

Note: AST Transformation Tests

Process called "test_transform_ast_simple":
    Let node be create_simple_ast_node with node_type as "original"
    
    Let transformer be Function that takes node as ASTManip.ASTNode returns ASTManip.ASTNode:
        Return ASTManip.create_ast_node with:
            node_type as "transformed"
            value as node.value
            children as node.children
            position as node.position
    
    Let transformed be ASTManip.transform_ast with node as node and transformer as transformer
    
    assert_not_null(transformed, "transform_ast_simple")
    assert_equal("transformed", transformed.node_type, "node_type_transformed")

Process called "test_transform_ast_preserve_structure":
    Let tree be create_complex_ast_tree()
    
    Let value_transformer be Function that takes node as ASTManip.ASTNode returns ASTManip.ASTNode:
        Return ASTManip.create_ast_node with:
            node_type as node.node_type
            value as "transformed_" plus node.value
            children as node.children
            position as node.position
    
    Let transformed_tree be ASTManip.transform_ast with node as tree and transformer as value_transformer
    
    assert_not_null(transformed_tree, "transform_preserves_structure")
    assert_equal("root", transformed_tree.node_type, "root_type_preserved")
    assert_equal("transformed_root_value", transformed_tree.value, "root_value_transformed")
    assert_equal(1, length of transformed_tree.children, "children_count_preserved")

Process called "test_transform_ast_recursive":
    Let tree be create_complex_ast_tree()
    
    Let recursive_transformer be Function that takes node as ASTManip.ASTNode returns ASTManip.ASTNode:
        If node.node_type is equal to "leaf1" or node.node_type is equal to "leaf2":
            Return ASTManip.create_ast_node with:
                node_type as "transformed_leaf"
                value as "new_leaf_value"
                children as list containing
                position as node.position
        Return node
    
    Let transformed_tree be ASTManip.transform_ast with node as tree and transformer as recursive_transformer
    
    assert_not_null(transformed_tree, "recursive_transform")
    Let leaf_node be transformed_tree.children[0].children[0]
    assert_equal("transformed_leaf", leaf_node.node_type, "leaf_transformed")

