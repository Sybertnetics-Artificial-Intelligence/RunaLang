    assert_not_null(pattern, "create_ast_pattern")
    assert_equal("test_pattern", pattern.pattern_type, "pattern_type_correct")

Process called "test_match_ast_pattern_simple":
    Let node be create_simple_ast_node with node_type as "match_test"
    Let pattern be ASTManip.ASTPattern with:
        pattern_type as "match_test"
        value as None
        children as list containing
        metadata as dictionary containing
    
    Let match_result be ASTManip.match_ast_pattern with node as node and pattern as pattern
    assert_true(match_result, "simple_pattern_match")

Process called "test_match_ast_pattern_value_mismatch":
    Let node be create_simple_ast_node with node_type as "match_test"
    Let pattern be ASTManip.ASTPattern with:
        pattern_type as "match_test"
        value as "different_value"
        children as list containing
        metadata as dictionary containing
    
    Let match_result be ASTManip.match_ast_pattern with node as node and pattern as pattern
    assert_true((not match_result), "value_mismatch_fails")

Process called "test_match_ast_pattern_complex":
    Let tree be create_complex_ast_tree()
    Let child_pattern be ASTManip.ASTPattern with:
        pattern_type as "branch1"
        value as None
        children as list containing
        metadata as dictionary containing
    
    Let root_pattern be ASTManip.ASTPattern with:
        pattern_type as "root"
        value as None
        children as list containing child_pattern
        metadata as dictionary containing
    
    Let match_result be ASTManip.match_ast_pattern with node as tree and pattern as root_pattern
    assert_true(match_result, "complex_pattern_match")

Note: AST Rewriting Tests

Process called "test_create_rewrite_rule":
    Let pattern be ASTManip.ASTPattern with:
        pattern_type as "old_type"
        value as None
        children as list containing
        metadata as dictionary containing
    
    Let replacement be create_simple_ast_node with node_type as "new_type"
    
    Let rule be ASTManip.RewriteRule with:
        rule_id as "test_rule"
        pattern as pattern
        replacement as replacement
        conditions as list containing
        metadata as dictionary containing
    
    assert_not_null(rule, "create_rewrite_rule")
    assert_equal("test_rule", rule.rule_id, "rule_id_correct")

Process called "test_rewrite_ast_simple":
    Let node be create_simple_ast_node with node_type as "old_type"
    
    Let pattern be ASTManip.ASTPattern with:
        pattern_type as "old_type"
        value as None
        children as list containing
        metadata as dictionary containing
    
    Let replacement be create_simple_ast_node with node_type as "new_type"
    
    Let rule be ASTManip.RewriteRule with:
        rule_id as "rewrite_test"
        pattern as pattern
        replacement as replacement
        conditions as list containing
        metadata as dictionary containing
    
    Let rewritten be ASTManip.rewrite_ast with node as node and rules as list containing rule
    
    assert_not_null(rewritten, "rewrite_ast_simple")
    assert_equal("new_type", rewritten.node_type, "node_type_rewritten")

Process called "test_rewrite_ast_no_match":
    Let node be create_simple_ast_node with node_type as "no_match"
    
    Let pattern be ASTManip.ASTPattern with:
        pattern_type as "different_type"
        value as None
        children as list containing
        metadata as dictionary containing
    
    Let replacement be create_simple_ast_node with node_type as "new_type"
    
    Let rule be ASTManip.RewriteRule with:
        rule_id as "no_match_test"
        pattern as pattern
        replacement as replacement
        conditions as list containing
        metadata as dictionary containing
    
    Let rewritten be ASTManip.rewrite_ast with node as node and rules as list containing rule
    
    assert_equal("no_match", rewritten.node_type, "no_rewrite_when_no_match")

Note: AST Annotation Tests

Process called "test_annotate_ast_node":
    Let node be create_simple_ast_node with node_type as "annotate_test"
    Let annotation be create_test_annotation with annotation_type as "test_annotation"
    
    Let annotated_node be ASTManip.annotate_ast_node with node as node and annotation as annotation
    
    assert_not_null(annotated_node, "annotate_ast_node")
    assert_equal(1, length of annotated_node.annotations, "annotation_added")
    assert_equal("test_annotation", annotated_node.annotations[0].annotation_type, "correct_annotation_type")

Process called "test_multiple_annotations":
    Let node be create_simple_ast_node with node_type as "multi_annotate_test"
    Let annotation1 be create_test_annotation with annotation_type as "annotation1"
    Let annotation2 be create_test_annotation with annotation_type as "annotation2"
    
    Let annotated_node be ASTManip.annotate_ast_node with node as node and annotation as annotation1
    Set annotated_node to ASTManip.annotate_ast_node with node as annotated_node and annotation as annotation2
    
    assert_equal(2, length of annotated_node.annotations, "multiple_annotations_added")

