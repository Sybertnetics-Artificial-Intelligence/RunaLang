    Let node be create_simple_ast_node with node_type as "valid_test"
    Let validation_result be ASTManip.validate_ast with node as node
    assert_true(validation_result, "valid_ast_passes_validation")

Process called "test_validate_ast_invalid_null_type":
    Let invalid_node be ASTManip.ASTNode with:
        node_type as null
        value as "test"
        children as list containing
        position as create_test_position()
        annotations as list containing
        metadata as dictionary containing
    
    Let validation_result be ASTManip.validate_ast with node as invalid_node
    assert_true((not validation_result), "null_type_fails_validation")

Process called "test_validate_ast_complex_tree":
    Let tree be create_complex_ast_tree()
    Let validation_result be ASTManip.validate_ast with node as tree
    assert_true(validation_result, "complex_tree_validates")

Note: AST Diffing Tests

Process called "test_diff_ast_identical":
    Let node1 be create_simple_ast_node with node_type as "identical"
    Let node2 be create_simple_ast_node with node_type as "identical"
    
    Let diff_result be ASTManip.diff_ast with node1 as node1 and node2 as node2
    
    assert_not_null(diff_result, "diff_ast_identical")
    assert_equal(0, length of diff_result.differences, "no_differences_for_identical")

Process called "test_diff_ast_type_difference":
    Let node1 be create_simple_ast_node with node_type as "type1"
    Let node2 be create_simple_ast_node with node_type as "type2"
    
    Let diff_result be ASTManip.diff_ast with node1 as node1 and node2 as node2
    
    assert_not_null(diff_result, "diff_ast_type_difference")
    assert_true((length of diff_result.differences is greater than 0), "type_difference_detected")
    assert_equal("type_or_value", diff_result.differences[0].diff_type, "correct_diff_type")

Process called "test_diff_ast_children_count":
    Let node1 be create_simple_ast_node with node_type as "parent"
    Let child be create_simple_ast_node with node_type as "child"
    Let node2 be ASTManip.create_ast_node with:
        node_type as "parent"
        value as "test_value"
        children as list containing child
        position as create_test_position()
    
    Let diff_result be ASTManip.diff_ast with node1 as node1 and node2 as node2
    
    assert_true((length of diff_result.differences is greater than 0), "children_count_difference_detected")

Note: AST Merging Tests

Process called "test_merge_ast_simple":
    Let node1 be create_simple_ast_node with node_type as "base"
    Let node2 be create_simple_ast_node with node_type as "other"
    
    Let merged be ASTManip.merge_ast with base as node1 and other as node2
    
    assert_not_null(merged, "merge_ast_simple")
    assert_equal("base", merged.node_type, "base_type_preserved")

Process called "test_merge_ast_children":
    Let child1 be create_simple_ast_node with node_type as "child1"
    Let child2 be create_simple_ast_node with node_type as "child2"
    
    Let base be ASTManip.create_ast_node with:
        node_type as "base"
        value as "base_value"
        children as list containing child1
        position as create_test_position()
    
    Let other be ASTManip.create_ast_node with:
        node_type as "other"
        value as "other_value"
        children as list containing child2
        position as create_test_position()
    
    Let merged be ASTManip.merge_ast with base as base and other as other
    
    assert_equal(2, length of merged.children, "children_merged")

Note: Deep Copy Tests

Process called "test_deep_copy_ast_node":
    Let original be create_complex_ast_tree()
    Let copied be ASTManip.deep_copy_ast_node with node as original
    
    assert_not_null(copied, "deep_copy_created")
    assert_equal(original.node_type, copied.node_type, "type_copied")
    assert_equal(original.value, copied.value, "value_copied")
    assert_equal(length of original.children, length of copied.children, "children_count_copied")

Process called "test_deep_copy_independence":
    Let original be create_simple_ast_node with node_type as "original"
    Let copied be ASTManip.deep_copy_ast_node with node as original
    
    Note: Modify original to test independence
    Set original.value to "modified"
    
    assert_equal("test_value", copied.value, "copy_remains_unchanged")

Process called "test_copy_position":
    Let original_position be ASTManip.Position with:
        line as 5
        column as 10
        offset as 50
        metadata as dictionary containing "test" as "value"
    
    Let copied_position be ASTManip.copy_position with position as original_position
    
    assert_equal(5, copied_position.line, "line_copied")
    assert_equal(10, copied_position.column, "column_copied")
    assert_equal(50, copied_position.offset, "offset_copied")

Process called "test_copy_annotation":
    Let original_annotation be ASTManip.Annotation with:
        annotation_type as "test_type"
        value as "test_value"
        metadata as dictionary containing "key" as "value"
    
    Let copied_annotation be ASTManip.copy_annotation with annotation as original_annotation
    
    assert_equal("test_type", copied_annotation.annotation_type, "annotation_type_copied")
    assert_equal("test_value", copied_annotation.value, "annotation_value_copied")

Note: Update AST Node Tests

Process called "test_update_ast_node_type":
    Let original be create_simple_ast_node with node_type as "original"
    
    Let updated be ASTManip.update_ast_node with:
        node as original
        node_type as "updated"
        value as None
        children as None
        annotations as None
        metadata as None
    
    assert_equal("updated", updated.node_type, "node_type_updated")
    assert_equal(original.value, updated.value, "other_fields_preserved")

Process called "test_update_ast_node_multiple_fields":
    Let original be create_simple_ast_node with node_type as "original"
    Let new_annotation be create_test_annotation with annotation_type as "new_annotation"
    
    Let updated be ASTManip.update_ast_node with:
        node as original
        node_type as "updated_type"
        value as "updated_value"
        children as None
        annotations as list containing new_annotation
        metadata as None
    
    assert_equal("updated_type", updated.node_type, "type_updated")
    assert_equal("updated_value", updated.value, "value_updated")
    assert_equal(1, length of updated.annotations, "annotations_updated")

Note: Performance Benchmark Tests

Process called "test_traversal_performance":
    Let large_tree be create_large_ast_tree(100)
    Let node_count be 0
    
    Let counting_visitor be Function that takes node as ASTManip.ASTNode:
        Set node_count to node_count plus 1
    
    Let start_time be Common.get_current_time()
    ASTManip.traverse_ast with node as large_tree and visitor as counting_visitor
    Let end_time be Common.get_current_time()
    
    Let traversal_time be end_time minus start_time
    assert_true((traversal_time is less than 100.0), "traversal_performance_acceptable")
    Display message "    Traversed " plus node_count plus " nodes in " plus traversal_time plus "ms"

Process called "test_transformation_performance":
    Let large_tree be create_large_ast_tree(50)
    
    Let identity_transformer be Function that takes node as ASTManip.ASTNode returns ASTManip.ASTNode:
        Return node
    
    Let start_time be Common.get_current_time()
    Let transformed be ASTManip.transform_ast with node as large_tree and transformer as identity_transformer
    Let end_time be Common.get_current_time()
    
    Let transformation_time be end_time minus start_time
    assert_true((transformation_time is less than 200.0), "transformation_performance_acceptable")
    Display message "    Transformed large tree in " plus transformation_time plus "ms"

Process called "test_deep_copy_performance":
    Let large_tree be create_large_ast_tree(50)
    
    Let start_time be Common.get_current_time()
    Let copied be ASTManip.deep_copy_ast_node with node as large_tree
    Let end_time be Common.get_current_time()
    
    Let copy_time be end_time minus start_time
    assert_true((copy_time is less than 150.0), "deep_copy_performance_acceptable")
    Display message "    Deep copied large tree in " plus copy_time plus "ms"

Note: Helper Functions

Process called "create_large_ast_tree" that takes depth as Integer returns ASTManip.ASTNode:
    If depth is less than or equal to 0:
        Return create_simple_ast_node with node_type as "leaf"
    
    Let left_child be create_large_ast_tree with depth as (depth minus 1)
    Let right_child be create_large_ast_tree with depth as (depth minus 1)
    
    Return ASTManip.create_ast_node with:
        node_type as "branch_" plus depth
        value as "value_" plus depth
        children as list containing left_child, right_child
        position as create_test_position()

Note: Master Test Runner

Process called "run_all_ast_manipulation_tests":
