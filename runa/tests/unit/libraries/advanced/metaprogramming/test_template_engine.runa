Note: Integration Tests

Process called "test_full_template_workflow":
    Let engine be create_test_template_engine()
    
    Note: Create base layout template
    Let base_layout be create_simple_template with:
        template_id as "layout"
        template_code as "<!DOCTYPE html>\n<html>\n<head><title>{{title}}</title></head>\n<body>{{content}}</body>\n</html>"
    
    Note: Create page template with inheritance
    Let variables be list containing:
        create_template_variable with name as "title" and variable_type as "String" and default_value as "Default Title"
        create_template_variable with name as "name" and variable_type as "String" and default_value as "User"
    
    Let page_template be create_template_with_variables with:
        template_id as "welcome_page"
        template_code as "<h1>Welcome, {{name}}!</h1>\n<p>This is the welcome page.</p>"
        variables as variables
    
    Set page_template.parent to "layout"
    
    Note: Register templates
    TemplateEngine.register_template with engine as engine and template as base_layout
    TemplateEngine.register_template with engine as engine and template as page_template
    
    Note: Render with context
    Let context be dictionary containing:
        "title" as "Welcome Page"
        "name" as "Alice"
    
    Let rendered be TemplateEngine.render_template with:
        engine as engine
        template_id as "welcome_page"
        context as context
    
    assert_contains(rendered, "<!DOCTYPE html>", "workflow_contains_doctype")
    assert_contains(rendered, "<title>Welcome Page</title>", "workflow_contains_title")
    assert_contains(rendered, "<h1>Welcome, Alice!</h1>", "workflow_contains_personalized_greeting")
    assert_contains(rendered, "</html>", "workflow_contains_closing_html")

Process called "test_complex_template_with_all_features":
    Let engine be create_test_template_engine()
    
    Note: Create header partial
    Let header_partial be create_simple_template with:
        template_id as "header"
        template_code as "<header><h1>{{site_name}}</h1></header>"
    
    Note: Create main template with control flow
    Let main_template_code be "{{header}}\n<main>\n{{#if show_welcome}}\n<p>Welcome, {{user_name}}!</p>\n{{/if}}\n<ul>\n{{#for item in menu_items}}\n<li>{{item}}</li>\n{{/for}}\n</ul>\n</main>"
    
    Let variables be list containing:
        create_template_variable with name as "site_name" and variable_type as "String" and default_value as "My Site"
        create_template_variable with name as "user_name" and variable_type as "String" and default_value as "Guest"
        create_template_variable with name as "show_welcome" and variable_type as "Boolean" and default_value as true
    
    Let main_template be create_template_with_variables with:
        template_id as "complex_main"
        template_code as main_template_code
        variables as variables
    
    Note: Register templates
    TemplateEngine.register_template with engine as engine and template as header_partial
    TemplateEngine.register_template with engine as engine and template as main_template
    
    Note: Render with complex context
    Let context be dictionary containing:
        "site_name" as "Advanced Site"
        "user_name" as "Bob"
        "show_welcome" as true
        "menu_items" as list containing "Home", "About", "Contact"
    
    Let rendered be TemplateEngine.render_template with:
        engine as engine
        template_id as "complex_main"
        context as context
    
    assert_contains(rendered, "Advanced Site", "complex_contains_site_name")
    assert_contains(rendered, "Welcome, Bob!", "complex_contains_welcome")
    assert_contains(rendered, "<li>Home</li>", "complex_contains_menu_items")
    assert_contains(rendered, "<li>Contact</li>", "complex_contains_last_menu_item")

Note: Performance Benchmark Tests

Process called "test_template_rendering_performance":
    Let engine be create_test_template_engine()
    
    Let variables be list containing:
        create_template_variable with name as "title" and variable_type as "String" and default_value as "Default"
        create_template_variable with name as "content" and variable_type as "String" and default_value as "Default Content"
    
    Let template be create_template_with_variables with:
        template_id as "performance_test"
        template_code as "<html><head><title>{{title}}</title></head><body><h1>{{title}}</h1><p>{{content}}</p></body></html>"
        variables as variables
    
    TemplateEngine.register_template with engine as engine and template as template
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 1000:
        Let context be dictionary containing:
            "title" as "Page " plus i
            "content" as "Content for page " plus i
        TemplateEngine.render_template with:
            engine as engine
            template_id as "performance_test"
            context as context
    
    Let end_time be Common.get_current_time()
    Let rendering_time be end_time minus start_time
    
    assert_true((rendering_time is less than 300.0), "template_rendering_performance_acceptable")
    assert_equal(1000, engine.stats.total_rendered, "performance_test_render_count")
    Display message "    Rendered 1000 templates in " plus rendering_time plus "ms"

Process called "test_control_flow_performance":
    Let template_code be "{{#if show_items}}\n{{#for item in items}}\nItem {{item}}: processed\n{{/for}}\n{{/if}}"
    Let template be create_simple_template with:
        template_id as "control_flow_perf"
        template_code as template_code
    
    Let items be list containing
    For i from 1 to 50:
        Add "item_" plus i to items
    
    Let context be dictionary containing:
        "show_items" as true
        "items" as items
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 100:
        TemplateEngine.render_with_control_flow with template as template and context as context
    
    Let end_time be Common.get_current_time()
    Let control_flow_time be end_time minus start_time
    
    assert_true((control_flow_time is less than 200.0), "control_flow_performance_acceptable")
    Display message "    Rendered 100 control flow templates in " plus control_flow_time plus "ms"

Process called "test_template_registration_performance":
    Let engine be create_test_template_engine()
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 500:
        Let template be create_simple_template with:
            template_id as "template_" plus i
            template_code as "Template " plus i plus " content"
        TemplateEngine.register_template with engine as engine and template as template
    
    Let end_time be Common.get_current_time()
    Let registration_time be end_time minus start_time
    
    assert_true((registration_time is less than 100.0), "template_registration_performance_acceptable")
    assert_equal(500, length of engine.templates, "all_templates_registered")
    Display message "    Registered 500 templates in " plus registration_time plus "ms"

