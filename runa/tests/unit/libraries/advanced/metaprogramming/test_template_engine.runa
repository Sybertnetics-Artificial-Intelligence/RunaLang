Note:
Comprehensive Test Suite for Advanced Metaprogramming Template Engine Module

Tests all functionality of the template engine including:
- Template engine creation and configuration
- Template registration and management
- Template rendering with variable interpolation
- Control flow (if/else, loops)
- Partial templates and inclusion
- Macro definition and rendering
- Template inheritance
- Error handling and validation
- Performance benchmarks
:End Note

Import "../../../../../../src/stdlib/advanced/metaprogramming/template_engine" as TemplateEngine
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Test Configuration and Global Counters
Let test_count be 0
Let passed_count be 0
Let failed_count be 0
Let test_results be List[Dictionary[String, Any]] containing

Note: Test Helper Functions

Process called "assert_equal" that takes expected as Any and actual as Any and test_name as String:
    Set test_count to test_count plus 1
    If expected is equal to actual:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as expected
            "actual" as actual
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected: " plus expected plus ", got: " plus actual plus ")"

Process called "assert_not_null" that takes value as Any and test_name as String:
    Set test_count to test_count plus 1
    If value is not null:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "value" as value
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "value" as null
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected non-null value)"

Process called "assert_true" that takes condition as Boolean and test_name as String:
    Set test_count to test_count plus 1
    If condition:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "condition" as true
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "condition" as false
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (condition was false)"

Process called "assert_contains" that takes text as String and substring as String and test_name as String:
    Set test_count to test_count plus 1
    If text contains substring:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"
    Otherwise:
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "text" as text
            "substring" as substring
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (text does not contain substring)"

Process called "assert_throws" that takes test_function as Function and test_name as String:
    Set test_count to test_count plus 1
    Try:
        test_function()
        Set failed_count to failed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "FAILED"
            "expected" as "exception"
            "actual" as "no exception"
        to test_results
        Display message "  ✗ " plus test_name plus " - FAILED (expected exception)"
    Catch error:
        Set passed_count to passed_count plus 1
        Add Dictionary[String, Any] containing:
            "test" as test_name
            "status" as "PASSED"
            "exception" as error.message
        to test_results
        Display message "  ✓ " plus test_name plus " - PASSED"

Process called "create_test_template_engine" returns TemplateEngine.TemplateEngine:
    Return TemplateEngine.TemplateEngine with:
        config as TemplateEngine.TemplateEngineConfig with:
            enable_inheritance as true
            enable_macros as true
            enable_partials as true
            enable_control_flow as true
            ai_mode as false
            metadata as dictionary containing
        templates as dictionary containing
        renderers as dictionary containing "default" as TemplateEngine.default_template_renderer
        stats as TemplateEngine.TemplateEngineStats with:
            total_rendered as 0
            total_errors as 0
            metadata as dictionary containing
        metadata as dictionary containing

Process called "create_simple_template" that takes template_id as String and template_code as String returns TemplateEngine.Template:
    Return TemplateEngine.Template with:
        template_id as template_id
        template_type as "default"
        template_code as template_code
        variables as list containing
        partials as list containing
        macros as list containing
        parent as None
        metadata as dictionary containing

Process called "create_template_with_variables" that takes template_id as String and template_code as String and variables as List[TemplateEngine.TemplateVariable] returns TemplateEngine.Template:
    Return TemplateEngine.Template with:
        template_id as template_id
        template_type as "default"
        template_code as template_code
        variables as variables
        partials as list containing
        macros as list containing
        parent as None
        metadata as dictionary containing

Process called "create_template_variable" that takes name as String and variable_type as String and default_value as Any returns TemplateEngine.TemplateVariable:
    Return TemplateEngine.TemplateVariable with:
        name as name
        variable_type as variable_type
        default_value as default_value
        metadata as dictionary containing

Note: Template Engine Configuration Tests

Process called "test_create_template_engine":
    Let engine be create_test_template_engine()
    
    assert_not_null(engine, "create_template_engine")
    assert_not_null(engine.config, "engine_has_config")
    assert_not_null(engine.templates, "engine_has_templates")
    assert_not_null(engine.renderers, "engine_has_renderers")
    assert_not_null(engine.stats, "engine_has_stats")
    assert_equal(true, engine.config.enable_inheritance, "inheritance_enabled")
    assert_equal(true, engine.config.enable_macros, "macros_enabled")

Process called "test_template_engine_config":
    Let config be TemplateEngine.TemplateEngineConfig with:
        enable_inheritance as false
        enable_macros as true
        enable_partials as false
        enable_control_flow as true
        ai_mode as true
        metadata as dictionary containing
    
    assert_not_null(config, "create_template_engine_config")
    assert_equal(false, config.enable_inheritance, "inheritance_disabled")
    assert_equal(true, config.ai_mode, "ai_mode_enabled")

Process called "test_template_engine_stats":
    Let stats be TemplateEngine.TemplateEngineStats with:
        total_rendered as 10
        total_errors as 2
        metadata as dictionary containing
    
    assert_not_null(stats, "create_template_engine_stats")
    assert_equal(10, stats.total_rendered, "rendered_count")
    assert_equal(2, stats.total_errors, "error_count")

Note: Template Creation Tests

Process called "test_create_simple_template":
    Let template be create_simple_template with:
        template_id as "test_template"
        template_code as "Hello, World!"
    
    assert_not_null(template, "create_simple_template")
    assert_equal("test_template", template.template_id, "template_id_correct")
    assert_equal("Hello, World!", template.template_code, "template_code_correct")
    assert_equal("default", template.template_type, "template_type_default")

Process called "test_create_template_with_variables":
    Let variables be list containing:
        create_template_variable with name as "name" and variable_type as "String" and default_value as "World"
        create_template_variable with name as "count" and variable_type as "Integer" and default_value as 0
    
    Let template be create_template_with_variables with:
        template_id as "variable_template"
        template_code as "Hello, {{name}}! Count: {{count}}"
        variables as variables
    
    assert_not_null(template, "create_template_with_variables")
    assert_equal(2, length of template.variables, "correct_variable_count")
    assert_equal("name", template.variables[0].name, "first_variable_name")
    assert_equal("count", template.variables[1].name, "second_variable_name")

Process called "test_template_variable_creation":
    Let variable be create_template_variable with:
        name as "test_var"
        variable_type as "String"
        default_value as "default_value"
    
    assert_not_null(variable, "create_template_variable")
    assert_equal("test_var", variable.name, "variable_name")
    assert_equal("String", variable.variable_type, "variable_type")
    assert_equal("default_value", variable.default_value, "variable_default_value")

Note: Template Registration Tests

Process called "test_register_template":
    Let engine be create_test_template_engine()
    Let template be create_simple_template with:
        template_id as "register_test"
        template_code as "Test template"
    
    Let success be TemplateEngine.register_template with engine as engine and template as template
    
    assert_true(success, "register_template_success")
    assert_true((engine.templates contains "register_test"), "template_registered")

Process called "test_register_multiple_templates":
    Let engine be create_test_template_engine()
    Let template1 be create_simple_template with:
        template_id as "template1"
        template_code as "Template 1"
    Let template2 be create_simple_template with:
        template_id as "template2"
        template_code as "Template 2"
    
    TemplateEngine.register_template with engine as engine and template as template1
    TemplateEngine.register_template with engine as engine and template as template2
    
    assert_equal(2, length of engine.templates, "multiple_templates_registered")
    assert_true((engine.templates contains "template1"), "template1_registered")
    assert_true((engine.templates contains "template2"), "template2_registered")

