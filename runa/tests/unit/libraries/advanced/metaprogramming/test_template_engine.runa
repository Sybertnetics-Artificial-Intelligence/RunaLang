Note: Template Inheritance Tests

Process called "test_template_inheritance":
    Let engine be create_test_template_engine()
    
    Let parent_template be create_simple_template with:
        template_id as "base_layout"
        template_code as "<html><body>{{content}}</body></html>"
    
    Let child_template be create_simple_template with:
        template_id as "page"
        template_code as "<h1>Page Content</h1>"
    
    Set child_template.parent to "base_layout"
    
    TemplateEngine.register_template with engine as engine and template as parent_template
    TemplateEngine.register_template with engine as engine and template as child_template
    
    Let rendered be TemplateEngine.render_template with:
        engine as engine
        template_id as "page"
        context as dictionary containing
    
    assert_contains(rendered, "<html><body>", "inheritance_contains_parent_structure")
    assert_contains(rendered, "<h1>Page Content</h1>", "inheritance_contains_child_content")

Note: Control Flow Tests

Process called "test_render_with_control_flow_if":
    Let template_code be "{{#if show_greeting}}\nHello, World!\n{{/if}}"
    Let template be create_simple_template with:
        template_id as "if_test"
        template_code as template_code
    
    Let context_true be dictionary containing "show_greeting" as true
    Let context_false be dictionary containing "show_greeting" as false
    
    Let rendered_true be TemplateEngine.render_with_control_flow with template as template and context as context_true
    Let rendered_false be TemplateEngine.render_with_control_flow with template as template and context as context_false
    
    assert_contains(rendered_true, "Hello, World!", "if_true_renders_content")
    assert_true((not (rendered_false contains "Hello, World!")), "if_false_skips_content")

Process called "test_render_with_control_flow_for":
    Let template_code be "{{#for item in items}}\nItem: {{item}}\n{{/for}}"
    Let template be create_simple_template with:
        template_id as "for_test"
        template_code as template_code
    
    Let context be dictionary containing "items" as list containing "apple", "banana", "cherry"
    
    Let rendered be TemplateEngine.render_with_control_flow with template as template and context as context
    
    assert_contains(rendered, "Item: apple", "for_loop_renders_first_item")
    assert_contains(rendered, "Item: banana", "for_loop_renders_second_item")
    assert_contains(rendered, "Item: cherry", "for_loop_renders_third_item")

Process called "test_render_with_control_flow_mixed":
    Let template_code be "Start\n{{#if show_list}}\n{{#for item in items}}\n- {{item}}\n{{/for}}\n{{/if}}\nEnd"
    Let template be create_simple_template with:
        template_id as "mixed_test"
        template_code as template_code
    
    Let context be dictionary containing:
        "show_list" as true
        "items" as list containing "first", "second"
    
    Let rendered be TemplateEngine.render_with_control_flow with template as template and context as context
    
    assert_contains(rendered, "Start", "mixed_contains_start")
    assert_contains(rendered, "- first", "mixed_contains_first_item")
    assert_contains(rendered, "- second", "mixed_contains_second_item")
    assert_contains(rendered, "End", "mixed_contains_end")

Note: Error Handling Tests

Process called "test_template_engine_error_creation":
    Let error be TemplateEngine.TemplateEngineError with:
