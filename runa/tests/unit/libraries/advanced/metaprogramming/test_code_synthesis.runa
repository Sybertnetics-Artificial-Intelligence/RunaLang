Note: Source Map Tests

Process called "test_create_source_map_builder":
    Let builder be CodeSynthesis.create_source_map_builder()
    
    assert_not_null(builder, "create_source_map_builder")
    assert_equal(1, builder.current_line, "initial_line_correct")
    assert_equal(0, builder.current_column, "initial_column_correct")
    assert_equal(0, length of builder.mappings, "initial_mappings_empty")

Process called "test_add_source_mapping":
    Let builder be CodeSynthesis.create_source_map_builder()
    
    CodeSynthesis.add_source_mapping with:
        builder as builder
        original_line as 5
        original_column as 10
        source_index as 0
        name_index as None
        ast_node as None
    
    assert_equal(1, length of builder.mappings, "source_mapping_added")
    assert_equal(5, builder.mappings[0].original_line, "original_line_correct")
    assert_equal(10, builder.mappings[0].original_column, "original_column_correct")

Process called "test_advance_source_map_position":
    Let builder be CodeSynthesis.create_source_map_builder()
    
    CodeSynthesis.advance_source_map_position with builder as builder and text as "hello\nworld"
    
    assert_equal(2, builder.current_line, "line_advanced_by_newline")
    assert_equal(5, builder.current_column, "column_advanced_by_characters")

Process called "test_finalize_source_map_builder":
    Let builder be CodeSynthesis.create_source_map_builder()
    Add "test.runa" to builder.sources
    Add "test_name" to builder.names
    
    Let source_map be CodeSynthesis.finalize_source_map_builder with builder as builder
    
    assert_not_null(source_map, "finalize_source_map_builder")
    assert_equal(3, source_map.version, "source_map_version_correct")
    assert_equal(1, length of source_map.sources, "sources_preserved")
    assert_equal(1, length of source_map.names, "names_preserved")

Process called "test_ensure_source_in_builder":
    Let builder be CodeSynthesis.create_source_map_builder()
    
    Let index1 be CodeSynthesis.ensure_source_in_builder with builder as builder and source as "test.runa"
    Let index2 be CodeSynthesis.ensure_source_in_builder with builder as builder and source as "test.runa"
    
    assert_equal(0, index1, "first_source_index_correct")
    assert_equal(0, index2, "duplicate_source_same_index")
    assert_equal(1, length of builder.sources, "no_duplicate_sources")

Process called "test_ensure_name_in_builder":
    Let builder be CodeSynthesis.create_source_map_builder()
    
    Let index1 be CodeSynthesis.ensure_name_in_builder with builder as builder and name as "test_name"
    Let index2 be CodeSynthesis.ensure_name_in_builder with builder as builder and name as "test_name"
    
    assert_equal(0, index1, "first_name_index_correct")
    assert_equal(0, index2, "duplicate_name_same_index")
    assert_equal(1, length of builder.names, "no_duplicate_names")

