Note: Integration Tests

Process called "test_full_synthesis_pipeline":
    Let context be create_test_synthesis_context()
    Let engine be CodeSynthesis.create_synthesis_engine with context as context
    Let ast be create_test_program_ast()
    
    Note: Synthesize code from AST
    Let synthesized be CodeSynthesis.synthesize_code_from_ast with engine as engine and ast as ast
    
    Note: Optimize the synthesized code
    Let optimized be CodeSynthesis.optimize_synthesized_code with engine as engine and code as synthesized
    
    assert_not_null(optimized, "full_synthesis_pipeline")
    assert_equal(1, optimized.stats.total_synthesized, "synthesis_stats_preserved")
    assert_equal(1, optimized.stats.total_optimized, "optimization_applied")

