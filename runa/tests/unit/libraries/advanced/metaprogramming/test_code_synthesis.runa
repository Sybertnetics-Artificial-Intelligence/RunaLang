    Let code be CodeSynthesis.emit_code_from_ast with node as binary_ast and indent as 0
    
    assert_contains(code, "plus", "binary_operation_contains_operator")
    assert_contains(code, "10", "binary_operation_contains_left_value")
    assert_contains(code, "5", "binary_operation_contains_right_value")

Process called "test_emit_code_from_ast_if_statement":
    Let if_ast be create_test_if_statement_ast()
    
    Let code be CodeSynthesis.emit_code_from_ast with node as if_ast and indent as 0
    
    assert_contains(code, "If", "if_statement_contains_if_keyword")
    assert_contains(code, "condition_var", "if_statement_contains_condition")

Process called "test_emit_code_from_ast_program":
    Let program_ast be create_test_program_ast()
    
    Let code be CodeSynthesis.emit_code_from_ast with node as program_ast and indent as 0
    
    assert_contains(code, "Let", "program_contains_let_statement")
    assert_contains(code, "test_var", "program_contains_variable_name")

