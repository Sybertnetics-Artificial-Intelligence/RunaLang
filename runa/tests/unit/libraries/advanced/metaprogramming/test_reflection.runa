    Let test_dict be Dictionary[String, Any] containing:
        "method1" as Function that returns String:
            Return "method1_result"
        "property1" as "not_a_function"
        "method2" as Function that takes x as Integer returns Integer:
            Return x multiplied by 2
    
    Let reflectable be Reflection.Reflectable with:
        type_info as Reflection.TypeInfo with:
            type_id as "Test"
            type_kind as "custom"
            size as 16
            alignment as 8
            is_primitive as false
            is_reference as true
            metadata as dictionary containing
        value as test_dict
        metadata as dictionary containing
    
    Let methods be Reflection.list_methods with context as context and value as reflectable
    
    assert_equal(2, length of methods, "reflectable_method_count")
    assert_true((methods contains "method1"), "reflectable_contains_method1")
    assert_true((methods contains "method2"), "reflectable_contains_method2")

