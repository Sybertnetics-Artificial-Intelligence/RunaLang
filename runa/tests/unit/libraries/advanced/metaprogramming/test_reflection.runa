Process called "test_get_metadata_dictionary":
    Let context be create_test_reflection_context()
    Let object_with_metadata be Dictionary[String, Any] containing:
        "data" as "test_data"
        "metadata" as Dictionary[String, Any] containing:
            "version" as "1.0"
            "author" as "test_author"
    
    Let metadata be Reflection.get_metadata with context as context and value as object_with_metadata
    
    assert_not_null(metadata, "get_metadata_dictionary")
    assert_true((metadata contains "version"), "metadata_has_version")
    assert_equal("1.0", metadata["version"], "metadata_version_correct")

