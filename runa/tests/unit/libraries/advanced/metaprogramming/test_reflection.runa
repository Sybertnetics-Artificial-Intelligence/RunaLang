Note: Method and Property Listing Tests

Process called "test_list_methods":
    Let context be create_test_reflection_context()
    Let test_object be create_test_object_with_methods()
    
    Let methods be Reflection.list_methods with context as context and value as test_object
    
    assert_not_null(methods, "list_methods")
    assert_true((methods contains "get_name"), "methods_contains_get_name")
    assert_true((methods contains "get_value"), "methods_contains_get_value")
    assert_true((methods contains "calculate"), "methods_contains_calculate")
    assert_true((not (methods contains "name")), "methods_excludes_non_function_properties")

Process called "test_list_methods_reflectable":
