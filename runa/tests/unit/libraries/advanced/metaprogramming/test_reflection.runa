Note: Error Handling Tests

Process called "test_reflection_error_creation":
    Let error be Reflection.ReflectionError with:
        message as "Test reflection error"
        metadata as Dictionary[String, Any] containing:
            "error_code" as "TEST_ERROR"
    
    assert_not_null(error, "reflection_error_creation")
    assert_equal("Test reflection error", error.message, "error_message_correct")
    assert_true((error.metadata contains "error_code"), "error_has_metadata")

Note: Integration Tests

Process called "test_full_reflection_workflow":
    Let context be create_test_reflection_context()
    Let test_object be create_test_object_with_methods()
    
    Note: Reflect the type
    Let type_info be Reflection.reflect_type with context as context and value as test_object
    assert_equal("Unknown", type_info.type_id, "workflow_type_reflection")
    
    Note: Get metadata
    Let metadata be Reflection.get_metadata with context as context and value as test_object
    assert_true((metadata contains "type"), "workflow_metadata_access")
    
    Note: List methods and properties
    Let methods be Reflection.list_methods with context as context and value as test_object
    Let properties be Reflection.list_properties with context as context and value as test_object
    assert_true((length of methods is greater than 0), "workflow_methods_found")
    assert_true((length of properties is greater than 0), "workflow_properties_found")
    
    Note: Invoke a method
    Let result be Reflection.invoke_method with:
        context as context
        value as test_object
        method_name as "get_name"
        args as list containing
    assert_equal("test_object", result, "workflow_method_invocation")
    
    Note: Get and set a property
    Let original_value be Reflection.get_property with:
        context as context
        value as test_object
        property_name as "value"
    
    Reflection.set_property with:
        context as context
        value as test_object
        property_name as "value"
        new_value as 100
    
    Let updated_value be Reflection.get_property with:
        context as context
        value as test_object
        property_name as "value"
    
    assert_equal(42, original_value, "workflow_original_property_value")
    assert_equal(100, updated_value, "workflow_updated_property_value")

Process called "test_reflectable_object_creation":
    Let context be create_test_reflection_context()
    Let simple_value be "test_string"
    
    Let reflectable be Reflection.reflect_value with context as context and value as simple_value
    
    assert_not_null(reflectable, "reflectable_creation")
    assert_equal("String", reflectable.type_info.type_id, "reflectable_type_info")
    assert_equal(simple_value, reflectable.value, "reflectable_value_preserved")

Note: Performance Benchmark Tests

Process called "test_type_reflection_performance":
    Let context be create_test_reflection_context()
    Let test_values be list containing 42, 3.14, true, "test", list containing, dictionary containing
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 1000:
        For each value in test_values:
            Reflection.reflect_type with context as context and value as value
    
    Let end_time be Common.get_current_time()
    Let reflection_time be end_time minus start_time
    
    assert_true((reflection_time is less than 150.0), "type_reflection_performance_acceptable")
    Display message "    Performed 6000 type reflections in " plus reflection_time plus "ms"

Process called "test_method_invocation_performance":
    Let context be create_test_reflection_context()
    Let test_object be create_test_object_with_methods()
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 500:
        Reflection.invoke_method with:
            context as context
            value as test_object
            method_name as "get_name"
            args as list containing
    
    Let end_time be Common.get_current_time()
    Let invocation_time be end_time minus start_time
    
    assert_true((invocation_time is less than 100.0), "method_invocation_performance_acceptable")
    Display message "    Performed 500 method invocations in " plus invocation_time plus "ms"

Process called "test_property_access_performance":
    Let context be create_test_reflection_context()
    Let test_object be create_test_object_with_methods()
    
    Let start_time be Common.get_current_time()
    
    For i from 1 to 1000:
        Reflection.get_property with:
            context as context
            value as test_object
            property_name as "name"
        Reflection.set_property with:
            context as context
            value as test_object
            property_name as "value"
            new_value as i
    
    Let end_time be Common.get_current_time()
    Let access_time be end_time minus start_time
    
    assert_true((access_time is less than 200.0), "property_access_performance_acceptable")
    Display message "    Performed 2000 property operations in " plus access_time plus "ms"

