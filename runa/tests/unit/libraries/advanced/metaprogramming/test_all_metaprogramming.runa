Note:
Master Test Runner for Advanced Metaprogramming Library

Coordinates comprehensive testing of all metaprogramming modules including:
- AST Manipulation module functionality
- Code Synthesis and generation capabilities
- Compile-Time metaprogramming features
- Reflection and introspection systems
- Template Engine processing
- Cross-module integration testing
- Performance benchmarking
- System reliability validation
:End Note

Import "../../../../../../src/stdlib/advanced/metaprogramming/ast_manipulation" as ASTManip
Import "../../../../../../src/stdlib/advanced/metaprogramming/code_synthesis" as CodeSynthesis
Import "../../../../../../src/stdlib/advanced/metaprogramming/compile_time" as CompileTime
Import "../../../../../../src/stdlib/advanced/metaprogramming/reflection" as Reflection
Import "../../../../../../src/stdlib/advanced/metaprogramming/template_engine" as TemplateEngine
Import "../../../../../../src/stdlib/advanced/utilities/common" as Common

Note: Import individual module test suites
Import "./test_ast_manipulation" as ASTManipTests
Import "./test_code_synthesis" as CodeSynthesisTests
Import "./test_compile_time" as CompileTimeTests
Import "./test_reflection" as ReflectionTests
Import "./test_template_engine" as TemplateEngineTests

Note: Test Configuration Constants
Let INTEGRATION_TEST_TIMEOUT be 30000.0
Let PERFORMANCE_BENCHMARK_DURATION be 10000.0
Let STRESS_TEST_ITERATIONS be 100

Note: Test Result Tracking
Let total_tests be 0
Let total_passed be 0
Let total_failed be 0
Let module_results be Dictionary[String, Dictionary[String, Any]] containing

Process called "run_module_tests" that takes module_name as String and test_runner as Function returns Dictionary[String, Any]:
    Display message "\n" plus "=" repeated 50
    Display message "Running " plus module_name plus " Module Tests"
    Display message "=" repeated 50
    
    Let start_time be Common.get_current_timestamp()
    
    Try:
        Let module_result be test_runner()
        Let end_time be Common.get_current_timestamp()
        
        Let execution_time be end_time minus start_time
        
        Note: Extract results from the module test results
        Let tests_run be module_result["tests_run"]
        Let tests_passed be module_result["tests_passed"] 
        Let tests_failed be module_result["tests_failed"]
        Let module_success be module_result.get("success", (tests_failed is equal to 0))
        
        If module_success:
            Display message "✓ " plus module_name plus " tests PASSED: " plus tests_passed plus "/" plus tests_run
        Otherwise:
            Display message "✗ " plus module_name plus " tests FAILED: " plus tests_failed plus " failures out of " plus tests_run
            If "error" in module_result:
                Display message "  Error: " plus module_result["error"]
        
        Return Dictionary[String, Any] containing:
            "success" as module_success
            "execution_time_ms" as execution_time
            "tests_run" as tests_run
            "tests_passed" as tests_passed
            "tests_failed" as tests_failed
            "details" as module_result
            
    Catch error:
        Let end_time be Common.get_current_timestamp()
        Let execution_time be end_time minus start_time
        
        Display message "✗ " plus module_name plus " module tests CRASHED: " plus error.message
        
        Return Dictionary[String, Any] containing:
            "success" as false
            "execution_time_ms" as execution_time
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "error" as error.message

Note: Core Module Tests

Process called "run_ast_manipulation_tests" returns Dictionary[String, Any]:
    Note: Execute comprehensive AST manipulation tests and capture real results
    Try:
        ASTManipTests.run_all_ast_manipulation_tests()
        Return Dictionary[String, Any] containing:
            "tests_run" as ASTManipTests.test_count
            "tests_passed" as ASTManipTests.passed_count
            "tests_failed" as ASTManipTests.failed_count
            "module" as "ast_manipulation"
            "success" as (ASTManipTests.failed_count is equal to 0)
    Catch error:
        Return Dictionary[String, Any] containing:
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "module" as "ast_manipulation"
            "success" as false
            "error" as error.message

Process called "run_code_synthesis_tests" returns Dictionary[String, Any]:
    Note: Execute comprehensive code synthesis tests and capture real results
    Try:
        CodeSynthesisTests.run_all_code_synthesis_tests()
        Return Dictionary[String, Any] containing:
            "tests_run" as CodeSynthesisTests.test_count
            "tests_passed" as CodeSynthesisTests.passed_count
            "tests_failed" as CodeSynthesisTests.failed_count
            "module" as "code_synthesis"
            "success" as (CodeSynthesisTests.failed_count is equal to 0)
    Catch error:
        Return Dictionary[String, Any] containing:
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "module" as "code_synthesis"
            "success" as false
            "error" as error.message

Process called "run_compile_time_tests" returns Dictionary[String, Any]:
    Note: Execute comprehensive compile-time metaprogramming tests and capture real results
    Try:
        CompileTimeTests.run_all_compile_time_tests()
        Return Dictionary[String, Any] containing:
            "tests_run" as CompileTimeTests.test_count
            "tests_passed" as CompileTimeTests.passed_count
            "tests_failed" as CompileTimeTests.failed_count
            "module" as "compile_time"
            "success" as (CompileTimeTests.failed_count is equal to 0)
    Catch error:
        Return Dictionary[String, Any] containing:
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "module" as "compile_time"
            "success" as false
            "error" as error.message

Process called "run_reflection_tests" returns Dictionary[String, Any]:
    Note: Execute comprehensive reflection tests and capture real results
    Try:
        ReflectionTests.run_all_reflection_tests()
        Return Dictionary[String, Any] containing:
            "tests_run" as ReflectionTests.test_count
            "tests_passed" as ReflectionTests.passed_count
            "tests_failed" as ReflectionTests.failed_count
            "module" as "reflection"
            "success" as (ReflectionTests.failed_count is equal to 0)
    Catch error:
        Return Dictionary[String, Any] containing:
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "module" as "reflection"
            "success" as false
            "error" as error.message

Process called "run_template_engine_tests" returns Dictionary[String, Any]:
    Note: Execute comprehensive template engine tests and capture real results
    Try:
        TemplateEngineTests.run_all_template_engine_tests()
        Return Dictionary[String, Any] containing:
            "tests_run" as TemplateEngineTests.test_count
            "tests_passed" as TemplateEngineTests.passed_count
            "tests_failed" as TemplateEngineTests.failed_count
            "module" as "template_engine"
            "success" as (TemplateEngineTests.failed_count is equal to 0)
    Catch error:
        Return Dictionary[String, Any] containing:
            "tests_run" as 0
            "tests_passed" as 0
            "tests_failed" as 1
            "module" as "template_engine"
            "success" as false
            "error" as error.message

Note: Integration Tests

Process called "run_integration_tests" returns Dictionary[String, Any]:
    Display message "\n" plus "=" repeated 50
    Display message "Running Metaprogramming Library Integration Tests"
    Display message "=" repeated 50
    
    Let integration_tests_passed be 0
    Let integration_tests_total be 8
    
    Note: AST Manipulation + Code Synthesis integration
    Let ast_node be ASTManip.create_ast_node with:
        node_type as "Program"
        value as "test_program"
        children as list containing
        position as ASTManip.Position with:
            line as 1
            column as 1
            offset as 0
            metadata as dictionary containing
    
    Let synthesis_context be CodeSynthesis.SynthesisContext with:
        config as CodeSynthesis.SynthesisConfig with:
            enable_optimization as true
            enable_repair as true
            max_steps as 10
            ai_mode as false
            metadata as dictionary containing
        stats as CodeSynthesis.SynthesisStats with:
            total_synthesized as 0
            total_repaired as 0
            total_optimized as 0
            error_count as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let synthesis_engine be CodeSynthesis.create_synthesis_engine with context as synthesis_context
    
    Try:
        Let synthesized_code be CodeSynthesis.synthesize_code_from_ast with engine as synthesis_engine and ast as ast_node
        If synthesized_code is not null:
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ AST-to-Code synthesis integration test passed"
    Catch error:
        Display message "  ✗ AST-to-Code synthesis integration test failed: " plus error.message
    
    Note: Reflection + Template Engine integration
    Let reflection_context be Reflection.ReflectionContext with:
        config as Reflection.ReflectionConfig with:
            enable_runtime_reflection as true
            enable_compile_time_reflection as true
            enable_dynamic_invocation as true
            ai_mode as false
            metadata as dictionary containing
        stats as Reflection.ReflectionStats with:
            total_introspections as 0
            total_invocations as 0
            total_errors as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let template_engine be TemplateEngine.TemplateEngine with:
        config as TemplateEngine.TemplateEngineConfig with:
            enable_inheritance as true
            enable_macros as true
            enable_partials as true
            enable_control_flow as true
            ai_mode as false
            metadata as dictionary containing
        templates as dictionary containing
        renderers as dictionary containing "default" as TemplateEngine.default_template_renderer
        stats as TemplateEngine.TemplateEngineStats with:
            total_rendered as 0
            total_errors as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Try:
        Let test_object be Dictionary[String, Any] containing:
            "name" as "TestObject"
            "properties" as list containing "prop1", "prop2"
        
        Let type_info be Reflection.reflect_type with context as reflection_context and value as test_object
        
        Let template be TemplateEngine.Template with:
            template_id as "reflection_template"
            template_type as "default"
            template_code as "Type: {{type_id}}, Kind: {{type_kind}}"
            variables as list containing
            partials as list containing
            macros as list containing
            parent as None
            metadata as dictionary containing
        
        TemplateEngine.register_template with engine as template_engine and template as template
        
        Let template_context be Dictionary[String, Any] containing:
            "type_id" as type_info.type_id
            "type_kind" as type_info.type_kind
        
        Let rendered be TemplateEngine.render_template with:
            engine as template_engine
            template_id as "reflection_template"
            context as template_context
        
        If rendered is not null and rendered contains "Type:":
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Reflection-Template integration test passed"
    Catch error:
        Display message "  ✗ Reflection-Template integration test failed: " plus error.message
    
    Note: Compile-Time + AST Manipulation integration
    Let compile_time_context be CompileTime.CompileTimeContext with:
        config as CompileTime.CompileTimeConfig with:
            enable_constant_folding as true
            enable_type_introspection as true
            enable_static_assertions as true
            enable_code_generation as true
            enable_macros as true
            ai_mode as false
            metadata as dictionary containing
        stats as CompileTime.CompileTimeStats with:
            total_evaluated as 0
            total_assertions as 0
            total_errors as 0
            total_warnings as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Try:
        Let binary_expr be Dictionary[String, Any] containing:
            "left" as 5
            "right" as 3
            "op" as "+"
        
        Let folded_result be CompileTime.constant_fold with context as compile_time_context and expr as binary_expr
        
        If folded_result is equal to 8:
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Compile-Time constant folding integration test passed"
    Catch error:
        Display message "  ✗ Compile-Time constant folding integration test failed: " plus error.message
    
    Note: Template Engine + Code Synthesis integration
    Try:
        Let template be TemplateEngine.Template with:
            template_id as "code_gen_template"
            template_type as "default"
            template_code as "Process called \"{{function_name}}\" returns {{return_type}}:\n    Return {{default_value}}"
            variables as list containing
            partials as list containing
            macros as list containing
            parent as None
            metadata as dictionary containing
        
        TemplateEngine.register_template with engine as template_engine and template as template
        
        Let code_context be Dictionary[String, Any] containing:
            "function_name" as "test_function"
            "return_type" as "Integer"
            "default_value" as "42"
        
        Let generated_code be TemplateEngine.render_template with:
            engine as template_engine
            template_id as "code_gen_template"
            context as code_context
        
        If generated_code contains "Process called" and generated_code contains "test_function":
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Template-to-Code generation integration test passed"
    Catch error:
        Display message "  ✗ Template-to-Code generation integration test failed: " plus error.message
    
    Note: Full metaprogramming pipeline test
    Try:
        Note: Create AST node
        Let pipeline_ast be ASTManip.create_ast_node with:
            node_type as "LetStatement"
            value as "test_variable"
            children as list containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        Note: Transform AST
        Let transformer be Function that takes node as ASTManip.ASTNode returns ASTManip.ASTNode:
            Return ASTManip.create_ast_node with:
                node_type as "enhanced_" plus node.node_type
                value as node.value
                children as node.children
                position as node.position
        
        Let transformed_ast be ASTManip.transform_ast with node as pipeline_ast and transformer as transformer
        
        Note: Generate code from transformed AST
        Let pipeline_synthesized be CodeSynthesis.synthesize_code_from_ast with engine as synthesis_engine and ast as transformed_ast
        
        Note: Reflect on the synthesized code
        Let code_type_info be Reflection.reflect_type with context as reflection_context and value as pipeline_synthesized.code
        
        If transformed_ast.node_type contains "enhanced_" and pipeline_synthesized is not null and code_type_info.type_id is equal to "String":
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Full metaprogramming pipeline integration test passed"
    Catch error:
        Display message "  ✗ Full metaprogramming pipeline integration test failed: " plus error.message
    
    Note: AST validation and code synthesis
    Try:
        Let validation_ast be ASTManip.create_ast_node with:
            node_type as "Program"
            value as "validation_test"
            children as list containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        Let is_valid be ASTManip.validate_ast with node as validation_ast
        
        If is_valid:
            Let validated_code be CodeSynthesis.synthesize_code_from_ast with engine as synthesis_engine and ast as validation_ast
            If validated_code is not null:
                Set integration_tests_passed to integration_tests_passed plus 1
                Display message "  ✓ AST validation + code synthesis integration test passed"
    Catch error:
        Display message "  ✗ AST validation + code synthesis integration test failed: " plus error.message
    
    Note: Reflection-driven template generation
    Try:
        Let reflection_object be Dictionary[String, Any] containing:
            "className" as "TestClass"
            "methods" as list containing "method1", "method2"
            "properties" as list containing "prop1", "prop2"
        
        Let properties_list be Reflection.list_properties with context as reflection_context and value as reflection_object
        
        Let class_template be TemplateEngine.Template with:
            template_id as "class_generator"
            template_type as "default"
            template_code as "Type called \"{{className}}\":\n{{#for prop in properties}}\n    {{prop}} as Any\n{{/for}}"
            variables as list containing
            partials as list containing
            macros as list containing
            parent as None
            metadata as dictionary containing
        
        TemplateEngine.register_template with engine as template_engine and template as class_template
        
        Let class_context be Dictionary[String, Any] containing:
            "className" as reflection_object["className"]
            "properties" as reflection_object["properties"]
        
        Let class_code be TemplateEngine.render_template with:
            engine as template_engine
            template_id as "class_generator"
            context as class_context
        
        If class_code contains "Type called" and class_code contains "TestClass":
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Reflection-driven template generation integration test passed"
    Catch error:
        Display message "  ✗ Reflection-driven template generation integration test failed: " plus error.message
    
    Note: Compile-time macro expansion with AST manipulation
    Try:
        Let macro_registry be CompileTime.create_macro_registry()
        
        Let test_macro_call be ASTManip.create_ast_node with:
            node_type as "MacroCall"
            value as "identity"
            children as list containing:
                ASTManip.create_ast_node with:
                    node_type as "Literal"
                    value as 42
                    children as list containing
                    position as ASTManip.Position with:
                        line as 1
                        column as 5
                        offset as 5
                        metadata as dictionary containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        Set test_macro_call.name to "identity"
        Set test_macro_call.arguments to list containing test_macro_call.children[0]
        
        Let macro_expansion be CompileTime.macro_expand with:
            context as compile_time_context
            registry as macro_registry
            macro_call as test_macro_call
        
        If macro_expansion is not null and macro_expansion.expanded_ast is not null:
            Set integration_tests_passed to integration_tests_passed plus 1
            Display message "  ✓ Compile-time macro expansion integration test passed"
    Catch error:
        Display message "  ✗ Compile-time macro expansion integration test failed: " plus error.message
    
    Return Dictionary[String, Any] containing:
        "tests_run" as integration_tests_total
        "tests_passed" as integration_tests_passed
        "tests_failed" as (integration_tests_total minus integration_tests_passed)
        "module" as "integration"

Note: Performance Benchmarks

Process called "run_performance_benchmarks" returns Dictionary[String, Any]:
    Display message "\n" plus "=" repeated 50
    Display message "Running Metaprogramming Library Performance Benchmarks"
    Display message "=" repeated 50
    
    Let benchmark_results be Dictionary[String, Float] containing
    
    Note: AST manipulation performance
    Let ast_start_time be Common.get_current_timestamp()
    For i from 1 to 500:
        Let test_ast be ASTManip.create_ast_node with:
            node_type as "TestNode"
            value as "test_" plus i
            children as list containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        Let visitor be Function that takes node as ASTManip.ASTNode:
            Return None
        
        ASTManip.traverse_ast with node as test_ast and visitor as visitor
    Let ast_end_time be Common.get_current_timestamp()
    
    Let ast_performance be (ast_end_time minus ast_start_time) divided by 500.0
    Set benchmark_results["ast_manipulation_ms"] to ast_performance
    Display message "  AST manipulation: " plus ast_performance plus "ms per operation"
    
    Note: Code synthesis performance
    Let synthesis_context be CodeSynthesis.SynthesisContext with:
        config as CodeSynthesis.SynthesisConfig with:
            enable_optimization as true
            enable_repair as false
            max_steps as 10
            ai_mode as false
            metadata as dictionary containing
        stats as CodeSynthesis.SynthesisStats with:
            total_synthesized as 0
            total_repaired as 0
            total_optimized as 0
            error_count as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let synthesis_engine be CodeSynthesis.create_synthesis_engine with context as synthesis_context
    
    Let synthesis_start_time be Common.get_current_timestamp()
    For i from 1 to 200:
        Let simple_ast be ASTManip.create_ast_node with:
            node_type as "Literal"
            value as i
            children as list containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        CodeSynthesis.synthesize_code_from_ast with engine as synthesis_engine and ast as simple_ast
    Let synthesis_end_time be Common.get_current_timestamp()
    
    Let synthesis_performance be (synthesis_end_time minus synthesis_start_time) divided by 200.0
    Set benchmark_results["code_synthesis_ms"] to synthesis_performance
    Display message "  Code synthesis: " plus synthesis_performance plus "ms per operation"
    
    Note: Template rendering performance
    Let template_engine be TemplateEngine.TemplateEngine with:
        config as TemplateEngine.TemplateEngineConfig with:
            enable_inheritance as true
            enable_macros as true
            enable_partials as true
            enable_control_flow as true
            ai_mode as false
            metadata as dictionary containing
        templates as dictionary containing
        renderers as dictionary containing "default" as TemplateEngine.default_template_renderer
        stats as TemplateEngine.TemplateEngineStats with:
            total_rendered as 0
            total_errors as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let perf_template be TemplateEngine.Template with:
        template_id as "performance_template"
        template_type as "default"
        template_code as "Hello {{name}}, your score is {{score}}!"
        variables as list containing
        partials as list containing
        macros as list containing
        parent as None
        metadata as dictionary containing
    
    TemplateEngine.register_template with engine as template_engine and template as perf_template
    
    Let template_start_time be Common.get_current_timestamp()
    For i from 1 to 1000:
        Let context be Dictionary[String, Any] containing:
            "name" as "User" plus i
            "score" as i
        
        TemplateEngine.render_template with:
            engine as template_engine
            template_id as "performance_template"
            context as context
    Let template_end_time be Common.get_current_timestamp()
    
    Let template_performance be (template_end_time minus template_start_time) divided by 1000.0
    Set benchmark_results["template_rendering_ms"] to template_performance
    Display message "  Template rendering: " plus template_performance plus "ms per operation"
    
    Note: Reflection performance
    Let reflection_context be Reflection.ReflectionContext with:
        config as Reflection.ReflectionConfig with:
            enable_runtime_reflection as true
            enable_compile_time_reflection as true
            enable_dynamic_invocation as true
            ai_mode as false
            metadata as dictionary containing
        stats as Reflection.ReflectionStats with:
            total_introspections as 0
            total_invocations as 0
            total_errors as 0
            metadata as dictionary containing
        metadata as dictionary containing
    
    Let reflection_start_time be Common.get_current_timestamp()
    For i from 1 to 500:
        Let test_value be Dictionary[String, Any] containing:
            "id" as i
            "data" as "test_data_" plus i
        
        Reflection.reflect_type with context as reflection_context and value as test_value
        Reflection.get_metadata with context as reflection_context and value as test_value
    Let reflection_end_time be Common.get_current_timestamp()
    
    Let reflection_performance be (reflection_end_time minus reflection_start_time) divided by 1000.0
    Set benchmark_results["reflection_ms"] to reflection_performance
    Display message "  Reflection operations: " plus reflection_performance plus "ms per operation"
    
    Return Dictionary[String, Any] containing:
        "benchmarks_run" as 4
        "ast_manipulation_ms" as ast_performance
        "code_synthesis_ms" as synthesis_performance
        "template_rendering_ms" as template_performance
        "reflection_ms" as reflection_performance
        "performance_acceptable" as (ast_performance is less than 2.0 and synthesis_performance is less than 5.0 and template_performance is less than 1.0 and reflection_performance is less than 1.0)

Note: Helper Functions for Testing

Process called "test_cross_module_workflow" returns Boolean:
    Note: Test a complete workflow using multiple metaprogramming modules
    Try:
        Note: Create an AST node
        Let workflow_ast be ASTManip.create_ast_node with:
            node_type as "ProcessDefinition"
            value as "example_process"
            children as list containing
            position as ASTManip.Position with:
                line as 1
                column as 1
                offset as 0
                metadata as dictionary containing
        
        Note: Synthesize code from the AST
        Let synthesis_context be CodeSynthesis.SynthesisContext with:
            config as CodeSynthesis.SynthesisConfig with:
                enable_optimization as true
                enable_repair as true
                max_steps as 10
                ai_mode as false
                metadata as dictionary containing
            stats as CodeSynthesis.SynthesisStats with:
                total_synthesized as 0
                total_repaired as 0
                total_optimized as 0
                error_count as 0
                metadata as dictionary containing
            metadata as dictionary containing
        
        Let synthesis_engine be CodeSynthesis.create_synthesis_engine with context as synthesis_context
        Let synthesized_code be CodeSynthesis.synthesize_code_from_ast with engine as synthesis_engine and ast as workflow_ast
        
        Note: Use reflection to inspect the synthesized code
        Let reflection_context be Reflection.ReflectionContext with:
            config as Reflection.ReflectionConfig with:
                enable_runtime_reflection as true
                enable_compile_time_reflection as true
                enable_dynamic_invocation as true
                ai_mode as false
                metadata as dictionary containing
            stats as Reflection.ReflectionStats with:
                total_introspections as 0
                total_invocations as 0
                total_errors as 0
                metadata as dictionary containing
            metadata as dictionary containing
        
        Let code_type_info be Reflection.reflect_type with context as reflection_context and value as synthesized_code.code
        
        Note: Use template engine to generate documentation
        Let template_engine be TemplateEngine.TemplateEngine with:
            config as TemplateEngine.TemplateEngineConfig with:
                enable_inheritance as true
                enable_macros as true
                enable_partials as true
                enable_control_flow as true
                ai_mode as false
                metadata as dictionary containing
            templates as dictionary containing
            renderers as dictionary containing "default" as TemplateEngine.default_template_renderer
            stats as TemplateEngine.TemplateEngineStats with:
                total_rendered as 0
                total_errors as 0
                metadata as dictionary containing
            metadata as dictionary containing
        
        Let doc_template be TemplateEngine.Template with:
            template_id as "code_documentation"
            template_type as "default"
            template_code as "# Code Documentation\n\nProcess: {{process_name}}\nType: {{type_info}}\nGenerated Code:\n```\n{{code}}\n```"
            variables as list containing
            partials as list containing
            macros as list containing
            parent as None
            metadata as dictionary containing
        
        TemplateEngine.register_template with engine as template_engine and template as doc_template
        
        Let doc_context be Dictionary[String, Any] containing:
            "process_name" as workflow_ast.value
            "type_info" as code_type_info.type_id
            "code" as synthesized_code.code
        
        Let documentation be TemplateEngine.render_template with:
            engine as template_engine
            template_id as "code_documentation"
            context as doc_context
        
        Return synthesized_code is not null and documentation contains "Code Documentation"
        
    Catch error:
        Return false

Note: Test Report Structure
Type called "MetaprogrammingMasterTestReport":
    total_tests as Integer
    total_passed as Integer
    total_failed as Integer
    overall_execution_time_ms as Float
    suite_results as List[Dictionary[String, Any]]
    performance_metrics as Dictionary[String, Float]
    integration_success as Boolean

Note: Main Test Execution

Process called "run_all_metaprogramming_tests" returns MetaprogrammingMasterTestReport:
    Display message "Starting Advanced Metaprogramming Library Comprehensive Test Suite"
    Display message "=" repeated 85 times
    Display message "Testing all 5 metaprogramming modules with integration and performance benchmarks"
    Display message "=" repeated 85 times
    
    Let overall_start_time be Common.get_current_timestamp()
    
    Note: Execute all module tests
    Set module_results["ast_manipulation"] to run_module_tests("AST Manipulation", run_ast_manipulation_tests)
    Set module_results["code_synthesis"] to run_module_tests("Code Synthesis", run_code_synthesis_tests)
    Set module_results["compile_time"] to run_module_tests("Compile-Time Metaprogramming", run_compile_time_tests)
    Set module_results["reflection"] to run_module_tests("Reflection", run_reflection_tests)
    Set module_results["template_engine"] to run_module_tests("Template Engine", run_template_engine_tests)
    
    Note: Execute integration tests
    Set module_results["integration"] to run_module_tests("Metaprogramming Integration Tests", run_integration_tests)
    
    Note: Execute performance benchmarks
    Set module_results["benchmarks"] to run_module_tests("Metaprogramming Performance Benchmarks", run_performance_benchmarks)
    
    Let overall_end_time be Common.get_current_timestamp()
    Let total_execution_time be overall_end_time minus overall_start_time
    
    Note: Calculate totals
    Set total_tests to 0
    Set total_passed to 0
    Set total_failed to 0
    
    For each module_name in keys of module_results:
        Let result be module_results[module_name]
        Set total_tests to total_tests plus result["tests_run"]
        Set total_passed to total_passed plus result["tests_passed"]
        Set total_failed to total_failed plus result["tests_failed"]
    
    Note: Display comprehensive results
    Display message "\n" plus "=" repeated 85 times
    Display message "ADVANCED METAPROGRAMMING LIBRARY - COMPREHENSIVE TEST RESULTS"
    Display message "=" repeated 85 times
    
    Display message "\nModule Test Results:"
    For each module_name in keys of module_results:
        Let result be module_results[module_name]
        Let success_rate be (result["tests_passed"] as Float divided by result["tests_run"] as Float) multiplied by 100.0
        If result["success"]:
            Display message "  ✓ " plus module_name plus ": " plus result["tests_passed"] plus "/" plus result["tests_run"] plus " (" plus success_rate plus "%) - " plus result["execution_time_ms"] plus "ms"
        Otherwise:
            Display message "  ✗ " plus module_name plus ": FAILED - " plus result.get("error", "Unknown error")
    
    Let overall_success_rate be (total_passed as Float divided by total_tests as Float) multiplied by 100.0
    
    Display message "\nOverall Test Summary:"
    Display message "  Total Tests: " plus total_tests
    Display message "  Tests Passed: " plus total_passed
    Display message "  Tests Failed: " plus total_failed
    Display message "  Success Rate: " plus overall_success_rate plus "%"
    Display message "  Total Execution Time: " plus total_execution_time plus "ms"
    
    Note: Performance benchmark summary
    If "benchmarks" in module_results and module_results["benchmarks"]["performance_acceptable"]:
        Display message "\n✅ Performance Benchmarks: All benchmarks within acceptable limits"
        Display message "  AST Manipulation: " plus module_results["benchmarks"]["ast_manipulation_ms"] plus "ms per operation"
        Display message "  Code Synthesis: " plus module_results["benchmarks"]["code_synthesis_ms"] plus "ms per operation"
        Display message "  Template Rendering: " plus module_results["benchmarks"]["template_rendering_ms"] plus "ms per operation"
        Display message "  Reflection: " plus module_results["benchmarks"]["reflection_ms"] plus "ms per operation"
    Otherwise:
        Display message "\n⚠️  Performance Benchmarks: Some benchmarks may need optimization"
    
    Note: Integration test summary
    If "integration" in module_results and module_results["integration"]["tests_failed"] is equal to 0:
        Display message "\n✅ Integration Tests: All cross-module integrations working correctly"
    Otherwise:
        Display message "\n⚠️  Integration Tests: Some integration issues detected"
    
    Note: Cross-module workflow test
    Let workflow_success be test_cross_module_workflow()
    If workflow_success:
        Display message "✅ Cross-module workflow test: PASSED"
    Otherwise:
        Display message "⚠️  Cross-module workflow test: FAILED"
    
    Note: Final assessment
    If total_failed is equal to 0:
        Display message "\n🎉 ALL METAPROGRAMMING LIBRARY TESTS PASSED! 🎉"
        Display message "The Advanced Metaprogramming Library is ready for production deployment."
        Display message "✅ AST manipulation and traversal capabilities verified"
        Display message "✅ Code synthesis and generation systems validated"
        Display message "✅ Compile-time metaprogramming features confirmed"
        Display message "✅ Reflection and introspection systems tested"
        Display message "✅ Template engine functionality verified"
        Display message "✅ Cross-module integration confirmed"
        Display message "✅ Performance benchmarks within acceptable limits"
        Display message "✅ Production-ready metaprogramming infrastructure"
    Otherwise:
        Display message "\n⚠️  Some tests failed. Please review the results above."
        Display message "Failed modules may need additional debugging before production use."
    
    Display message "\n🎯 Advanced Metaprogramming Library Testing Complete!"
    Display message "Documentation: See docs/user/libraries/advanced/metaprogramming/ for usage guides"
    Display message "=" repeated 85 times
    
    Note: Prepare suite results list
    Let suite_results_list be list containing
    For each module_name in keys of module_results:
        Let result be module_results[module_name]
        Add Dictionary[String, Any] containing:
            "suite_name" as module_name
            "total_tests" as result["tests_run"]
            "passed_tests" as result["tests_passed"]
            "failed_tests" as result["tests_failed"]
            "execution_time_ms" as result["execution_time_ms"]
            "success" as result["success"]
        to suite_results_list
    
    Note: Prepare performance metrics
    Let perf_metrics be Dictionary[String, Float] containing
    If "benchmarks" in module_results:
        Set perf_metrics["ast_manipulation_ms"] to module_results["benchmarks"]["ast_manipulation_ms"]
        Set perf_metrics["code_synthesis_ms"] to module_results["benchmarks"]["code_synthesis_ms"]
        Set perf_metrics["template_rendering_ms"] to module_results["benchmarks"]["template_rendering_ms"]
        Set perf_metrics["reflection_ms"] to module_results["benchmarks"]["reflection_ms"]
    
    Let integration_passed be ("integration" in module_results and module_results["integration"]["tests_failed"] is equal to 0 and workflow_success)
    
    Return MetaprogrammingMasterTestReport with:
        total_tests as total_tests
        total_passed as total_passed
        total_failed as total_failed
        overall_execution_time_ms as total_execution_time
        suite_results as suite_results_list
        performance_metrics as perf_metrics
        integration_success as integration_passed

Note: Execute comprehensive test suite when file is run directly
Let test_report be run_all_metaprogramming_tests()

Display message "Advanced Metaprogramming Library comprehensive testing completed."
Display message "All modules have been validated for production readiness."