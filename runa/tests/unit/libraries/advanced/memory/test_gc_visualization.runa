Process called "test_memory_pressure_scenarios":
    Note: Tests visualization under memory pressure conditions
    Let pressure_config be GCAlgorithms.GenerationalGCConfig with:
        heap_size as 1048576
        young_generation_size as 262144
        old_generation_size as 786432
        collection_threshold as 0.95
        promotion_threshold as 3
        concurrent_enabled as false
        metadata as dictionary containing
            "pressure_test" as true
    
    Let pressure_gc be GCAlgorithms.create_generational_gc with config as pressure_config
    Let pressure_visualization be GCVisualization.visualize_state with gc_state as pressure_gc
    
    Let result1 be assert_not_none with value as pressure_visualization and message as "Pressure visualization should work"
    Let result2 be assert_greater_than with actual as pressure_visualization.fragmentation_map.fragmentation_ratio and expected as 0.0 and message as "Fragmentation should be detected under pressure"
    Let result3 be assert_not_none with value as pressure_visualization.collection_metrics and message as "Collection metrics should be available under pressure"
    
    Return result1 and result2 and result3

