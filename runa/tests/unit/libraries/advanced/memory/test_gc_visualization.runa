        young_generation_size as 33554432
        old_generation_size as 100663296
        collection_threshold as 0.8
        promotion_threshold as 5
        concurrent_enabled as true
        metadata as dictionary containing
    
    Let large_gc be GCAlgorithms.create_generational_gc with config as large_config
