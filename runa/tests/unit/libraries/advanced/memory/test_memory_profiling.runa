    run_test with test_name as "Performance Overhead Monitoring" and test_function as test_performance_overhead_monitoring
    run_test with test_name as "Memory Turnover Analysis" and test_function as test_memory_turnover_analysis
    
    Note: Thread safety tests
    run_test with test_name as "Thread Safe Allocation Tracking" and test_function as test_thread_safe_allocation_tracking
    run_test with test_name as "Thread Local Profiling Data" and test_function as test_thread_local_profiling_data
    
    Note: Export and import tests
    run_test with test_name as "Profiling Data Export" and test_function as test_profiling_data_export
    run_test with test_name as "Profiling Data Import" and test_function as test_profiling_data_import
    run_test with test_name as "JSON Export Format" and test_function as test_json_export_format
    
    Note: AI/Agent integration tests
