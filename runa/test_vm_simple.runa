"""
Simplified Runa VM for bootstrap testing
"""

# Test VM creation and basic operations
Let vm be empty dictionary
Let vm at key "state" be "idle"
Let vm at key "stack" be empty list
Let vm at key "variables" be empty dictionary

Display "VM initialized with state:" followed by vm at key "state"

# Test instruction execution
Let instruction be empty dictionary
Let instruction at key "opcode" be "LOAD_CONST"
Let instruction at key "value" be 42

Let vm at key "stack" be vm at key "stack" plus instruction at key "value"

Display "Stack after LOAD_CONST:" followed by vm at key "stack"

# Test arithmetic instruction
Let left be 10
Let right be 5
Let result be left plus right

Display "Arithmetic test result:" followed by result

Display "Simplified VM test complete!" 