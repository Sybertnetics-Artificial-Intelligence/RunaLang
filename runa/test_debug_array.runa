"""
Debug test for array indexing patterns
"""

# Test basic array access
Let instructions be list containing "LOAD", "ADD", "STORE", "RETURN"
Let index be 1
Let instruction be instructions at index index

Display "Basic array access:" followed by instruction

# Test array access with arithmetic
Let i be 2
Display "Variable i before arithmetic:" followed by i
Let prev_index be i minus 1
Display "Calculated prev_index:" followed by prev_index
Let prev_instruction be instructions at index prev_index

Display "Array access with arithmetic:" followed by prev_instruction 