# BULLETPROOF MONOREPO PROTECTION
# This .gitignore ensures ONLY runa/ directory content can be committed
# Everything else in the monorepo is completely ignored

# =============================================================================
# IGNORE EVERYTHING AT ROOT LEVEL
# =============================================================================

# Ignore all files and directories at the root
/*

# =============================================================================
# EXPLICITLY ALLOW ONLY RUNA DIRECTORY
# =============================================================================

# Allow the runa directory and all its contents
!/runa/

# Allow this .gitignore file itself
!.gitignore

# Allow README.md if it exists at root (for GitHub)
!README.md

# =============================================================================
# EXTRA PROTECTION: EXPLICITLY BLOCK SENSITIVE DIRECTORIES
# =============================================================================

# Even if somehow included, block these explicitly
docs/
hermod/
build/
__pycache__/
.vscode/
.idea/
*.log
*.tmp

# =============================================================================
# SECURITY: BLOCK COMMON SENSITIVE FILES
# =============================================================================

# Environment and config files
.env
.env.*
*.key
*.secret
*.pem
*.p12
*.pfx
config.json
settings.json
secrets.json

# Database files
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup
*.old

# =============================================================================
# DEVELOPMENT ARTIFACTS
# =============================================================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
desktop.ini
$RECYCLE.BIN/

# =============================================================================
# CLAUDE/AI WORKING FILES
# =============================================================================

# Any temporary AI working files
claude_temp/
ai_temp/
temp/
tmp/

# =============================================================================
# VERIFICATION COMMENTS
# =============================================================================

# This configuration ensures:
# 1. Only runa/ directory contents can be committed
# 2. No accidental exposure of proprietary monorepo content
# 3. Protection against common sensitive file patterns
# 4. Safe for use with public GitHub repository
# 5. Compatible with automated sync workflows